{%- doc -%}
  MK 媒体组件

  渲染图片或视频媒体块

  @param {object} block - 区块对象
  @param {string} [class] - 额外CSS类名

  @example
  {% render 'mk-media', block: block %}
{%- enddoc -%}

{% liquid
  assign block_settings = block.settings | default: {}
  assign media_type = block_settings.media_type | default: 'image'
  assign image = block_settings.image | default: nil
  assign link = block_settings.link | default: nil
  assign image_position = block_settings.image_position | default: 'cover'
-%}

<div class="mk-media {{ class }}" {{ block.shopify_attributes }}>
  {%- case media_type -%}
    {%- when 'image' -%}
      {%- if image != nil -%}
        <div class="mk-media__wrapper">
          {%- if link != blank -%}
            <a href="{{ link }}" class="mk-media__link">
          {%- endif -%}

          {{ image | image_url: width: 1200 | image_tag: class: 'mk-media__image' }}

          {%- if link != blank -%}
            </a>
          {%- endif -%}
        </div>
      {%- else -%}
        <div class="mk-media__placeholder">
          {{ 'detailed-apparel-1' | placeholder_svg_tag: 'mk-media__placeholder-svg' }}
        </div>
      {%- endif -%}

    {%- when 'video' -%}
      {%- if block_settings.video != blank -%}
        <div class="mk-media__video">
          {{ block_settings.video | video_tag: autoplay: true, loop: true, muted: true, controls: true, class: 'mk-media__video-element' }}
        </div>
      {%- else -%}
        <div class="mk-media__placeholder">
          {{ 'hero-apparel-3' | placeholder_svg_tag: 'mk-media__placeholder-svg' }}
        </div>
      {%- endif -%}

    {%- else -%}
      <div class="mk-media__placeholder">
        {{ 'image' | placeholder_svg_tag: 'mk-media__placeholder-svg' }}
      </div>
  {%- endcase -%}
</div>

{% stylesheet %}
  .mk-media {
    overflow: hidden;
    position: relative;
    border-radius: var(--border-radius, 12px);
  }

  .mk-media__wrapper {
    position: relative;
    width: 100%;
    height: 100%;
  }

  .mk-media__link {
    display: block;
    width: 100%;
    height: 100%;
  }

  .mk-media__image {
    width: 100%;
    height: 100%;
    object-fit: var(--image-position, cover);
    object-position: center;
  }

  .mk-media__video {
    position: relative;
    width: 100%;
    padding-top: 56.25%; /* 16:9 */
  }

  .mk-media__video-element {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .mk-media__placeholder {
    width: 100%;
    aspect-ratio: 16 / 9;
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: var(--color-background-secondary, #f5f5f5);
  }

  .mk-media__placeholder-svg {
    width: 50%;
    height: 50%;
    opacity: 0.3;
  }
{% endstylesheet %}
