{%- comment -%}
  MK Countdown Timer Section板块

  倒计时完整版

  作者：崽崽 (AI助手)
{%- endcomment -%}

{% liquid
  assign ss = section.settings
-%}

<section id="{{ section.id }}" class="mk-countdown-timer-section color-{{ ss.color_scheme | default: 'background-1' }}">
  <div class="mk-countdown-timer-section__container">
    {%- if ss.title != blank -%}
      <h2 class="mk-countdown-timer-section__title">{{ ss.title }}</h2>
    {%- endif -%}

    <div class="mk-countdown-timer-section__countdown" data-countdown-timer data-end="{{ ss.end_date | default: '' | date: '%Y-%m-%dT%H:%M:%S' }}">
      <div class="mk-countdown-timer-section__item">
        <div class="mk-countdown-timer-section__num" data-days>00</div>
        <div class="mk-countdown-timer-section__label">天</div>
      </div>
      <div class="mk-countdown-timer-section__sep">:</div>
      <div class="mk-countdown-timer-section__item">
        <div class="mk-countdown-timer-section__num" data-hours>00</div>
        <div class="mk-countdown-timer-section__label">时</div>
      </div>
      <div class="mk-countdown-timer-section__sep">:</div>
      <div class="mk-countdown-timer-section__item">
        <div class="mk-countdown-timer-section__num" data-minutes>00</div>
        <div class="mk-countdown-timer-section__label">分</div>
      </div>
      <div class="mk-countdown-timer-section__sep">:</div>
      <div class="mk-countdown-timer-section__item">
        <div class="mk-countdown-timer-section__num" data-seconds>00</div>
        <div class="mk-countdown-timer-section__label">秒</div>
      </div>
    </div>

    {%- if ss.show_progress -%}
      <div class="mk-countdown-timer-section__progress">
        <div class="mk-countdown-timer-section__progress-bar">
          <div class="mk-countdown-timer-section__progress-fill" data-progress-fill></div>
        </div>
      </div>
    {%- endif -%}

    {%- if ss.button_text != blank -%}
      <a href="{{ ss.button_link | default: '#' }}" class="mk-countdown-timer-section__button">{{ ss.button_text }}</a>
    {%- endif -%}
  </div>
</section>

{% stylesheet %}
  .mk-countdown-timer-section { padding: {{ ss.padding_top_mobile | default: 64 }}px 0 {{ ss.padding_bottom_mobile | default: 64 }}px; background: var(--color-background-secondary, #f5f5f5); }
  @media (min-width: 750px) { .mk-countdown-timer-section { padding: {{ ss.padding_top_desktop | default: 96 }}px 0 {{ ss.padding_bottom_desktop | default: 96 }}px; } }
  .mk-countdown-timer-section__container { max-width: var(--container-max-width, 800px); margin: 0 auto; padding: 0 var(--container-padding, 32px); text-align: center; }
  .mk-countdown-timer-section__title { margin: 0 0 32px 0; font-size: 28px; font-weight: 700; }
  .mk-countdown-timer-section__countdown { display: flex; justify-content: center; align-items: center; gap: 12px; margin-bottom: 32px; }
  .mk-countdown-timer-section__item { display: flex; flex-direction: column; align-items: center; gap: 8px; }
  .mk-countdown-timer-section__num { min-width: 72px; padding: 16px; background: var(--color-background); border-radius: 12px; font-size: 32px; font-weight: 700; }
  @media (min-width: 750px) { .mk-countdown-timer-section__num { min-width: 88px; padding: 20px; font-size: 40px; } }
  .mk-countdown-timer-section__label { font-size: 12px; color: var(--color-text-secondary, #666); text-transform: uppercase; }
  .mk-countdown-timer-section__sep { font-size: 32px; font-weight: 700; color: var(--color-text-secondary, #666); }
  .mk-countdown-timer-section__progress { max-width: 400px; margin: 0 auto 24px; }
  .mk-countdown-timer-section__progress-bar { height: 6px; background: var(--color-border); border-radius: 100px; overflow: hidden; }
  .mk-countdown-timer-section__progress-fill { height: 100%; background: var(--color-primary, #000); border-radius: 100px; transition: width 1s ease; }
  .mk-countdown-timer-section__button { display: inline-flex; padding: 16px 40px; font-size: 14px; font-weight: 600; color: var(--color-on-primary, #fff); background: var(--color-primary, #000); border-radius: 8px; text-decoration: none; }
  .mk-countdown-timer-section__button:hover { opacity: 0.85; }
{% endstylesheet %}

{% javascript %}
  (function() {
    const countdown = document.querySelector('[data-countdown-timer]');
    if (!countdown) return;
    const endDate = new Date(countdown.dataset.end).getTime();
    const totalDuration = parseInt(countdown.dataset.duration) || 86400000 * 7;
    function update() {
      const now = Date.now();
      const diff = Math.max(0, endDate - now);
      const days = Math.floor(diff / 86400000);
      const hours = Math.floor((diff % 86400000) / 3600000);
      const minutes = Math.floor((diff % 3600000) / 60000);
      const seconds = Math.floor((diff % 60000) / 1000);
      countdown.querySelector('[data-days]').textContent = String(days).padStart(2, '0');
      countdown.querySelector('[data-hours]').textContent = String(hours).padStart(2, '0');
      countdown.querySelector('[data-minutes]').textContent = String(minutes).padStart(2, '0');
      countdown.querySelector('[data-seconds]').textContent = String(seconds).padStart(2, '0');
      const progress = Math.max(0, Math.min(100, ((totalDuration - diff) / totalDuration) * 100));
      const fill = countdown.querySelector('[data-progress-fill]');
      if (fill) fill.style.width = progress + '%';
    }
    update();
    setInterval(update, 1000);
  })();
{% endjavascript %}

