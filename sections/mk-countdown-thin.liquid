{%- comment -%}
  MK Countdown Thin板块

  薄型倒计时

  作者：崽崽 (AI助手)
{%- endcomment -%}

{% liquid
  assign ss = section.settings
-%}

<section id="{{ section.id }}" class="mk-countdown-thin color-{{ ss.color_scheme | default: 'background-1' }}">
  <div class="mk-countdown-thin__container">
    {%- if ss.title != blank -%}
      <h2 class="mk-countdown-thin__title">{{ ss.title }}</h2>
    {%- endif -%}
    <div class="mk-countdown-thin__countdown" data-countdown-thin data-end="{{ ss.end_date | default: '' | date: '%Y-%m-%dT%H:%M:%S' }}">
      <div class="mk-countdown-thin__item"><span class="mk-countdown-thin__num" data-days>00</span><span class="mk-countdown-thin__label">Days</span></div>
      <div class="mk-countdown-thin__item"><span class="mk-countdown-thin__num" data-hours>00</span><span class="mk-countdown-thin__label">Hours</span></div>
      <div class="mk-countdown-thin__item"><span class="mk-countdown-thin__num" data-minutes>00</span><span class="mk-countdown-thin__label">Minutes</span></div>
      <div class="mk-countdown-thin__item"><span class="mk-countdown-thin__num" data-seconds>00</span><span class="mk-countdown-thin__label">Seconds</span></div>
    </div>
  </div>
</section>

{% stylesheet %}
  .mk-countdown-thin { padding: 80px 0; }
  .mk-countdown-thin__container { max-width: 800px; margin: 0 auto; padding: 0 32px; text-align: center; }
  .mk-countdown-thin__title { margin: 0 0 40px 0; font-size: var(--mk-font-size-5xl); font-weight: 700; }
  .mk-countdown-thin__countdown { display: flex; justify-content: center; gap: var(--mk-spacing-2xl); }
  .mk-countdown-thin__item { display: flex; flex-direction: column; align-items: center; gap: var(--mk-spacing-sm); }
  .mk-countdown-thin__num { min-width: 88px; padding: var(--mk-spacing-xl) 16px; background: var(--color-background-secondary, var(--mk-color-bg-secondary)); border-radius: var(--mk-radius-md); font-size: 38px; font-weight: 700; }
  .mk-countdown-thin__label { font-size: var(--mk-font-size-xs); text-transform: uppercase; letter-spacing: 1px; color: var(--color-text-secondary, #666); }
{% endstylesheet %}

{% javascript %}
  (function() {
    const c = document.querySelector('[data-countdown-thin]');
    if (!c) return;
    const end = new Date(c.dataset.end).getTime();
    function u() {
      const now = Date.now(), diff = Math.max(0, end - now);
      const d = Math.floor(diff/86400000), h = Math.floor((diff%86400000)/3600000), m = Math.floor((diff%3600000)/60000), s = Math.floor((diff%60000)/1000);
      c.querySelector('[data-days]').textContent = String(d).padStart(2,'0');
      c.querySelector('[data-hours]').textContent = String(h).padStart(2,'0');
      c.querySelector('[data-minutes]').textContent = String(m).padStart(2,'0');
      c.querySelector('[data-seconds]').textContent = String(s).padStart(2,'0');
    }
    u(); setInterval(u, 1000);
  })();
{% endjavascript %}

{% schema %}
{
  "name": "MK Countdown Thin",
  "tag": "section",
  "settings": [
    { "type": "text", "id": "title", "label": "标题" },
    { "type": "text", "id": "end_date", "label": "结束日期" },
    { "type": "color_scheme", "id": "color_scheme", "label": "颜色方案", "default": "scheme-1" }
  ],
  "presets": [{ "name": "MK Countdown Thin" }]
}
{% endschema %}
