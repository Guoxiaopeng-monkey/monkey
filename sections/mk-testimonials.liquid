{%- comment -%}
  MK Testimonials轮播板块

  客户评价轮播

  作者：崽崽 (AI助手)
{%- endcomment -%}

{% liquid
  assign ss = section.settings
-%}

<section id="{{ section.id }}" class="mk-testimonials color-{{ ss.color_scheme | default: 'background-1' }}">
  <div class="mk-testimonials__container">
    {%- if ss.title != blank -%}
      <h2 class="mk-testimonials__title">{{ ss.title }}</h2>
    {%- endif -%}

    <div class="mk-testimonials__track" data-testimonials-track>
      {%- for i in (1..6) -%}
        {%- assign text_setting = 'text_' | append: i -%}
        {%- assign author_setting = 'author_' | append: i -%}
        {%- assign role_setting = 'role_' | append: i -%}
        {%- assign rating_setting = 'rating_' | append: i -%}

        {%- if ss[text_setting] != blank -%}
          <div class="mk-testimonials__slide" data-slide="{{ forloop.index0 }}">
            <div class="mk-testimonials__card">
              <div class="mk-testimonials__stars">
                {%- assign rating = ss[rating_setting] | default: 5 | plus: 0 -%}
                {%- for star in (1..5) -%}
                  <span class="mk-testimonials__star {% if star <= rating %}filled{% endif %}">{{- 'icon-star.svg' | inline_asset_content -}}</span>
                {%- endfor -%}
              </div>
              <blockquote class="mk-testimonials__text">{{ ss[text_setting] }}</blockquote>
              {%- if ss[author_setting] != blank -%}
                <cite class="mk-testimonials__author">{{ ss[author_setting] }}</cite>
              {%- endif -%}
              {%- if ss[role_setting] != blank -%}
                <span class="mk-testimonials__role">{{ ss[role_setting] }}</span>
              {%- endif -%}
            </div>
          </div>
        {%- endif -%}
      {%- endfor -%}
    </div>

    {%- if ss.show_arrows -%}
      <div class="mk-testimonials__arrows">
        <button type="button" class="mk-testimonials__arrow" data-arrow="prev">{{- 'icon-arrow-left.svg' | inline_asset_content -}}</button>
        <button type="button" class="mk-testimonials__arrow" data-arrow="next">{{- 'icon-arrow-right.svg' | inline_asset_content -}}</button>
      </div>
    {%- endif -%}
  </div>
</section>

{% stylesheet %}
  .mk-testimonials { padding: {{ ss.padding_top_mobile | default: 48 }}px 0 {{ ss.padding_bottom_mobile | default: 48 }}px; }
  @media (min-width: 750px) { .mk-testimonials { padding: {{ ss.padding_top_desktop | default: 80 }}px 0 {{ ss.padding_bottom_desktop | default: 80 }}px; } }
  .mk-testimonials__container { max-width: var(--container-max-width, 1000px); margin: 0 auto; padding: 0 var(--container-padding, 32px); }
  .mk-testimonials__title { margin: 0 0 40px 0; font-size: var(--mk-font-size-3xl); font-weight: 700; text-align: center; }
  .mk-testimonials__track { overflow: hidden; }
  .mk-testimonials__slide { display: none; }
  .mk-testimonials__slide.active { display: block; }
  .mk-testimonials__card { max-width: 600px; margin: 0 auto; padding: var(--mk-spacing-3xl); background: var(--color-background-secondary, var(--mk-color-bg-secondary)); border-radius: var(--mk-radius-lg); text-align: center; }
  .mk-testimonials__stars { display: flex; justify-content: center; gap: var(--mk-spacing-xs); margin-bottom: 16px; }
  .mk-testimonials__star { display: flex; width: 20px; height: 20px; }
  .mk-testimonials__star svg { fill: var(--color-border); }
  .mk-testimonials__star.filled svg { fill: #f5a623; }
  .mk-testimonials__text { margin: 0 0 20px 0; font-size: var(--mk-font-size-lg); line-height: 1.6; font-style: italic; }
  .mk-testimonials__author { font-size: var(--mk-font-size-md); font-weight: 600; font-style: normal; }
  .mk-testimonials__role { display: block; font-size: var(--mk-font-size-sm); color: var(--color-text-secondary, #666); margin-top: 4px; }
  .mk-testimonials__arrows { display: flex; justify-content: center; gap: var(--mk-spacing-lg); margin-top: 24px; }
  .mk-testimonials__arrow { display: flex; align-items: center; justify-content: center; width: 44px; height: 44px; background: var(--color-background); border: 1px solid var(--color-border); border-radius: 50%; cursor: pointer; }
  .mk-testimonials__arrow svg { width: 18px; height: 18px; }
{% endstylesheet %}

{% javascript %}
  (function() {
    const slider = document.querySelector('[data-testimonials-track]');
    if (!slider) return;
    const slides = slider.querySelectorAll('[data-slide]');
    let current = 0;
    function goTo(idx) {
      slides[current].classList.remove('active');
      current = (idx + slides.length) % slides.length;
      slides[current].classList.add('active');
    }
    slider.parentElement.querySelectorAll('[data-arrow]').forEach(btn => {
      btn.addEventListener('click', () => {
        goTo(btn.dataset.arrow === 'next' ? current + 1 : current - 1);
      });
    });
    if (slides.length > 0) slides[0].classList.add('active');
  })();
{% endjavascript %}

{% schema %}
{
  "name": "MK Testimonials",
  "tag": "section",
  "settings": [
    { "type": "text", "id": "title", "label": "标题" },
    { "type": "checkbox", "id": "show_arrows", "label": "显示箭头", "default": true },
    { "type": "header", "content": "评价 1" }, { "type": "textarea", "id": "text_1", "label": "内容 1" }, { "type": "text", "id": "author_1", "label": "作者 1" }, { "type": "text", "id": "role_1", "label": "角色 1" }, { "type": "range", "id": "rating_1", "label": "评分 1", "min": 1, "max": 5, "default": 5 },
    { "type": "header", "content": "评价 2" }, { "type": "textarea", "id": "text_2", "label": "内容 2" }, { "type": "text", "id": "author_2", "label": "作者 2" }, { "type": "text", "id": "role_2", "label": "角色 2" }, { "type": "range", "id": "rating_2", "label": "评分 2", "min": 1, "max": 5, "default": 5 },
    { "type": "header", "content": "评价 3" }, { "type": "textarea", "id": "text_3", "label": "内容 3" }, { "type": "text", "id": "author_3", "label": "作者 3" }, { "type": "text", "id": "role_3", "label": "角色 3" }, { "type": "range", "id": "rating_3", "label": "评分 3", "min": 1, "max": 5, "default": 5 },
    { "type": "header", "content": "间距" },
    { "type": "range", "id": "padding_top_mobile", "label": "上边距 (移动端)", "min": 0, "max": 120, "default": 48, "unit": "px" },
    { "type": "range", "id": "padding_bottom_mobile", "label": "下边距 (移动端)", "min": 0, "max": 120, "default": 48, "unit": "px" },
    { "type": "range", "id": "padding_top_desktop", "label": "上边距 (PC端)", "min": 0, "max": 200, "default": 80, "unit": "px" },
    { "type": "range", "id": "padding_bottom_desktop", "label": "下边距 (PC端)", "min": 0, "max": 200, "default": 80, "unit": "px" },
    { "type": "color_scheme", "id": "color_scheme", "label": "颜色方案", "default": "scheme-1" }
  ],
  "presets": [{ "name": "MK Testimonials" }]
}
{% endschema %}
