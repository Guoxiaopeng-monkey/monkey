{%- comment -%}
  MK Countdown Modern板块

  现代倒计时

  作者：崽崽 (AI助手)
{%- endcomment -%}

{% liquid
  assign ss = section.settings
-%}

<section id="{{ section.id }}" class="mk-countdown-modern color-{{ ss.color_scheme | default: 'background-1' }}">
  <div class="mk-countdown-modern__container">
    {%- if ss.title != blank -%}
      <h2 class="mk-countdown-modern__title">{{ ss.title }}</h2>
    {%- endif -%}
    <div class="mk-countdown-modern__countdown" data-countdown-modern data-end="{{ ss.end_date | default: '' | date: '%Y-%m-%dT%H:%M:%S' }}">
      <div class="mk-countdown-modern__item"><span class="mk-countdown-modern__num" data-days>00</span><span class="mk-countdown-modern__label">Days</span></div>
      <div class="mk-countdown-modern__item"><span class="mk-countdown-modern__num" data-hours>00</span><span class="mk-countdown-modern__label">Hours</span></div>
      <div class="mk-countdown-modern__item"><span class="mk-countdown-modern__num" data-minutes>00</span><span class="mk-countdown-modern__label">Minutes</span></div>
      <div class="mk-countdown-modern__item"><span class="mk-countdown-modern__num" data-seconds>00</span><span class="mk-countdown-modern__label">Seconds</span></div>
    </div>
  </div>
</section>

{% stylesheet %}
  .mk-countdown-modern { padding: 80px 0; background: linear-gradient(135deg, #0f0c29 0%, #302b63 50%, #24243e 100%); }
  .mk-countdown-modern__container { max-width: 800px; margin: 0 auto; padding: 0 32px; text-align: center; }
  .mk-countdown-modern__title { margin: 0 0 40px 0; font-size: var(--mk-font-size-5xl); font-weight: 700; color: #fff; }
  .mk-countdown-modern__countdown { display: flex; justify-content: center; gap: 20px; }
  .mk-countdown-modern__item { display: flex; flex-direction: column; align-items: center; gap: var(--mk-spacing-sm); }
  .mk-countdown-modern__num { min-width: 90px; padding: var(--mk-spacing-2xl) 16px; background: rgba(255,255,255,0.1); backdrop-filter: blur(10px); border: 1px solid rgba(255,255,255,0.2); border-radius: var(--mk-radius-lg); font-size: 40px; font-weight: 700; color: #fff; }
  .mk-countdown-modern__label { font-size: var(--mk-font-size-xs); text-transform: uppercase; letter-spacing: 2px; color: rgba(255,255,255,0.6); }
{% endstylesheet %}

{% javascript %}
  (function() {
    const c = document.querySelector('[data-countdown-modern]');
    if (!c) return;
    const end = new Date(c.dataset.end).getTime();
    function u() {
      const now = Date.now(), diff = Math.max(0, end - now);
      const d = Math.floor(diff/86400000), h = Math.floor((diff%86400000)/3600000), m = Math.floor((diff%3600000)/60000), s = Math.floor((diff%60000)/1000);
      c.querySelector('[data-days]').textContent = String(d).padStart(2,'0');
      c.querySelector('[data-hours]').textContent = String(h).padStart(2,'0');
      c.querySelector('[data-minutes]').textContent = String(m).padStart(2,'0');
      c.querySelector('[data-seconds]').textContent = String(s).padStart(2,'0');
    }
    u(); setInterval(u, 1000);
  })();
{% endjavascript %}

{% schema %}
{
  "name": "MK Countdown Modern",
  "tag": "section",
  "settings": [
    { "type": "text", "id": "title", "label": "标题" },
    { "type": "text", "id": "end_date", "label": "结束日期" },
    { "type": "color_scheme", "id": "color_scheme", "label": "颜色方案", "default": "scheme-1" }
  ],
  "presets": [{ "name": "MK Countdown Modern" }]
}
{% endschema %}
