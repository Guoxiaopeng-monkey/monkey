{%- comment -%}
  MK Instagram动态组件

  展示Instagram图片流

  作者：崽崽 (AI助手)
{%- endcomment -%}

{% liquid
  assign ss = section.settings
  assign images_per_row = ss.images_per_row | default: 4
-%}

<section
  id="{{ section.id }}"
  class="mk-instagram-feed color-{{ ss.color_scheme | default: 'background-1' }}"
>
  <div class="mk-instagram-feed__container">
    {%- if ss.title != blank -%}
      <div class="mk-instagram-feed__header">
        <h2 class="mk-instagram-feed__title">{{ ss.title }}</h2>
        {%- if ss.username != blank -%}
          <a href="https://instagram.com/{{ ss.username }}" target="_blank" class="mk-instagram-feed__username">
            @{{ ss.username }}
          </a>
        {%- endif -%}
      </div>
    {%- endif -%}

    <div
      class="mk-instagram-feed__grid"
      style="--images-per-row: {{ images_per_row }};"
    >
      {%- for i in (1..8) -%}
        {%- assign image_setting = 'image_' | append: i -%}
        {%- assign image = ss[image_setting] -%}

        {%- if image != blank -%}
          <div class="mk-instagram-feed__item">
            {{ image | image_url: width: 400 | image_tag: class: 'mk-instagram-feed__image' }}
            <div class="mk-instagram-feed__overlay">
              <span class="mk-instagram-feed__icon">{{- 'icon-instagram.svg' | inline_asset_content -}}</span>
            </div>
          </div>
        {%- else -%}
          {%- comment -%} 占位符图片 {%- endcomment -%}
          <div class="mk-instagram-feed__item mk-instagram-feed__item--placeholder">
            {{ 'image' | placeholder_svg_tag: 'mk-instagram-feed__image' }}
          </div>
        {%- endif -%}
      {%- endfor -%}
    </div>

    {%- if ss.button_text != blank -%}
      <div class="mk-instagram-feed__footer">
        <a href="https://instagram.com/{{ ss.username | default: 'shop' }}" target="_blank" class="mk-instagram-feed__button">
          {{ ss.button_text }}
        </a>
      </div>
    {%- endif -%}
  </div>
</section>

{% stylesheet %}
  .mk-instagram-feed {
    padding: {{ ss.padding_top_mobile | default: 48 }}px 0 {{ ss.padding_bottom_mobile | default: 48 }}px;
  }

  @media (min-width: 750px) {
    .mk-instagram-feed {
      padding: {{ ss.padding_top_desktop | default: 64 }}px 0 {{ ss.padding_bottom_desktop | default: 64 }}px;
    }
  }

  .mk-instagram-feed__container {
    max-width: var(--container-max-width, 1200px);
    margin: 0 auto;
    padding: 0 var(--container-padding, 32px);
  }

  .mk-instagram-feed__header {
    text-align: center;
    margin-bottom: 32px;
  }

  .mk-instagram-feed__title {
    margin: 0 0 8px 0;
    font-size: var(--mk-font-size-3xl);
    font-weight: 700;
  }

  .mk-instagram-feed__username {
    font-size: var(--mk-font-size-md);
    color: var(--color-text-secondary, #666);
    text-decoration: none;
  }

  .mk-instagram-feed__username:hover {
    color: var(--color-primary, #000);
  }

  .mk-instagram-feed__grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--mk-spacing-sm);
  }

  @media (min-width: 480px) {
    .mk-instagram-feed__grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  @media (min-width: 750px) {
    .mk-instagram-feed__grid {
      grid-template-columns: repeat(var(--images-per-row, 4), 1fr);
      gap: var(--mk-spacing-lg);
    }
  }

  .mk-instagram-feed__item {
    position: relative;
    aspect-ratio: 1 / 1;
    overflow: hidden;
    border-radius: var(--mk-radius-sm);
    background-color: var(--color-background-secondary, var(--mk-color-bg-secondary));
  }

  .mk-instagram-feed__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.3s ease;
  }

  .mk-instagram-feed__item:hover .mk-instagram-feed__image {
    transform: scale(1.05);
  }

  .mk-instagram-feed__overlay {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: rgba(0, 0, 0, 0.3);
    opacity: 0;
    transition: opacity 0.3s ease;
  }

  .mk-instagram-feed__item:hover .mk-instagram-feed__overlay {
    opacity: 1;
  }

  .mk-instagram-feed__icon {
    display: flex;
    width: 32px;
    height: 32px;
    color: #fff;
  }

  .mk-instagram-feed__icon svg {
    width: 100%;
    height: 100%;
    fill: #fff;
  }

  .mk-instagram-feed__item--placeholder {
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .mk-instagram-feed__item--placeholder svg {
    width: 50%;
    height: 50%;
    opacity: 0.3;
  }

  .mk-instagram-feed__footer {
    text-align: center;
    margin-top: 32px;
  }

  .mk-instagram-feed__button {
    display: inline-flex;
    align-items: center;
    gap: var(--mk-spacing-sm);
    padding: var(--mk-spacing-md) 24px;
    font-size: var(--mk-font-size-md);
    font-weight: 500;
    color: var(--color-foreground);
    background-color: transparent;
    border: 1px solid var(--color-border);
    border-radius: 100px;
    text-decoration: none;
    transition: all 0.2s ease;
  }

  .mk-instagram-feed__button:hover {
    background-color: var(--color-foreground);
    color: var(--color-background);
  }
{% endstylesheet %}

