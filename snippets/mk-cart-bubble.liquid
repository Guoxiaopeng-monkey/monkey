{%- doc -%}
  MK 购物车气泡组件

  渲染购物车数量气泡

  @param {string} [class] - 额外CSS类名

  @example
  {% render 'mk-cart-bubble' %}
{%- enddoc -%}

{% liquid
  assign class = class | default: ''
  assign cart_count = cart.item_count | default: 0
-%}

<a
  href="{{ routes.cart_url }}"
  class="mk-cart-bubble {{ class }}"
  aria-label="{{ 'cart.title' | t | default: '购物车' }}: {{ cart_count }}"
>
  {{- 'icon-cart.svg' | inline_asset_content -}}
  {%- if cart_count > 0 -%}
    <span class="mk-cart-bubble__count" data-cart-count>{{ cart_count }}</span>
  {%- endif -%}
</a>

{% stylesheet %}
  .mk-cart-bubble {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    color: var(--color-foreground);
    border-radius: 50%;
    transition: background-color 0.2s ease;
  }

  .mk-cart-bubble:hover {
    background-color: var(--color-background-secondary, var(--mk-color-bg-secondary));
  }

  .mk-cart-bubble svg {
    width: 22px;
    height: 22px;
  }

  .mk-cart-bubble__count {
    position: absolute;
    top: 2px;
    right: 2px;
    min-width: 18px;
    height: 18px;
    padding: 0 5px;
    font-size: var(--mk-font-size-xs);
    font-weight: 700;
    line-height: 18px;
    text-align: center;
    color: var(--color-on-primary, #fff);
    background-color: var(--color-primary, #000);
    border-radius: 100px;
  }
{% endstylesheet %}

{% javascript %}
  document.addEventListener('cart:updated', () => {
    fetch('/cart.js')
      .then(res => res.json())
      .then(cart => {
        const countEl = document.querySelector('[data-cart-count]');
        if (countEl) {
          const count = cart.item_count;
          if (count > 0) {
            countEl.textContent = count;
            countEl.hidden = false;
          } else {
            countEl.hidden = true;
          }
        }
      });
  });
{% endjavascript %}
