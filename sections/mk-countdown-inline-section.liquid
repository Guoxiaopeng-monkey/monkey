{%- comment -%}
  MK Countdown Inline Section板块

  内联倒计时区块

  作者：崽崽 (AI助手)
{%- endcomment -%}

{% liquid
  assign ss = section.settings
-%}

<section id="{{ section.id }}" class="mk-countdown-inline-section color-{{ ss.color_scheme | default: 'background-1' }}">
  <div class="mk-countdown-inline-section__container">
    {%- if ss.title != blank -%}
      <span class="mk-countdown-inline-section__label">{{ ss.title }}</span>
    {%- endif -%}

    <div class="mk-countdown-inline-section__countdown" data-countdown-inline data-end="{{ ss.end_date | default: '' | date: '%Y-%m-%dT%H:%M:%S' }}">
      <div class="mk-countdown-inline-section__item">
        <span class="mk-countdown-inline-section__num" data-days>00</span>
        <span class="mk-countdown-inline-section__unit">天</span>
      </div>
      <span class="mk-countdown-inline-section__sep">:</span>
      <div class="mk-countdown-inline-section__item">
        <span class="mk-countdown-inline-section__num" data-hours>00</span>
        <span class="mk-countdown-inline-section__unit">时</span>
      </div>
      <span class="mk-countdown-inline-section__sep">:</span>
      <div class="mk-countdown-inline-section__item">
        <span class="mk-countdown-inline-section__num" data-minutes>00</span>
        <span class="mk-countdown-inline-section__unit">分</span>
      </div>
      <span class="mk-countdown-inline-section__sep">:</span>
      <div class="mk-countdown-inline-section__item">
        <span class="mk-countdown-inline-section__num" data-seconds>00</span>
        <span class="mk-countdown-inline-section__unit">秒</span>
      </div>
    </div>
  </div>
</section>

{% stylesheet %}
  .mk-countdown-inline-section { padding: var(--mk-spacing-lg) 0; }
  .mk-countdown-inline-section__container { max-width: var(--container-max-width, 1200px); margin: 0 auto; padding: 0 var(--container-padding, 32px); display: flex; align-items: center; justify-content: center; gap: var(--mk-spacing-md); flex-wrap: wrap; }
  .mk-countdown-inline-section__label { font-size: var(--mk-font-size-md); font-weight: 600; }
  .mk-countdown-inline-section__countdown { display: flex; align-items: center; gap: var(--mk-spacing-xs); }
  .mk-countdown-inline-section__item { display: flex; align-items: baseline; gap: 2px; }
  .mk-countdown-inline-section__num { font-size: var(--mk-font-size-xl); font-weight: 700; min-width: 28px; text-align: center; }
  .mk-countdown-inline-section__unit { font-size: var(--mk-font-size-xs); color: var(--color-text-secondary, #666); }
  .mk-countdown-inline-section__sep { font-size: var(--mk-font-size-xl); font-weight: 700; color: var(--color-text-secondary, #666); }
{% endstylesheet %}

{% javascript %}
  (function() {
    const countdown = document.querySelector('[data-countdown-inline]');
    if (!countdown) return;
    const endDate = new Date(countdown.dataset.end).getTime();
    function update() {
      const now = Date.now();
      const diff = Math.max(0, endDate - now);
      const days = Math.floor(diff / 86400000);
      const hours = Math.floor((diff % 86400000) / 3600000);
      const minutes = Math.floor((diff % 3600000) / 60000);
      const seconds = Math.floor((diff % 60000) / 1000);
      countdown.querySelector('[data-days]').textContent = String(days).padStart(2, '0');
      countdown.querySelector('[data-hours]').textContent = String(hours).padStart(2, '0');
      countdown.querySelector('[data-minutes]').textContent = String(minutes).padStart(2, '0');
      countdown.querySelector('[data-seconds]').textContent = String(seconds).padStart(2, '0');
    }
    update();
    setInterval(update, 1000);
  })();
{% endjavascript %}

{% schema %}
{
  "name": "MK Countdown Inline Section",
  "tag": "section",
  "settings": [
    { "type": "text", "id": "title", "label": "标签文字" },
    { "type": "text", "id": "end_date", "label": "结束日期", "info": "格式: YYYY-MM-DD HH:MM" },
    { "type": "color_scheme", "id": "color_scheme", "label": "颜色方案", "default": "scheme-1" }
  ],
  "presets": [{ "name": "MK Countdown Inline Section" }]
}
{% endschema %}
