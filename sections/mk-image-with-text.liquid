{%- comment -%}
  MK 图片与文本组件
  
  功能：图片与文本的灵活布局展示
  
  作者：崽崽 (AI助手)
  基于：whale ug-img-with-text.liquid, demo-horizon image-with-text
{%- endcomment -%}

{%- liquid
  assign ss = section.settings
  assign bg_color = ss.background_color | default: '#ffffff'
  assign image = ss.image
  assign image_position = ss.image_position
  assign image_ratio = ss.image_ratio | default: 'adapt'
  
  assign pt_mob = ss.padding_top_mobile | default: 48
  assign pb_mob = ss.padding_bottom_mobile | default: 48
  assign pt_desk = ss.padding_top_desktop | default: 80
  assign pb_desk = ss.padding_bottom_desktop | default: 80
-%}

<style>
  #{{ section.id }} {
    --iwt-bg: {{ bg_color }};
    --iwt-pt-mob: {{ pt_mob }}px;
    --iwt-pb-mob: {{ pb_mob }}px;
    --iwt-pt-desk: {{ pt_desk }}px;
    --iwt-pb-desk: {{ pb_desk }}px;
    --iwt-image-ratio: {{ image_ratio }};
    background-color: var(--iwt-bg);
    padding: var(--iwt-pt-mob) 0 var(--iwt-pb-mob);
  }
  
  @media (min-width: 750px) {
    #{{ section.id }} {
      padding: var(--iwt-pt-desk) 0 var(--iwt-pb-desk);
    }
  }
  
  #{{ section.id }} .mk-image-with-text__grid {
    grid-template-columns: {% if image_position == 'right' %}1fr{% else %}1fr{% endif %};
    direction: {% if image_position == 'right' %}rtl{% else %}ltr{% endif %};
  }
  
  @media (min-width: 750px) {
    #{{ section.id }} .mk-image-with-text__grid {
      grid-template-columns: {% if image_position == 'right' %}1fr 1fr{% else %}1fr 1fr{% endif %};
      direction: ltr;
    }
  }
  
  #{{ section.id }} .mk-image-with-text__image-wrapper {
    direction: ltr;
  }
</style>

<section
  id="{{ section.id }}"
  class="mk-image-with-text"
  data-skip-node-update
>
  <div class="mk-image-with-text__container">
    <div class="mk-image-with-text__grid">
      
      {%- comment -%} 图片区域 {%- endcomment -%}
      <div class="mk-image-with-text__image-wrapper">
        {% if image != blank %}
          <img
            src="{{ image | image_url: width: 1200 }}"
            alt="{{ image.alt | default: ss.heading }}"
            width="1200"
            height="{{ 1200 | divided_by: image.aspect_ratio | round }}"
            loading="lazy"
            class="mk-image-with-text__image"
          >
        {% else %}
          {{ 'image' | placeholder_svg_tag: 'mk-image-with-text__placeholder' }}
        {% endif %}
      </div>
      
      {%- comment -%} 内容区域 {%- endcomment -%}
      <div class="mk-image-with-text__content" style="text-align: {{ ss.content_alignment }};">
        {% if ss.label != blank %}
          <p class="mk-image-with-text__label">{{ ss.label }}</p>
        {% endif %}
        
        {% if ss.heading != blank %}
          <h2 class="mk-image-with-text__heading">{{ ss.heading }}</h2>
        {% endif %}
        
        {% if ss.text != blank %}
          <div class="mk-image-with-text__text">{{ ss.text }}</div>
        {% endif %}
        
        {% if ss.button_text != blank %}
          <a 
            href="{{ ss.button_link | default: '#' }}" 
            class="mk-image-with-text__button mk-image-with-text__button--{{ ss.button_style | default: 'primary' }}"
          >
            {{ ss.button_text }}
            {% if ss.show_arrow %}
              <span class="mk-image-with-text__arrow">
                {{- 'icon-arrow-right.svg' | inline_asset_content -}}
              </span>
            {% endif %}
          </a>
        {% endif %}
      </div>
    </div>
  </div>
</section>

{% stylesheet %}
  .mk-image-with-text__container {
    max-width: var(--container-max-width, 1440px);
    margin: 0 auto;
    padding: 0 var(--container-padding, 32px);
  }

  .mk-image-with-text__grid {
    display: grid;
    gap: var(--mk-spacing-3xl);
    align-items: center;
  }

  @media (min-width: 750px) {
    .mk-image-with-text__grid {
      gap: 64px;
    }
  }

  /* Image */
  .mk-image-with-text__image-wrapper {
    position: relative;
    overflow: hidden;
    border-radius: var(--mk-radius-sm);
  }

  .mk-image-with-text__image {
    display: block;
    width: 100%;
    height: auto;
    object-fit: cover;
  }

  @if image_ratio == 'square' {
    .mk-image-with-text__image-wrapper {
      aspect-ratio: 1 / 1;
    }
  }

  @if image_ratio == 'portrait' {
    .mk-image-with-text__image-wrapper {
      aspect-ratio: 3 / 4;
    }
  }

  .mk-image-with-text__placeholder {
    width: 100%;
    aspect-ratio: 4 / 3;
    background: var(--color-background-secondary, var(--mk-color-bg-secondary));
  }

  /* Content */
  .mk-image-with-text__content {
    max-width: 520px;
  }

  @media (min-width: 750px) {
    .mk-image-with-text__content {
      padding: 0 24px;
    }
  }

  .mk-image-with-text__label {
    margin: 0 0 12px 0;
    font-size: var(--mk-font-size-sm);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 1.5px;
    color: var(--color-primary, #000);
  }

  .mk-image-with-text__heading {
    margin: 0 0 20px 0;
    font-size: clamp(28px, 4vw, 40px);
    font-weight: 700;
    line-height: 1.15;
  }

  .mk-image-with-text__text {
    font-size: var(--mk-font-size-lg);
    line-height: 1.7;
    opacity: 0.85;
  }

  .mk-image-with-text__text p {
    margin: 0 0 16px 0;
  }

  .mk-image-with-text__text p:last-child {
    margin-bottom: 0;
  }

  /* Button */
  .mk-image-with-text__button {
    display: inline-flex;
    align-items: center;
    gap: var(--mk-spacing-sm);
    margin-top: 28px;
    padding: 14px 28px;
    font-size: var(--mk-font-size-md);
    font-weight: 600;
    text-decoration: none;
    border-radius: var(--mk-radius-xs);
    transition: all 0.2s ease;
  }

  .mk-image-with-text__button--primary {
    background: var(--color-primary, #000);
    color: var(--color-background, #fff);
  }

  .mk-image-with-text__button--primary:hover {
    opacity: 0.85;
  }

  .mk-image-with-text__button--outline {
    background: transparent;
    color: var(--color-primary, #000);
    border: 1.5px solid var(--color-primary, #000);
  }

  .mk-image-with-text__button--outline:hover {
    background: var(--color-primary, #000);
    color: var(--color-background, #fff);
  }

  .mk-image-with-text__arrow {
    display: flex;
    width: 16px;
    height: 16px;
    transition: transform 0.2s ease;
  }

  .mk-image-with-text__button:hover .mk-image-with-text__arrow {
    transform: translateX(4px);
  }

  .mk-image-with-text__arrow svg {
    width: 100%;
    height: 100%;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "MK 图片与文本",
  "tag": "section",
  "settings": [
    {
      "type": "header",
      "content": "图片设置"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "图片"
    },
    {
      "type": "select",
      "id": "image_position",
      "label": "图片位置",
      "options": [
        { "value": "left", "label": "居左" },
        { "value": "right", "label": "居右" }
      ],
      "default": "left"
    },
    {
      "type": "select",
      "id": "image_ratio",
      "label": "图片比例",
      "options": [
        { "value": "adapt", "label": "自适应" },
        { "value": "square", "label": "正方形 1:1" },
        { "value": "portrait", "label": "竖向 3:4" }
      ],
      "default": "adapt"
    },
    {
      "type": "header",
      "content": "内容设置"
    },
    {
      "type": "text",
      "id": "label",
      "label": "标签文字"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "标题",
      "default": "讲述您的故事"
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "文本内容"
    },
    {
      "type": "select",
      "id": "content_alignment",
      "label": "内容对齐",
      "options": [
        { "value": "left", "label": "居左" },
        { "value": "center", "label": "居中" },
        { "value": "right", "label": "居右" }
      ],
      "default": "left"
    },
    {
      "type": "header",
      "content": "按钮设置"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "按钮文字"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "按钮链接"
    },
    {
      "type": "select",
      "id": "button_style",
      "label": "按钮样式",
      "options": [
        { "value": "primary", "label": "实心（Primary）" },
        { "value": "outline", "label": "描边（Outline）" }
      ],
      "default": "primary"
    },
    {
      "type": "checkbox",
      "id": "show_arrow",
      "label": "显示箭头",
      "default": true
    },
    {
      "type": "header",
      "content": "颜色设置"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "背景颜色",
      "default": "#ffffff"
    },
    {
      "type": "header",
      "content": "间距设置"
    },
    {
      "type": "range",
      "id": "padding_top_mobile",
      "label": "上边距 (移动端)",
      "min": 0,
      "max": 120,
      "default": 48,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "label": "下边距 (移动端)",
      "min": 0,
      "max": 120,
      "default": 48,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_top_desktop",
      "label": "上边距 (PC端)",
      "min": 0,
      "max": 200,
      "default": 80,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_bottom_desktop",
      "label": "下边距 (PC端)",
      "min": 0,
      "max": 200,
      "default": 80,
      "unit": "px"
    }
  ],
  "presets": [
    {
      "name": "MK 图片与文本"
    }
  ]
}
{% endschema %}
