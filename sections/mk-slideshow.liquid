{%- comment -%}
  MK 轮播图板块

  全屏轮播图展示

  作者：崽崽 (AI助手)
{%- endcomment -%}

{% liquid
  assign ss = section.settings
  assign slides = section.blocks
  assign autoplay = ss.autoplay | default: false
  assign interval = ss.interval | default: 5
-%}

<section
  id="{{ section.id }}"
  class="mk-slideshow color-{{ ss.color_scheme | default: 'background-1' }}"
  data-autoplay="{{ autoplay }}"
  data-interval="{{ interval }}"
>
  <div class="mk-slideshow__container">
    <div class="mk-slideshow__wrapper">
      {%- for block in slides -%}
        {% liquid
          assign bs = block.settings
          assign image = bs.image
          assign link = bs.link
          assign title = bs.title
          assign subtitle = bs.subtitle
          assign text_align = bs.text_align | default: 'center'
        %}

        <div class="mk-slideshow__slide" data-slide-index="{{ forloop.index0 }}" {{ block.shopify_attributes }}>
          {%- if image != blank -%}
            {{ image | image_url: width: 1920 | image_tag: class: 'mk-slideshow__image' }}
          {%- else -%}
            <div class="mk-slideshow__placeholder">{{ 'lifestyle-1' | placeholder_svg_tag }}</div>
          {%- endif -%}

          {%- if title != blank or subtitle != blank -%}
            <div class="mk-slideshow__content mk-slideshow__content--{{ text_align }}">
              {%- if subtitle != blank -%}
                <p class="mk-slideshow__subtitle">{{ subtitle }}</p>
              {%- endif -%}

              {%- if title != blank -%}
                <h2 class="mk-slideshow__title">{{ title }}</h2>
              {%- endif -%}

              {%- if link != blank -%}
                <a href="{{ link }}" class="mk-slideshow__button">{{ bs.button_text | default: '查看更多' }}</a>
              {%- endif -%}
            </div>
          {%- endif -%}
        </div>
      {%- endfor -%}
    </div>

    {%- comment -%} 导航控制 {%- endcomment -%}
    <div class="mk-slideshow__controls">
      <button type="button" class="mk-slideshow__arrow mk-slideshow__arrow--prev" aria-label="{{ 上一个 }}">
        {{- 'icon-arrow-left.svg' | inline_asset_content -}}
      </button>

      <div class="mk-slideshow__dots">
        {%- for i in (0..slides.size) -%}
          {%- if forloop.index0 < slides.size -%}
            <button
              type="button"
              class="mk-slideshow__dot {% if forloop.first %}mk-slideshow__dot--active{% endif %}"
              data-dot-index="{{ forloop.index0 }}"
              aria-label="{{ 'slideshow.go_to_slide' | t: index: forloop.index0 }}"
            ></button>
          {%- endif -%}
        {%- endfor -%}
      </div>

      <button type="button" class="mk-slideshow__arrow mk-slideshow__arrow--next" aria-label="{{ 下一个 }}">
        {{- 'icon-arrow-right.svg' | inline_asset_content -}}
      </button>
    </div>
  </div>
</section>

{% stylesheet %}
  .mk-slideshow {
    position: relative;
    overflow: hidden;
  }

  .mk-slideshow__container {
    position: relative;
    width: 100%;
  }

  .mk-slideshow__wrapper {
    display: flex;
    transition: transform 0.5s ease;
  }

  .mk-slideshow__slide {
    position: relative;
    width: 100%;
    flex-shrink: 0;
  }

  .mk-slideshow__image {
    width: 100%;
    height: 60vh;
    min-height: 400px;
    max-height: 800px;
    object-fit: cover;
  }

  .mk-slideshow__placeholder {
    width: 100%;
    height: 60vh;
    min-height: 400px;
    max-height: 800px;
    background-color: var(--color-background-secondary, var(--mk-color-bg-secondary));
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .mk-slideshow__placeholder svg {
    width: 30%;
    height: 30%;
    opacity: 0.3;
  }

  /* 内容层 */
  .mk-slideshow__content {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 90%;
    max-width: 600px;
    text-align: center;
    color: #fff;
    z-index: 10;
  }

  .mk-slideshow__content--left {
    left: 10%;
    transform: translateY(-50%);
    text-align: left;
  }

  .mk-slideshow__content--right {
    left: auto;
    right: 10%;
    transform: translateY(-50%);
    text-align: right;
  }

  .mk-slideshow__subtitle {
    margin: 0 0 8px 0;
    font-size: var(--mk-font-size-md);
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 2px;
  }

  .mk-slideshow__title {
    margin: 0 0 24px 0;
    font-size: var(--mk-font-size-4xl);
    font-weight: 700;
    line-height: 1.2;
  }

  @media (min-width: 750px) {
    .mk-slideshow__title {
      font-size: 48px;
    }
  }

  .mk-slideshow__button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 14px 32px;
    font-size: var(--mk-font-size-md);
    font-weight: 600;
    color: var(--color-foreground, #000);
    background-color: #fff;
    border-radius: var(--mk-radius-sm);
    text-decoration: none;
    transition: all 0.2s ease;
  }

  .mk-slideshow__button:hover {
    opacity: 0.9;
    transform: translateY(-2px);
  }

  /* 导航控制 */
  .mk-slideshow__controls {
    position: absolute;
    bottom: 24px;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    align-items: center;
    gap: var(--mk-spacing-lg);
    z-index: 10;
  }

  .mk-slideshow__arrow {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 44px;
    height: 44px;
    background-color: rgba(255, 255, 255, 0.9);
    border: none;
    border-radius: 50%;
    cursor: pointer;
    transition: all 0.2s ease;
  }

  .mk-slideshow__arrow:hover {
    background-color: #fff;
    transform: scale(1.05);
  }

  .mk-slideshow__arrow svg {
    width: 20px;
    height: 20px;
    color: var(--color-foreground, #000);
  }

  .mk-slideshow__dots {
    display: flex;
    gap: var(--mk-spacing-sm);
  }

  .mk-slideshow__dot {
    width: 10px;
    height: 10px;
    padding: 0;
    background-color: rgba(255, 255, 255, 0.5);
    border: none;
    border-radius: 50%;
    cursor: pointer;
    transition: all 0.2s ease;
  }

  .mk-slideshow__dot--active {
    background-color: #fff;
    transform: scale(1.2);
  }
{% endstylesheet %}

{% javascript %}
  class Slideshow extends HTMLElement {
    constructor() {
      super();
      this.wrapper = this.querySelector('.mk-slideshow__wrapper');
      this.slides = this.querySelectorAll('.mk-slideshow__slide');
      this.prevBtn = this.querySelector('.mk-slideshow__arrow--prev');
      this.nextBtn = this.querySelector('.mk-slideshow__arrow--next');
      this.dots = this.querySelectorAll('.mk-slideshow__dot');

      this.currentIndex = 0;
      this.autoplay = this.dataset.autoplay === 'true';
      this.interval = parseInt(this.dataset.interval) * 1000;
      this.autoplayTimer = null;

      this.init();
    }

    init() {
      this.prevBtn.addEventListener('click', () => this.prev());
      this.nextBtn.addEventListener('click', () => this.next());

      this.dots.forEach((dot, index) => {
        dot.addEventListener('click', () => this.goTo(index));
      });

      if (this.autoplay) {
        this.startAutoplay();
        this.addEventListener('mouseenter', () => this.stopAutoplay());
        this.addEventListener('mouseleave', () => this.startAutoplay());
      }
    }

    prev() {
      this.currentIndex = (this.currentIndex - 1 + this.slides.length) % this.slides.length;
      this.update();
    }

    next() {
      this.currentIndex = (this.currentIndex + 1) % this.slides.length;
      this.update();
    }

    goTo(index) {
      this.currentIndex = index;
      this.update();
    }

    update() {
      this.wrapper.style.transform = `translateX(-${this.currentIndex * 100}%)`;

      this.dots.forEach((dot, index) => {
        dot.classList.toggle('mk-slideshow__dot--active', index === this.currentIndex);
      });
    }

    startAutoplay() {
      if (this.autoplayTimer) return;
      this.autoplayTimer = setInterval(() => this.next(), this.interval);
    }

    stopAutoplay() {
      if (this.autoplayTimer) {
        clearInterval(this.autoplayTimer);
        this.autoplayTimer = null;
      }
    }
  }

  customElements.define('slideshow-component', Slideshow);
{% endjavascript %}

{% schema %}
{
  "name": "MK 轮播图",
  "tag": "section",
  "settings": [
    {
      "type": "checkbox",
      "id": "autoplay",
      "label": "自动播放",
      "default": false
    },
    {
      "type": "range",
      "id": "interval",
      "label": "自动播放间隔（秒）",
      "min": 3,
      "max": 10,
      "default": 5
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "颜色方案",
      "default": "scheme-1"
    }
  ],
  "blocks": [
    {
      "type": "slide",
      "name": "幻灯片",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "图片"
        },
        {
          "type": "text",
          "id": "subtitle",
          "label": "副标题"
        },
        {
          "type": "text",
          "id": "title",
          "label": "标题"
        },
        {
          "type": "text",
          "id": "button_text",
          "label": "按钮文字"
        },
        {
          "type": "url",
          "id": "link",
          "label": "链接"
        },
        {
          "type": "select",
          "id": "text_align",
          "label": "文本对齐",
          "options": [
            { "value": "left", "label": "左对齐" },
            { "value": "center", "label": "居中" },
            { "value": "right", "label": "右对齐" }
          ],
          "default": "center"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "MK 轮播图",
      "blocks": [
        { "type": "slide" },
        { "type": "slide" }
      ]
    }
  ]
}
{% endschema %}
