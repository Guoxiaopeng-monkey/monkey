{%- doc -%}
  MK 时间线范围组件

  渲染时间线中的项目范围

  @param {string} start - 开始时间
  @param {string} end - 结束时间
  @param {string} [class] - 额外CSS类名

  @example
  {% render 'mk-timeline-scope', start: '2020', end: '2022' %}
{%- enddoc -%}

{% liquid
  assign start = start | default: ''
  assign end = end | default: ''
  assign class = class | default: ''
-%}

<div class="mk-timeline-scope {{ class }}">
  <span class="mk-timeline-scope__start">{{ start }}</span>
  <span class="mk-timeline-scope__separator">-</span>
  <span class="mk-timeline-scope__end">{{ end }}</span>
</div>

{% stylesheet %}
  .mk-timeline-scope { display: inline-flex; align-items: center; gap: 4px; font-size: 13px; font-weight: 500; }
  .mk-timeline-scope__separator { color: var(--color-text-secondary, #666); }
{% endstylesheet %}
