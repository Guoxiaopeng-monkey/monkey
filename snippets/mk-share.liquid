{%- doc -%}
  MK 分享组件

  渲染社交分享按钮

  @param {string} [url] - 分享链接
  @param {string} [title] - 分享标题
  @param {string} [class] - 额外CSS类名

  @example
  {% render 'mk-share', url: product.url, title: product.title %}
{%- enddoc -%}

{% liquid
  assign url = url | default: ''
  assign title = title | default: ''
  assign class = class | default: ''
  assign encoded_url = url | url_encode
  assign encoded_title = title | url_encode
-%}

<div class="mk-share {{ class }}">
  <span class="mk-share__label">{{ 'share.label' | t | default: '分享' }}</span>

  <div class="mk-share__buttons">
    <a
      href="https://www.facebook.com/sharer/sharer.php?u={{ encoded_url }}"
      target="_blank"
      rel="noopener noreferrer"
      class="mk-share__btn mk-share__btn--facebook"
      aria-label="{{ 'share.facebook' | t | default: '分享到Facebook' }}"
    >
      {{- 'icon-facebook.svg' | inline_asset_content -}}
    </a>

    <a
      href="https://twitter.com/intent/tweet?url={{ encoded_url }}&text={{ encoded_title }}"
      target="_blank"
      rel="noopener noreferrer"
      class="mk-share__btn mk-share__btn--twitter"
      aria-label="{{ 'share.twitter' | t | default: '分享到Twitter' }}"
    >
      {{- 'icon-twitter.svg' | inline_asset_content -}}
    </a>

    <a
      href="https://pinterest.com/pin/create/button/?url={{ encoded_url }}&description={{ encoded_title }}"
      target="_blank"
      rel="noopener noreferrer"
      class="mk-share__btn mk-share__btn--pinterest"
      aria-label="{{ 'share.pinterest' | t | default: '分享到Pinterest' }}"
    >
      {{- 'icon-pinterest.svg' | inline_asset_content -}}
    </a>

    <a
      href="mailto:?subject={{ encoded_title }}&body={{ encoded_url }}"
      class="mk-share__btn mk-share__btn--email"
      aria-label="{{ 'share.email' | t | default: '邮件分享' }}"
    >
      {{- 'icon-mail.svg' | inline_asset_content -}}
    </a>
  </div>
</div>

{% stylesheet %}
  .mk-share {
    display: flex;
    align-items: center;
    gap: var(--mk-spacing-md);
  }

  .mk-share__label {
    font-size: var(--mk-font-size-sm);
    font-weight: 500;
    color: var(--color-foreground);
  }

  .mk-share__buttons {
    display: flex;
    gap: var(--mk-spacing-sm);
  }

  .mk-share__btn {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    color: var(--color-foreground);
    background-color: var(--color-background-secondary, var(--mk-color-bg-secondary));
    border-radius: 50%;
    text-decoration: none;
    transition: all 0.2s ease;
  }

  .mk-share__btn:hover {
    background-color: var(--color-border);
    transform: translateY(-2px);
  }

  .mk-share__btn svg {
    width: 16px;
    height: 16px;
  }
{% endstylesheet %}
