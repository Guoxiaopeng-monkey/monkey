{%- comment -%}
  MK Collection Banner板块

  专辑横幅

  作者：崽崽 (AI助手)
{%- endcomment -%}

{% liquid
  assign ss = section.settings
-%}

<section id="{{ section.id }}" class="mk-collection-banner color-{{ ss.color_scheme | default: 'background-1' }}">
  <div class="mk-collection-banner__wrapper">
    {%- if collection.image -%}
      <div class="mk-collection-banner__image">
        {{ collection.image | image_url: width: 1920 | image_tag: loading: 'lazy', class: 'mk-collection-banner__img' }}
      </div>
    {%- endif -%}
    <div class="mk-collection-banner__overlay"></div>
    <div class="mk-collection-banner__content">
      {%- if ss.show_title and collection.title != blank -%}
        <h1 class="mk-collection-banner__title">{{ collection.title }}</h1>
      {%- endif -%}
      {%- if ss.show_description and collection.description != blank -%}
        <p class="mk-collection-banner__description">{{ collection.description | truncate: 200 }}</p>
      {%- endif -%}
    </div>
  </div>
</section>

{% stylesheet %}
  .mk-collection-banner__wrapper { position: relative; min-height: {{ ss.height_mobile | default: 300 }}px; display: flex; align-items: center; justify-content: center; overflow: hidden; }
  @media (min-width: 750px) { .mk-collection-banner__wrapper { min-height: {{ ss.height_desktop | default: 400 }}px; } }
  .mk-collection-banner__image { position: absolute; inset: 0; }
  .mk-collection-banner__img { width: 100%; height: 100%; object-fit: cover; }
  .mk-collection-banner__overlay { position: absolute; inset: 0; background: rgba(0,0,0,{{ ss.overlay_opacity | default: 0.3 }}); }
  .mk-collection-banner__content { position: relative; z-index: 1; text-align: {{ ss.text_align | default: 'center' }}; padding: var(--mk-spacing-5xl) 32px; max-width: 800px; }
  .mk-collection-banner__title { margin: 0 0 12px 0; font-size: var(--mk-font-size-3xl); font-weight: 700; color: #fff; }
  @media (min-width: 750px) { .mk-collection-banner__title { font-size: 42px; } }
  .mk-collection-banner__description { margin: 0; font-size: var(--mk-font-size-md); color: rgba(255,255,255,0.9); line-height: 1.6; }
{% endstylesheet %}

{% schema %}
{
  "name": "MK Collection Banner",
  "tag": "section",
  "settings": [
    { "type": "checkbox", "id": "show_title", "label": "显示标题", "default": true },
    { "type": "checkbox", "id": "show_description", "label": "显示描述", "default": true },
    { "type": "select", "id": "text_align", "label": "文本对齐", "options": [{ "value": "left", "label": "左" }, { "value": "center", "label": "中" }, { "value": "right", "label": "右" }], "default": "center" },
    { "type": "range", "id": "overlay_opacity", "label": "遮罩透明度", "min": 0, "max": 1, "step": 0.1, "default": 0.3 },
    { "type": "range", "id": "height_mobile", "label": "高度 (移动端)", "min": 200, "max": 600, "default": 300, "unit": "px" },
    { "type": "range", "id": "height_desktop", "label": "高度 (PC端)", "min": 300, "max": 800, "default": 400, "unit": "px" },
    { "type": "color_scheme", "id": "color_scheme", "label": "颜色方案", "default": "scheme-1" }
  ],
  "presets": [{ "name": "MK Collection Banner" }]
}
{% endschema %}
