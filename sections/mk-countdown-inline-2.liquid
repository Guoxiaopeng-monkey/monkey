{%- comment -%}
  MK Countdown Inline 2板块

  内联倒计时第二版

  作者：崽崽 (AI助手)
{%- endcomment -%}

{% liquid
  assign ss = section.settings
-%}

<div id="{{ section.id }}" class="mk-countdown-inline-2" data-countdown-inline-2 data-end="{{ ss.end_date | default: '' | date: '%Y-%m-%dT%H:%M:%S' }}">
  <span class="mk-countdown-inline-2__text">{{ ss.text | default: 'Sale ends in' }}:</span>
  <div class="mk-countdown-inline-2__time">
    <span class="mk-countdown-inline-2__item"><span data-days>00</span>d</span>
    <span class="mk-countdown-inline-2__item"><span data-hours>00</span>h</span>
    <span class="mk-countdown-inline-2__item"><span data-minutes>00</span>m</span>
    <span class="mk-countdown-inline-2__item"><span data-seconds>00</span>s</span>
  </div>
</div>

{% stylesheet %}
  .mk-countdown-inline-2 { display: flex; align-items: center; gap: var(--mk-spacing-md); }
  .mk-countdown-inline-2__text { font-size: var(--mk-font-size-md); font-weight: 500; }
  .mk-countdown-inline-2__time { display: flex; align-items: center; gap: var(--mk-spacing-sm); font-size: var(--mk-font-size-md); font-weight: 700; }
  .mk-countdown-inline-2__item { display: flex; align-items: center; gap: 2px; }
{% endstylesheet %}

{% javascript %}
  (function() {
    const c = document.querySelector('[data-countdown-inline-2]');
    if (!c) return;
    const end = new Date(c.dataset.end).getTime();
    function u() {
      const now = Date.now(), diff = Math.max(0, end - now);
      const d = Math.floor(diff/86400000), h = Math.floor((diff%86400000)/3600000), m = Math.floor((diff%3600000)/60000), s = Math.floor((diff%60000)/1000);
      c.querySelector('[data-days]').textContent = String(d).padStart(2,'0');
      c.querySelector('[data-hours]').textContent = String(h).padStart(2,'0');
      c.querySelector('[data-minutes]').textContent = String(m).padStart(2,'0');
      c.querySelector('[data-seconds]').textContent = String(s).padStart(2,'0');
    }
    u(); setInterval(u, 1000);
  })();
{% endjavascript %}

{% schema %}
{
  "name": "MK Countdown Inline 2",
  "tag": "div",
  "settings": [
    { "type": "text", "id": "text", "label": "文字" },
    { "type": "text", "id": "end_date", "label": "结束日期" }
  ],
  "presets": [{ "name": "MK Countdown Inline 2" }]
}
{% endschema %}
