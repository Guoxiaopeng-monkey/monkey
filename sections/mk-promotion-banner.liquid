{%- comment -%}
  MK 促销横幅组件

  显示促销信息横幅

  作者：崽崽 (AI助手)
{%- endcomment -%}

{% liquid
  assign ss = section.settings
-%}

<section
  id="{{ section.id }}"
  class="mk-promotion-banner color-{{ ss.color_scheme | default: 'background-1' }}"
>
  <div class="mk-promotion-banner__container">
    {%- if ss.icon != blank -%}
      <div class="mk-promotion-banner__icon">
        {{ ss.icon | image_url: width: 48 | image_tag }}
      </div>
    {%- endif -%}

    <div class="mk-promotion-banner__content">
      {%- if ss.title != blank -%}
        <h3 class="mk-promotion-banner__title">{{ ss.title }}</h3>
      {%- endif -%}

      {%- if ss.description != blank -%}
        <p class="mk-promotion-banner__description">{{ ss.description }}</p>
      {%- endif -%}

      {%- if ss.link_text != blank and ss.link != blank -%}
        <a href="{{ ss.link }}" class="mk-promotion-banner__link">{{ ss.link_text }}</a>
      {%- endif -%}
    </div>

    {%- if ss.show_close_button -%}
      <button type="button" class="mk-promotion-banner__close" aria-label="{{ 关闭 }}">
        {{- 'icon-close.svg' | inline_asset_content -}}
      </button>
    {%- endif -%}
  </div>
</section>

{% stylesheet %}
  .mk-promotion-banner {
    padding: 12px 0;
    background-color: var(--color-background-secondary, #f5f5f5);
  }

  .mk-promotion-banner__container {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 12px;
    max-width: var(--container-max-width, 1200px);
    margin: 0 auto;
    padding: 0 var(--container-padding, 32px);
    text-align: center;
    position: relative;
  }

  .mk-promotion-banner__icon {
    display: flex;
    flex-shrink: 0;
  }

  .mk-promotion-banner__icon img {
    width: 24px;
    height: 24px;
    object-fit: contain;
  }

  .mk-promotion-banner__content {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .mk-promotion-banner__title {
    margin: 0;
    font-size: 14px;
    font-weight: 600;
    color: var(--color-foreground);
  }

  .mk-promotion-banner__description {
    margin: 0;
    font-size: 13px;
    color: var(--color-text-secondary, #666);
  }

  .mk-promotion-banner__link {
    font-size: 13px;
    font-weight: 500;
    color: var(--color-primary, #000);
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  .mk-promotion-banner__link:hover {
    opacity: 0.7;
  }

  .mk-promotion-banner__close {
    position: absolute;
    top: 50%;
    right: 16px;
    transform: translateY(-50%);
    display: flex;
    align-items: center;
    justify-content: center;
    width: 28px;
    height: 28px;
    padding: 0;
    background: transparent;
    border: none;
    border-radius: 50%;
    cursor: pointer;
    color: var(--color-text-secondary, #666);
    transition: background-color 0.2s ease;
  }

  .mk-promotion-banner__close:hover {
    background-color: rgba(0, 0, 0, 0.1);
  }

  .mk-promotion-banner__close svg {
    width: 16px;
    height: 16px;
  }

  @media (max-width: 480px) {
    .mk-promotion-banner__close {
      right: 8px;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "MK 促销横幅",
  "tag": "section",
  "settings": [
    {
      "type": "image_picker",
      "id": "icon",
      "label": "图标"
    },
    {
      "type": "text",
      "id": "title",
      "label": "标题",
      "default": "限时优惠"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "描述",
      "default": "全场满100减10，错过再等一年！"
    },
    {
      "type": "text",
      "id": "link_text",
      "label": "链接文字"
    },
    {
      "type": "url",
      "id": "link",
      "label": "链接"
    },
    {
      "type": "checkbox",
      "id": "show_close_button",
      "label": "显示关闭按钮",
      "default": true
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "颜色方案",
      "default": "scheme-1"
    }
  ],
  "presets": [
    {
      "name": "MK 促销横幅"
    }
  ]
}
{% endschema %}
