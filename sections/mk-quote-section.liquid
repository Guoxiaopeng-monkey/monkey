{%- comment -%}
  MK Quote Section板块

  引用区块

  作者：崽崽 (AI助手)
{%- endcomment -%}

{% liquid
  assign ss = section.settings
-%}

<section id="{{ section.id }}" class="mk-quote-section color-{{ ss.color_scheme | default: 'background-1' }}">
  <div class="mk-quote-section__container">
    <blockquote class="mk-quote-section__quote">
      {%- if ss.icon != blank -%}
        <div class="mk-quote-section__icon">{{ ss.icon | default: 'icon-quote.svg' | inline_asset_content }}</div>
      {%- endif -%}

      {%- if ss.text != blank -%}
        <p class="mk-quote-section__text">{{ ss.text }}</p>
      {%- endif -%}

      {%- if ss.author != blank or ss.role != blank -%}
        <footer class="mk-quote-section__footer">
          {%- if ss.author_image != blank -%}
            {{ ss.author_image | image_url: width: 80 | image_tag: class: 'mk-quote-section__author-image' }}
          {%- endif -%}
          <div class="mk-quote-section__author-info">
            {%- if ss.author != blank -%}
              <cite class="mk-quote-section__author">{{ ss.author }}</cite>
            {%- endif -%}
            {%- if ss.role != blank -%}
              <span class="mk-quote-section__role">{{ ss.role }}</span>
            {%- endif -%}
          </div>
        </footer>
      {%- endif -%}
    </blockquote>
  </div>
</section>

{% stylesheet %}
  .mk-quote-section { padding: {{ ss.padding_top_mobile | default: 48 }}px 0 {{ ss.padding_bottom_mobile | default: 48 }}px; }
  @media (min-width: 750px) { .mk-quote-section { padding: {{ ss.padding_top_desktop | default: 80 }}px 0 {{ ss.padding_bottom_desktop | default: 80 }}px; } }
  .mk-quote-section__container { max-width: var(--container-max-width, 800px); margin: 0 auto; padding: 0 var(--container-padding, 32px); }
  .mk-quote-section__quote { margin: 0; padding: var(--mk-spacing-3xl); background: var(--color-background-secondary, var(--mk-color-bg-secondary)); border-radius: var(--mk-radius-lg); text-align: center; }
  .mk-quote-section__icon { display: flex; justify-content: center; margin-bottom: 20px; opacity: 0.3; }
  .mk-quote-section__icon svg { width: 48px; height: 48px; }
  .mk-quote-section__text { margin: 0 0 24px 0; font-size: var(--mk-font-size-2xl); font-weight: 500; line-height: 1.5; font-style: italic; }
  @media (min-width: 750px) { .mk-quote-section__text { font-size: var(--mk-font-size-3xl); } }
  .mk-quote-section__footer { display: flex; align-items: center; justify-content: center; gap: var(--mk-spacing-lg); }
  .mk-quote-section__author-image { width: 48px; height: 48px; border-radius: 50%; object-fit: cover; }
  .mk-quote-section__author-info { display: flex; flex-direction: column; text-align: left; }
  .mk-quote-section__author { font-size: var(--mk-font-size-md); font-weight: 600; font-style: normal; }
  .mk-quote-section__role { font-size: var(--mk-font-size-sm); color: var(--color-text-secondary, #666); }
{% endstylesheet %}

{% schema %}
{
  "name": "MK Quote Section",
  "tag": "section",
  "settings": [
    { "type": "text", "id": "icon", "label": "图标" },
    { "type": "textarea", "id": "text", "label": "引用文字" },
    { "type": "text", "id": "author", "label": "作者" },
    { "type": "text", "id": "role", "label": "角色/职位" },
    { "type": "image_picker", "id": "author_image", "label": "作者头像" },
    { "type": "header", "content": "间距" },
    { "type": "range", "id": "padding_top_mobile", "label": "上边距 (移动端)", "min": 0, "max": 120, "default": 48, "unit": "px" },
    { "type": "range", "id": "padding_bottom_mobile", "label": "下边距 (移动端)", "min": 0, "max": 120, "default": 48, "unit": "px" },
    { "type": "range", "id": "padding_top_desktop", "label": "上边距 (PC端)", "min": 0, "max": 200, "default": 80, "unit": "px" },
    { "type": "range", "id": "padding_bottom_desktop", "label": "下边距 (PC端)", "min": 0, "max": 200, "default": 80, "unit": "px" },
    { "type": "color_scheme", "id": "color_scheme", "label": "颜色方案", "default": "scheme-1" }
  ],
  "presets": [{ "name": "MK Quote Section" }]
}
{% endschema %}
