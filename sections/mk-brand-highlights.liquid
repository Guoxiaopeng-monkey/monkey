{%- comment -%}
  MK 品牌亮点板块

  展示品牌特色/优势

  作者：崽崽 (AI助手)
{%- endcomment -%}

{% liquid
  assign ss = section.settings
-%}

<section
  id="{{ section.id }}"
  class="mk-brand-highlights color-{{ ss.color_scheme | default: 'background-1' }}"
>
  <div class="mk-brand-highlights__container">
    {%- if ss.title != blank -%}
      <h2 class="mk-brand-highlights__title">{{ ss.title }}</h2>
    {%- endif -%}

    <div class="mk-brand-highlights__grid">
      {%- for i in (1..6) -%}
        {%- assign icon_setting = 'icon_' | append: i -%}
        {%- assign heading_setting = 'heading_' | append: i -%}
        {%- assign text_setting = 'text_' | append: i -%}

        {%- if ss[heading_setting] != blank -%}
          <div class="mk-brand-highlights__item">
            {%- if ss[icon_setting] != blank -%}
              <div class="mk-brand-highlights__icon">
                {{ ss[icon_setting] | default: 'icon-check.svg' | inline_asset_content }}
              </div>
            {%- endif -%}

            <h3 class="mk-brand-highlights__heading">{{ ss[heading_setting] }}</h3>
            <p class="mk-brand-highlights__text">{{ ss[text_setting] }}</p>
          </div>
        {%- endif -%}
      {%- endfor -%}
    </div>
  </div>
</section>

{% stylesheet %}
  .mk-brand-highlights {
    padding: {{ ss.padding_top_mobile | default: 48 }}px 0 {{ ss.padding_bottom_mobile | default: 48 }}px;
  }

  @media (min-width: 750px) {
    .mk-brand-highlights {
      padding: {{ ss.padding_top_desktop | default: 80 }}px 0 {{ ss.padding_bottom_desktop | default: 80 }}px;
    }
  }

  .mk-brand-highlights__container {
    max-width: var(--container-max-width, 1200px);
    margin: 0 auto;
    padding: 0 var(--container-padding, 32px);
  }

  .mk-brand-highlights__title {
    margin: 0 0 40px 0;
    font-size: 28px;
    font-weight: 700;
    text-align: center;
  }

  .mk-brand-highlights__grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 32px;
  }

  @media (min-width: 750px) {
    .mk-brand-highlights__grid {
      grid-template-columns: repeat(3, 1fr);
      gap: 48px;
    }
  }

  @media (min-width: 1024px) {
    .mk-brand-highlights__grid {
      grid-template-columns: repeat(6, 1fr);
    }
  }

  .mk-brand-highlights__item {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 12px;
  }

  .mk-brand-highlights__icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 48px;
    height: 48px;
    color: var(--color-primary, #000);
  }

  .mk-brand-highlights__icon svg {
    width: 32px;
    height: 32px;
  }

  .mk-brand-highlights__heading {
    margin: 0;
    font-size: 14px;
    font-weight: 600;
    color: var(--color-foreground);
  }

  .mk-brand-highlights__text {
    margin: 0;
    font-size: 13px;
    line-height: 1.6;
    color: var(--color-text-secondary, #666);
  }
{% endstylesheet %}

{% schema %}
{
  "name": "MK 品牌亮点",
  "tag": "section",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "标题"
    },
    {
      "type": "header",
      "content": "亮点 1"
    },
    {
      "type": "text",
      "id": "heading_1",
      "label": "标题 1"
    },
    {
      "type": "textarea",
      "id": "text_1",
      "label": "描述 1"
    },
    {
      "type": "header",
      "content": "亮点 2"
    },
    {
      "type": "text",
      "id": "heading_2",
      "label": "标题 2"
    },
    {
      "type": "textarea",
      "id": "text_2",
      "label": "描述 2"
    },
    {
      "type": "header",
      "content": "亮点 3"
    },
    {
      "type": "text",
      "id": "heading_3",
      "label": "标题 3"
    },
    {
      "type": "textarea",
      "id": "text_3",
      "label": "描述 3"
    },
    {
      "type": "header",
      "content": "间距"
    },
    {
      "type": "range",
      "id": "padding_top_mobile",
      "label": "上边距 (移动端)",
      "min": 0,
      "max": 120,
      "default": 48,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "label": "下边距 (移动端)",
      "min": 0,
      "max": 120,
      "default": 48,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_top_desktop",
      "label": "上边距 (PC端)",
      "min": 0,
      "max": 200,
      "default": 80,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_bottom_desktop",
      "label": "下边距 (PC端)",
      "min": 0,
      "max": 200,
      "default": 80,
      "unit": "px"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "颜色方案",
      "default": "scheme-1"
    }
  ],
  "presets": [
    {
      "name": "MK 品牌亮点"
    }
  ]
}
{% endschema %}
