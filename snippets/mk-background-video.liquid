{%- doc -%}
  MK 背景视频组件

  设置背景视频

  @param {string} video_url - 视频URL
  @param {string} [poster] - 封面图
  @param {string} [class] - 额外CSS类名

  @example
  {% render 'mk-background-video', video_url: section.settings.video_url %}
{%- enddoc -%}

{% liquid
  assign video_url = video_url | default: ''
  assign poster = poster | default: ''
  assign class = class | default: ''
-%}

{%- if video_url != blank -%}
  <div class="mk-background-video {{ class }}">
    <video
      class="mk-background-video__video"
      src="{{ video_url }}"
      autoplay
      loop
      muted
      playsinline
      {% if poster != blank %}poster="{{ poster | image_url }}"{% endif %}
    ></video>
    <div class="mk-background-video__overlay"></div>
    <div class="mk-background-video__content">
      {{ content }}
    </div>
  </div>
{%- endif -%}

{% stylesheet %}
  .mk-background-video {
    position: relative;
    overflow: hidden;
  }
  .mk-background-video__video {
    position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover;
  }
  .mk-background-video__overlay {
    position: absolute; inset: 0; background: rgba(0,0,0,0.3); pointer-events: none;
  }
  .mk-background-video__content { position: relative; z-index: 1; }
{% endstylesheet %}
