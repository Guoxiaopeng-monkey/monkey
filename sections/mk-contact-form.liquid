{%- comment -%}
  MK 联系表单组件
  
  功能：联系表单，支持多种字段类型
  
  作者：崽崽 (AI助手)
  基于：whale ug-contact-section.liquid
{%- endcomment -%}

{%- liquid
  assign ss = section.settings
  assign bg_color = ss.background_color | default: 'var(--mk-color-bg-tertiary)'
  assign text_color = ss.text_color | default: '#1a1a1a'
  
  assign pt_mob = ss.padding_top_mobile | default: 48
  assign pb_mob = ss.padding_bottom_mobile | default: 48
  assign pt_desk = ss.padding_top_desktop | default: 80
  assign pb_desk = ss.padding_bottom_desktop | default: 80
-%}

<style>
  #{{ section.id }} {
    --cf-bg: {{ bg_color }};
    --cf-text: {{ text_color }};
    --cf-pt-mob: {{ pt_mob }}px;
    --cf-pb-mob: {{ pb_mob }}px;
    --cf-pt-desk: {{ pt_desk }}px;
    --cf-pb-desk: {{ pb_desk }}px;
    background-color: var(--cf-bg);
    color: var(--cf-text);
    padding: var(--cf-pt-mob) 0 var(--cf-pb-mob);
  }
  
  @media (min-width: 750px) {
    #{{ section.id }} {
      padding: var(--cf-pt-desk) 0 var(--cf-pb-desk);
    }
  }
</style>

<section
  id="{{ section.id }}"
  class="mk-contact-form"
  data-skip-node-update
>
  <div class="mk-contact-form__container">
    
    {%- comment -%} 左侧信息 {%- endcomment -%}
    <div class="mk-contact-form__info">
      {% if ss.label != blank %}
        <p class="mk-contact-form__label">{{ ss.label }}</p>
      {% endif %}
      {% if ss.heading != blank %}
        <h2 class="mk-contact-form__heading">{{ ss.heading }}</h2>
      {% endif %}
      {% if ss.description != blank %}
        <p class="mk-contact-form__description">{{ ss.description }}</p>
      {% endif %}
      
      {%- comment -%} 联系信息 {%- endcomment -%}
      <div class="mk-contact-form__details">
        {% if ss.email != blank %}
          <div class="mk-contact-form__detail">
            <span class="mk-contact-form__detail-icon">
              {{- 'icon-email.svg' | inline_asset_content -}}
            </span>
            <a href="mailto:{{ ss.email }}" class="mk-contact-form__detail-text">{{ ss.email }}</a>
          </div>
        {% endif %}
        
        {% if ss.phone != blank %}
          <div class="mk-contact-form__detail">
            <span class="mk-contact-form__detail-icon">
              {{- 'icon-phone.svg' | inline_asset_content -}}
            </span>
            <a href="tel:{{ ss.phone }}" class="mk-contact-form__detail-text">{{ ss.phone }}</a>
          </div>
        {% endif %}
        
        {% if ss.address != blank %}
          <div class="mk-contact-form__detail">
            <span class="mk-contact-form__detail-icon">
              {{- 'icon-location.svg' | inline_asset_content -}}
            </span>
            <span class="mk-contact-form__detail-text">{{ ss.address }}</span>
          </div>
        {% endif %}
      </div>
      
      {%- comment -%} 社交链接 {%- endcomment -%}
      {% if ss.show_social %}
        <div class="mk-contact-form__social">
          {%- if settings.social_facebook_link != blank -%}
            <a href="{{ settings.social_facebook_link }}" class="mk-contact-form__social-link" aria-label="Facebook">
              {{- 'icon-facebook.svg' | inline_asset_content -}}
            </a>
          {%- endif -%}
          {%- if settings.social_instagram_link != blank -%}
            <a href="{{ settings.social_instagram_link }}" class="mk-contact-form__social-link" aria-label="Instagram">
              {{- 'icon-instagram.svg' | inline_asset_content -}}
            </a>
          {%- endif -%}
          {%- if settings.social_twitter_link != blank -%}
            <a href="{{ settings.social_twitter_link }}" class="mk-contact-form__social-link" aria-label="Twitter">
              {{- 'icon-twitter.svg' | inline_asset_content -}}
            </a>
          {%- endif -%}
        </div>
      {% endif %}
    </div>
    
    {%- comment -%} 右侧表单 {%- endcomment -%}
    <div class="mk-contact-form__form-wrapper">
      {%- form 'contact', id: 'contact-form', class: 'mk-contact-form__form' -%}
        
        {%- if form.posted_successfully? -%}
          <div class="mk-contact-form__success" role="alert">
            <h3>{{ 'contact.form.success_heading' | t | default: '消息已发送！' }}</h3>
            <p>{{ 'contact.form.success_message' | t | default: '感谢您联系我们，我们会尽快回复您。' }}</p>
          </div>
        {%- else -%}
        
          {%- if form.errors -%}
            <div class="mk-contact-form__error" role="alert">
              {{ form.errors | default_errors }}
            </div>
          {%- endif -%}
          
          <div class="mk-contact-form__fields">
            {%- for block in section.blocks -%}
              {%- case block.type -%}
                {%- when 'text_field' -%}
                  <div class="mk-contact-form__field" {{ block.shopify_attributes }}>
                    <label for="{{ block.id }}" class="mk-contact-form__field-label">
                      {{ block.settings.label }}
                      {% if block.settings.required %}
                        <span class="mk-contact-form__required">*</span>
                      {% endif %}
                    </label>
                    <input
                      type="text"
                      id="{{ block.id }}"
                      name="contact[{{ block.settings.name }}]"
                      class="mk-contact-form__input"
                      placeholder="{{ block.settings.placeholder }}"
                      {% if block.settings.required %}required{% endif %}
                      autocomplete="{{ block.settings.autocomplete }}"
                    >
                  </div>
                  
                {%- when 'email_field' -%}
                  <div class="mk-contact-form__field" {{ block.shopify_attributes }}>
                    <label for="{{ block.id }}" class="mk-contact-form__field-label">
                      {{ block.settings.label }}
                      <span class="mk-contact-form__required">*</span>
                    </label>
                    <input
                      type="email"
                      id="{{ block.id }}"
                      name="contact[email]"
                      class="mk-contact-form__input"
                      placeholder="{{ block.settings.placeholder }}"
                      required
                      autocomplete="email"
                    >
                  </div>
                  
                {%- when 'phone_field' -%}
                  <div class="mk-contact-form__field" {{ block.shopify_attributes }}>
                    <label for="{{ block.id }}" class="mk-contact-form__field-label">
                      {{ block.settings.label }}
                      {% if block.settings.required %}
                        <span class="mk-contact-form__required">*</span>
                      {% endif %}
                    </label>
                    <input
                      type="tel"
                      id="{{ block.id }}"
                      name="contact[{{ block.settings.name }}]"
                      class="mk-contact-form__input"
                      placeholder="{{ block.settings.placeholder }}"
                      {% if block.settings.required %}required{% endif %}
                      autocomplete="tel"
                    >
                  </div>
                  
                {%- when 'textarea' -%}
                  <div class="mk-contact-form__field mk-contact-form__field--full" {{ block.shopify_attributes }}>
                    <label for="{{ block.id }}" class="mk-contact-form__field-label">
                      {{ block.settings.label }}
                      {% if block.settings.required %}
                        <span class="mk-contact-form__required">*</span>
                      {% endif %}
                    </label>
                    <textarea
                      id="{{ block.id }}"
                      name="contact[{{ block.settings.name }}]"
                      class="mk-contact-form__textarea"
                      placeholder="{{ block.settings.placeholder }}"
                      rows="{{ block.settings.rows | default: 5 }}"
                      {% if block.settings.required %}required{% endif %}
                    ></textarea>
                  </div>
                  
                {%- when 'select_field' -%}
                  <div class="mk-contact-form__field" {{ block.shopify_attributes }}>
                    <label for="{{ block.id }}" class="mk-contact-form__field-label">
                      {{ block.settings.label }}
                      {% if block.settings.required %}
                        <span class="mk-contact-form__required">*</span>
                      {% endif %}
                    </label>
                    <select
                      id="{{ block.id }}"
                      name="contact[{{ block.settings.name }}]"
                      class="mk-contact-form__select"
                      {% if block.settings.required %}required{% endif %}
                    >
                      <option value="" disabled selected>{{ block.settings.placeholder }}</option>
                      {%- for option in block.settings.options -%}
                        <option value="{{ option }}">{{ option }}</option>
                      {%- endfor -%}
                    </select>
                  </div>
              {%- endcase -%}
            {%- endfor -%}
          </div>
          
          <button type="submit" class="mk-contact-form__submit">
            {{ ss.button_text | default: '发送消息' }}
            {{- 'icon-arrow-right.svg' | inline_asset_content -}}
          </button>
        {%- endif -%}
        
      {%- endform -%}
    </div>
    
  </div>
</section>

{% stylesheet %}
  .mk-contact-form__container {
    display: grid;
    gap: 48px;
    max-width: var(--container-max-width, 1440px);
    margin: 0 auto;
    padding: 0 var(--container-padding, 32px);
  }

  @media (min-width: 990px) {
    .mk-contact-form__container {
      grid-template-columns: 1fr 1.2fr;
      gap: 80px;
      align-items: start;
    }
  }

  /* Info */
  .mk-contact-form__info {
    max-width: 480px;
  }

  .mk-contact-form__label {
    margin: 0 0 12px 0;
    font-size: var(--mk-font-size-sm);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 1.5px;
    color: var(--color-primary, #000);
  }

  .mk-contact-form__heading {
    margin: 0 0 20px 0;
    font-size: clamp(28px, 4vw, 40px);
    font-weight: 700;
    line-height: 1.2;
  }

  .mk-contact-form__description {
    margin: 0 0 32px 0;
    font-size: var(--mk-font-size-lg);
    line-height: 1.7;
    opacity: 0.85;
  }

  /* Details */
  .mk-contact-form__details {
    display: flex;
    flex-direction: column;
    gap: var(--mk-spacing-lg);
    margin-bottom: 32px;
  }

  .mk-contact-form__detail {
    display: flex;
    align-items: center;
    gap: var(--mk-spacing-md);
  }

  .mk-contact-form__detail-icon {
    display: flex;
    width: 20px;
    height: 20px;
    color: var(--color-primary, #000);
  }

  .mk-contact-form__detail-icon svg {
    width: 100%;
    height: 100%;
  }

  .mk-contact-form__detail-text {
    font-size: var(--mk-font-size-md);
    text-decoration: none;
    color: inherit;
  }

  a.mk-contact-form__detail-text:hover {
    text-decoration: underline;
  }

  /* Social */
  .mk-contact-form__social {
    display: flex;
    gap: var(--mk-spacing-md);
  }

  .mk-contact-form__social-link {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    border-radius: 50%;
    background: rgba(0, 0, 0, 0.08);
    color: inherit;
    text-decoration: none;
    transition: background 0.2s ease;
  }

  .mk-contact-form__social-link:hover {
    background: var(--mk-shadow-md)5);
  }

  .mk-contact-form__social-link svg {
    width: 18px;
    height: 18px;
  }

  /* Form */
  .mk-contact-form__form-wrapper {
    background: var(--color-background, #fff);
    padding: var(--mk-spacing-4xl);
    border-radius: var(--mk-radius-lg);
    box-shadow: 0 4px 24px rgba(0, 0, 0, 0.08);
  }

  .mk-contact-form__fields {
    display: grid;
    gap: 20px;
  }

  @media (min-width: 480px) {
    .mk-contact-form__fields {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  .mk-contact-form__field--full {
    grid-column: 1 / -1;
  }

  .mk-contact-form__field-label {
    display: block;
    margin-bottom: 8px;
    font-size: var(--mk-font-size-md);
    font-weight: 500;
  }

  .mk-contact-form__required {
    color: #e53935;
  }

  .mk-contact-form__input,
  .mk-contact-form__textarea,
  .mk-contact-form__select {
    width: 100%;
    padding: 14px 16px;
    font-size: var(--mk-font-size-md);
    background: var(--color-background-secondary, var(--mk-color-bg-tertiary));
    border: 1px solid var(--mk-shadow-md)2);
    border-radius: var(--mk-radius-sm);
    color: inherit;
    transition: border-color 0.2s ease;
  }

  .mk-contact-form__input:focus,
  .mk-contact-form__textarea:focus,
  .mk-contact-form__select:focus {
    outline: none;
    border-color: var(--color-primary, #000);
  }

  .mk-contact-form__textarea {
    resize: vertical;
    min-height: 120px;
  }

  /* Submit */
  .mk-contact-form__submit {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: var(--mk-spacing-sm);
    width: 100%;
    margin-top: 24px;
    padding: var(--mk-spacing-lg) 32px;
    font-size: var(--mk-font-size-md);
    font-weight: 600;
    color: var(--color-background, #fff);
    background: var(--color-primary, #000);
    border: none;
    border-radius: var(--mk-radius-sm);
    cursor: pointer;
    transition: all 0.2s ease;
  }

  .mk-contact-form__submit:hover {
    opacity: 0.85;
    transform: translateY(-2px);
  }

  .mk-contact-form__submit svg {
    width: 16px;
    height: 16px;
  }

  /* Success/Error */
  .mk-contact-form__success,
  .mk-contact-form__error {
    padding: var(--mk-spacing-2xl);
    border-radius: var(--mk-radius-sm);
    text-align: center;
  }

  .mk-contact-form__success {
    background: rgba(0, 200, 83, 0.1);
  }

  .mk-contact-form__success h3 {
    margin: 0 0 8px 0;
    font-size: var(--mk-font-size-xl);
    font-weight: 600;
    color: #00c853;
  }

  .mk-contact-form__success p {
    margin: 0;
    font-size: var(--mk-font-size-md);
    color: inherit;
  }

  .mk-contact-form__error {
    background: rgba(229, 57, 53, 0.1);
    color: #e53935;
    margin-bottom: 20px;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "MK 联系表单",
  "tag": "section",
  "settings": [
    {
      "type": "header",
      "content": "内容设置"
    },
    {
      "type": "text",
      "id": "label",
      "label": "标签文字"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "标题",
      "default": "联系我们"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "描述文字"
    },
    {
      "type": "header",
      "content": "联系信息"
    },
    {
      "type": "text",
      "id": "email",
      "label": "邮箱"
    },
    {
      "type": "text",
      "id": "phone",
      "label": "电话"
    },
    {
      "type": "textarea",
      "id": "address",
      "label": "地址"
    },
    {
      "type": "header",
      "content": "社交链接"
    },
    {
      "type": "checkbox",
      "id": "show_social",
      "label": "显示社交媒体链接",
      "default": true
    },
    {
      "type": "header",
      "content": "提交按钮"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "按钮文字",
      "default": "发送消息"
    },
    {
      "type": "header",
      "content": "颜色设置"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "背景颜色",
      "default": "var(--mk-color-bg-tertiary)"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "文字颜色",
      "default": "#1a1a1a"
    },
    {
      "type": "header",
      "content": "间距设置"
    },
    {
      "type": "range",
      "id": "padding_top_mobile",
      "label": "上边距 (移动端)",
      "min": 0,
      "max": 120,
      "default": 48,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "label": "下边距 (移动端)",
      "min": 0,
      "max": 120,
      "default": 48,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_top_desktop",
      "label": "上边距 (PC端)",
      "min": 0,
      "max": 200,
      "default": 80,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_bottom_desktop",
      "label": "下边距 (PC端)",
      "min": 0,
      "max": 200,
      "default": 80,
      "unit": "px"
    }
  ],
  "blocks": [
    {
      "type": "text_field",
      "name": "文本字段",
      "settings": [
        {
          "type": "text",
          "id": "label",
          "label": "标签",
          "default": "姓名"
        },
        {
          "type": "text",
          "id": "name",
          "label": "字段名",
          "default": "name"
        },
        {
          "type": "text",
          "id": "placeholder",
          "label": "占位符"
        },
        {
          "type": "checkbox",
          "id": "required",
          "label": "必填",
          "default": true
        },
        {
          "type": "select",
          "id": "autocomplete",
          "label": "自动完成",
          "options": [
            { "value": "name", "label": "姓名" },
            { "value": "given-name", "label": "名" },
            { "value": "family-name", "label": "姓" }
          ],
          "default": "name"
        }
      ]
    },
    {
      "type": "email_field",
      "name": "邮箱字段",
      "settings": [
        {
          "type": "text",
          "id": "label",
          "label": "标签",
          "default": "邮箱"
        },
        {
          "type": "text",
          "id": "placeholder",
          "label": "占位符",
          "default": "your@email.com"
        }
      ]
    },
    {
      "type": "phone_field",
      "name": "电话字段",
      "settings": [
        {
          "type": "text",
          "id": "label",
          "label": "标签",
          "default": "电话"
        },
        {
          "type": "text",
          "id": "name",
          "label": "字段名",
          "default": "phone"
        },
        {
          "type": "text",
          "id": "placeholder",
          "label": "占位符"
        },
        {
          "type": "checkbox",
          "id": "required",
          "label": "必填",
          "default": false
        }
      ]
    },
    {
      "type": "textarea",
      "name": "文本域",
      "settings": [
        {
          "type": "text",
          "id": "label",
          "label": "标签",
          "default": "留言"
        },
        {
          "type": "text",
          "id": "name",
          "label": "字段名",
          "default": "body"
        },
        {
          "type": "text",
          "id": "placeholder",
          "label": "占位符",
          "default": "请输入您的留言..."
        },
        {
          "type": "checkbox",
          "id": "required",
          "label": "必填",
          "default": true
        },
        {
          "type": "range",
          "id": "rows",
          "label": "行数",
          "min": 3,
          "max": 10,
          "default": 5
        }
      ]
    },
    {
      "type": "select_field",
      "name": "下拉字段",
      "settings": [
        {
          "type": "text",
          "id": "label",
          "label": "标签",
          "default": "主题"
        },
        {
          "type": "text",
          "id": "name",
          "label": "字段名",
          "default": "subject"
        },
        {
          "type": "text",
          "id": "placeholder",
          "label": "占位符",
          "default": "请选择"
        },
        {
          "type": "checkbox",
          "id": "required",
          "label": "必填",
          "default": true
        },
        {
          "type": "textarea",
          "id": "options",
          "label": "选项",
          "info": "每行一个选项"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "MK 联系表单"
    }
  ]
}
{% endschema %}
