{%- comment -%}
  MK Product Media Tabs板块

  产品媒体Tab切换

  作者：崽崽 (AI助手)
{%- endcomment -%}

{% liquid
  assign ss = section.settings
-%}

<section id="{{ section.id }}" class="mk-product-media-tabs color-{{ ss.color_scheme | default: 'background-1' }}">
  <div class="mk-product-media-tabs__container">
    <div class="mk-product-media-tabs__header">
      {%- for i in (1..3) -%}
        {%- assign title_setting = 'tab_title_' | append: i -%}
        {%- if ss[title_setting] != blank -%}
          <button type="button" class="mk-product-media-tabs__tab {% if forloop.first %}active{% endif %}" data-tab="{{ forloop.index0 }}">
            {{ ss[title_setting] }}
          </button>
        {%- endif -%}
      {%- endfor -%}
    </div>

    <div class="mk-product-media-tabs__content">
      {%- for i in (1..3) -%}
        {%- assign title_setting = 'tab_title_' | append: i -%}
        {%- assign media_setting = 'tab_media_' | append: i -%}

        {%- if ss[title_setting] != blank -%}
          <div class="mk-product-media-tabs__panel {% if forloop.first %}active{% endif %}" data-panel="{{ forloop.index0 }}">
            {%- if ss[media_setting] != blank -%}
              {{ ss[media_setting] | video_tag: controls: true, class: 'mk-product-media-tabs__video' }}
            {%- endif -%}
          </div>
        {%- endif -%}
      {%- endfor -%}
    </div>
  </div>
</section>

{% stylesheet %}
  .mk-product-media-tabs { padding: {{ ss.padding_top_mobile | default: 32 }}px 0 {{ ss.padding_bottom_mobile | default: 32 }}px; }
  @media (min-width: 750px) { .mk-product-media-tabs { padding: {{ ss.padding_top_desktop | default: 48 }}px 0 {{ ss.padding_bottom_desktop | default: 48 }}px; } }
  .mk-product-media-tabs__container { max-width: var(--container-max-width, 900px); margin: 0 auto; padding: 0 var(--container-padding, 32px); }
  .mk-product-media-tabs__header { display: flex; border-bottom: 1px solid var(--color-border); margin-bottom: 24px; }
  .mk-product-media-tabs__tab { padding: var(--mk-spacing-lg) 24px; font-size: var(--mk-font-size-md); font-weight: 500; color: var(--color-text-secondary, #666); background: transparent; border: none; cursor: pointer; border-bottom: 2px solid transparent; margin-bottom: -1px; transition: all 0.2s ease; }
  .mk-product-media-tabs__tab:hover { color: var(--color-foreground); }
  .mk-product-media-tabs__tab.active { color: var(--color-primary, #000); border-bottom-color: var(--color-primary, #000); }
  .mk-product-media-tabs__panel { display: none; }
  .mk-product-media-tabs__panel.active { display: block; }
  .mk-product-media-tabs__video { width: 100%; height: auto; border-radius: var(--mk-radius-md); }
{% endstylesheet %}

{% javascript %}
  document.querySelectorAll('.mk-product-media-tabs__tab').forEach(tab => {
    tab.addEventListener('click', () => {
      const section = tab.closest('.mk-product-media-tabs');
      section.querySelectorAll('.mk-product-media-tabs__tab').forEach(t => t.classList.remove('active'));
      section.querySelectorAll('.mk-product-media-tabs__panel').forEach(p => p.classList.remove('active'));
      tab.classList.add('active');
      section.querySelector(`[data-panel="${tab.dataset.tab}"]`).classList.add('active');
    });
  });
{% endjavascript %}

{% schema %}
{
  "name": "MK Product Media Tabs",
  "tag": "section",
  "settings": [
    { "type": "header", "content": "Tab 1" }, { "type": "text", "id": "tab_title_1", "label": "标题 1" }, { "type": "video", "id": "tab_media_1", "label": "视频 1" },
    { "type": "header", "content": "Tab 2" }, { "type": "text", "id": "tab_title_2", "label": "标题 2" }, { "type": "video", "id": "tab_media_2", "label": "视频 2" },
    { "type": "header", "content": "Tab 3" }, { "type": "text", "id": "tab_title_3", "label": "标题 3" }, { "type": "video", "id": "tab_media_3", "label": "视频 3" },
    { "type": "header", "content": "间距" },
    { "type": "range", "id": "padding_top_mobile", "label": "上边距 (移动端)", "min": 0, "max": 80, "default": 32, "unit": "px" },
    { "type": "range", "id": "padding_bottom_mobile", "label": "下边距 (移动端)", "min": 0, "max": 80, "default": 32, "unit": "px" },
    { "type": "range", "id": "padding_top_desktop", "label": "上边距 (PC端)", "min": 0, "max": 120, "default": 48, "unit": "px" },
    { "type": "range", "id": "padding_bottom_desktop", "label": "下边距 (PC端)", "min": 0, "max": 120, "default": 48, "unit": "px" },
    { "type": "color_scheme", "id": "color_scheme", "label": "颜色方案", "default": "scheme-1" }
  ],
  "presets": [{ "name": "MK Product Media Tabs" }]
}
{% endschema %}
