{%- doc -%}
  MK 文本块组件

  渲染文本内容块

  @param {string} [text] - 文本内容
  @param {string} [class] - 额外CSS类名
  @param {string} [tag] - HTML标签：p, div, span

  @example
  {% render 'mk-text', text: '这是文本内容', class: 'intro-text' %}
{%- enddoc -%}

{% liquid
  assign text = text | default: ''
  assign class = class | default: ''
  assign tag = tag | default: 'p'
-%}

<{{ tag }} class="mk-text {{ class }}">
  {{ text }}
</{{ tag }}>

{% stylesheet %}
  .mk-text {
    margin: 0;
    font-size: var(--mk-font-size-lg);
    line-height: 1.6;
    color: var(--color-foreground);
  }

  .mk-text a {
    color: var(--color-primary, #000);
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  .mk-text a:hover {
    opacity: 0.7;
  }

  /* 尺寸变体 */
  .mk-text--small {
    font-size: var(--mk-font-size-sm);
  }

  .mk-text--large {
    font-size: var(--mk-font-size-xl);
  }

  .mk-text--xl {
    font-size: var(--mk-font-size-2xl);
  }

  /* 颜色变体 */
  .mk-text--secondary {
    color: var(--color-text-secondary, #666);
  }

  .mk-text--white {
    color: #fff;
  }

  /* 对齐变体 */
  .mk-text--center {
    text-align: center;
  }

  .mk-text--right {
    text-align: right;
  }
{% endstylesheet %}
