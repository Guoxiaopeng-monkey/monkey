{%- comment -%}
  MK 页面组件
  
  功能：自定义页面展示
  
  作者：崽崽 (AI助手)
{%- endcomment -%}

{%- liquid
  assign ss = section.settings
  assign page = page
  assign pt_mob = ss.padding_top_mobile | default: 32
  assign pb_mob = ss.padding_bottom_mobile | default: 32
  assign pt_desk = ss.padding_top_desktop | default: 48
  assign pb_desk = ss.padding_bottom_desktop | default: 48
-%}

<style>
  #{{ section.id }} {
    --page-pt-mob: {{ pt_mob }}px;
    --page-pb-mob: {{ pb_mob }}px;
    --page-pt-desk: {{ pt_desk }}px;
    --page-pb-desk: {{ pb_desk }}px;
    padding: var(--page-pt-mob) 0 var(--page-pb-mob);
  }
  
  @media (min-width: 750px) {
    #{{ section.id }} {
      padding: var(--page-pt-desk) 0 var(--page-pb-desk);
    }
  }
</style>

<section
  id="{{ section.id }}"
  class="mk-page"
  data-skip-node-update
>
  <div class="mk-page__container">
    <header class="mk-page__header">
      <h1 class="mk-page__title">{{ page.title }}</h1>
    </header>
    
    <div class="mk-page__content rte">
      {{ page.content }}
    </div>
  </div>
</section>

{% stylesheet %}
  .mk-page__container {
    max-width: var(--container-max-width, 800px);
    margin: 0 auto;
    padding: 0 var(--container-padding, 32px);
  }

  .mk-page__header {
    text-align: center;
    margin-bottom: 40px;
    padding-bottom: 24px;
    border-bottom: 1px solid rgba(var(--color-border), 0.15);
  }

  .mk-page__title {
    margin: 0;
    font-size: clamp(28px, 4vw, 40px);
    font-weight: 700;
  }

  .mk-page__content {
    font-size: 16px;
    line-height: 1.8;
  }

  .mk-page__content p {
    margin: 0 0 24px 0;
  }

  .mk-page__content h2 {
    margin: 40px 0 20px 0;
    font-size: 24px;
    font-weight: 600;
  }

  .mk-page__content h3 {
    margin: 32px 0 16px 0;
    font-size: 20px;
    font-weight: 600;
  }

  .mk-page__content img {
    max-width: 100%;
    height: auto;
    border-radius: 8px;
    margin: 24px 0;
  }

  .mk-page__content ul,
  .mk-page__content ol {
    margin: 0 0 24px 0;
    padding-left: 24px;
  }

  .mk-page__content li {
    margin-bottom: 8px;
  }

  .mk-page__content blockquote {
    margin: 32px 0;
    padding: 20px 24px;
    border-left: 4px solid var(--color-primary, #000);
    background: var(--color-background-secondary, #f9f9f9);
    font-style: italic;
  }

  .mk-page__content table {
    width: 100%;
    margin: 24px 0;
    border-collapse: collapse;
  }

  .mk-page__content th,
  .mk-page__content td {
    padding: 12px 16px;
    text-align: left;
    border-bottom: 1px solid rgba(var(--color-border), 0.15);
  }

  .mk-page__content th {
    font-weight: 600;
    background: var(--color-background-secondary, #f9f9f9);
  }

  .mk-page__content a {
    color: var(--color-primary, #000);
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  .mk-page__content a:hover {
    opacity: 0.7;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "MK 页面",
  "tag": "section",
  "settings": [
    {
      "type": "header",
      "content": "间距设置"
    },
    {
      "type": "range",
      "id": "padding_top_mobile",
      "label": "上边距 (移动端)",
      "min": 0,
      "max": 120,
      "default": 32,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "label": "下边距 (移动端)",
      "min": 0,
      "max": 120,
      "default": 32,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_top_desktop",
      "label": "上边距 (PC端)",
      "min": 0,
      "max": 200,
      "default": 48,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_bottom_desktop",
      "label": "下边距 (PC端)",
      "min": 0,
      "max": 200,
      "default": 48,
      "unit": "px"
    }
  ],
  "presets": [
    {
      "name": "MK 页面"
    }
  ]
}
{% endschema %}
