{%- comment -%}
  MK Logo列表板块

  展示合作品牌/客户Logo

  作者：崽崽 (AI助手)
{%- endcomment -%}

{% liquid
  assign ss = section.settings
  assign logos_per_row = ss.logos_per_row | default: 5
-%}

<section
  id="{{ section.id }}"
  class="mk-logo-list color-{{ ss.color_scheme | default: 'background-1' }}"
>
  <div class="mk-logo-list__container">
    {%- if ss.title != blank -%}
      <h2 class="mk-logo-list__title">{{ ss.title }}</h2>
    {%- endif -%}

    <div
      class="mk-logo-list__grid"
      style="--logos-per-row: {{ logos_per_row }};"
    >
      {%- for i in (1..10) -%}
        {%- assign logo_setting = 'logo_' | append: i -%}
        {%- assign link_setting = 'link_' | append: i -%}
        {%- assign logo = ss[logo_setting] -%}
        {%- assign link = ss[link_setting] -%}

        {%- if logo != blank -%}
          <div class="mk-logo-list__item">
            {%- if link != blank -%}
              <a href="{{ link }}" target="_blank" rel="noopener" class="mk-logo-list__link">
            {%- endif -%}

            {{ logo | image_url: width: 200 | image_tag: class: 'mk-logo-list__image' }}

            {%- if link != blank -%}
              </a>
            {%- endif -%}
          </div>
        {%- endif -%}
      {%- endfor -%}
    </div>
  </div>
</section>

{% stylesheet %}
  .mk-logo-list {
    padding: {{ ss.padding_top_mobile | default: 48 }}px 0 {{ ss.padding_bottom_mobile | default: 48 }}px;
  }

  @media (min-width: 750px) {
    .mk-logo-list {
      padding: {{ ss.padding_top_desktop | default: 64 }}px 0 {{ ss.padding_bottom_desktop | default: 64 }}px;
    }
  }

  .mk-logo-list__container {
    max-width: var(--container-max-width, 1200px);
    margin: 0 auto;
    padding: 0 var(--container-padding, 32px);
  }

  .mk-logo-list__title {
    margin: 0 0 32px 0;
    font-size: var(--mk-font-size-2xl);
    font-weight: 700;
    text-align: center;
  }

  .mk-logo-list__grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--mk-spacing-2xl);
    align-items: center;
  }

  @media (min-width: 480px) {
    .mk-logo-list__grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  @media (min-width: 750px) {
    .mk-logo-list__grid {
      grid-template-columns: repeat(var(--logos-per-row, 5), 1fr);
      gap: var(--mk-spacing-3xl);
    }
  }

  .mk-logo-list__item {
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .mk-logo-list__link {
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0.7;
    transition: opacity 0.2s ease;
  }

  .mk-logo-list__link:hover {
    opacity: 1;
  }

  .mk-logo-list__image {
    max-width: 120px;
    max-height: 60px;
    width: auto;
    height: auto;
    object-fit: contain;
  }
{% endstylesheet %}

