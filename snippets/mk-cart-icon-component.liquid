{%- doc -%}
  MK 购物车图标组件

  渲染购物车图标（带数量）

  @param {string} [class] - 额外CSS类名

  @example
  {% render 'mk-cart-icon-component' %}
{%- enddoc -%}

{% liquid
  assign class = class | default: ''
  assign count = cart.item_count | default: 0
-%}

<a href="{{ routes.cart_url }}" class="mk-cart-icon-component {{ class }}" aria-label="{{ 'cart.title' | t | default: '购物车' }}">
  {{- 'icon-cart.svg' | inline_asset_content -}}
  {%- if count > 0 -%}
    <span class="mk-cart-icon-component__count" data-cart-count>{{ count }}</span>
  {%- endif -%}
</a>

{% stylesheet %}
  .mk-cart-icon-component {
    position: relative; display: flex; align-items: center; justify-content: center;
    width: 40px; height: 40px; color: var(--color-foreground); border-radius: 50%;
    transition: background-color 0.2s ease;
  }
  .mk-cart-icon-component:hover { background-color: var(--color-background-secondary, #f5f5f5); }
  .mk-cart-icon-component svg { width: 22px; height: 22px; }
  .mk-cart-icon-component__count {
    position: absolute; top: 2px; right: 2px; min-width: 18px; height: 18px;
    padding: 0 5px; font-size: 10px; font-weight: 700; line-height: 18px;
    text-align: center; color: var(--color-on-primary, #fff);
    background-color: var(--color-primary, #000); border-radius: 100px;
  }
{% endstylesheet %}
