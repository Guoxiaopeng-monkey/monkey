{%- comment -%}
  MK Countdown Subtle板块

  柔和倒计时

  作者：崽崽 (AI助手)
{%- endcomment -%}

{% liquid
  assign ss = section.settings
-%}

<section id="{{ section.id }}" class="mk-countdown-subtle color-{{ ss.color_scheme | default: 'background-1' }}">
  <div class="mk-countdown-subtle__container">
    {%- if ss.title != blank -%}
      <h2 class="mk-countdown-subtle__title">{{ ss.title }}</h2>
    {%- endif -%}
    <div class="mk-countdown-subtle__countdown" data-countdown-subtle data-end="{{ ss.end_date | default: '' | date: '%Y-%m-%dT%H:%M:%S' }}">
      <div class="mk-countdown-subtle__item"><span class="mk-countdown-subtle__num" data-days>00</span><span class="mk-countdown-subtle__label">Days</span></div>
      <div class="mk-countdown-subtle__item"><span class="mk-countdown-subtle__num" data-hours>00</span><span class="mk-countdown-subtle__label">Hours</span></div>
      <div class="mk-countdown-subtle__item"><span class="mk-countdown-subtle__num" data-minutes>00</span><span class="mk-countdown-subtle__label">Minutes</span></div>
      <div class="mk-countdown-subtle__item"><span class="mk-countdown-subtle__num" data-seconds>00</span><span class="mk-countdown-subtle__label">Seconds</span></div>
    </div>
  </div>
</section>

{% stylesheet %}
  .mk-countdown-subtle { padding: 60px 0; background: var(--color-background-secondary, #fafafa); text-align: center; }
  .mk-countdown-subtle__container { max-width: 800px; margin: 0 auto; padding: 0 32px; }
  .mk-countdown-subtle__title { margin: 0 0 32px 0; font-size: 28px; font-weight: 700; }
  .mk-countdown-subtle__countdown { display: flex; justify-content: center; gap: 16px; }
  .mk-countdown-subtle__item { display: flex; flex-direction: column; align-items: center; gap: 6px; }
  .mk-countdown-subtle__num { min-width: 70px; padding: 16px 12px; background: var(--color-background); border: 1px solid var(--color-border); border-radius: 8px; font-size: 32px; font-weight: 700; }
  .mk-countdown-subtle__label { font-size: 10px; text-transform: uppercase; letter-spacing: 1px; color: var(--color-text-secondary, #999); }
{% endstylesheet %}

{% javascript %}
  (function() {
    const c = document.querySelector('[data-countdown-subtle]');
    if (!c) return;
    const end = new Date(c.dataset.end).getTime();
    function u() {
      const now = Date.now(), diff = Math.max(0, end - now);
      const d = Math.floor(diff/86400000), h = Math.floor((diff%86400000)/3600000), m = Math.floor((diff%3600000)/60000), s = Math.floor((diff%60000)/1000);
      c.querySelector('[data-days]').textContent = String(d).padStart(2,'0');
      c.querySelector('[data-hours]').textContent = String(h).padStart(2,'0');
      c.querySelector('[data-minutes]').textContent = String(m).padStart(2,'0');
      c.querySelector('[data-seconds]').textContent = String(s).padStart(2,'0');
    }
    u(); setInterval(u, 1000);
  })();
{% endjavascript %}

{% schema %}
{
  "name": "MK Countdown Subtle",
  "tag": "section",
  "settings": [
    { "type": "text", "id": "title", "label": "标题" },
    { "type": "text", "id": "end_date", "label": "结束日期" },
    { "type": "color_scheme", "id": "color_scheme", "label": "颜色方案", "default": "scheme-1" }
  ],
  "presets": [{ "name": "MK Countdown Subtle" }]
}
{% endschema %}
