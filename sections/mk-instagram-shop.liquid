{%- comment -%}
  MK Instagram Shop板块

  Instagram商品展示

  作者：崽崽 (AI助手)
{%- endcomment -%}

{% liquid
  assign ss = section.settings
-%}

<section id="{{ section.id }}" class="mk-instagram-shop color-{{ ss.color_scheme | default: 'background-1' }}">
  <div class="mk-instagram-shop__container">
    {%- if ss.title != blank -%}
      <h2 class="mk-instagram-shop__title">{{ ss.title }}</h2>
    {%- endif -%}

    <div class="mk-instagram-shop__grid">
      {%- for i in (1..6) -%}
        {%- assign image_setting = 'image_' | append: i -%}
        {%- assign link_setting = 'link_' | append: i -%}

        {%- if ss[image_setting] != blank -%}
          <a href="{{ ss[link_setting] | default: '#' }}" class="mk-instagram-shop__item" target="_blank">
            {{ ss[image_setting] | image_url: width: 400 | image_tag: loading: 'lazy', class: 'mk-instagram-shop__image' }}
            <div class="mk-instagram-shop__overlay">
              {{- 'icon-instagram.svg' | inline_asset_content -}}
            </div>
          </a>
        {%- endif -%}
      {%- endfor -%}
    </div>

    {%- if ss.show_follow -%}
      <a href="{{ ss.follow_url | default: 'https://instagram.com' }}" class="mk-instagram-shop__follow" target="_blank">
        {{ ss.follow_text | default: '关注我们' }}
      </a>
    {%- endif -%}
  </div>
</section>

{% stylesheet %}
  .mk-instagram-shop { padding: {{ ss.padding_top_mobile | default: 48 }}px 0 {{ ss.padding_bottom_mobile | default: 48 }}px; }
  @media (min-width: 750px) { .mk-instagram-shop { padding: {{ ss.padding_top_desktop | default: 80 }}px 0 {{ ss.padding_bottom_desktop | default: 80 }}px; } }
  .mk-instagram-shop__container { max-width: var(--container-max-width, 1200px); margin: 0 auto; padding: 0 var(--container-padding, 32px); }
  .mk-instagram-shop__title { margin: 0 0 32px 0; font-size: var(--mk-font-size-3xl); font-weight: 700; text-align: center; }
  .mk-instagram-shop__grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: var(--mk-spacing-sm); }
  @media (min-width: 750px) { .mk-instagram-shop__grid { grid-template-columns: repeat(3, 1fr); gap: var(--mk-spacing-lg); } }
  @media (min-width: 1024px) { .mk-instagram-shop__grid { grid-template-columns: repeat(6, 1fr); } }
  .mk-instagram-shop__item { position: relative; aspect-ratio: 1; overflow: hidden; border-radius: var(--mk-radius-sm); }
  .mk-instagram-shop__image { width: 100%; height: 100%; object-fit: cover; transition: transform 0.3s ease; }
  .mk-instagram-shop__item:hover .mk-instagram-shop__image { transform: scale(1.05); }
  .mk-instagram-shop__overlay { position: absolute; inset: 0; display: flex; align-items: center; justify-content: center; background: rgba(0,0,0,0.4); opacity: 0; transition: opacity 0.2s ease; }
  .mk-instagram-shop__item:hover .mk-instagram-shop__overlay { opacity: 1; }
  .mk-instagram-shop__overlay svg { width: 32px; height: 32px; color: #fff; }
  .mk-instagram-shop__follow { display: inline-flex; margin-top: 32px; padding: 14px 32px; font-size: var(--mk-font-size-md); font-weight: 600; color: var(--color-on-primary, #fff); background: var(--color-primary, #000); border-radius: var(--mk-radius-sm); text-decoration: none; }
  .mk-instagram-shop__follow:hover { opacity: 0.85; }
{% endstylesheet %}

