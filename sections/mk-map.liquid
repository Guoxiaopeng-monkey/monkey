{%- comment -%}
  MK 地图板块

  展示地图位置

  作者：崽崽 (AI助手)
{%- endcomment -%}

{% liquid
  assign ss = section.settings
-%}

<section
  id="{{ section.id }}"
  class="mk-map color-{{ ss.color_scheme | default: 'background-1' }}"
>
  <div class="mk-map__container">
    {%- if ss.title != blank -%}
      <h2 class="mk-map__title">{{ ss.title }}</h2>
    {%- endif -%}

    <div class="mk-map__wrapper">
      {%- if ss.map_address != blank -%}
        <iframe
          class="mk-map__iframe"
          src="https://maps.google.com/maps?output=embed&q={{ ss.map_address | url_encode }}"
          width="100%"
          height="100%"
          style="border:0;"
          allowfullscreen=""
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"
        ></iframe>
      {%- else -%}
        <div class="mk-map__placeholder">
          <span class="mk-map__placeholder-icon">{{- 'icon-map.svg' | inline_asset_content -}}</span>
          <p>{{ 'sections.map.placeholder' | t | default: '地图占位符' }}</p>
        </div>
      {%- endif -%}
    </div>

    {%- if ss.address != blank -%}
      <div class="mk-map__info">
        <h3 class="mk-map__info-title">{{ ss.address_title | default: '我们的位置' }}</h3>
        <p class="mk-map__address">{{ ss.address }}</p>
        {%- if ss.phone != blank -%}
          <p class="mk-map__phone">{{ ss.phone }}</p>
        {%- endif -%}
      </div>
    {%- endif -%}
  </div>
</section>

{% stylesheet %}
  .mk-map {
    padding: {{ ss.padding_top_mobile | default: 48 }}px 0 {{ ss.padding_bottom_mobile | default: 48 }}px;
  }

  @media (min-width: 750px) {
    .mk-map {
      padding: {{ ss.padding_top_desktop | default: 64 }}px 0 {{ ss.padding_bottom_desktop | default: 64 }}px;
    }
  }

  .mk-map__container {
    max-width: var(--container-max-width, 1200px);
    margin: 0 auto;
    padding: 0 var(--container-padding, 32px);
  }

  .mk-map__title {
    margin: 0 0 24px 0;
    font-size: var(--mk-font-size-3xl);
    font-weight: 700;
    text-align: center;
  }

  .mk-map__wrapper {
    position: relative;
    width: 100%;
    height: 400px;
    border-radius: var(--mk-radius-md);
    overflow: hidden;
    background-color: var(--color-background-secondary, var(--mk-color-bg-secondary));
  }

  .mk-map__iframe {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
  }

  .mk-map__placeholder {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: var(--mk-spacing-md);
    color: var(--color-text-secondary, #666);
  }

  .mk-map__placeholder-icon {
    display: flex;
    width: 48px;
    height: 48px;
    opacity: 0.5;
  }

  .mk-map__placeholder-icon svg {
    width: 100%;
    height: 100%;
  }

  .mk-map__placeholder p {
    margin: 0;
    font-size: var(--mk-font-size-md);
  }

  .mk-map__info {
    margin-top: 24px;
    text-align: center;
  }

  .mk-map__info-title {
    margin: 0 0 8px 0;
    font-size: var(--mk-font-size-xl);
    font-weight: 600;
  }

  .mk-map__address {
    margin: 0 0 4px 0;
    font-size: var(--mk-font-size-md);
    color: var(--color-text-secondary, #666);
  }

  .mk-map__phone {
    margin: 0;
    font-size: var(--mk-font-size-md);
    color: var(--color-primary, #000);
  }
{% endstylesheet %}

{% schema %}
{
  "name": "MK 地图",
  "tag": "section",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "标题"
    },
    {
      "type": "text",
      "id": "map_address",
      "label": "地图地址",
      "info": "输入地址，地图将显示该位置"
    },
    {
      "type": "text",
      "id": "address_title",
      "label": "地址标题"
    },
    {
      "type": "textarea",
      "id": "address",
      "label": "地址文本"
    },
    {
      "type": "text",
      "id": "phone",
      "label": "电话"
    },
    {
      "type": "header",
      "content": "间距"
    },
    {
      "type": "range",
      "id": "padding_top_mobile",
      "label": "上边距 (移动端)",
      "min": 0,
      "max": 120,
      "default": 48,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "label": "下边距 (移动端)",
      "min": 0,
      "max": 120,
      "default": 48,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_top_desktop",
      "label": "上边距 (PC端)",
      "min": 0,
      "max": 200,
      "default": 64,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_bottom_desktop",
      "label": "下边距 (PC端)",
      "min": 0,
      "max": 200,
      "default": 64,
      "unit": "px"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "颜色方案",
      "default": "scheme-1"
    }
  ],
  "presets": [
    {
      "name": "MK 地图"
    }
  ]
}
{% endschema %}
