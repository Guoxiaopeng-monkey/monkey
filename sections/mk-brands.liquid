{%- comment -%}
  MK Brands板块

  展示品牌列表

  作者：崽崽 (AI助手)
{%- endcomment -%}

{% liquid
  assign ss = section.settings
-%}

<section id="{{ section.id }}" class="mk-brands color-{{ ss.color_scheme | default: 'background-1' }}">
  <div class="mk-brands__container">
    {%- if ss.title != blank -%}
      <h2 class="mk-brands__title">{{ ss.title }}</h2>
    {%- endif -%}

    <div class="mk-brands__grid">
      {%- for i in (1..8) -%}
        {%- assign image_setting = 'image_' | append: i -%}
        {%- assign link_setting = 'link_' | append: i -%}

        {%- if ss[image_setting] != blank -%}
          <a href="{{ ss[link_setting] | default: '#' }}" class="mk-brands__item">
            {{ ss[image_setting] | image_url: width: 200 | image_tag: loading: 'lazy', class: 'mk-brands__image' }}
          </a>
        {%- endif -%}
      {%- endfor -%}
    </div>
  </div>
</section>

{% stylesheet %}
  .mk-brands { padding: {{ ss.padding_top_mobile | default: 48 }}px 0 {{ ss.padding_bottom_mobile | default: 48 }}px; }
  @media (min-width: 750px) { .mk-brands { padding: {{ ss.padding_top_desktop | default: 80 }}px 0 {{ ss.padding_bottom_desktop | default: 80 }}px; } }
  .mk-brands__container { max-width: var(--container-max-width, 1200px); margin: 0 auto; padding: 0 var(--container-padding, 32px); }
  .mk-brands__title { margin: 0 0 32px 0; font-size: 28px; font-weight: 700; text-align: center; }
  .mk-brands__grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 24px; }
  @media (min-width: 750px) { .mk-brands__grid { grid-template-columns: repeat(4, 1fr); gap: 32px; } }
  .mk-brands__item { display: flex; align-items: center; justify-content: center; padding: 20px; background: var(--color-background-secondary, #f5f5f5); border-radius: 12px; transition: all 0.2s ease; }
  .mk-brands__item:hover { background: var(--color-border); }
  .mk-brands__image { max-width: 120px; height: auto; opacity: 0.7; transition: opacity 0.2s ease; }
  .mk-brands__item:hover .mk-brands__image { opacity: 1; }
{% endstylesheet %}

{% schema %}
{
  "name": "MK Brands",
  "tag": "section",
  "settings": [
    { "type": "text", "id": "title", "label": "标题" },
    { "type": "header", "content": "品牌" },
    { "type": "image_picker", "id": "image_1", "label": "品牌 1" }, { "type": "url", "id": "link_1", "label": "链接 1" },
    { "type": "image_picker", "id": "image_2", "label": "品牌 2" }, { "type": "url", "id": "link_2", "label": "链接 2" },
    { "type": "image_picker", "id": "image_3", "label": "品牌 3" }, { "type": "url", "id": "link_3", "label": "链接 3" },
    { "type": "image_picker", "id": "image_4", "label": "品牌 4" }, { "type": "url", "id": "link_4", "label": "链接 4" },
    { "type": "image_picker", "id": "image_5", "label": "品牌 5" }, { "type": "url", "id": "link_5", "label": "链接 5" },
    { "type": "image_picker", "id": "image_6", "label": "品牌 6" }, { "type": "url", "id": "link_6", "label": "链接 6" },
    { "type": "image_picker", "id": "image_7", "label": "品牌 7" }, { "type": "url", "id": "link_7", "label": "链接 7" },
    { "type": "image_picker", "id": "image_8", "label": "品牌 8" }, { "type": "url", "id": "link_8", "label": "链接 8" },
    { "type": "header", "content": "间距" },
    { "type": "range", "id": "padding_top_mobile", "label": "上边距 (移动端)", "min": 0, "max": 120, "default": 48, "unit": "px" },
    { "type": "range", "id": "padding_bottom_mobile", "label": "下边距 (移动端)", "min": 0, "max": 120, "default": 48, "unit": "px" },
    { "type": "range", "id": "padding_top_desktop", "label": "上边距 (PC端)", "min": 0, "max": 200, "default": 80, "unit": "px" },
    { "type": "range", "id": "padding_bottom_desktop", "label": "下边距 (PC端)", "min": 0, "max": 200, "default": 80, "unit": "px" },
    { "type": "color_scheme", "id": "color_scheme", "label": "颜色方案", "default": "scheme-1" }
  ],
  "presets": [{ "name": "MK Brands" }]
}
{% endschema %}
