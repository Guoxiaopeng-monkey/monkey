{%- doc -%}
  MK 空状态组件

  渲染空状态提示

  @param {string} [title] - 标题
  @param {string} [description] - 描述
  @param {string} [button_text] - 按钮文字
  @param {string} [button_link] - 按钮链接

  @example
  {% render 'mk-empty-state', title: '没有找到产品', description: '尝试其他关键词', button_text: '浏览全部', button_link: '/collections/all' %}
{%- enddoc -%}

{% liquid
  assign title = title | default: ''
  assign description = description | default: ''
  assign button_text = button_text | default: ''
  assign button_link = button_link | default: '#'
  assign class = class | default: ''
-%}

<div class="mk-empty-state {{ class }}">
  <div class="mk-empty-state__icon">
    {{- 'icon-package.svg' | inline_asset_content -}}
  </div>

  {%- if title != blank -%}
    <h3 class="mk-empty-state__title">{{ title }}</h3>
  {%- endif -%}

  {%- if description != blank -%}
    <p class="mk-empty-state__description">{{ description }}</p>
  {%- endif -%}

  {%- if button_text != blank -%}
    <a href="{{ button_link }}" class="mk-empty-state__button">
      {{ button_text }}
    </a>
  {%- endif -%}
</div>

{% stylesheet %}
  .mk-empty-state {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: var(--mk-spacing-5xl) 24px;
    text-align: center;
  }

  .mk-empty-state__icon {
    display: flex;
    width: 64px;
    height: 64px;
    margin-bottom: 20px;
    color: var(--color-text-secondary, #666);
    opacity: 0.5;
  }

  .mk-empty-state__icon svg {
    width: 100%;
    height: 100%;
  }

  .mk-empty-state__title {
    margin: 0 0 8px 0;
    font-size: var(--mk-font-size-xl);
    font-weight: 600;
    color: var(--color-foreground);
  }

  .mk-empty-state__description {
    margin: 0 0 24px 0;
    font-size: var(--mk-font-size-md);
    color: var(--color-text-secondary, #666);
    max-width: 300px;
  }

  .mk-empty-state__button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: var(--mk-spacing-md) 24px;
    font-size: var(--mk-font-size-md);
    font-weight: 600;
    color: var(--color-on-primary, #fff);
    background-color: var(--color-primary, #000);
    border-radius: var(--mk-radius-sm);
    text-decoration: none;
    transition: all 0.2s ease;
  }

  .mk-empty-state__button:hover {
    opacity: 0.85;
  }
{% endstylesheet %}
