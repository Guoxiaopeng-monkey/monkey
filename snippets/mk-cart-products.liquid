{%- doc -%}
  MK 购物车商品列表组件

  渲染购物车中的商品列表

  @param {string} [type] - 渲染类型：'empty'（空状态）或默认（商品列表）

  @example
  {% render 'mk-cart-products' %}
  {% render 'mk-cart-products', type: 'empty' %}
{%- enddoc -%}

{% liquid
  assign type = type | default: 'items'
-%}

{%- if type == 'empty' -%}
  {%- comment -%} 空购物车状态 {%- endcomment -%}
  <div class="mk-cart-empty">
    <div class="mk-cart-empty__icon">
      {{- 'icon-cart.svg' | inline_asset_content -}}
    </div>
    <p class="mk-cart-empty__text">{{ 'cart.empty_message' | t | default: '您的购物车目前没有商品。' }}</p>
    <a href="{{ routes.all_products_collection_url }}" class="mk-cart-empty__btn button button--primary">
      {{ 'cart.continue_shopping' | t | default: '开始购物' }}
    </a>
  </div>
{%- else -%}
  {%- comment -%} 购物车商品列表 {%- endcomment -%}
  <form action="{{ routes.cart_url }}" class="mk-cart-form" id="mk-cart-form" method="post">
    <div class="mk-cart-items__list">
      {% for item in cart.items %}
        <div class="mk-cart-item" data-item-id="{{ item.id }}" data-item-key="{{ item.key }}">
          {%- comment -%} 商品图片 {%- endcomment -%}
          <div class="mk-cart-item__media">
            {% if item.image != blank %}
              <a href="{{ item.url }}" class="mk-cart-item__image-link">
                {{ item.image | image_url: width: 200 | image_tag: class: 'mk-cart-item__image' }}
              </a>
            {% else %}
              <a href="{{ item.url }}" class="mk-cart-item__image-link mk-cart-item__image-placeholder">
                {{ 'product-1' | placeholder_svg_tag }}
              </a>
            {% endif %}
          </div>

          {%- comment -%} 商品详情 {%- endcomment -%}
          <div class="mk-cart-item__details">
            <a href="{{ item.url }}" class="mk-cart-item__title">{{ item.product.title }}</a>

            {%- comment -%} 供应商 {%- endcomment -%}
            {% if item.product.vendor %}
              <p class="mk-cart-item__vendor">{{ item.product.vendor }}</p>
            {% endif %}

            {%- comment -%} 变体信息 {%- endcomment -%}
            {% unless item.product.has_only_default_variant or item.item_components.size == 0 %}
              <dl class="mk-cart-item__variants">
                {%- for option in item.options_with_values -%}
                  <div class="mk-cart-item__variant">
                    <dt>{{ option.name }}:</dt>
                    <dd>{{ option.value }}</dd>
                  </div>
                {%- endfor -%}
              </dl>
            {% endunless %}

            {%- comment -%} 属性信息 {%- endcomment -%}
            {%- for property in item.properties -%}
              {%- assign first_char = property.first | slice: 0 -%}
              {%- if property.last != blank and first_char != '_' -%}
                <p class="mk-cart-item__property">
                  {{ property.first }}: {{ property.last }}
                </p>
              {%- endif -%}
            {%- endfor -%}

            {%- comment -%} 订阅信息 {%- endcomment -%}
            {% if item.selling_plan_allocation %}
              <p class="mk-cart-item__selling-plan">{{ item.selling_plan_allocation.selling_plan.name }}</p>
            {% endif %}

            {%- comment -%} 折扣信息 {%- endcomment -%}
            {% if item.line_level_discount_allocations.size > 0 %}
              <ul class="mk-cart-item__discounts list-unstyled">
                {%- for discount in item.line_level_discount_allocations -%}
                  <li>{{ discount.discount_application.title | escape }}</li>
                {%- endfor -%}
              </ul>
            {% endif %}

            {%- comment -%} 价格 {%- endcomment -%}
            <div class="mk-cart-item__price">
              {% if item.original_line_price > item.final_line_price %}
                <span class="mk-cart-item__price-compare">{{ item.original_price | money }}</span>
                <span class="mk-cart-item__price-final">{{ item.final_price | money }}</span>
              {% else %}
                <span class="mk-cart-item__price-final">{{ item.original_price | money }}</span>
              {% endif %}

              {% if item.unit_price_measurement %}
                <span class="mk-cart-item__unit-price">
                  ({{ item.unit_price | money }} / {{ item.unit_price_measurement.reference_unit_value }})
                </span>
              {% endif %}
            </div>
          </div>

          {%- comment -%} 数量选择器 {%- endcomment -%}
          <div class="mk-cart-item__quantity">
            <div class="mk-quantity-selector">
              <button type="button" class="mk-quantity-selector__btn" data-action="decrease" aria-label="{{ 'actions.decrease_quantity' | t }}">
                {{- 'icon-minus.svg' | inline_asset_content -}}
              </button>
              <input
                type="number"
                name="updates[]"
                value="{{ item.quantity }}"
                min="0"
                class="mk-quantity-selector__input"
                data-item-id="{{ item.id }}"
                data-item-key="{{ item.key }}"
                aria-label="{{ 'actions.quantity' | t }}"
              >
              <button type="button" class="mk-quantity-selector__btn" data-action="increase" aria-label="{{ 'actions.increase_quantity' | t }}">
                {{- 'icon-plus.svg' | inline_asset_content -}}
              </button>
            </div>

            <button type="button" class="mk-cart-item__remove" data-item-remove aria-label="{{ 'accessibility.remove_item' | t }}">
              {{- 'icon-delete.svg' | inline_asset_content -}}
            </button>
          </div>

          {%- comment -%} 小计 {%- endcomment -%}
          <div class="mk-cart-item__total">
            {% if item.original_line_price > item.final_line_price %}
              <span class="visually-hidden">{{ 'content.price_sale' | t }}</span>
            {% endif %}
            <span class="mk-cart-item__total-final">{{ item.final_line_price | money }}</span>
          </div>
        </div>
      {% endfor %}
    </div>
  </form>
{%- endif -%}

{% stylesheet %}
  .mk-cart-form {
    width: 100%;
  }

  .mk-cart-items__list {
    display: flex;
    flex-direction: column;
  }

  .mk-cart-item {
    display: grid;
    grid-template-columns: 80px 1fr auto;
    grid-template-rows: auto auto;
    gap: 12px;
    padding: 16px;
    border-bottom: 1px solid var(--color-border);
  }

  @media (min-width: 750px) {
    .mk-cart-item {
      grid-template-columns: 100px 1fr 120px 80px;
      grid-template-rows: auto;
      gap: 16px;
      padding: 20px;
    }
  }

  .mk-cart-item__media {
    grid-row: span 2;
  }

  .mk-cart-item__image-link {
    display: block;
    aspect-ratio: 1;
    overflow: hidden;
    border-radius: 8px;
    background-color: var(--color-background-secondary, #f5f5f5);
  }

  .mk-cart-item__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .mk-cart-item__image-placeholder {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    height: 100%;
  }

  .mk-cart-item__image-placeholder svg {
    width: 50%;
    height: 50%;
    opacity: 0.5;
  }

  .mk-cart-item__details {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .mk-cart-item__title {
    font-size: 14px;
    font-weight: 600;
    text-decoration: none;
    color: inherit;
    line-height: 1.3;
  }

  .mk-cart-item__title:hover {
    text-decoration: underline;
  }

  .mk-cart-item__vendor {
    font-size: 12px;
    color: var(--color-text-secondary, #666);
    margin: 0;
  }

  .mk-cart-item__variants {
    margin: 4px 0 0 0;
    font-size: 12px;
    color: var(--color-text-secondary, #666);
  }

  .mk-cart-item__variant {
    display: inline;
  }

  .mk-cart-item__variant dt,
  .mk-cart-item__variant dd {
    display: inline;
  }

  .mk-cart-item__variant dt::after {
    content: ":";
  }

  .mk-cart-item__variant dd {
    margin: 0;
  }

  .mk-cart-item__variant dd:not(:last-child)::after {
    content: ",";
    margin-right: 4px;
  }

  .mk-cart-item__property {
    margin: 2px 0 0 0;
    font-size: 12px;
    color: var(--color-text-secondary, #666);
  }

  .mk-cart-item__selling-plan {
    margin: 2px 0 0 0;
    font-size: 12px;
    color: var(--color-text-secondary, #666);
  }

  .mk-cart-item__discounts {
    margin: 4px 0 0 0;
    font-size: 12px;
    color: var(--color-sale, #2e7d32);
  }

  .mk-cart-item__price {
    margin-top: 8px;
    font-size: 14px;
    font-weight: 500;
  }

  .mk-cart-item__price-compare {
    text-decoration: line-through;
    color: var(--color-text-secondary, #999);
    margin-right: 8px;
  }

  .mk-cart-item__unit-price {
    display: block;
    font-size: 11px;
    color: var(--color-text-secondary, #999);
  }

  .mk-cart-item__quantity {
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .mk-quantity-selector {
    display: flex;
    align-items: center;
    border: 1px solid var(--color-border);
    border-radius: 4px;
  }

  .mk-quantity-selector__btn {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 32px;
    height: 32px;
    padding: 0;
    background: transparent;
    border: none;
    cursor: pointer;
    color: var(--color-foreground);
    transition: background-color 0.2s ease;
  }

  .mk-quantity-selector__btn:hover {
    background-color: var(--color-background-secondary, #f5f5f5);
  }

  .mk-quantity-selector__btn svg {
    width: 14px;
    height: 14px;
  }

  .mk-quantity-selector__input {
    width: 40px;
    height: 32px;
    padding: 0;
    font-size: 14px;
    text-align: center;
    border: none;
    border-left: 1px solid var(--color-border);
    border-right: 1px solid var(--color-border);
    background: transparent;
  }

  .mk-quantity-selector__input:focus {
    outline: none;
  }

  .mk-cart-item__remove {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 32px;
    height: 32px;
    padding: 0;
    background: transparent;
    border: none;
    cursor: pointer;
    color: var(--color-text-secondary, #666);
    transition: color 0.2s ease;
  }

  .mk-cart-item__remove:hover {
    color: var(--color-error, #e53935);
  }

  .mk-cart-item__remove svg {
    width: 16px;
    height: 16px;
  }

  .mk-cart-item__total {
    font-size: 14px;
    font-weight: 600;
    text-align: right;
  }

  /* Empty State */
  .mk-cart-empty {
    text-align: center;
    padding: 40px 20px;
  }

  .mk-cart-empty__icon {
    display: flex;
    justify-content: center;
    margin-bottom: 16px;
  }

  .mk-cart-empty__icon svg {
    width: 64px;
    height: 64px;
    opacity: 0.3;
  }

  .mk-cart-empty__text {
    font-size: 14px;
    color: var(--color-text-secondary, #666);
    margin: 0 0 24px 0;
  }

  .mk-cart-empty__btn {
    display: inline-block;
    padding: 12px 24px;
    font-size: 14px;
    font-weight: 600;
    text-decoration: none;
    color: var(--color-on-primary, #fff);
    background-color: var(--color-primary, #000);
    border-radius: 4px;
    transition: opacity 0.2s ease;
  }

  .mk-cart-empty__btn:hover {
    opacity: 0.85;
  }
{% endstylesheet %}
