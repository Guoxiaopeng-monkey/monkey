{%- comment -%}
  MK 视频组件

  展示视频内容，支持YouTube/Vimeo/本地视频

  作者：崽崽 (AI助手)
{%- endcomment -%}

{% liquid
  assign ss = section.settings
-%}

<section
  id="{{ section.id }}"
  class="mk-video-section color-{{ ss.color_scheme | default: 'background-1' }}"
>
  <div class="mk-video-section__container">
    {%- if ss.title != blank -%}
      <h2 class="mk-video-section__title">{{ ss.title }}</h2>
    {%- endif -%}

    <div class="mk-video-section__wrapper">
      {%- case ss.video_type -%}
        {%- when 'youtube' -%}
          <div class="mk-video-section__embed">
            <iframe
              src="https://www.youtube.com/embed/{{ ss.video_id }}?enablejsapi=1"
              frameborder="0"
              allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
              allowfullscreen
              loading="lazy"
            ></iframe>
          </div>

        {%- when 'vimeo' -%}
          <div class="mk-video-section__embed">
            <iframe
              src="https://player.vimeo.com/video/{{ ss.video_id }}"
              frameborder="0"
              allow="autoplay; fullscreen; picture-in-picture"
              allowfullscreen
              loading="lazy"
            ></iframe>
          </div>

        {%- when 'hosted' -%}
          {%- if ss.video != blank -%}
            <video
              class="mk-video-section__video"
              src="{{ ss.video }}"
              autoplay="{{ ss.autoplay }}"
              loop="{{ ss.loop }}"
              muted="{{ ss.muted }}"
              controls
              playsinline
            >
              您的浏览器不支持视频标签。
            </video>
          {%- endif -%}

        {%- else -%}
          {%- if ss.video_url != blank -%}
            <div class="mk-video-section__embed">
              {{ ss.video_url | video_tag: autoplay: ss.autoplay, loop: ss.loop, muted: ss.muted, controls: true, class: 'mk-video-section__video' }}
            </div>
          {%- endif -%}
      {%- endcase -%}

      {%- if ss.overlay_enabled -%}
        <div class="mk-video-section__overlay" style="opacity: {{ ss.overlay_opacity }};"></div>
      {%- endif -%}
    </div>

    {%- if ss.description != blank -%}
      <p class="mk-video-section__description">{{ ss.description }}</p>
    {%- endif -%}
  </div>
</section>

{% stylesheet %}
  .mk-video-section {
    padding: {{ ss.padding_top_mobile | default: 48 }}px 0 {{ ss.padding_bottom_mobile | default: 48 }}px;
  }

  @media (min-width: 750px) {
    .mk-video-section {
      padding: {{ ss.padding_top_desktop | default: 64 }}px 0 {{ ss.padding_bottom_desktop | default: 64 }}px;
    }
  }

  .mk-video-section__container {
    max-width: var(--container-max-width, 1200px);
    margin: 0 auto;
    padding: 0 var(--container-padding, 32px);
  }

  .mk-video-section__title {
    margin: 0 0 24px 0;
    font-size: var(--mk-font-size-3xl);
    font-weight: 700;
    text-align: center;
  }

  .mk-video-section__wrapper {
    position: relative;
    width: 100%;
    aspect-ratio: {{ ss.aspect_ratio | default: '16/9' }};
    background-color: #000;
    border-radius: var(--mk-radius-md);
    overflow: hidden;
  }

  .mk-video-section__embed {
    position: absolute;
    inset: 0;
  }

  .mk-video-section__embed iframe {
    width: 100%;
    height: 100%;
  }

  .mk-video-section__video {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .mk-video-section__overlay {
    position: absolute;
    inset: 0;
    pointer-events: none;
    background-color: #000;
  }

  .mk-video-section__description {
    margin: var(--mk-spacing-lg) 0 0 0;
    font-size: var(--mk-font-size-md);
    color: var(--color-text-secondary, #666);
    text-align: center;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "MK 视频",
  "tag": "section",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "标题"
    },
    {
      "type": "select",
      "id": "video_type",
      "label": "视频来源",
      "options": [
        { "value": "youtube", "label": "YouTube" },
        { "value": "vimeo", "label": "Vimeo" },
        { "value": "hosted", "label": "本地视频" },
        { "value": "url", "label": "视频URL" }
      ],
      "default": "youtube"
    },
    {
      "type": "text",
      "id": "video_id",
      "label": "YouTube/Vimeo ID",
      "info": "例如：dQw4w9WgXcQ"
    },
    {
      "type": "video",
      "id": "video",
      "label": "本地视频"
    },
    {
      "type": "video_url",
      "id": "video_url",
      "label": "视频URL",
      "accept": ["youtube", "vimeo"]
    },
    {
      "type": "select",
      "id": "aspect_ratio",
      "label": "视频比例",
      "options": [
        { "value": "16/9", "label": "16:9" },
        { "value": "21/9", "label": "21:9" },
        { "value": "4/3", "label": "4:3" },
        { "value": "1/1", "label": "1:1" }
      ],
      "default": "16/9"
    },
    {
      "type": "checkbox",
      "id": "autoplay",
      "label": "自动播放"
    },
    {
      "type": "checkbox",
      "id": "loop",
      "label": "循环播放"
    },
    {
      "type": "checkbox",
      "id": "muted",
      "label": "静音"
    },
    {
      "type": "checkbox",
      "id": "overlay_enabled",
      "label": "启用遮罩"
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "label": "遮罩透明度",
      "min": 0,
      "max": 1,
      "step": 0.1,
      "default": 0.3
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "描述"
    },
    {
      "type": "header",
      "content": "间距"
    },
    {
      "type": "range",
      "id": "padding_top_mobile",
      "label": "上边距 (移动端)",
      "min": 0,
      "max": 120,
      "default": 48,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "label": "下边距 (移动端)",
      "min": 0,
      "max": 120,
      "default": 48,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_top_desktop",
      "label": "上边距 (PC端)",
      "min": 0,
      "max": 200,
      "default": 64,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_bottom_desktop",
      "label": "下边距 (PC端)",
      "min": 0,
      "max": 200,
      "default": 64,
      "unit": "px"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "颜色方案",
      "default": "scheme-1"
    }
  ],
  "presets": [
    {
      "name": "MK 视频"
    }
  ]
}
{% endschema %}
