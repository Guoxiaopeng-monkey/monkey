{%- comment -%}
  MK 密码保护页面板块

  渲染密码保护商店页面

  作者：崽崽 (AI助手)
{%- endcomment -%}

{% liquid
  assign ss = section.settings
-%}

<section
  id="{{ section.id }}"
  class="mk-password color-{{ ss.color_scheme | default: 'background-1' }}"
>
  <div class="mk-password__container">
    {%- if ss.logo != blank -%}
      <a href="{{ routes.root_url }}" class="mk-password__logo">
        {{ ss.logo | image_url: width: 200 | image_tag }}
      </a>
    {%- else -%}
      <h1 class="mk-password__shop-name">{{ shop.name }}</h1>
    {%- endif -%}

    {%- if ss.show_shop_name -%}
      <h2 class="mk-password__title">{{ ss.title | default: '我们的商店即将上线' }}</h2>
    {%- else -%}
      <h2 class="mk-password__title">{{ ss.title | default: '即将上线' }}</h2>
    {%- endif -%}

    {%- if ss.description != blank -%}
      <p class="mk-password__description">{{ ss.description }}</p>
    {%- else -%}
      <p class="mk-password__description">{{ 'password.opening_soon' | t | default: '我们正在准备一些特别的东西。请稍等片刻。' }}</p>
    {%- endif -%}

    {%- form 'storefront_password', class: 'mk-password__form' -%}
      {%- if form.errors -%}
        <p class="mk-password__error">{{ form.errors.messages['form'] }}</p>
      {%- endif -%}

      <div class="mk-password__fields">
        <input
          type="password"
          name="password"
          id="password"
          class="mk-password__input"
          placeholder="{{ 'password.input_placeholder' | t | default: '请输入密码' }}"
          autocomplete="current-password"
          required
        >
        <button type="submit" class="mk-password__button">
          {{ 'password.enter' | t | default: '进入' }}
        </button>
      </div>
    {%- endform -%}

    <p class="mk-password__hint">
      {{ 'password.hint' | t | default: '店主请登录' }}
      <a href="{{ routes.account_login_url }}">{{ 'password.login_link' | t | default: '这里' }}</a>
    </p>
  </div>
</section>

{% stylesheet %}
  .mk-password {
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: var(--mk-spacing-5xl) 24px;
    text-align: center;
  }

  .mk-password__container {
    max-width: 500px;
  }

  .mk-password__logo {
    display: block;
    margin-bottom: 24px;
  }

  .mk-password__logo img {
    max-width: 200px;
    height: auto;
  }

  .mk-password__shop-name {
    margin: 0 0 24px 0;
    font-size: var(--mk-font-size-3xl);
    font-weight: 700;
  }

  .mk-password__title {
    margin: 0 0 16px 0;
    font-size: var(--mk-font-size-3xl);
    font-weight: 600;
  }

  .mk-password__description {
    margin: 0 0 32px 0;
    font-size: var(--mk-font-size-lg);
    line-height: 1.7;
    color: var(--color-text-secondary, #666);
  }

  .mk-password__form {
    margin-bottom: 16px;
  }

  .mk-password__fields {
    display: flex;
    gap: var(--mk-spacing-sm);
  }

  .mk-password__input {
    flex: 1;
    padding: 14px 16px;
    font-size: var(--mk-font-size-md);
    color: var(--color-foreground);
    background-color: var(--color-background);
    border: 1px solid var(--color-border);
    border-radius: var(--mk-radius-sm);
    transition: border-color 0.2s ease;
  }

  .mk-password__input:focus {
    outline: none;
    border-color: var(--color-primary, #000);
  }

  .mk-password__button {
    padding: 14px 28px;
    font-size: var(--mk-font-size-md);
    font-weight: 600;
    color: var(--color-on-primary, #fff);
    background-color: var(--color-primary, #000);
    border: none;
    border-radius: var(--mk-radius-sm);
    cursor: pointer;
    transition: all 0.2s ease;
  }

  .mk-password__button:hover {
    opacity: 0.85;
  }

  .mk-password__error {
    margin: var(--mk-spacing-md) 0;
    padding: var(--mk-spacing-md);
    background-color: rgba(229, 57, 53, 0.1);
    color: var(--color-error, #e53935);
    border-radius: var(--mk-radius-sm);
    font-size: var(--mk-font-size-sm);
  }

  .mk-password__hint {
    margin: 0;
    font-size: var(--mk-font-size-sm);
    color: var(--color-text-secondary, #666);
  }

  .mk-password__hint a {
    color: var(--color-primary, #000);
    text-decoration: underline;
    text-underline-offset: 2px;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "MK 密码保护页",
  "tag": "section",
  "settings": [
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Logo"
    },
    {
      "type": "checkbox",
      "id": "show_shop_name",
      "label": "显示商店名称",
      "default": true
    },
    {
      "type": "text",
      "id": "title",
      "label": "标题"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "描述"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "颜色方案",
      "default": "scheme-1"
    }
  ],
  "presets": [
    {
      "name": "MK 密码保护页"
    }
  ]
}
{% endschema %}
