{%- comment -%}
  MK Floating Buttons板块

  浮动按钮

  作者：崽崽 (AI助手)
{%- endcomment -%}

{% liquid
  assign ss = section.settings
-%}

<div id="{{ section.id }}" class="mk-floating-buttons" data-floating-buttons>
  {%- if ss.show_back_to_top -%}
    <button type="button" class="mk-floating-buttons__btn mk-floating-buttons__btn--top" data-back-to-top aria-label="返回顶部">
      {{- 'icon-arrow-up.svg' | inline_asset_content -}}
    </button>
  {%- endif -%}

  {%- if ss.show_whatsapp and ss.whatsapp_number != blank -%}
    <a href="https://wa.me/{{ ss.whatsapp_number | remove: '+' | remove: ' ' }}" target="_blank" rel="noopener" class="mk-floating-buttons__btn mk-floating-buttons__btn--whatsapp" aria-label="WhatsApp">
      {{- 'icon-whatsapp.svg' | inline_asset_content -}}
    </a>
  {%- endif -%}

  {%- if ss.show_messenger and ss.messenger_url != blank -%}
    <a href="{{ ss.messenger_url }}" target="_blank" rel="noopener" class="mk-floating-buttons__btn mk-floating-buttons__btn--messenger" aria-label="Messenger">
      {{- 'icon-messenger.svg' | inline_asset_content -}}
    </a>
  {%- endif -%}
</div>

{% stylesheet %}
  .mk-floating-buttons { position: fixed; bottom: 24px; right: 24px; z-index: 9997; display: flex; flex-direction: column; gap: 12px; }
  .mk-floating-buttons__btn { display: flex; align-items: center; justify-content: center; width: 48px; height: 48px; background: var(--color-primary, #000); color: #fff; border: none; border-radius: 50%; cursor: pointer; box-shadow: 0 4px 16px rgba(0,0,0,0.15); transition: all 0.2s ease; text-decoration: none; }
  .mk-floating-buttons__btn:hover { transform: scale(1.05); }
  .mk-floating-buttons__btn svg { width: 22px; height: 22px; }
{% endstylesheet %}

{% javascript %}
  document.querySelector('[data-back-to-top]')?.addEventListener('click', () => window.scrollTo({ top: 0, behavior: 'smooth' }));
{% endjavascript %}

{% schema %}
{
  "name": "MK Floating Buttons",
  "tag": "div",
  "settings": [
    { "type": "checkbox", "id": "show_back_to_top", "label": "显示返回顶部", "default": true },
    { "type": "checkbox", "id": "show_whatsapp", "label": "显示WhatsApp", "default": false },
    { "type": "text", "id": "whatsapp_number", "label": "WhatsApp号码" },
    { "type": "checkbox", "id": "show_messenger", "label": "显示Messenger", "default": false },
    { "type": "url", "id": "messenger_url", "label": "Messenger链接" }
  ],
  "presets": [{ "name": "MK Floating Buttons" }]
}
{% endschema %}
