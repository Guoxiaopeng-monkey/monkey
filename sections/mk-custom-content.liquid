{%- comment -%}
  MK Custom Content板块

  自定义内容区块

  作者：崽崽 (AI助手)
{%- endcomment -%}

{% liquid
  assign ss = section.settings
-%}

<section id="{{ section.id }}" class="mk-custom-content color-{{ ss.color_scheme | default: 'background-1' }}">
  <div class="mk-custom-content__container">
    {%- if ss.title != blank -%}
      <h2 class="mk-custom-content__title">{{ ss.title }}</h2>
    {%- endif -%}

    <div class="mk-custom-content__content">
      {{ ss.html_content }}
    </div>
  </div>
</section>

{% stylesheet %}
  .mk-custom-content { padding: {{ ss.padding_top_mobile | default: 48 }}px 0 {{ ss.padding_bottom_mobile | default: 48 }}px; }
  @media (min-width: 750px) { .mk-custom-content { padding: {{ ss.padding_top_desktop | default: 80 }}px 0 {{ ss.padding_bottom_desktop | default: 80 }}px; } }
  .mk-custom-content__container { max-width: var(--container-max-width, 1200px); margin: 0 auto; padding: 0 var(--container-padding, 32px); }
  .mk-custom-content__title { margin: 0 0 32px 0; font-size: var(--mk-font-size-3xl); font-weight: 700; text-align: center; }
  .mk-custom-content__content { font-size: var(--mk-font-size-md); line-height: 1.6; }
{% endstylesheet %}

{% schema %}
{
  "name": "MK Custom Content",
  "tag": "section",
  "settings": [
    { "type": "text", "id": "title", "label": "标题" },
    { "type": "html", "id": "html_content", "label": "HTML内容" },
    { "type": "header", "content": "间距" },
    { "type": "range", "id": "padding_top_mobile", "label": "上边距 (移动端)", "min": 0, "max": 120, "default": 48, "unit": "px" },
    { "type": "range", "id": "padding_bottom_mobile", "label": "下边距 (移动端)", "min": 0, "max": 120, "default": 48, "unit": "px" },
    { "type": "range", "id": "padding_top_desktop", "label": "上边距 (PC端)", "min": 0