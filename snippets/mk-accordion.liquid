{%- doc -%}
  MK 手风琴组件

  渲染可展开/收起的折叠面板

  @param {string[]} items - 对象数组：{ title: string, content: string }
  @param {string} [class] - 额外CSS类名

  @example
  {% render 'mk-accordion', items: sections %}
{%- enddoc -%}

{% liquid
  assign items = items | default: empty_array
  if items == empty_array
    assign items = '[]' | parse_json
  endif
-%}

<div class="mk-accordion {{ class }}">
  {%- for item in items -%}
    <details class="mk-accordion__item" {{ item.attrs }}>
      <summary class="mk-accordion__header">
        <span class="mk-accordion__title">{{ item.title }}</span>
        <span class="mk-accordion__icon">{{- 'icon-plus.svg' | inline_asset_content -}}</span>
      </summary>
      <div class="mk-accordion__content">
        {{ item.content }}
      </div>
    </details>
  {%- endfor -%}
</div>

{% stylesheet %}
  .mk-accordion {
    border: 1px solid var(--color-border);
    border-radius: 12px;
    overflow: hidden;
  }

  .mk-accordion__item {
    border-bottom: 1px solid var(--color-border);
  }

  .mk-accordion__item:last-child {
    border-bottom: none;
  }

  .mk-accordion__header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    padding: 16px 20px;
    cursor: pointer;
    list-style: none;
    transition: background-color 0.2s ease;
  }

  .mk-accordion__header::-webkit-details-marker {
    display: none;
  }

  .mk-accordion__header:hover {
    background-color: var(--color-background-secondary, #f5f5f5);
  }

  .mk-accordion__title {
    font-size: 14px;
    font-weight: 500;
    color: var(--color-foreground);
  }

  .mk-accordion__icon {
    display: flex;
    width: 20px;
    height: 20px;
    flex-shrink: 0;
    color: var(--color-text-secondary, #666);
    transition: transform 0.2s ease;
  }

  .mk-accordion__icon svg {
    width: 100%;
    height: 100%;
  }

  .mk-accordion__item[open] .mk-accordion__icon {
    transform: rotate(45deg);
  }

  .mk-accordion__content {
    padding: 0 20px 16px 20px;
    font-size: 14px;
    color: var(--color-text-secondary, #666);
    line-height: 1.6;
  }
{% endstylesheet %}
