{%- comment -%}
  MK Countdown Elegant板块

  优雅倒计时

  作者：崽崽 (AI助手)
{%- endcomment -%}

{% liquid
  assign ss = section.settings
-%}

<section id="{{ section.id }}" class="mk-countdown-elegant color-{{ ss.color_scheme | default: 'background-1' }}">
  <div class="mk-countdown-elegant__container">
    {%- if ss.title != blank -%}
      <h2 class="mk-countdown-elegant__title">{{ ss.title }}</h2>
    {%- endif -%}
    <div class="mk-countdown-elegant__countdown" data-countdown-elegant data-end="{{ ss.end_date | default: '' | date: '%Y-%m-%dT%H:%M:%S' }}">
      <div class="mk-countdown-elegant__item"><span class="mk-countdown-elegant__num" data-days>00</span><span class="mk-countdown-elegant__label">Days</span></div>
      <div class="mk-countdown-elegant__item"><span class="mk-countdown-elegant__num" data-hours>00</span><span class="mk-countdown-elegant__label">Hours</span></div>
      <div class="mk-countdown-elegant__item"><span class="mk-countdown-elegant__num" data-minutes>00</span><span class="mk-countdown-elegant__label">Minutes</span></div>
      <div class="mk-countdown-elegant__item"><span class="mk-countdown-elegant__num" data-seconds>00</span><span class="mk-countdown-elegant__label">Seconds</span></div>
    </div>
  </div>
</section>

{% stylesheet %}
  .mk-countdown-elegant { padding: 80px 0; background: #1a1a2e; }
  .mk-countdown-elegant__container { max-width: 800px; margin: 0 auto; padding: 0 32px; text-align: center; }
  .mk-countdown-elegant__title { margin: 0 0 40px 0; font-size: 36px; font-weight: 700; color: #fff; }
  .mk-countdown-elegant__countdown { display: flex; justify-content: center; gap: 24px; }
  .mk-countdown-elegant__item { display: flex; flex-direction: column; align-items: center; gap: 8px; }
  .mk-countdown-elegant__num { min-width: 90px; padding: 24px 16px; background: #16213e; border-radius: 50%; aspect-ratio: 1; display: flex; align-items: center; justify-content: center; font-size: 36px; font-weight: 700; color: #e94560; }
  .mk-countdown-elegant__label { font-size: 11px; text-transform: uppercase; letter-spacing: 2px; color: #888; }
{% endstylesheet %}

{% javascript %}
  (function() {
    const c = document.querySelector('[data-countdown-elegant]');
    if (!c) return;
    const end = new Date(c.dataset.end).getTime();
    function u() {
      const now = Date.now(), diff = Math.max(0, end - now);
      const d = Math.floor(diff/86400000), h = Math.floor((diff%86400000)/3600000), m = Math.floor((diff%3600000)/60000), s = Math.floor((diff%60000)/1000);
      c.querySelector('[data-days]').textContent = String(d).padStart(2,'0');
      c.querySelector('[data-hours]').textContent = String(h).padStart(2,'0');
      c.querySelector('[data-minutes]').textContent = String(m).padStart(2,'0');
      c.querySelector('[data-seconds]').textContent = String(s).padStart(2,'0');
    }
    u(); setInterval(u, 1000);
  })();
{% endjavascript %}

{% schema %}
{
  "name": "MK Countdown Elegant",
  "tag": "section",
  "settings": [
    { "type": "text", "id": "title", "label": "标题" },
    { "type": "text", "id": "end_date", "label": "结束日期" },
    { "type": "color_scheme", "id": "color_scheme", "label": "颜色方案", "default": "scheme-1" }
  ],
  "presets": [{ "name": "MK Countdown Elegant" }]
}
{% endschema %}
