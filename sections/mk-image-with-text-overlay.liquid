{%- comment -%}
  MK Image With Text Overlay板块

  图片叠加文字

  作者：崽崽 (AI助手)
{%- endcomment -%}

{% liquid
  assign ss = section.settings
-%}

<section id="{{ section.id }}" class="mk-image-with-text-overlay color-{{ ss.color_scheme | default: 'background-1' }}">
  <div class="mk-image-with-text-overlay__wrapper">
    {%- if ss.image != blank -%}
      {{ ss.image | image_url: width: 1920 | image_tag: loading: 'lazy', class: 'mk-image-with-text-overlay__image' }}
    {%- endif -%}
    <div class="mk-image-with-text-overlay__overlay"></div>
    <div class="mk-image-with-text-overlay__content mk-image-with-text-overlay__content--{{ ss.position | default: 'center' }}">
      {%- if ss.badge != blank -%}
        <span class="mk-image-with-text-overlay__badge">{{ ss.badge }}</span>
      {%- endif -%}
      {%- if ss.title != blank -%}
        <h2 class="mk-image-with-text-overlay__title">{{ ss.title }}</h2>
      {%- endif -%}
      {%- if ss.text != blank -%}
        <p class="mk-image-with-text-overlay__text">{{ ss.text }}</p>
      {%- endif -%}
      {%- if ss.button_text != blank -%}
        <a href="{{ ss.button_link | default: '#' }}" class="mk-image-with-text-overlay__button">{{ ss.button_text }}</a>
      {%- endif -%}
    </div>
  </div>
</section>

{% stylesheet %}
  .mk-image-with-text-overlay__wrapper { position: relative; min-height: {{ ss.height_mobile | default: 400 }}px; display: flex; align-items: center; justify-content: center; overflow: hidden; }
  @media (min-width: 750px) { .mk-image-with-text-overlay__wrapper { min-height: {{ ss.height_desktop | default: 600 }}px; } }
  .mk-image-with-text-overlay__image { position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; }
  .mk-image-with-text-overlay__overlay { position: absolute; inset: 0; background: rgba(0,0,0,{{ ss.overlay_opacity | default: 0.4 }}); }
  .mk-image-with-text-overlay__content { position: relative; z-index: 1; padding: var(--mk-spacing-5xl) 32px; max-width: 600px; text-align: center; }
  .mk-image-with-text-overlay__content--center { margin: auto; }
  .mk-image-with-text-overlay__content--left { margin-right: auto; text-align: left; }
  .mk-image-with-text-overlay__content--right { margin-left: auto; text-align: right; }
  .mk-image-with-text-overlay__badge { display: inline-block; padding: var(--mk-spacing-xs) 16px; font-size: var(--mk-font-size-sm); font-weight: 600; text-transform: uppercase; letter-spacing: 1px; color: #fff; background: var(--color-primary, #000); border-radius: 100px; margin-bottom: 16px; }
  .mk-image-with-text-overlay__title { margin: 0 0 16px 0; font-size: var(--mk-font-size-3xl); font-weight: 700; color: #fff; }
  @media (min-width: 750px) { .mk-image-with-text-overlay__title { font-size: 42px; } }
  .mk-image-with-text-overlay__text { margin: 0 0 24px 0; font-size: var(--mk-font-size-lg); color: rgba(255,255,255,0.9); line-height: 1.6; }
  .mk-image-with-text-overlay__button { display: inline-flex; padding: 14px 32px; font-size: var(--mk-font-size-md); font-weight: 600; color: var(--color-on-primary, #fff); background: var(--color-primary, #000); border-radius: var(--mk-radius-sm); text-decoration: none; }
  .mk-image-with-text-overlay__button:hover { opacity: 0.85; }
{% endstylesheet %}

{% schema %}
{
  "name": "MK Image With Text Overlay",
  "tag": "section",
  "settings": [
    { "type": "image_picker", "id": "image", "label": "图片" },
    { "type": "text", "id": "badge", "label": "徽章" },
    { "type": "text", "id": "title", "label": "标题" },
    { "type": "textarea", "id": "text", "label": "描述" },
    { "type": "text", "id": "button_text", "label": "按钮文字" },
    { "type": "url", "id": "button_link", "label": "按钮链接" },
    { "type": "select", "id": "position", "label": "内容位置", "options": [{ "value": "left", "label": "左" }, { "value": "center", "label": "中" }, { "value": "right", "label": "右" }], "default": "center" },
    { "type": "range", "id": "overlay_opacity", "label": "遮罩透明度", "min": 0, "max": 1, "step": 0.1, "default": 0.4 },
    { "type": "range", "id": "height_mobile", "label": "高度 (移动端)", "min": 200, "max": 800, "default": 400, "unit": "px" },
    { "type": "range", "id": "height_desktop", "label": "高度 (PC端)", "min": 400, "max": 1000, "default": 600, "unit": "px" },
    { "type": "color_scheme",