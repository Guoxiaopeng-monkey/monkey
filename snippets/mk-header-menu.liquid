{%- doc -%}
  MK 头部菜单组件

  渲染顶部导航菜单

  @param {string} [class] - 额外CSS类名

  @example
  {% render 'mk-header-menu' %}
{%- enddoc -%}

{% liquid
  assign class = class | default: ''
-%}

<nav class="mk-header-menu {{ class }}" role="navigation" aria-label="{{ 'header.main_menu' | t | default: '主菜单' }}">
  {%- for link in linklists[section.settings.menu].links -%}
    <div class="mk-header-menu__item" {% if link.links.size > 0 %}data-has-submenu{% endif %}>
      <a href="{{ link.url }}" class="mk-header-menu__link">
        {{ link.title }}
      </a>
      {%- if link.links.size > 0 -%}
        <button type="button" class="mk-header-menu__toggle" aria-expanded="false">
          {{- 'icon-chevron-down.svg' | inline_asset_content -}}
        </button>
        <ul class="mk-header-menu__submenu" hidden>
          {%- for childlink in link.links -%}
            <li>
              <a href="{{ childlink.url }}" class="mk-header-menu__child-link">
                {{ childlink.title }}
              </a>
            </li>
          {%- endfor -%}
        </ul>
      {%- endif -%}
    </div>
  {%- endfor -%}
</nav>

{% stylesheet %}
  .mk-header-menu { display: flex; align-items: center; gap: var(--mk-spacing-sm); }
  .mk-header-menu__item { position: relative; }
  .mk-header-menu__link {
    display: flex; align-items: center; padding: var(--mk-spacing-md) 16px;
    font-size: var(--mk-font-size-md); font-weight: 500; color: var(--color-foreground); text-decoration: none;
  }
  .mk-header-menu__link:hover { opacity: 0.7; }
  .mk-header-menu__toggle {
    display: flex; width: 20px; height: 20px; padding: 0; background: transparent;
    border: none; cursor: pointer; color: var(--color-foreground);
  }
  .mk-header-menu__toggle svg { width: 100%; height: 100%; }
  .mk-header-menu__submenu {
    position: absolute; top: 100%; left: 0; min-width: 200px; padding: var(--mk-spacing-sm);
    background: var(--color-background); border: 1px solid var(--color-border);
    border-radius: var(--mk-radius-sm); box-shadow: 0 4px 20px rgba(0,0,0,0.1); z-index: 100;
    list-style: none;
  }
  .mk-header-menu__submenu[hidden] { display: none; }
  .mk-header-menu__child-link {
    display: block; padding: var(--mk-spacing-sm) 12px; font-size: var(--mk-font-size-md); color: var(--color-foreground); text-decoration: none;
  }
  .mk-header-menu__child-link:hover { background: var(--color-background-secondary, var(--mk-color-bg-secondary)); border-radius: var(--mk-radius-xs); }
{% endstylesheet %}

{% javascript %}
  document.querySelectorAll('[data-has-submenu]').forEach(item => {
    const toggle = item.querySelector('.mk-header-menu__toggle');
    const submenu = item.querySelector('.mk-header-menu__submenu');
    toggle?.addEventListener('click', () => {
      const isExpanded = toggle.getAttribute('aria-expanded') === 'true';
      toggle.setAttribute('aria-expanded', !isExpanded);
      submenu.hidden = isExpanded;
    });
  });
{% endjavascript %}
