{%- comment -%}
  MK 博客文章列表组件
  
  功能：展示博客文章列表网格
  
  作者：崽崽 (AI助手)
  基于：spx-blog-layout.liquid, whale ug-main-blog.liquid
{%- endcomment -%}

{%- liquid
  assign ss = section.settings
  assign bg_color = ss.background_color | default: '#ffffff'
  
  assign pt_mob = ss.padding_top_mobile | default: 48
  assign pb_mob = ss.padding_bottom_mobile | default: 48
  assign pt_desk = ss.padding_top_desktop | default: 80
  assign pb_desk = ss.padding_bottom_desktop | default: 80
  
  assign articles_to_show = ss.articles_to_show | default: 6
  assign columns_mobile = ss.columns_mobile | default: 1
  assign columns_tablet = ss.columns_tablet | default: 2
  assign columns_desktop = ss.columns_desktop | default: 3
  assign show_image = ss.show_image
  assign show_date = ss.show_date
  assign show_excerpt = ss.show_excerpt
  assign show_author = ss.show_author
-%}

<style>
  #{{ section.id }} {
    --blog-bg: {{ bg_color }};
    --blog-pt-mob: {{ pt_mob }}px;
    --blog-pb-mob: {{ pb_mob }}px;
    --blog-pt-desk: {{ pt_desk }}px;
    --blog-pb-desk: {{ pb_desk }}px;
    --blog-cols-mob: {{ columns_mobile }};
    --blog-cols-tablet: {{ columns_tablet }};
    --blog-cols-desk: {{ columns_desktop }};
    background-color: var(--blog-bg);
    padding: var(--blog-pt-mob) 0 var(--blog-pb-mob);
  }
  
  @media (min-width: 750px) {
    #{{ section.id }} {
      padding: var(--blog-pt-desk) 0 var(--blog-pb-desk);
    }
  }
</style>

<section
  id="{{ section.id }}"
  class="mk-blog-posts"
  data-skip-node-update
>
  <div class="mk-blog-posts__container">
    
    {%- comment -%} 标题区域 {%- endcomment -%}
    <div class="mk-blog-posts__header">
      {% if ss.heading != blank %}
        <h2 class="mk-blog-posts__heading">{{ ss.heading }}</h2>
      {% endif %}
      {% if ss.description != blank %}
        <p class="mk-blog-posts__description">{{ ss.description }}</p>
      {% endif %}
    </div>
    
    {%- comment -%} 文章网格 {%- endcomment -%}
    <div class="mk-blog-posts__grid">
      {%- if ss.blog != blank -%}
        {%- for article in ss.blog.articles limit: articles_to_show -%}
          <article class="mk-blog-posts__article" {{ block.shopify_attributes }}>
            {%- comment -%} 图片 {%- endcomment -%}
            {% if show_image and article.image != blank %}
              <a href="{{ article.url }}" class="mk-blog-posts__media-link">
                <div class="mk-blog-posts__media">
                  <img
                    src="{{ article.image | image_url: width: 600 }}"
                    alt="{{ article.image.alt | default: article.title }}"
                    width="600"
                    height="{{ 600 | divided_by: article.image.aspect_ratio | round }}"
                    loading="lazy"
                    class="mk-blog-posts__image"
                  >
                </div>
              </a>
            {% endif %}
            
            {%- comment -%} 内容 {%- endcomment -%}
            <div class="mk-blog-posts__content">
              {%- comment -%} Meta {%- endcomment -%}
              <div class="mk-blog-posts__meta">
                {% if show_date %}
                  <time class="mk-blog-posts__date" datetime="{{ article.published_at | date: '%Y-%m-%d' }}">
                    {{ article.published_at | date: "%Y年%m月%d日" }}
                  </time>
                {% endif %}
                {% if show_author and article.author != blank %}
                  <span class="mk-blog-posts__author">{{ article.author }}</span>
                {% endif %}
              </div>
              
              {%- comment -%} 标题 {%- endcomment -%}
              <h3 class="mk-blog-posts__title">
                <a href="{{ article.url }}" class="mk-blog-posts__title-link">
                  {{ article.title }}
                </a>
              </h3>
              
              {%- comment -%} 摘要 {%- endcomment -%}
              {% if show_excerpt %}
                {% if article.excerpt != blank %}
                  <p class="mk-blog-posts__excerpt">{{ article.excerpt | truncate: 120 }}</p>
                {% else %}
                  <p class="mk-blog-posts__excerpt">{{ article.content | strip_html | truncate: 120 }}</p>
                {% endif %}
              {% endif %}
              
              {%- comment -%} 阅读更多 {%- endcomment -%}
              <a href="{{ article.url }}" class="mk-blog-posts__read-more">
                {{ ss.read_more_text | default: '阅读更多' }}
                {{- 'icon-arrow-right.svg' | inline_asset_content -}}
              </a>
            </div>
          </article>
        {%- endfor -%}
      {%- else -%}
        {%- for i in (1..articles_to_show) -%}
          <article class="mk-blog-posts__article">
            {% if show_image %}
              <div class="mk-blog-posts__media-link">
                <div class="mk-blog-posts__media mk-blog-posts__media--placeholder">
                  {{ 'image' | placeholder_svg_tag: '' }}
                </div>
              </div>
            {% endif %}
            <div class="mk-blog-posts__content">
              <div class="mk-blog-posts__meta">
                {% if show_date %}
                  <time class="mk-blog-posts__date">2024年01月01日</time>
                {% endif %}
              </div>
              <h3 class="mk-blog-posts__title">
                <span class="mk-blog-posts__title-link">示例文章标题</span>
              </h3>
              {% if show_excerpt %}
                <p class="mk-blog-posts__excerpt">这是示例文章摘要内容，展示了文章的简短描述。</p>
              {% endif %}
            </div>
          </article>
        {%- endfor -%}
      {%- endif -%}
    </div>
    
    {%- comment -%} View All {%- endcomment -%}
    {% if ss.show_view_all and ss.blog != blank %}
      <div class="mk-blog-posts__footer">
        <a href="{{ ss.blog.url }}" class="mk-blog-posts__view-all">
          {{ ss.view_all_text | default: '查看全部文章' }}
          {{- 'icon-arrow-right.svg' | inline_asset_content -}}
        </a>
      </div>
    {% endif %}
  </div>
</section>

{% stylesheet %}
  .mk-blog-posts__container {
    max-width: var(--container-max-width, 1440px);
    margin: 0 auto;
    padding: 0 var(--container-padding, 32px);
  }

  /* Header */
  .mk-blog-posts__header {
    text-align: center;
    max-width: 700px;
    margin: 0 auto 48px auto;
  }

  .mk-blog-posts__heading {
    margin: 0 0 16px 0;
    font-size: clamp(28px, 4vw, 42px);
    font-weight: 700;
    line-height: 1.2;
  }

  .mk-blog-posts__description {
    margin: 0;
    font-size: 16px;
    line-height: 1.6;
    opacity: 0.85;
  }

  /* Grid */
  .mk-blog-posts__grid {
    display: grid;
    grid-template-columns: repeat(var(--blog-cols-mob, 1), 1fr);
    gap: 32px;
  }

  @media (min-width: 480px) {
    .mk-blog-posts__grid {
      gap: 24px;
    }
  }

  @media (min-width: 750px) {
    .mk-blog-posts__grid {
      grid-template-columns: repeat(var(--blog-cols-tablet, 2), 1fr);
    }
  }

  @media (min-width: 990px) {
    .mk-blog-posts__grid {
      grid-template-columns: repeat(var(--blog-cols-desk, 3), 1fr);
      gap: 32px;
    }
  }

  /* Article */
  .mk-blog-posts__article {
    display: flex;
    flex-direction: column;
    height: 100%;
  }

  /* Media */
  .mk-blog-posts__media-link {
    display: block;
    text-decoration: none;
    overflow: hidden;
    border-radius: 12px;
    margin-bottom: 20px;
  }

  .mk-blog-posts__media {
    aspect-ratio: 16 / 10;
    overflow: hidden;
  }

  .mk-blog-posts__media--placeholder {
    background: var(--color-background-secondary, #f5f5f5);
  }

  .mk-blog-posts__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.4s ease;
  }

  .mk-blog-posts__article:hover .mk-blog-posts__image {
    transform: scale(1.05);
  }

  .mk-blog-posts__media--placeholder svg {
    width: 100%;
    height: 100%;
  }

  /* Content */
  .mk-blog-posts__content {
    flex: 1;
    display: flex;
    flex-direction: column;
  }

  /* Meta */
  .mk-blog-posts__meta {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 12px;
    margin-bottom: 12px;
    font-size: 13px;
    color: var(--color-text-secondary, #666);
  }

  .mk-blog-posts__date {
    font-weight: 500;
  }

  .mk-blog-posts__author::before {
    content: '•';
    margin-right: 12px;
  }

  /* Title */
  .mk-blog-posts__title {
    margin: 0 0 12px 0;
    font-size: 18px;
    font-weight: 600;
    line-height: 1.4;
  }

  .mk-blog-posts__title-link {
    text-decoration: none;
    color: inherit;
    transition: opacity 0.2s ease;
  }

  .mk-blog-posts__title-link:hover {
    opacity: 0.7;
  }

  /* Excerpt */
  .mk-blog-posts__excerpt {
    margin: 0 0 16px 0;
    font-size: 14px;
    line-height: 1.6;
    opacity: 0.85;
    flex: 1;
  }

  /* Read More */
  .mk-blog-posts__read-more {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-size: 14px;
    font-weight: 600;
    text-decoration: none;
    color: var(--color-primary, #000);
    margin-top: auto;
  }

  .mk-blog-posts__read-more svg {
    width: 14px;
    height: 14px;
    transition: transform 0.2s ease;
  }

  .mk-blog-posts__read-more:hover svg {
    transform: translateX(4px);
  }

  /* Footer */
  .mk-blog-posts__footer {
    display: flex;
    justify-content: center;
    margin-top: 48px;
  }

  .mk-blog-posts__view-all {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 14px 28px;
    font-size: 14px;
    font-weight: 600;
    text-decoration: none;
    color: var(--color-primary, #000);
    border: 1.5px solid var(--color-primary, #000);
    border-radius: 4px;
    transition: all 0.2s ease;
  }

  .mk-blog-posts__view-all:hover {
    background: var(--color-primary, #000);
    color: var(--color-background, #fff);
  }

  .mk-blog-posts__view-all svg {
    width: 16px;
    height: 16px;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "MK 博客文章",
  "tag": "section",
  "settings": [
    {
      "type": "header",
      "content": "内容设置"
    },
    {
      "type": "blog",
      "id": "blog",
      "label": "博客"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "标题",
      "default": "最新文章"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "描述文字"
    },
    {
      "type": "header",
      "content": "布局设置"
    },
    {
      "type": "range",
      "id": "articles_to_show",
      "label": "显示文章数量",
      "min": 3,
      "max": 12,
      "default": 6
    },
    {
      "type": "range",
      "id": "columns_mobile",
      "label": "列数 (移动端)",
      "min": 1,
      "max": 2,
      "default": 1
    },
    {
      "type": "range",
      "id": "columns_tablet",
      "label": "列数 (平板)",
      "min": 2,
      "max": 3,
      "default": 2
    },
    {
      "type": "range",
      "id": "columns_desktop",
      "label": "列数 (PC端)",
      "min": 2,
      "max": 4,
      "default": 3
    },
    {
      "type": "header",
      "content": "文章信息"
    },
    {
      "type": "checkbox",
      "id": "show_image",
      "label": "显示图片",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_date",
      "label": "显示日期",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_author",
      "label": "显示作者",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_excerpt",
      "label": "显示摘要",
      "default": true
    },
    {
      "type": "text",
      "id": "read_more_text",
      "label": "阅读更多文字",
      "default": "阅读更多"
    },
    {
      "type": "header",
      "content": "查看全部链接"
    },
    {
      "type": "checkbox",
      "id": "show_view_all",
      "label": "显示查看全部按钮",
      "default": true
    },
    {
      "type": "text",
      "id": "view_all_text",
      "label": "按钮文字",
      "default": "查看全部文章"
    },
    {
      "type": "header",
      "content": "颜色设置"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "背景颜色",
      "default": "#ffffff"
    },
    {
      "type": "header",
      "content": "间距设置"
    },
    {
      "type": "range",
      "id": "padding_top_mobile",
      "label": "上边距 (移动端)",
      "min": 0,
      "max": 120,
      "default": 48,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "label": "下边距 (移动端)",
      "min": 0,
      "max": 120,
      "default": 48,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_top_desktop",
      "label": "上边距 (PC端)",
      "min": 0,
      "max": 200,
      "default": 80,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_bottom_desktop",
      "label": "下边距 (PC端)",
      "min": 0,
      "max": 200,
      "default": 80,
      "unit": "px"
    }
  ],
  "presets": [
    {
      "name": "MK 博客文章"
    }
  ]
}
{% endschema %}
