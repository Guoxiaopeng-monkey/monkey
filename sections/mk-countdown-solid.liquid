{%- comment -%}
  MK Countdown Solid板块

  实色倒计时

  作者：崽崽 (AI助手)
{%- endcomment -%}

{% liquid
  assign ss = section.settings
-%}

<section id="{{ section.id }}" class="mk-countdown-solid" style="background: {{ ss.bg_color | default: '#000' }};">
  <div class="mk-countdown-solid__container">
    {%- if ss.title != blank -%}
      <h2 class="mk-countdown-solid__title" style="color: {{ ss.text_color | default: '#fff' }};">{{ ss.title }}</h2>
    {%- endif -%}
    <div class="mk-countdown-solid__countdown" data-countdown-solid data-end="{{ ss.end_date | default: '' | date: '%Y-%m-%dT%H:%M:%S' }}">
      <div class="mk-countdown-solid__item"><span class="mk-countdown-solid__num" data-days>00</span><span class="mk-countdown-solid__label">Days</span></div>
      <div class="mk-countdown-solid__item"><span class="mk-countdown-solid__num" data-hours>00</span><span class="mk-countdown-solid__label">Hours</span></div>
      <div class="mk-countdown-solid__item"><span class="mk-countdown-solid__num" data-minutes>00</span><span class="mk-countdown-solid__label">Minutes</span></div>
      <div class="mk-countdown-solid__item"><span class="mk-countdown-solid__num" data-seconds>00</span><span class="mk-countdown-solid__label">Seconds</span></div>
    </div>
  </div>
</section>

{% stylesheet %}
  .mk-countdown-solid { padding: 80px 0; text-align: center; }
  .mk-countdown-solid__container { max-width: 900px; margin: 0 auto; padding: 0 32px; }
  .mk-countdown-solid__title { margin: 0 0 40px 0; font-size: var(--mk-font-size-5xl); font-weight: 700; }
  .mk-countdown-solid__countdown { display: flex; justify-content: center; gap: 20px; }
  .mk-countdown-solid__item { display: flex; flex-direction: column; align-items: center; gap: var(--mk-spacing-sm); }
  .mk-countdown-solid__num { min-width: 90px; padding: var(--mk-spacing-xl); border-radius: var(--mk-radius-md); font-size: 42px; font-weight: 700; color: #000; background: #fff; }
  .mk-countdown-solid__label { font-size: var(--mk-font-size-xs); text-transform: uppercase; letter-spacing: 1px; color: rgba(255,255,255,0.7); }
{% endstylesheet %}

{% javascript %}
  (function() {
    const c = document.querySelector('[data-countdown-solid]');
    if (!c) return;
    const end = new Date(c.dataset.end).getTime();
    function u() {
      const now = Date.now(), diff = Math.max(0, end - now);
      const d = Math.floor(diff/86400000), h = Math.floor((diff%86400000)/3600000), m = Math.floor((diff%3600000)/60000), s = Math.floor((diff%60000)/1000);
      c.querySelector('[data-days]').textContent = String(d).padStart(2,'0');
      c.querySelector('[data-hours]').textContent = String(h).padStart(2,'0');
      c.querySelector('[data-minutes]').textContent = String(m).padStart(2,'0');
      c.querySelector('[data-seconds]').textContent = String(s).padStart(2,'0');
    }
    u(); setInterval(u, 1000);
  })();
{% endjavascript %}

{% schema %}
{
  "name": "MK Countdown Solid",
  "tag": "section",
  "settings": [
    { "type": "text", "id": "title", "label": "标题" },
    { "type": "text", "id": "end_date", "label": "结束日期" },
    { "type": "color", "id": "bg_color", "label": "背景颜色" },
    { "type": "color", "id": "text_color", "label": "文字颜色" }
  ],
  "presets": [{ "name": "MK Countdown Solid" }]
}
{% endschema %}
