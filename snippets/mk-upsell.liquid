{%- doc -%}
  MK 加购推荐组件

  渲染加购推荐产品

  @param {object} product - 当前产品
  @param {string} [class] - 额外CSS类名

  @example
  {% render 'mk-upsell', product: product %}
{%- enddoc -%}

{% liquid
  assign product = product | default: nil
  assign class = class | default: ''
  assign upsell_products = product.metafields.custom.upsell_products | default: empty_array
-%}

{%- if upsell_products.size > 0 -%}
  <div class="mk-upsell {{ class }}">
    <h3 class="mk-upsell__title">{{ 'products.frequently_bought' | t | default: '常一起购买' }}</h3>

    <div class="mk-upsell__grid">
      {%- for upsell in upsell_products limit: 3 -%}
        <div class="mk-upsell__item">
          {{ upsell.featured_image | image_url: width: 200 | image_tag: class: 'mk-upsell__image', loading: 'lazy' }}
          <div class="mk-upsell__info">
            <h4 class="mk-upsell__name">{{ upsell.title }}</h4>
            <p class="mk-upsell__price">{{ upsell.price | money }}</p>
          </div>
        </div>
      {%- endfor -%}
    </div>
  </div>
{%- endif -%}

{% stylesheet %}
  .mk-upsell {
    padding: var(--mk-spacing-xl);
    background-color: var(--color-background-secondary, var(--mk-color-bg-secondary));
    border-radius: var(--mk-radius-md);
  }

  .mk-upsell__title {
    margin: 0 0 16px 0;
    font-size: var(--mk-font-size-lg);
    font-weight: 600;
    color: var(--color-foreground);
  }

  .mk-upsell__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--mk-spacing-md);
  }

  .mk-upsell__item {
    display: flex;
    flex-direction: column;
    gap: var(--mk-spacing-sm);
  }

  .mk-upsell__image {
    width: 100%;
    aspect-ratio: 1;
    object-fit: cover;
    border-radius: var(--mk-radius-sm);
  }

  .mk-upsell__name {
    margin: 0;
    font-size: var(--mk-font-size-sm);
    font-weight: 500;
    color: var(--color-foreground);
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .mk-upsell__price {
    margin: 0;
    font-size: var(--mk-font-size-sm);
    font-weight: 600;
    color: var(--color-primary, #000);
  }
{% endstylesheet %}
