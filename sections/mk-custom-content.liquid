{%- comment -%}
  MK 自定义内容组件
  
  功能：灵活的多列自定义内容布局
  
  作者：崽崽 (AI助手)
  基于：whale ug-custom-content.liquid, ug-index-section-*.liquid
{%- endcomment -%}

{%- liquid
  assign ss = section.settings
  assign bg_color = ss.background_color | default: '#ffffff'
  
  assign columns_mobile = ss.columns_mobile | default: 1
  assign columns_tablet = ss.columns_tablet | default: 2
  assign columns_desktop = ss.columns_desktop | default: 3
  assign gap = ss.gap | default: 24
  
  assign pt_mob = ss.padding_top_mobile | default: 48
  assign pb_mob = ss.padding_bottom_mobile | default: 48
  assign pt_desk = ss.padding_top_desktop | default: 80
  assign pb_desk = ss.padding_bottom_desktop | default: 80
-%}

<style>
  #{{ section.id }} {
    --cc-bg: {{ bg_color }};
    --cc-gap: {{ gap }}px;
    --cc-cols-mob: {{ columns_mobile }};
    --cc-cols-tablet: {{ columns_tablet }};
    --cc-cols-desk: {{ columns_desktop }};
    --cc-pt-mob: {{ pt_mob }}px;
    --cc-pb-mob: {{ pb_mob }}px;
    --cc-pt-desk: {{ pt_desk }}px;
    --cc-pb-desk: {{ pb_desk }}px;
    background-color: var(--cc-bg);
    padding: var(--cc-pt-mob) 0 var(--cc-pb-mob);
  }
  
  @media (min-width: 750px) {
    #{{ section.id }} {
      padding: var(--cc-pt-desk) 0 var(--cc-pb-desk);
    }
  }
</style>

<section
  id="{{ section.id }}"
  class="mk-custom-content"
  data-skip-node-update
>
  <div class="mk-custom-content__container">
    
    {%- comment -%} 头部 {%- endcomment -%}
    {% if ss.heading != blank or ss.description != blank %}
      <div class="mk-custom-content__header">
        {% if ss.label != blank %}
          <p class="mk-custom-content__label">{{ ss.label }}</p>
        {% endif %}
        {% if ss.heading != blank %}
          <h2 class="mk-custom-content__heading">{{ ss.heading }}</h2>
        {% endif %}
        {% if ss.description != blank %}
          <p class="mk-custom-content__description">{{ ss.description }}</p>
        {% endif %}
      </div>
    {% endif %}
    
    {%- comment -%} 内容块 {%- endcomment -%}
    <div class="mk-custom-content__grid">
      {%- for block in section.blocks -%}
        {%- case block.type -%}
          {%- when 'text' -%}
            <div class="mk-custom-content__item" {{ block.shopify_attributes }}>
              {% if block.settings.icon != blank %}
                <div class="mk-custom-content__icon">
                  {{ block.settings.icon | image_url: width: 64 | image_tag: width: 64 }}
                </div>
              {% endif %}
              {% if block.settings.title != blank %}
                <h3 class="mk-custom-content__item-title">{{ block.settings.title }}</h3>
              {% endif %}
              {% if block.settings.text != blank %}
                <div class="mk-custom-content__item-text">{{ block.settings.text }}</div>
              {% endif %}
              {% if block.settings.button_text != blank %}
                <a href="{{ block.settings.button_link | default: '#' }}" class="mk-custom-content__item-link">
                  {{ block.settings.button_text }}
                  {{- 'icon-arrow-right.svg' | inline_asset_content -}}
                </a>
              {% endif %}
            </div>
            
          {%- when 'image' -%}
            <div class="mk-custom-content__item mk-custom-content__item--image" {{ block.shopify_attributes }}>
              {% if block.settings.image != blank %}
                <img
                  src="{{ block.settings.image | image_url: width: 800 }}"
                  alt="{{ block.settings.image.alt | default: block.settings.title }}"
                  width="800"
                  height="{{ 800 | divided_by: block.settings.image.aspect_ratio | round }}"
                  loading="lazy"
                  class="mk-custom-content__image"
                >
              {% else %}
                <div class="mk-custom-content__placeholder">
                  {{ 'image' | placeholder_svg_tag: '' }}
                </div>
              {% endif %}
            </div>
            
          {%- when 'video' -%}
            <div class="mk-custom-content__item mk-custom-content__item--video" {{ block.shopify_attributes }}>
              {% if block.settings.video_url != blank %}
                <video
                  src="{{ block.settings.video_url }}"
                  autoplay="{{ block.settings.autoplay }}"
                  loop="{{ block.settings.loop }}"
                  muted="{{ block.settings.muted }}"
                  playsinline
                  class="mk-custom-content__video"
                ></video>
              {% endif %}
            </div>
            
          {%- when 'divider' -%}
            <div class="mk-custom-content__divider" {{ block.shopify_attributes }}>
              {% if block.settings.show_line %}
                <hr class="mk-custom-content__line">
              {% endif %}
              {% if block.settings.text != blank %}
                <span class="mk-custom-content__divider-text">{{ block.settings.text }}</span>
              {% endif %}
            </div>
        {%- endcase -%}
      {%- endfor -%}
    </div>
    
    {%- comment -%} 底部内容 {%- endcomment -%}
    {% if ss.footer_text != blank %}
      <div class="mk-custom-content__footer">
        {{ ss.footer_text }}
      </div>
    {% endif %}
  </div>
</section>

{% stylesheet %}
  .mk-custom-content__container {
    max-width: var(--container-max-width, 1440px);
    margin: 0 auto;
    padding: 0 var(--container-padding, 32px);
  }

  /* Header */
  .mk-custom-content__header {
    text-align: center;
    margin-bottom: 48px;
  }

  .mk-custom-content__label {
    margin: 0 0 12px 0;
    font-size: 13px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 1.5px;
    color: var(--color-primary, #000);
  }

  .mk-custom-content__heading {
    margin: 0 0 16px 0;
    font-size: clamp(28px, 4vw, 40px);
    font-weight: 700;
    line-height: 1.2;
  }

  .mk-custom-content__description {
    margin: 0;
    font-size: 16px;
    line-height: 1.6;
    opacity: 0.8;
    max-width: 700px;
    margin-left: auto;
    margin-right: auto;
  }

  /* Grid */
  .mk-custom-content__grid {
    display: grid;
    grid-template-columns: repeat(var(--cc-cols-mob, 1), 1fr);
    gap: var(--cc-gap, 24px);
  }

  @media (min-width: 480px) {
    .mk-custom-content__grid {
      grid-template-columns: repeat(var(--cc-cols-tablet, 2), 1fr);
    }
  }

  @media (min-width: 990px) {
    .mk-custom-content__grid {
      grid-template-columns: repeat(var(--cc-cols-desk, 3), 1fr);
    }
  }

  /* Item - Text */
  .mk-custom-content__item {
    padding: 24px;
    background: var(--color-background-secondary, #f9f9f9);
    border-radius: 12px;
    text-align: center;
  }

  .mk-custom-content__item--image,
  .mk-custom-content__item--video {
    padding: 0;
    background: transparent;
  }

  .mk-custom-content__icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 64px;
    height: 64px;
    margin: 0 auto 20px auto;
  }

  .mk-custom-content__icon img {
    width: 100%;
    height: auto;
  }

  .mk-custom-content__item-title {
    margin: 0 0 12px 0;
    font-size: 20px;
    font-weight: 600;
    line-height: 1.3;
  }

  .mk-custom-content__item-text {
    font-size: 15px;
    line-height: 1.7;
    opacity: 0.85;
  }

  .mk-custom-content__item-text p {
    margin: 0 0 12px 0;
  }

  .mk-custom-content__item-text p:last-child {
    margin-bottom: 0;
  }

  .mk-custom-content__item-link {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    margin-top: 16px;
    font-size: 14px;
    font-weight: 600;
    text-decoration: none;
    color: var(--color-primary, #000);
  }

  .mk-custom-content__item-link svg {
    width: 14px;
    height: 14px;
    transition: transform 0.2s ease;
  }

  .mk-custom-content__item-link:hover svg {
    transform: translateX(4px);
  }

  /* Image */
  .mk-custom-content__image {
    width: 100%;
    height: auto;
    border-radius: 8px;
  }

  .mk-custom-content__placeholder {
    width: 100%;
    aspect-ratio: 4 / 3;
    background: var(--color-background-secondary, #f5f5f5);
    border-radius: 8px;
  }

  /* Video */
  .mk-custom-content__video {
    width: 100%;
    height: auto;
    border-radius: 8px;
  }

  /* Divider */
  .mk-custom-content__divider {
    grid-column: 1 / -1;
    display: flex;
    align-items: center;
    gap: 16px;
    padding: 16px 0;
  }

  .mk-custom-content__line {
    flex: 1;
    border: none;
    border-top: 1px solid var(--color-border, #ddd);
    margin: 0;
  }

  .mk-custom-content__divider-text {
    font-size: 12px;
    text-transform: uppercase;
    letter-spacing: 1px;
    color: var(--color-text-secondary, #666);
    white-space: nowrap;
  }

  /* Footer */
  .mk-custom-content__footer {
    margin-top: 48px;
    text-align: center;
    font-size: 14px;
    opacity: 0.8;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "MK 自定义内容",
  "tag": "section",
  "settings": [
    {
      "type": "header",
      "content": "内容设置"
    },
    {
      "type": "text",
      "id": "label",
      "label": "标签文字"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "标题"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "描述文字"
    },
    {
      "type": "richtext",
      "id": "footer_text",
      "label": "底部内容"
    },
    {
      "type": "header",
      "content": "布局设置"
    },
    {
      "type": "range",
      "id": "columns_mobile",
      "label": "列数 (移动端)",
      "min": 1,
      "max": 3,
      "default": 1
    },
    {
      "type": "range",
      "id": "columns_tablet",
      "label": "列数 (平板)",
      "min": 2,
      "max": 4,
      "default": 2
    },
    {
      "type": "range",
      "id": "columns_desktop",
      "label": "列数 (PC端)",
      "min": 2,
      "max": 6,
      "default": 3
    },
    {
      "type": "range",
      "id": "gap",
      "label": "网格间距",
      "min": 0,
      "max": 60,
      "default": 24,
      "unit": "px"
    },
    {
      "type": "header",
      "content": "颜色设置"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "背景颜色",
      "default": "#ffffff"
    },
    {
      "type": "header",
      "content": "间距设置"
    },
    {
      "type": "range",
      "id": "padding_top_mobile",
      "label": "上边距 (移动端)",
      "min": 0,
      "max": 120,
      "default": 48,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "label": "下边距 (移动端)",
      "min": 0,
      "max": 120,
      "default": 48,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_top_desktop",
      "label": "上边距 (PC端)",
      "min": 0,
      "max": 200,
      "default": 80,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_bottom_desktop",
      "label": "下边距 (PC端)",
      "min": 0,
      "max": 200,
      "default": 80,
      "unit": "px"
    }
  ],
  "blocks": [
    {
      "type": "text",
      "name": "文本块",
      "settings": [
        {
          "type": "image_picker",
          "id": "icon",
          "label": "图标"
        },
        {
          "type": "text",
          "id": "title",
          "label": "标题",
          "default": "特性标题"
        },
        {
          "type": "richtext",
          "id": "text",
          "label": "内容",
          "default": "<p>详细描述文字...</p>"
        },
        {
          "type": "text",
          "id": "button_text",
          "label": "按钮文字"
        },
        {
          "type": "url",
          "id": "button_link",
          "label": "按钮链接"
        }
      ]
    },
    {
      "type": "image",
      "name": "图片块",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "图片"
        }
      ]
    },
    {
      "type": "video",
      "name": "视频块",
      "settings": [
        {
          "type": "url",
          "id": "video_url",
          "label": "视频URL"
        },
        {
          "type": "checkbox",
          "id": "autoplay",
          "label": "自动播放",
          "default": false
        },
        {
          "type": "checkbox",
          "id": "loop",
          "label": "循环播放",
          "default": true
        },
        {
          "type": "checkbox",
          "id": "muted",
          "label": "静音",
          "default": true
        }
      ]
    },
    {
      "type": "divider",
      "name": "分隔符",
      "settings": [
        {
          "type": "checkbox",
          "id": "show_line",
          "label": "显示分隔线",
          "default": true
        },
        {
          "type": "text",
          "id": "text",
          "label": "分隔符文字"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "MK 自定义内容"
    }
  ]
}
{% endschema %}
