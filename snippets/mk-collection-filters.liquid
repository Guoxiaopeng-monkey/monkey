{%- doc -%}
  MK 收藏夹过滤器组件

  渲染收藏夹/筛选区块

  @param {string} [class] - 额外CSS类名

  @example
  {% render 'mk-collection-filters' %}
{%- enddoc -%}

{% liquid
  assign class = class | default: ''
-%}

<div class="mk-collection-filters {{ class }}">
  <div class="mk-collection-filters__active" data-active-filters>
    {%- comment -%} 动态渲染活跃筛选器 {%- endcomment -%}
  </div>

  <div class="mk-collection-filters__bar">
    <button type="button" class="mk-collection-filters__toggle" data-filters-toggle>
      <span>{{ 'products.filters' | t | default: '筛选' }}</span>
      {% render 'mk-inline-spinner', text: '' %}
    </button>

    <div class="mk-collection-filters__sort">
      {%- render 'mk-sorting' -%}
    </div>
  </div>

  <div class="mk-collection-filters__drawer" data-filters-drawer hidden>
    <div class="mk-collection-filters__overlay" data-filters-close></div>
    <div class="mk-collection-filters__panel">
      <div class="mk-collection-filters__panel-header">
        <h3>{{ 'products.filters' | t | default: '筛选' }}</h3>
        <button type="button" data-filters-close>{{ 关闭 }}</button>
      </div>

      <div class="mk-collection-filters__panel-content">
        {%- render 'mk-facets-actions' -%}
      </div>

      <div class="mk-collection-filters__panel-footer">
        <button type="button" class="mk-collection-filters__clear" data-clear-filters>
          {{ 'products.clear_all' | t | default: '清除全部' }}
        </button>
        <button type="button" class="mk-collection-filters__apply" data-apply-filters>
          {{ 'products.apply' | t | default: '应用' }}
        </button>
      </div>
    </div>
  </div>
</div>

{% stylesheet %}
  .mk-collection-filters {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .mk-collection-filters__active {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }

  .mk-collection-filters__bar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
  }

  .mk-collection-filters__toggle {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 10px 16px;
    font-size: 14px;
    font-weight: 500;
    color: var(--color-foreground);
    background-color: var(--color-background);
    border: 1px solid var(--color-border);
    border-radius: 8px;
    cursor: pointer;
    transition: all 0.2s ease;
  }

  .mk-collection-filters__toggle:hover {
    border-color: var(--color-foreground);
  }

  .mk-collection-filters__sort {
    flex: 1;
    max-width: 250px;
  }

  .mk-collection-filters__drawer[hidden] {
    display: none;
  }

  .mk-collection-filters__overlay {
    position: fixed;
    inset: 0;
    background-color: rgba(0, 0, 0, 0.5);
    z-index: 998;
  }

  .mk-collection-filters__panel {
    position: fixed;
    top: 0;
    right: 0;
    width: 320px;
    max-width: 90%;
    height: 100vh;
    background-color: var(--color-background);
    z-index: 999;
    display: flex;
    flex-direction: column;
    box-shadow: 0 0 30px rgba(0, 0, 0, 0.15);
  }

  .mk-collection-filters__panel-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 20px;
    border-bottom: 1px solid var(--color-border);
  }

  .mk-collection-filters__panel-header h3 {
    margin: 0;
    font-size: 18px;
    font-weight: 600;
  }

  .mk-collection-filters__panel-content {
    flex: 1;
    overflow-y: auto;
    padding: 20px;
  }

  .mk-collection-filters__panel-footer {
    display: flex;
    gap: 12px;
    padding: 20px;
    border-top: 1px solid var(--color-border);
  }

  .mk-collection-filters__clear,
  .mk-collection-filters__apply {
    flex: 1;
    padding: 14px;
    font-size: 14px;
    font-weight: 600;
    border-radius: 8px;
    cursor: pointer;
    transition: all 0.2s ease;
  }

  .mk-collection-filters__clear {
    color: var(--color-foreground);
    background-color: transparent;
    border: 1px solid var(--color-border);
  }

  .mk-collection-filters__clear:hover {
    background-color: var(--color-background-secondary, #f5f5f5);
  }

  .mk-collection-filters__apply {
    color: var(--color-on-primary, #fff);
    background-color: var(--color-primary, #000);
    border: none;
  }

  .mk-collection-filters__apply:hover {
    opacity: 0.85;
  }
{% endstylesheet %}
