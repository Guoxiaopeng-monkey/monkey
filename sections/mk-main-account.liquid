{%- comment -%}
  MK 账户页面组件
  
  功能：客户账户页面
  
  作者：崽崽 (AI助手)
{%- endcomment -%}

{%- liquid
  assign ss = section.settings
  assign customer = customer
  assign pt_mob = ss.padding_top_mobile | default: 32
  assign pb_mob = ss.padding_bottom_mobile | default: 32
  assign pt_desk = ss.padding_top_desktop | default: 48
  assign pb_desk = ss.padding_bottom_desktop | default: 48
-%}

<style>
  #{{ section.id }} {
    --account-pt-mob: {{ pt_mob }}px;
    --account-pb-mob: {{ pb_mob }}px;
    --account-pt-desk: {{ pt_desk }}px;
    --account-pb-desk: {{ pb_desk }}px;
    padding: var(--account-pt-mob) 0 var(--account-pb-mob);
  }
  
  @media (min-width: 750px) {
    #{{ section.id }} {
      padding: var(--account-pt-desk) 0 var(--account-pb-desk);
    }
  }
</style>

<section
  id="{{ section.id }}"
  class="mk-main-account"
  data-skip-node-update
>
  <div class="mk-main-account__container">
    
    {%- comment -%} 账户头部 {%- endcomment -%}
    <header class="mk-main-account__header">
      <h1 class="mk-main-account__title">
        {{ 'customers.account.title' | t | default: '我的账户' }}
      </h1>
      <p class="mk-main-account__welcome">
        欢迎回来, {{ customer.name | default: customer.email }}！
      </p>
    </header>
    
    {%- comment -%} 账户布局 {%- endcomment -%}
    <div class="mk-main-account__layout">
      
      {%- comment -%} 侧边栏 {%- endcomment -%}
      <aside class="mk-main-account__sidebar">
        <nav class="mk-main-account__nav">
          <a href="#orders" class="mk-main-account__nav-link mk-main-account__nav-link--active" data-tab="orders">
            {{- 'icon-package.svg' | inline_asset_content -}}
            <span>{{ 'customers.account.orders' | t | default: '订单' }}</span>
          </a>
          <a href="#addresses" class="mk-main-account__nav-link" data-tab="addresses">
            {{- 'icon-map-pin.svg' | inline_asset_content -}}
            <span>{{ 'customers.account.addresses' | t | default: '收货地址' }}</span>
          </a>
          <a href="{{ routes.account_logout_url }}" class="mk-main-account__nav-link mk-main-account__nav-link--logout">
            {{- 'icon-log-out.svg' | inline_asset_content -}}
            <span>{{ 'customers.account.logout' | t | default: '退出登录' }}</span>
          </a>
        </nav>
      </aside>
      
      {%- comment -%} 主内容区 {%- endcomment -%}
      <div class="mk-main-account__main">
        
        {%- comment -%} 订单标签页 {%- endcomment -%}
        <div id="orders" class="mk-main-account__tab mk-main-account__tab--active">
          <h2 class="mk-main-account__section-title">
            {{ 'customers.orders.title' | t | default: '订单历史' }}
          </h2>
          
          {%- assign orders = customer.orders | sort: 'created_at' | reverse -%}
          {%- if orders.size > 0 -%}
            <div class="mk-main-account__orders">
              {%- for order in orders -%}
                <div class="mk-main-account__order">
                  <div class="mk-main-account__order-header">
                    <div class="mk-main-account__order-info">
                      <a href="{{ order.customer_order_url }}" class="mk-main-account__order-number">
                        订单 #{{ order.name }}
                      </a>
                      <time class="mk-main-account__order-date">
                        {{ order.created_at | date: "%Y年%m月%d日" }}
                      </time>
                    </div>
                    <div class="mk-main-account__order-status">
                      {% case order.fulfillment_status_label %}
                        {% when '已完成' %}
                          <span class="mk-main-account__order-badge mk-main-account__order-badge--complete">
                            {{ order.fulfillment_status_label }}
                          </span>
                        {% when '处理中' %}
                          <span class="mk-main-account__order-badge mk-main-account__order-badge--processing">
                            {{ order.fulfillment_status_label }}
                          </span>
                        {% when '已取消' %}
                          <span class="mk-main-account__order-badge mk-main-account__order-badge--cancelled">
                            {{ order.fulfillment_status_label }}
                          </span>
                        {% when '缺货' %}
                          <span class="mk-main-account__order-badge mk-main-account__order-badge--unfulfilled">
                            {{ order.fulfillment_status_label }}
                          </span>
                        {% else %}
                          <span class="mk-main-account__order-badge">
                            {{ order.financial_status_label }}
                          </span>
                      {% endcase %}
                    </div>
                  </div>
                  
                  <div class="mk-main-account__order-items">
                    {%- for item in order.line_items -%}
                      <div class="mk-main-account__order-item">
                        {% if item.image != blank %}
                          <img
                            src="{{ item.image | image_url: width: 80 }}"
                            alt="{{ item.title }}"
                            width="80"
                            height="80"
                            loading="lazy"
                          >
                        {% endif %}
                        <div class="mk-main-account__order-item-info">
                          <p class="mk-main-account__order-item-title">{{ item.title }}</p>
                          <p class="mk-main-account__order-item-variant">
                            {%- for option in item.options_with_values -%}
                              {{ option.name }}: {{ option.value }}
                              {% unless forloop.last %} / {% endunless %}
                            {%- endfor -%}
                          </p>
                          <p class="mk-main-account__order-item-qty">x {{ item.quantity }}</p>
                        </div>
                        <p class="mk-main-account__order-item-price">
                          {{ item.final_line_price | money }}
                        </p>
                      </div>
                    {%- endfor -%}
                  </div>
                  
                  <div class="mk-main-account__order-footer">
                    <p class="mk-main-account__order-total">
                      {{ 'customers.orders.total' | t | default: '总计' }}: {{ order.total_price | money }}
                    </p>
                    <a href="{{ order.customer_order_url }}" class="mk-main-account__order-link">
                      查看详情
                      {{- 'icon-arrow-right.svg' | inline_asset_content -}}
                    </a>
                  </div>
                </div>
              {%- endfor -%}
            </div>
          {%- else -%}
            <div class="mk-main-account__empty">
              <p>{{ 'customers.orders.none' | t | default: '您还没有下过订单。' }}</p>
              <a href="{{ routes.all_products_collection_url }}" class="mk-main-account__empty-btn">
                开始购物
              </a>
            </div>
          {%- endif -%}
        </div>
        
        {%- comment -%} 地址标签页 {%- endcomment -%}
        <div id="addresses" class="mk-main-account__tab">
          <h2 class="mk-main-account__section-title">
            {{ 'customers.account.addresses' | t | default: '收货地址' }}
          </h2>
          
          <div class="mk-main-account__addresses">
            {%- if customer.addresses.size > 0 -%}
              {%- for address in customer.addresses -%}
                <div class="mk-main-account__address">
                  <div class="mk-main-account__address-default">
                    {% if address.default %}
                      <span class="mk-main-account__address-badge">默认地址</span>
                    {% endif %}
                  </div>
                  <p class="mk-main-account__address-name">{{ address.name }}</p>
                  <p class="mk-main-account__address-text">
                    {{ address.company }}<br>
                    {{ address.address1 }}<br>
                    {% if address.address2 != blank %}
                      {{ address.address2 }}<br>
                    {% endif %}
                    {{ address.city }}, {{ address.province }} {{ address.zip }}<br>
                    {{ address.country }}
                  </p>
                  <p class="mk-main-account__address-phone">
                    {{ address.phone }}
                  </p>
                  <div class="mk-main-account__address-actions">
                    <button type="button" class="mk-main-account__address-btn">
                      编辑
                    </button>
                    <button type="button" class="mk-main-account__address-btn mk-main-account__address-btn--delete">
                      删除
                    </button>
                  </div>
                </div>
              {%- endfor -%}
            {%- else -%}
              <p class="mk-main-account__addresses-empty">暂无收货地址</p>
            {%- endif -%}
            
            <button type="button" class="mk-main-account__add-address-btn">
              {{- 'icon-plus.svg' | inline_asset_content -}}
              添加新地址
            </button>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

{% stylesheet %}
  .mk-main-account__container {
    max-width: var(--container-max-width, 1200px);
    margin: 0 auto;
    padding: 0 var(--container-padding, 32px);
  }

  /* Header */
  .mk-main-account__header {
    margin-bottom: 40px;
    text-align: center;
  }

  .mk-main-account__title {
    margin: 0 0 12px 0;
    font-size: 28px;
    font-weight: 700;
  }

  .mk-main-account__welcome {
    margin: 0;
    font-size: 16px;
    color: var(--color-text-secondary, #666);
  }

  /* Layout */
  .mk-main-account__layout {
    display: grid;
    gap: 40px;
  }

  @media (min-width: 768px) {
    .mk-main-account__layout {
      grid-template-columns: 240px 1fr;
      gap: 48px;
    }
  }

  /* Sidebar */
  .mk-main-account__sidebar {
    display: flex;
    flex-direction: column;
  }

  @media (max-width: 767px) {
    .mk-main-account__sidebar {
      border-bottom: 1px solid rgba(var(--color-border), 0.15);
      padding-bottom: 24px;
    }
  }

  .mk-main-account__nav {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  @media (max-width: 767px) {
    .mk-main-account__nav {
      flex-direction: row;
      overflow-x: auto;
    }
  }

  .mk-main-account__nav-link {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 12px 16px;
    font-size: 14px;
    font-weight: 500;
    text-decoration: none;
    color: inherit;
    border-radius: 8px;
    transition: all 0.2s ease;
    white-space: nowrap;
  }

  @media (max-width: 767px) {
    .mk-main-account__nav-link {
      padding: 10px 14px;
    }
  }

  .mk-main-account__nav-link:hover {
    background: var(--color-background-secondary, #f5f5f5);
  }

  .mk-main-account__nav-link--active {
    background: var(--color-primary, #000);
    color: var(--color-background, #fff);
  }

  .mk-main-account__nav-link--logout {
    margin-top: auto;
    color: var(--color-error, #e53935);
  }

  .mk-main-account__nav-link svg {
    width: 18px;
    height: 18px;
    flex-shrink: 0;
  }

  /* Tabs */
  .mk-main-account__tab {
    display: none;
  }

  .mk-main-account__tab--active {
    display: block;
  }

  /* Section */
  .mk-main-account__section-title {
    margin: 0 0 24px 0;
    font-size: 20px;
    font-weight: 600;
  }

  /* Orders */
  .mk-main-account__orders {
    display: flex;
    flex-direction: column;
    gap: 20px;
  }

  .mk-main-account__order {
    padding: 20px;
    background: var(--color-background-secondary, #f9f9f9);
    border-radius: 12px;
  }

  .mk-main-account__order-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    margin-bottom: 16px;
    padding-bottom: 16px;
    border-bottom: 1px solid rgba(var(--color-border), 0.1);
  }

  .mk-main-account__order-info {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .mk-main-account__order-number {
    font-size: 15px;
    font-weight: 600;
    text-decoration: none;
    color: inherit;
  }

  .mk-main-account__order-number:hover {
    text-decoration: underline;
  }

  .mk-main-account__order-date {
    font-size: 13px;
    color: var(--color-text-secondary, #666);
  }

  /* Badge */
  .mk-main-account__order-badge {
    padding: 4px 10px;
    font-size: 12px;
    font-weight: 500;
    border-radius: 4px;
    background: #e0e0e0;
    color: #616161;
  }

  .mk-main-account__order-badge--complete {
    background: #e8f5e9;
    color: #2e7d32;
  }

  .mk-main-account__order-badge--processing {
    background: #e3f2fd;
    color: #1565c0;
  }

  .mk-main-account__order-badge--cancelled {
    background: #ffebee;
    color: #c62828;
  }

  .mk-main-account__order-badge--unfulfilled {
    background: #fff3e0;
    color: #ef6c00;
  }

  /* Order Items */
  .mk-main-account__order-items {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .mk-main-account__order-item {
    display: grid;
    grid-template-columns: 60px 1fr auto;
    gap: 12px;
    align-items: center;
  }

  .mk-main-account__order-item img {
    width: 60px;
    height: 60px;
    object-fit: cover;
    border-radius: 6px;
    background: var(--color-background, #fff);
  }

  .mk-main-account__order-item-info {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .mk-main-account__order-item-title {
    margin: 0;
    font-size: 14px;
    font-weight: 500;
  }

  .mk-main-account__order-item-variant {
    margin: 0;
    font-size: 12px;
    color: var(--color-text-secondary, #666);
  }

  .mk-main-account__order-item-qty {
    margin: 0;
    font-size: 12px;
    color: var(--color-text-secondary, #999);
  }

  .mk-main-account__order-item-price {
    margin: 0;
    font-size: 14px;
    font-weight: 500;
  }

  /* Order Footer */
  .mk-main-account__order-footer {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-top: 16px;
    padding-top: 16px;
    border-top: 1px solid rgba(var(--color-border), 0.1);
  }

  .mk-main-account__order-total {
    margin: 0;
    font-size: 15px;
    font-weight: 600;
  }

  .mk-main-account__order-link {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    font-size: 13px;
    font-weight: 500;
    text-decoration: none;
    color: var(--color-primary, #000);
  }

  .mk-main-account__order-link:hover {
    text-decoration: underline;
  }

  .mk-main-account__order-link svg {
    width: 14px;
    height: 14px;
  }

  /* Empty */
  .mk-main-account__empty {
    text-align: center;
    padding: 48px 20px;
    background: var(--color-background-secondary, #f9f9f9);
    border-radius: 12px;
  }

  .mk-main-account__empty p {
    margin: 0 0 20px 0;
    font-size: 15px;
    color: var(--color-text-secondary, #666);
  }

  .mk-main-account__empty-btn {
    display: inline-block;
    padding: 12px 24px;
    font-size: 14px;
    font-weight: 600;
    text-decoration: none;
    color: var(--color-background, #fff);
    background: var(--color-primary, #000);
    border-radius: 4px;
  }

  /* Addresses */
  .mk-main-account__addresses {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 20px;
  }

  .mk-main-account__address {
    padding: 20px;
    background: var(--color-background-secondary, #f9f9f9);
    border-radius: 12px;
  }

  .mk-main-account__address-default {
    margin-bottom: 12px;
  }

  .mk-main-account__address-badge {
    padding: 4px 10px;
    font-size: 12px;
    font-weight: 500;
    background: var(--color-primary, #000);
    color: var(--color-background, #fff);
    border-radius: 4px;
  }

  .mk-main-account__address-name {
    margin: 0 0 12px 0;
    font-size: 15px;
    font-weight: 600;
  }

  .mk-main-account__address-text {
    margin: 0 0 8px 0;
    font-size: 14px;
    line-height: 1.5;
    color: var(--color-text-secondary, #666);
  }

  .mk-main-account__address-phone {
    margin: 0 0 16px 0;
    font-size: 14px;
    color: var(--color-text-secondary, #666);
  }

  .mk-main-account__address-actions {
    display: flex;
    gap: 12px;
  }

  .mk-main-account__address-btn {
    padding: 8px 14px;
    font-size: 13px;
    font-weight: 500;
    background: transparent;
    border: 1px solid rgba(var(--color-border), 0.3);
    border-radius: 4px;
    cursor: pointer;
    transition: all 0.2s ease;
  }

  .mk-main-account__address-btn:hover {
    border-color: var(--color-primary, #000);
  }

  .mk-main-account__address-btn--delete {
    color: var(--color-error, #e53935);
  }

  .mk-main-account__address-btn--delete:hover {
    border-color: var(--color-error, #e53935);
  }

  .mk-main-account__addresses-empty {
    margin: 0;
    font-size: 15px;
    color: var(--color-text-secondary, #666);
  }

  .mk-main-account__add-address-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    padding: 20px;
    font-size: 14px;
    font-weight: 500;
    background: transparent;
    border: 2px dashed rgba(var(--color-border), 0.3);
    border-radius: 12px;
    cursor: pointer;
    transition: all 0.2s ease;
  }

  .mk-main-account__add-address-btn:hover {
    border-color: var(--color-primary, #000);
    background: var(--color-background-secondary, #f9f9f9);
  }

  .mk-main-account__add-address-btn svg {
    width: 18px;
    height: 18px;
  }
{% endstylesheet %}

{% javascript %}
  class MKMainAccount extends HTMLElement {
    constructor() {
      super();
      this.initTabs();
    }

    initTabs() {
      const navLinks = this.querySelectorAll('.mk-main-account__nav-link[data-tab]');
      const tabs = this.querySelectorAll('.mk-main-account__tab');

      navLinks.forEach(link => {
        link.addEventListener('click', (e) => {
          e.preventDefault();
          const targetId = link.dataset.tab;

          navLinks.forEach(l => l.classList.remove('mk-main-account__nav-link--active'));
          link.classList.add('mk-main-account__nav-link--active');

          tabs.forEach(tab => {
            tab.classList.remove('mk-main-account__tab--active');
            if (tab.id === targetId) {
              tab.classList.add('mk-main-account__tab--active');
            }
          });
        });
      });
    }
  }

  customElements.define('mk-main-account', MKMainAccount);
{% endjavascript %}

{% schema %}
{
  "name": "MK 账户页面",
  "tag": "section",
  "settings": [
    {
      "type": "header",
      "content": "间距设置"
    },
    {
      "type": "range",
      "id": "padding_top_mobile",
      "label": "上边距 (移动端)",
      "min": 0,
      "max": 120,
      "default": 32,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "label": "下边距 (移动端)",
      "min": 0,
      "max": 120,
      "default": 32,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_top_desktop",
      "label": "上边距 (PC端)",
      "min": 0,
      "max": 200,
      "default": 48,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_bottom_desktop",
      "label": "下边距 (PC端)",
      "min": 0,
      "max": 200,
      "default": 48,
      "unit": "px"
    }
  ],
  "presets": [
    {
      "name": "MK 账户页面"
    }
  ]
}
{% endschema %}
