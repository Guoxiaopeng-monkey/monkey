{%- comment -%}
  MK Lookbook板块

  展示时尚穿搭Lookbook

  作者：崽崽 (AI助手)
{%- endcomment -%}

{% liquid
  assign ss = section.settings
-%}

<section
  id="{{ section.id }}"
  class="mk-lookbook color-{{ ss.color_scheme | default: 'background-1' }}"
>
  <div class="mk-lookbook__container">
    {%- if ss.title != blank -%}
      <h2 class="mk-lookbook__title">{{ ss.title }}</h2>
    {%- endif -%}

    <div class="mk-lookbook__grid">
      {%- for i in (1..6) -%}
        {%- assign image_setting = 'image_' | append: i -%}
        {%- assign link_setting = 'link_' | append: i -%}

        {%- if ss[image_setting] != blank -%}
          <a href="{{ ss[link_setting] | default: '#' }}" class="mk-lookbook__item">
            {{ ss[image_setting] | image_url: width: 600 | image_tag: loading: 'lazy', class: 'mk-lookbook__image' }}
            <div class="mk-lookbook__overlay">
              <span class="mk-lookbook__text">{{ 'products.shop_now' | t | default: '立即选购' }}</span>
            </div>
          </a>
        {%- endif -%}
      {%- endfor -%}
    </div>
  </div>
</section>

{% stylesheet %}
  .mk-lookbook { padding: {{ ss.padding_top_mobile | default: 48 }}px 0 {{ ss.padding_bottom_mobile | default: 48 }}px; }
  @media (min-width: 750px) { .mk-lookbook { padding: {{ ss.padding_top_desktop | default: 80 }}px 0 {{ ss.padding_bottom_desktop | default: 80 }}px; } }
  .mk-lookbook__container { max-width: var(--container-max-width, 1200px); margin: 0 auto; padding: 0 var(--container-padding, 32px); }
  .mk-lookbook__title { margin: 0 0 32px 0; font-size: var(--mk-font-size-3xl); font-weight: 700; text-align: center; }
  .mk-lookbook__grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: var(--mk-spacing-lg); }
  @media (min-width: 750px) { .mk-lookbook__grid { grid-template-columns: repeat(3, 1fr); gap: var(--mk-spacing-2xl); } }
  .mk-lookbook__item { position: relative; aspect-ratio: 3/4; overflow: hidden; border-radius: var(--mk-radius-lg); }
  .mk-lookbook__image { width: 100%; height: 100%; object-fit: cover; transition: transform 0.4s ease; }
  .mk-lookbook__item:hover .mk-lookbook__image { transform: scale(1.05); }
  .mk-lookbook__overlay { position: absolute; inset: 0; display: flex; align-items: center; justify-content: center; background: rgba(0,0,0,0.3); opacity: 0; transition: opacity 0.3s ease; }
  .mk-lookbook__item:hover .mk-lookbook__overlay { opacity: 1; }
  .mk-lookbook__text { padding: var(--mk-spacing-md) 24px; font-size: var(--mk-font-size-md); font-weight: 600; color: #fff; background: var(--color-primary, #000); border-radius: 100px; }
{% endstylesheet %}

{% schema %}
{
  "name": "MK Lookbook",
  "tag": "section",
  "settings": [
    { "type": "text", "id": "title", "label": "标题" },
    { "type": "header", "content": "图片" },
    { "type": "image_picker", "id": "image_1", "label": "图片 1" },
    { "type": "url", "id": "link_1", "label": "链接 1" },
    { "type": "image_picker", "id": "image_2", "label": "图片 2" },
    { "type": "url", "id": "link_2", "label": "链接 2" },
    { "type": "image_picker", "id": "image_3", "label": "图片 3" },
    { "type": "url", "id": "link_3", "label": "链接 3" },
    { "type": "image_picker", "id": "image_4", "label": "图片 4" },
    { "type": "url", "id": "link_4", "label": "链接 4" },
    { "type": "image_picker", "id": "image_5", "label": "图片 5" },
    { "type": "url", "id": "link_5", "label": "链接 5" },
    { "type": "image_picker", "id": "image_6", "label": "图片 6" },
    { "type": "url", "id": "link_6", "label": "链接 6" },
    { "type": "header", "content": "间距" },
    { "type": "range", "id": "padding_top_mobile", "label": "上边距 (移动端)", "min": 0, "max": 120, "default": 48, "unit": "px" },
    { "type": "range", "id": "padding_bottom_mobile", "label": "下边距 (移动端)", "min": 0, "max": 120, "default": 48, "unit": "px" },
    { "type": "range", "id": "padding_top_desktop", "label": "上边距 (PC端)", "min": 0, "max": 200, "default": 80, "unit": "px" },
    { "type": "range", "id": "padding_bottom_desktop", "label": "下边距 (PC端)", "min": 0, "max": 200, "default": 80, "unit": "px" },
    { "type": "color_scheme", "id": "color_scheme", "label": "颜色方案", "default": "scheme-1" }
  ],
  "presets": [{ "name": "MK Lookbook" }]
}
{% endschema %}
