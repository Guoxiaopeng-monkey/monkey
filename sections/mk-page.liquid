{%- comment -%}
  MK 自定义页面板块

  渲染自定义页面内容

  作者：崽崽 (AI助手)
{%- endcomment -%}

{% liquid
  assign ss = section.settings
  assign page = page | default: nil
-%}

<section
  id="{{ section.id }}"
  class="mk-page color-{{ ss.color_scheme | default: 'background-1' }}"
>
  <div class="mk-page__container">
    {%- if page.title != blank -%}
      <h1 class="mk-page__title">{{ page.title }}</h1>
    {%- endif -%}

    {%- if page.content != blank -%}
      <div class="mk-page__content rte">
        {{ page.content }}
      </div>
    {%- endif -%}
  </div>
</section>

{% stylesheet %}
  .mk-page {
    padding: {{ ss.padding_top_mobile | default: 48 }}px 0 {{ ss.padding_bottom_mobile | default: 48 }}px;
  }

  @media (min-width: 750px) {
    .mk-page {
      padding: {{ ss.padding_top_desktop | default: 64 }}px 0 {{ ss.padding_bottom_desktop | default: 64 }}px;
    }
  }

  .mk-page__container {
    max-width: var(--container-max-width, 800px);
    margin: 0 auto;
    padding: 0 var(--container-padding, 32px);
  }

  .mk-page__title {
    margin: 0 0 24px 0;
    font-size: var(--mk-font-size-3xl);
    font-weight: 700;
    text-align: center;
  }

  @media (min-width: 750px) {
    .mk-page__title {
      font-size: var(--mk-font-size-5xl);
    }
  }

  .mk-page__content {
    font-size: var(--mk-font-size-lg);
    line-height: 1.8;
    color: var(--color-foreground);
  }

  .mk-page__content h2 {
    margin: var(--mk-spacing-3xl) 0 16px 0;
    font-size: var(--mk-font-size-3xl);
    font-weight: 700;
  }

  .mk-page__content h3 {
    margin: var(--mk-spacing-2xl) 0 12px 0;
    font-size: var(--mk-font-size-2xl);
    font-weight: 600;
  }

  .mk-page__content p {
    margin: 0 0 16px 0;
  }

  .mk-page__content img {
    max-width: 100%;
    height: auto;
    border-radius: var(--mk-radius-sm);
  }

  .mk-page__content a {
    color: var(--color-primary, #000);
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  .mk-page__content ul,
  .mk-page__content ol {
    margin: 0 0 16px 0;
    padding-left: 24px;
  }

  .mk-page__content li {
    margin-bottom: 8px;
  }

  .mk-page__content blockquote {
    margin: var(--mk-spacing-2xl) 0;
    padding: var(--mk-spacing-lg) 24px;
    border-left: 4px solid var(--color-primary, #000);
    background-color: var(--color-background-secondary, var(--mk-color-bg-secondary));
    border-radius: 0 8px 8px 0;
  }

  .mk-page__content blockquote p {
    margin: 0;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "MK 自定义页面",
  "tag": "section",
  "settings": [
    {
      "type": "header",
      "content": "间距"
    },
    {
      "type": "range",
      "id": "padding_top_mobile",
      "label": "上边距 (移动端)",
      "min": 0,
      "max": 120,
      "default": 48,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "label": "下边距 (移动端)",
      "min": 0,
      "max": 120,
      "default": 48,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_top_desktop",
      "label": "上边距 (PC端)",
      "min": 0,
      "max": 200,
      "default": 64,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_bottom_desktop",
      "label": "下边距 (PC端)",
      "min": 0,
      "max": 200,
      "default": 64,
      "unit": "px"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "颜色方案",
      "default": "scheme-1"
    }
  ],
  "presets": [
    {
      "name": "MK 自定义页面"
    }
  ]
}
{% endschema %}
