{%- doc -%}
  MK Select下拉框组件

  渲染自定义下拉选择框

  @param {string} id - ID
  @param {string} name - 名称
  @param {string[]} options - 选项数组
  @param {string} [selected] - 选中值
  @param {string} [label] - 标签
  @param {string} [class] - 额外CSS类名

  @example
  {% render 'mk-select', id: 'country', name: 'country', options: countries, selected: 'CN', label: '国家' %}
{%- enddoc -%}

{% liquid
  assign id = id | default: ''
  assign name = name | default: ''
  assign options = options | default: empty_array
  assign selected = selected | default: ''
  assign label = label | default: ''
  assign class = class | default: ''

  if options == empty_array
    assign options = '[]' | parse_json
  endif
-%}

<div class="mk-select {{ class }}">
  {%- if label != blank -%}
    <label for="{{ id }}" class="mk-select__label">{{ label }}</label>
  {%- endif -%}

  <div class="mk-select__wrapper">
    <select id="{{ id }}" name="{{ name }}" class="mk-select__input">
      {%- for option in options -%}
        {%- if option is_a: String -%}
          <option value="{{ option }}" {% if option == selected %}selected{% endif %}>{{ option }}</option>
        {%- else -%}
          <option value="{{ option.value }}" {% if option.value == selected %}selected{% endif %}>{{ option.label | default: option.value }}</option>
        {%- endif -%}
      {%- endfor -%}
    </select>
    <span class="mk-select__icon">{{- 'icon-chevron-down.svg' | inline_asset_content -}}</span>
  </div>
</div>

{% stylesheet %}
  .mk-select {
    display: flex;
    flex-direction: column;
    gap: 6px;
  }

  .mk-select__label {
    font-size: 14px;
    font-weight: 500;
    color: var(--color-foreground);
  }

  .mk-select__wrapper {
    position: relative;
  }

  .mk-select__input {
    width: 100%;
    padding: 12px 40px 12px 14px;
    font-size: 14px;
    color: var(--color-foreground);
    background-color: var(--color-background);
    border: 1px solid var(--color-border);
    border-radius: 8px;
    cursor: pointer;
    appearance: none;
    transition: border-color 0.2s ease;
  }

  .mk-select__input:hover {
    border-color: var(--color-foreground);
  }

  .mk-select__input:focus {
    outline: none;
    border-color: var(--color-primary, #000);
  }

  .mk-select__icon {
    position: absolute;
    right: 12px;
    top: 50%;
    transform: translateY(-50%);
    display: flex;
    width: 16px;
    height: 16px;
    pointer-events: none;
    color: var(--color-text-secondary, #666);
  }

  .mk-select__icon svg {
    width: 100%;
    height: 100%;
  }
{% endstylesheet %}
