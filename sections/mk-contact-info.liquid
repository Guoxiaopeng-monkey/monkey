{%- comment -%}
  MK Contact Info板块

  联系信息展示

  作者：崽崽 (AI助手)
{%- endcomment -%}

{% liquid
  assign ss = section.settings
-%}

<section id="{{ section.id }}" class="mk-contact-info color-{{ ss.color_scheme | default: 'background-1' }}">
  <div class="mk-contact-info__container">
    <div class="mk-contact-info__content">
      {%- if ss.title != blank -%}
        <h2 class="mk-contact-info__title">{{ ss.title }}</h2>
      {%- endif -%}
      {%- if ss.description != blank -%}
        <p class="mk-contact-info__description">{{ ss.description }}</p>
      {%- endif -%}

      <div class="mk-contact-info__items">
        {%- for i in (1..4) -%}
          {%- assign icon_setting = 'icon_' | append: i -%}
          {%- assign label_setting = 'label_' | append: i -%}
          {%- assign value_setting = 'value_' | append: i -%}

          {%- if ss[label_setting] != blank -%}
            <div class="mk-contact-info__item">
              <div class="mk-contact-info__icon">
                {{ ss[icon_setting] | default: 'icon-check.svg' | inline_asset_content }}
              </div>
              <div class="mk-contact-info__text">
                <span class="mk-contact-info__label">{{ ss[label_setting] }}</span>
                <span class="mk-contact-info__value">{{ ss[value_setting] }}</span>
              </div>
            </div>
          {%- endif -%}
        {%- endfor -%}
      </div>

      {%- if ss.show_social -%}
        <div class="mk-contact-info__social">
          <span class="mk-contact-info__social-label">关注我们</span>
          <div class="mk-contact-info__social-icons">
            {% render 'mk-social-icons' %}
          </div>
        </div>
      {%- endif -%}
    </div>

    <div class="mk-contact-info__form">
      {%- if ss.form_title != blank -%}
        <h3 class="mk-contact-info__form-title">{{ ss.form_title }}</h3>
      {%- endif -%}
      {% render 'mk-contact-form' %}
    </div>
  </div>
</section>

{% stylesheet %}
  .mk-contact-info { padding: {{ ss.padding_top_mobile | default: 48 }}px 0 {{ ss.padding_bottom_mobile | default: 48 }}px; }
  @media (min-width: 750px) { .mk-contact-info { padding: {{ ss.padding_top_desktop | default: 80 }}px 0 {{ ss.padding_bottom_desktop | default: 80 }}px; } }
  .mk-contact-info__container { max-width: var(--container-max-width, 1200px); margin: 0 auto; padding: 0 var(--container-padding, 32px); display: grid; grid-template-columns: 1fr; gap: 48px; }
  @media (min-width: 750px) { .mk-contact-info__container { grid-template-columns: 1fr 1fr; gap: 64px; } }
  .mk-contact-info__title { margin: 0 0 16px 0; font-size: var(--mk-font-size-3xl); font-weight: 700; }
  .mk-contact-info__description { margin: 0 0 32px 0; font-size: var(--mk-font-size-md); color: var(--color-text-secondary, #666); line-height: 1.6; }
  .mk-contact-info__items { display: flex; flex-direction: column; gap: 20px; }
  .mk-contact-info__item { display: flex; align-items: flex-start; gap: var(--mk-spacing-lg); }
  .mk-contact-info__icon { display: flex; flex-shrink: 0; width: 40px; height: 40px; align-items: center; justify-content: center; background: var(--color-background-secondary, var(--mk-color-bg-secondary)); border-radius: 50%; }
  .mk-contact-info__icon svg { width: 20px; height: 20px; color: var(--color-primary, #000); }
  .mk-contact-info__text { display: flex; flex-direction: column; gap: 2px; }
  .mk-contact-info__label { font-size: var(--mk-font-size-sm); color: var(--color-text-secondary, #666); }
  .mk-contact-info__value { font-size: var(--mk-font-size-md); font-weight: 500; }
  .mk-contact-info__social { margin-top: 32px; }
  .mk-contact-info__social-label { font-size: var(--mk-font-size-md); font-weight: 600; margin-bottom: 12px; display: block; }
  .mk-contact-info__form { padding: var(--mk-spacing-3xl); background: var(--color-background-secondary, var(--mk-color-bg-secondary)); border-radius: var(--mk-radius-lg); }
  .mk-contact-info__form-title { margin: 0 0 24px 0; font-size: var(--mk-font-size-2xl); font-weight: 700; }
{% endstylesheet %}

