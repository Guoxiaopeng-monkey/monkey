{%- comment -%}
  MK Share Section板块

  分享区块

  作者：崽崽 (AI助手)
{%- endcomment -%}

{% liquid
  assign ss = section.settings
  assign share_url = ss.share_url | default: request.origin | append: request.path
  assign share_title = ss.share_title | default: page_title | default: ''
-%}

<section id="{{ section.id }}" class="mk-share-section color-{{ ss.color_scheme | default: 'background-1' }}">
  <div class="mk-share-section__container">
    {%- if ss.title != blank -%}
      <h3 class="mk-share-section__title">{{ ss.title }}</h3>
    {%- endif -%}

    <div class="mk-share-section__platforms">
      <a href="https://www.facebook.com/sharer/sharer.php?u={{ share_url | url_encode }}" target="_blank" rel="noopener" class="mk-share-section__btn mk-share-section__btn--facebook" aria-label="分享到Facebook">
        {{- 'icon-facebook.svg' | inline_asset_content -}}
      </a>
      <a href="https://twitter.com/intent/tweet?url={{ share_url | url_encode }}&text={{ share_title | url_encode }}" target="_blank" rel="noopener" class="mk-share-section__btn mk-share-section__btn--twitter" aria-label="分享到Twitter">
        {{- 'icon-twitter.svg' | inline_asset_content -}}
      </a>
      <a href="https://pinterest.com/pin/create/button/?url={{ share_url | url_encode }}&description={{ share_title | url_encode }}" target="_blank" rel="noopener" class="mk-share-section__btn mk-share-section__btn--pinterest" aria-label="分享到Pinterest">
        {{- 'icon-pinterest.svg' | inline_asset_content -}}
      </a>
      <a href="https://www.linkedin.com/shareArticle?mini=true&url={{ share_url | url_encode }}&title={{ share_title | url_encode }}" target="_blank" rel="noopener" class="mk-share-section__btn mk-share-section__btn--linkedin" aria-label="分享到LinkedIn">
        {{- 'icon-linkedin.svg' | inline_asset_content -}}
      </a>
      <button type="button" class="mk-share-section__btn mk-share-section__btn--copy" data-copy-link data-url="{{ share_url }}" aria-label="复制链接">
        {{- 'icon-link.svg' | inline_asset_content -}}
      </button>
    </div>
  </div>
</section>

{% stylesheet %}
  .mk-share-section { padding: 24px 0; }
  .mk-share-section__container { max-width: var(--container-max-width, 1200px); margin: 0 auto; padding: 0 var(--container-padding, 32px); display: flex; align-items: center; justify-content: center; gap: 16px; flex-wrap: wrap; }
  .mk-share-section__title { margin: 0; font-size: 14px; font-weight: 600; }
  .mk-share-section__platforms { display: flex; align-items: center; gap: 8px; }
  .mk-share-section__btn { display: flex; align-items: center; justify-content: center; width: 40px; height: 40px; border-radius: 50%; background: var(--color-background-secondary, #f5f5f5); transition: all 0.2s ease; text-decoration: none; }
  .mk-share-section__btn:hover { background: var(--color-border); }
  .mk-share-section__btn svg { width: 18px; height: 18px; }
  .mk-share-section__btn--copy.copied { background: var(--color-primary, #000); color: #fff; }
{% endstylesheet %}

{% javascript %}
  document.querySelectorAll('[data-copy-link]').forEach(btn => {
    btn.addEventListener('click', () => {
      navigator.clipboard.writeText(btn.dataset.url).then(() => {
        btn.classList.add('copied');
        setTimeout(() => btn.classList.remove('copied'), 2000);
      });
    });
  });
{% endjavascript %}

{% schema %}
{
  "name": "MK Share Section",
  "tag": "section",
  "settings": [
    { "type": "text", "id": "title", "label": "标题" },
    { "type": "url", "id": "share_url", "label": "分享链接" },
    { "type": "text", "id": "share_title", "label": "分享标题" },
    { "type": "color_scheme", "id": "color_scheme", "label": "颜色方案", "default": "scheme-1" }
  ],
  "presets": [{ "name": "MK Share Section" }]
}
{% endschema %}
