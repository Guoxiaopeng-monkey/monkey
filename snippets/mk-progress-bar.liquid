{%- doc -%}
  MK 进度条组件

  渲染进度条

  @param {number} value - 当前值
  @param {number} [max] - 最大值
  @param {string} [label] - 标签文字
  @param {string} [show_percent] - 是否显示百分比

  @example
  {% render 'mk-progress-bar', value: 75, max: 100, label: '完成进度' %}
{%- enddoc -%}

{% liquid
  assign value = value | default: 0
  assign max = max | default: 100
  assign label = label | default: ''
  assign show_percent = show_percent | default: true

  assign percent = value | times: 100.0 | divided_by: max | at_most: 100
-%}

<div class="mk-progress-bar" data-progress-bar>
  {%- if label != blank -%}
    <div class="mk-progress-bar__header">
      <span class="mk-progress-bar__label">{{ label }}</span>
      {%- if show_percent -%}
        <span class="mk-progress-bar__percent">{{ percent | round }}%</span>
      {%- endif -%}
    </div>
  {%- endif -%}

  <div class="mk-progress-bar__track">
    <div class="mk-progress-bar__fill" style="--progress: {{ percent }}%;"></div>
  </div>
</div>

{% stylesheet %}
  .mk-progress-bar {
    width: 100%;
  }

  .mk-progress-bar__header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 8px;
  }

  .mk-progress-bar__label {
    font-size: var(--mk-font-size-sm);
    font-weight: 500;
    color: var(--color-foreground);
  }

  .mk-progress-bar__percent {
    font-size: var(--mk-font-size-sm);
    font-weight: 600;
    color: var(--color-primary, #000);
  }

  .mk-progress-bar__track {
    width: 100%;
    height: 8px;
    background-color: var(--color-background-secondary, var(--mk-color-bg-secondary));
    border-radius: var(--mk-radius-xs);
    overflow: hidden;
  }

  .mk-progress-bar__fill {
    height: 100%;
    width: var(--progress, 0%);
    background-color: var(--color-primary, #000);
    border-radius: var(--mk-radius-xs);
    transition: width 0.3s ease;
  }

  /* 进度条变体 */
  .mk-progress-bar--small .mk-progress-bar__track {
    height: 4px;
  }

  .mk-progress-bar--large .mk-progress-bar__track {
    height: 12px;
    border-radius: 6px;
  }
{% endstylesheet %}
