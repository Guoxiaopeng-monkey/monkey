{%- doc -%}
  MK 图标组件

  渲染 SVG 图标，支持从资源文件或内联 SVG 加载

  @param {string} icon - 图标名称（不含扩展名）
  @param {string} [size] - 图标尺寸，如 '20px'、'1.5em'
  @param {string} [class] - 额外的 CSS 类名
  @param {string} [aria_label] - 无障碍标签

  @example
  {% render 'mk-icon', icon: 'cart', size: '24px' %}
  {% render 'mk-icon', icon: 'search', class: 'header__icon' %}
{%- enddoc -%}

{% liquid
  assign size = size | default: '24px'
  assign class = class | default: ''
  assign aria_label = aria_label | default: ''
-%}

<span
  class="mk-icon mk-icon--{{ icon }} {{ class }}"
  style="width: {{ size }}; height: {{ size }};"
  {% if aria_label != '' %}
    aria-label="{{ aria_label }}"
    role="img"
  {% else %}
    aria-hidden="true"
  {% endif %}
>
  {% case icon %}
    {% when 'cart' %}
      {{- 'icon-cart.svg' | inline_asset_content -}}
    {% when 'search' %}
      {{- 'icon-search.svg' | inline_asset_content -}}
    {% when 'account' %}
      {{- 'icon-account.svg' | inline_asset_content -}}
    {% when 'menu' %}
      {{- 'icon-menu.svg' | inline_asset_content -}}
    {% when 'close' %}
      {{- 'icon-close.svg' | inline_asset_content -}}
    {% when 'arrow-left' %}
      {{- 'icon-arrow-left.svg' | inline_asset_content -}}
    {% when 'arrow-right' %}
      {{- 'icon-arrow-right.svg' | inline_asset_content -}}
    {% when 'plus' %}
      {{- 'icon-plus.svg' | inline_asset_content -}}
    {% when 'minus' %}
      {{- 'icon-minus.svg' | inline_asset_content -}}
    {% when 'check' %}
      {{- 'icon-check.svg' | inline_asset_content -}}
    {% when 'filter' %}
      {{- 'icon-filter.svg' | inline_asset_content -}}
    {% when 'home' %}
      {{- 'icon-home.svg' | inline_asset_content -}}
    {% when 'wishlist' %}
      {{- 'icon-wishlist.svg' | inline_asset_content -}}
    {% when 'compare' %}
      {{- 'icon-compare.svg' | inline_asset_content -}}
    {% when 'truck' %}
      {{- 'icon-truck.svg' | inline_asset_content -}}
    {% when 'return' %}
      {{- 'icon-return.svg' | inline_asset_content -}}
    {% when 'shield' %}
      {{- 'icon-shield.svg' | inline_asset_content -}}
    {% when 'package' %}
      {{- 'icon-package.svg' | inline_asset_content -}}
    {% when 'user' %}
      {{- 'icon-user.svg' | inline_asset_content -}}
    {% when 'log-out' %}
      {{- 'icon-log-out.svg' | inline_asset_content -}}
    {% when 'map-pin' %}
      {{- 'icon-map-pin.svg' | inline_asset_content -}}
    {% when 'facebook' %}
      {{- 'icon-facebook.svg' | inline_asset_content -}}
    {% when 'twitter' %}
      {{- 'icon-twitter.svg' | inline_asset_content -}}
    {% else %}
      {{- 'icon-default.svg' | inline_asset_content | default: '<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/></svg>' -}}
  {% endcase %}
</span>

{% stylesheet %}
  .mk-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .mk-icon svg {
    width: 100%;
    height: 100%;
    fill: currentColor;
    stroke: currentColor;
  }
{% endstylesheet %}
