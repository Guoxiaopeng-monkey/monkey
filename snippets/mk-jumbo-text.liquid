{%- doc -%}
  MK 大号文本组件

  渲染大号展示文本

  @param {string} text - 文本内容
  @param {string} [class] - 额外CSS类名

  @example
  {% render 'mk-jumbo-text', text: section.settings.title %}
{%- enddoc -%}

{% liquid
  assign text = text | default: ''
  assign class = class | default: ''
-%}

<div class="mk-jumbo-text {{ class }}" data-jumbo-text>
  {%- for word in text | split: ' ' -%}
    <span class="mk-jumbo-text__word">{{ word }}</span>
  {%- endfor -%}
</div>

{% stylesheet %}
  .mk-jumbo-text {
    display: flex;
    flex-wrap: wrap;
    gap: 0.2em;
    font-size: clamp(48px, 10vw, 120px);
    font-weight: 700;
    line-height: 1.1;
    letter-spacing: -0.02em;
  }
  .mk-jumbo-text__word {
    display: inline-block;
  }
{% endstylesheet %}
