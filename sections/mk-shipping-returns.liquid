{%- comment -%}
  MK Shipping Returns Section板块

  物流退换信息

  作者：崽崽 (AI助手)
{%- endcomment -%}

{% liquid
  assign ss = section.settings
-%}

<section id="{{ section.id }}" class="mk-shipping-returns color-{{ ss.color_scheme | default: 'background-1' }}">
  <div class="mk-shipping-returns__container">
    {%- if ss.title != blank -%}
      <h2 class="mk-shipping-returns__title">{{ ss.title }}</h2>
    {%- endif -%}

    <div class="mk-shipping-returns__grid">
      {%- for i in (1..3) -%}
        {%- assign icon_setting = 'icon_' | append: i -%}
        {%- assign title_setting = 'title_' | append: i -%}
        {%- assign text_setting = 'text_' | append: i -%}

        {%- if ss[title_setting] != blank -%}
          <div class="mk-shipping-returns__item">
            <div class="mk-shipping-returns__icon">
              {{ ss[icon_setting] | default: 'icon-check.svg' | inline_asset_content }}
            </div>
            <h3 class="mk-shipping-returns__item-title">{{ ss[title_setting] }}</h3>
            <p class="mk-shipping-returns__text">{{ ss[text_setting] }}</p>
          </div>
        {%- endif -%}
      {%- endfor -%}
    </div>
  </div>
</section>

{% stylesheet %}
  .mk-shipping-returns { padding: {{ ss.padding_top_mobile | default: 48 }}px 0 {{ ss.padding_bottom_mobile | default: 48 }}px; }
  @media (min-width: 750px) { .mk-shipping-returns { padding: {{ ss.padding_top_desktop | default: 80 }}px 0 {{ ss.padding_bottom_desktop | default: 80 }}px; } }
  .mk-shipping-returns__container { max-width: var(--container-max-width, 1000px); margin: 0 auto; padding: 0 var(--container-padding, 32px); }
  .mk-shipping-returns__title { margin: 0 0 40px 0; font-size: 28px; font-weight: 700; text-align: center; }
  .mk-shipping-returns__grid { display: grid; grid-template-columns: 1fr; gap: 32px; }
  @media (min-width: 750px) { .mk-shipping-returns__grid { grid-template-columns: repeat(3, 1fr); gap: 48px; } }
  .mk-shipping-returns__item { display: flex; flex-direction: column; align-items: center; text-align: center; gap: 12px; }
  .mk-shipping-returns__icon { display: flex; align-items: center; justify-content: center; width: 56px; height: 56px; background: var(--color-background-secondary, #f5f5f5); border-radius: 50%; }
  .mk-shipping-returns__icon svg { width: 28px; height: 28px; color: var(--color-primary, #000); }
  .mk-shipping-returns__item-title { margin: 0; font-size: 16px; font-weight: 600; }
  .mk-shipping-returns__text { margin: 0; font-size: 14px; color: var(--color-text-secondary, #666); line-height: 1.6; }
{% endstylesheet %}

{% schema %}
{
  "name": "MK Shipping Returns",
  "tag": "section",
  "settings": [
    { "type": "text", "id": "title", "label": "标题" },
    { "type": "header", "content": "项 1" }, { "type": "text", "id": "icon_1", "label": "图标 1" }, { "type": "text", "id": "title_1", "label": "标题 1" }, { "type": "textarea", "id": "text_1", "label": "描述 1" },
    { "type": "header", "content": "项 2" }, { "type": "text", "id": "icon_2", "label": "图标 2" }, { "type": "text", "id": "title_2", "label": "标题 2" }, { "type": "textarea", "id": "text_2", "label": "描述 2" },
    { "type": "header", "content": "项 3" }, { "type": "text", "id": "icon_3", "label": "图标 3" }, { "type": "text", "id": "title_3", "label": "标题 3" }, { "type": "textarea", "id": "text_3", "label": "描述 3" },
    { "type": "header", "content": "间距" },
    { "type": "range", "id": "padding_top_mobile", "label": "上边距 (移动端)", "min": 0, "max": 120, "default": 48, "unit": "px" },
    { "type": "range", "id": "padding_bottom_mobile", "label": "下边距 (移动端)", "min": 0, "max": 120, "default": 48, "unit": "px" },
    { "type": "range", "id": "padding_top_desktop", "label": "上边距 (PC端)", "min": 0, "max": 200, "default": 80, "unit": "px" },
    { "type": "range", "id": "padding_bottom_desktop", "label": "下边距 (PC端)", "min": 0, "max": 200, "default": 80, "unit": "px" },
    { "type": "color_scheme", "id": "color_scheme", "label": "颜色方案", "default": "scheme-1" }
  ],
  "presets": [{ "name": "MK Shipping Returns