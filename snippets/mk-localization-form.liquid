{%- doc -%}
  MK 本地化表单组件

  渲染语言/货币选择表单

  @param {string} [class] - 额外CSS类名

  @example
  {% render 'mk-localization-form' %}
{%- enddoc -%}

{% liquid
  assign class = class | default: ''
-%}

{% form 'localization', class: 'mk-localization-form {{ class }}' %}
  <div class="mk-localization-form__row">
    <div class="mk-localization-form__field">
      <label for="locale-code">{{ 语言 | default: '语言' }}</label>
      <select name="locale_code" id="locale-code" class="mk-localization-form__select">
        {%- for locale in form.available_locales -%}
          <option value="{{ locale.iso_code }}" {% if locale.iso_code == localization.language.iso_code %}selected{% endif %}>
            {{ locale.endonym_name }}
          </option>
        {%- endfor -%}
      </select>
    </div>

    <div class="mk-localization-form__field">
      <label for="currency-code">{{ 货币 | default: '货币' }}</label>
      <select name="currency_code" id="currency-code" class="mk-localization-form__select">
        {%- for currency in form.available_currencies -%}
          <option value="{{ currency.iso_code }}" {% if currency.iso_code == localization.currency.iso_code %}selected{% endif %}>
            {{ currency.iso_code }} ({{ currency.symbol }})
          </option>
        {%- endfor -%}
      </select>
    </div>
  </div>
  <button type="submit" class="mk-localization-form__submit">{{ 更新 | default: '更新' }}</button>
{% endform %}

{% stylesheet %}
  .mk-localization-form { display: flex; flex-direction: column; gap: var(--mk-spacing-lg); }
  .mk-localization-form__row { display: flex; gap: var(--mk-spacing-lg); flex-wrap: wrap; }
  .mk-localization-form__field { flex: 1; min-width: 150px; display: flex; flex-direction: column; gap: 6px; }
  .mk-localization-form__field label { font-size: var(--mk-font-size-sm); font-weight: 500; }
  .mk-localization-form__select {
    padding: var(--mk-spacing-sm) 12px; font-size: var(--mk-font-size-md); border: 1px solid var(--color-border);
    border-radius: var(--mk-radius-sm); background: var(--color-background); cursor: pointer;
  }
  .mk-localization-form__select:focus { outline: none; border-color: var(--color-primary, #000); }
  .mk-localization-form__submit {
    align-self: flex-start; padding: var(--mk-spacing-sm) 20px; font-size: var(--mk-font-size-md); font-weight: 600;
    color: var(--color-on-primary, #fff); background: var(--color-primary, #000);
    border: none; border-radius: var(--mk-radius-sm); cursor: pointer;
  }
{% endstylesheet %}
