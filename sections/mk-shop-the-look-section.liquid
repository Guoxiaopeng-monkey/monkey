{%- comment -%}
  MK Shop The Look Section板块

  穿搭推荐区块

  作者：崽崽 (AI助手)
{%- endcomment -%}

{% liquid
  assign ss = section.settings
-%}

<section id="{{ section.id }}" class="mk-shop-the-look-section color-{{ ss.color_scheme | default: 'background-1' }}">
  <div class="mk-shop-the-look-section__container">
    {%- if ss.title != blank -%}
      <h2 class="mk-shop-the-look-section__title">{{ ss.title }}</h2>
    {%- endif -%}

    <div class="mk-shop-the-look-section__looks">
      {%- for i in (1..3) -%}
        {%- assign image_setting = 'image_' | append: i -%}
        {%- assign name_setting = 'name_' | append: i -%}
        {%- assign desc_setting = 'description_' | append: i -%}

        {%- if ss[image_setting] != blank -%}
          <div class="mk-shop-the-look-section__look">
            <div class="mk-shop-the-look-section__image">
              {{ ss[image_setting] | image_url: width: 600 | image_tag: loading: 'lazy' }}
              {%- if ss[name_setting] != blank -%}
                <div class="mk-shop-the-look-section__badge">{{ ss[name_setting] }}</div>
              {%- endif -%}
            </div>
            {%- if ss[desc_setting] != blank -%}
              <p class="mk-shop-the-look-section__description">{{ ss[desc_setting] }}</p>
            {%- endif -%}
          </div>
        {%- endif -%}
      {%- endfor -%}
    </div>
  </div>
</section>

{% stylesheet %}
  .mk-shop-the-look-section { padding: {{ ss.padding_top_mobile | default: 48 }}px 0 {{ ss.padding_bottom_mobile | default: 48 }}px; }
  @media (min-width: 750px) { .mk-shop-the-look-section { padding: {{ ss.padding_top_desktop | default: 80 }}px 0 {{ ss.padding_bottom_desktop | default: 80 }}px; } }
  .mk-shop-the-look-section__container { max-width: var(--container-max-width, 1200px); margin: 0 auto; padding: 0 var(--container-padding, 32px); }
  .mk-shop-the-look-section__title { margin: 0 0 32px 0; font-size: 28px; font-weight: 700; text-align: center; }
  .mk-shop-the-look-section__looks { display: grid; grid-template-columns: 1fr; gap: 24px; }
  @media (min-width: 750px) { .mk-shop-the-look-section__looks { grid-template-columns: repeat(3, 1fr); gap: 32px; } }
  .mk-shop-the-look-section__image { position: relative; border-radius: 16px; overflow: hidden; }
  .mk-shop-the-look-section__image img { width: 100%; height: auto; display: block; transition: transform 0.3s ease; }
  .mk-shop-the-look-section__look:hover .mk-shop-the-look-section__image img { transform: scale(1.03); }
  .mk-shop-the-look-section__badge { position: absolute; bottom: 16px; left: 16px; padding: 8px 16px; font-size: 13px; font-weight: 600; color: #fff; background: rgba(0,0,0,0.7); border-radius: 100px; }
  .mk-shop-the-look-section__description { margin: 12px 0 0 0; font-size: 14px; color: var(--color-text-secondary, #666); }
{% endstylesheet %}

{% schema %}
{
  "name": "MK Shop The Look Section",
  "tag": "section",
  "settings": [
    { "type": "text", "id": "title", "label": "标题" },
    { "type": "header", "content": "Look 1" }, { "type": "image_picker", "id": "image_1", "label": "图片 1" }, { "type": "text", "id": "name_1", "label": "名称 1" }, { "type": "textarea", "id": "description_1", "label": "描述 1" },
    { "type": "header", "content": "Look 2" }, { "type": "image_picker", "id": "image_2", "label": "图片 2" }, { "type": "text", "id": "name_2", "label": "名称 2" }, { "type": "textarea", "id": "description_2", "label": "描述 2" },
    { "type": "header", "content": "Look 3" }, { "type": "image_picker", "id": "image_3", "label": "图片 3" }, { "type": "text", "id": "name_3", "label": "名称 3" }, { "type": "textarea", "id": "description_3", "label": "描述 3" },
    { "type": "header", "content": "间距" },
    { "type": "range", "id": "padding_top_mobile", "label": "上边距 (移动端)", "min": 0, "max": 120, "default": 48, "unit": "px" },
    { "type": "range", "id": "padding_bottom_mobile", "label": "下边距 (移动端)", "min": 0, "max": 120, "default": 48, "unit": "px" },
    { "type": "range", "id": "padding_top_desktop", "label": "上边距 (PC端)", "min": 0, "max": 200, "default": 80, "unit": "px" },
    { "type": "range", "id": "padding_bottom_desktop", "label": "下边距 (PC端)", "min": 0, "max": 200, "default": 80, "unit": "px" },
    { "type": "color_scheme", "id": "color_scheme", "label": "颜色方案", "default": "scheme-1" }
  ],
  "presets": [{ "name": "MK Shop The Look Section" }]
}
{% endschema %}
