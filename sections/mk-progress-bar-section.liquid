{%- comment -%}
  MK Progress Bar Section板块

  进度条区块

  作者：崽崽 (AI助手)
{%- endcomment -%}

{% liquid
  assign ss = section.settings
-%}

<section id="{{ section.id }}" class="mk-progress-bar-section color-{{ ss.color_scheme | default: 'background-1' }}">
  <div class="mk-progress-bar-section__container">
    {%- if ss.title != blank -%}
      <h3 class="mk-progress-bar-section__title">{{ ss.title }}</h3>
    {%- endif -%}

    <div class="mk-progress-bar-section__bar">
      <div class="mk-progress-bar-section__track">
        <div class="mk-progress-bar-section__fill" style="width: {{ ss.percentage | default: 0 }}%;"></div>
      </div>
      <span class="mk-progress-bar-section__label">{{ ss.percentage | default: 0 }}%</span>
    </div>

    {%- if ss.subtitle != blank -%}
      <p class="mk-progress-bar-section__subtitle">{{ ss.subtitle }}</p>
    {%- endif -%}
  </div>
</section>

{% stylesheet %}
  .mk-progress-bar-section { padding: var(--mk-spacing-2xl) 0; }
  .mk-progress-bar-section__container { max-width: var(--container-max-width, 600px); margin: 0 auto; padding: 0 var(--container-padding, 32px); }
  .mk-progress-bar-section__title { margin: 0 0 16px 0; font-size: var(--mk-font-size-xl); font-weight: 600; text-align: center; }
  .mk-progress-bar-section__bar { display: flex; align-items: center; gap: var(--mk-spacing-md); }
  .mk-progress-bar-section__track { flex: 1; height: 8px; background: var(--color-background-secondary, var(--mk-color-bg-secondary)); border-radius: 100px; overflow: hidden; }
  .mk-progress-bar-section__fill { height: 100%; background: var(--color-primary, #000); border-radius: 100px; transition: width 0.5s ease; }
  .mk-progress-bar-section__label { font-size: var(--mk-font-size-md); font-weight: 700; min-width: 40px; text-align: right; }
  .mk-progress-bar-section__subtitle { margin: var(--mk-spacing-md) 0 0 0; font-size: var(--mk-font-size-sm); color: var(--color-text-secondary, #666); text-align: center; }
{% endstylesheet %}

{% schema %}
{
  "name": "MK Progress Bar Section",
  "tag": "section",
  "settings": [
    { "type": "text", "id": "title", "label": "标题" },
    { "type": "range", "id": "percentage", "label": "百分比", "min": 0, "max": 100, "default": 50 },
    { "type": "text", "id": "subtitle", "label": "副标题" },
    { "type": "color_scheme", "id": "color_scheme", "label": "颜色方案", "default": "scheme-1" }
  ],
  "presets": [{ "name": "MK Progress Bar Section" }]
}
{% endschema %}
