{%- comment -%}
  MK Newsletter Simple Section板块

  简洁订阅区块

  作者：崽崽 (AI助手)
{%- endcomment -%}

{% liquid
  assign ss = section.settings
-%}

<section id="{{ section.id }}" class="mk-newsletter-simple color-{{ ss.color_scheme | default: 'background-1' }}">
  <div class="mk-newsletter-simple__container">
    {%- if ss.title != blank -%}
      <h2 class="mk-newsletter-simple__title">{{ ss.title }}</h2>
    {%- endif -%}

    {%- form 'customer', class: 'mk-newsletter-simple__form' -%}
      <input type="hidden" name="contact[tags]" value="newsletter">
      <input type="email" name="contact[email]" required class="mk-newsletter-simple__input" placeholder="{{ ss.placeholder | default: '输入邮箱地址' }}">
      <button type="submit" class="mk-newsletter-simple__btn">{{ ss.button_text | default: '订阅' }}</button>
    {%- endform -%}

    {%- if ss.privacy_text != blank -%}
      <p class="mk-newsletter-simple__privacy">{{ ss.privacy_text }}</p>
    {%- endif -%}
  </div>
</section>

{% stylesheet %}
  .mk-newsletter-simple { padding: {{ ss.padding_top_mobile | default: 48 }}px 0 {{ ss.padding_bottom_mobile | default: 48 }}px; }
  @media (min-width: 750px) { .mk-newsletter-simple { padding: {{ ss.padding_top_desktop | default: 80 }}px 0 {{ ss.padding_bottom_desktop | default: 80 }}px; } }
  .mk-newsletter-simple__container { max-width: var(--container-max-width, 600px); margin: 0 auto; padding: 0 var(--container-padding, 32px); text-align: center; }
  .mk-newsletter-simple__title { margin: 0 0 20px 0; font-size: 28px; font-weight: 700; }
  .mk-newsletter-simple__form { display: flex; gap: 8px; }
  .mk-newsletter-simple__input { flex: 1; padding: 14px 16px; font-size: 14px; border: 1px solid var(--color-border); border-radius: 8px; background: var(--color-background); }
  .mk-newsletter-simple__btn { padding: 14px 28px; font-size: 14px; font-weight: 600; color: var(--color-on-primary, #fff); background: var(--color-primary, #000); border: none; border-radius: 8px; cursor: pointer; white-space: nowrap; }
  .mk-newsletter-simple__btn:hover { opacity: 0.85; }
  .mk-newsletter-simple__privacy { margin: 12px 0 0 0; font-size: 12px; color: var(--color-text-secondary, #666); }
{% endstylesheet %}

{% schema %}
{
  "name": "MK Newsletter Simple",
  "tag": "section",
  "settings": [
    { "type": "text", "id": "title", "label": "标题" },
    { "type": "text", "id": "placeholder", "label": "占位符" },
    { "type": "text", "id": "button_text", "label": "按钮文字", "default": "订阅" },
    { "type": "text", "id": "privacy_text", "label": "隐私说明" },
    { "type": "header", "content": "间距" },
    { "type": "range", "id": "padding_top_mobile", "label": "上边距 (移动端)", "min": 0, "max": 120, "default": 48, "unit": "px" },
    { "type": "range", "id": "padding_bottom_mobile", "label": "下边距 (移动端)", "min": 0, "max": 120, "default": 48, "unit": "px" },
    { "type": "range", "id": "padding_top_desktop", "label": "上边距 (PC端)", "min": 0, "max": 200, "default": 80, "unit": "px" },
    { "type": "range", "id": "padding_bottom_desktop", "label": "下边距 (PC端)", "min": 0, "max": 200, "default": 80, "unit": "px" },
    { "type": "color_scheme", "id": "color_scheme", "label": "颜色方案", "default": "scheme-1" }
  ],
  "presets": [{ "name": "MK Newsletter Simple" }]
}
{% endschema %}
