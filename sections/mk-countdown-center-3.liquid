{%- comment -%}
  MK Countdown Center 3板块

  居中倒计时第三版

  作者：崽崽 (AI助手)
{%- endcomment -%}

{% liquid
  assign ss = section.settings
-%}

<section id="{{ section.id }}" class="mk-countdown-center-3">
  <div class="mk-countdown-center-3__bg">
    {%- if ss.image != blank -%}
      {{ ss.image | image_url: width: 1920 | image_tag: loading: 'lazy', class: 'mk-countdown-center-3__image' }}
    {%- endif -%}
    <div class="mk-countdown-center-3__overlay"></div>
  </div>
  <div class="mk-countdown-center-3__content">
    {%- if ss.subtitle != blank -%}
      <p class="mk-countdown-center-3__subtitle">{{ ss.subtitle }}</p>
    {%- endif -%}
    {%- if ss.title != blank -%}
      <h2 class="mk-countdown-center-3__title">{{ ss.title }}</h2>
    {%- endif -%}
    <div class="mk-countdown-center-3__countdown" data-countdown-center-3 data-end="{{ ss.end_date | default: '' | date: '%Y-%m-%dT%H:%M:%S' }}">
      <div class="mk-countdown-center-3__item"><span class="mk-countdown-center-3__num" data-days>00</span><span class="mk-countdown-center-3__label">Days</span></div>
      <div class="mk-countdown-center-3__item"><span class="mk-countdown-center-3__num" data-hours>00</span><span class="mk-countdown-center-3__label">Hours</span></div>
      <div class="mk-countdown-center-3__item"><span class="mk-countdown-center-3__num" data-minutes>00</span><span class="mk-countdown-center-3__label">Minutes</span></div>
      <div class="mk-countdown-center-3__item"><span class="mk-countdown-center-3__num" data-seconds>00</span><span class="mk-countdown-center-3__label">Seconds</span></div>
    </div>
    {%- if ss.button_text != blank -%}
      <a href="{{ ss.button_link | default: '#' }}" class="mk-countdown-center-3__btn">{{ ss.button_text }}</a>
    {%- endif -%}
  </div>
</section>

{% stylesheet %}
  .mk-countdown-center-3 { position: relative; min-height: 600px; display: flex; align-items: center; justify-content: center; }
  .mk-countdown-center-3__bg { position: absolute; inset: 0; }
  .mk-countdown-center-3__image { width: 100%; height: 100%; object-fit: cover; }
  .mk-countdown-center-3__overlay { position: absolute; inset: 0; background: linear-gradient(to bottom, rgba(0,0,0,0.3), rgba(0,0,0,0.7)); }
  .mk-countdown-center-3__content { position: relative; z-index: 1; text-align: center; padding: 64px 32px; max-width: 800px; }
  .mk-countdown-center-3__subtitle { margin: 0 0 16px 0; font-size: 14px; font-weight: 600; text-transform: uppercase; letter-spacing: 2px; color: rgba(255,255,255,0.8); }
  .mk-countdown-center-3__title { margin: 0 0 40px 0; font-size: 48px; font-weight: 700; color: #fff; }
  .mk-countdown-center-3__countdown { display: flex; justify-content: center; gap: 20px; margin-bottom: 40px; }
  .mk-countdown-center-3__item { display: flex; flex-direction: column; align-items: center; gap: 8px; }
  .mk-countdown-center-3__num { min-width: 90px; padding: 20px; background: rgba(255,255,255,0.15); backdrop-filter: blur(10px); border-radius: 16px; font-size: 44px; font-weight: 700; color: #fff; }
  .mk-countdown-center-3__label { font-size: 11px; text-transform: uppercase; letter-spacing: 1px; color: rgba(255,255,255,0.7); }
  .mk-countdown-center-3__btn { display: inline-flex; padding: 16px 40px; font-size: 14px; font-weight: 600; color: #000; background: #fff; border-radius: 100px; text-decoration: none; }
{% endstylesheet %}

{% javascript %}
  (function() {
    const c = document.querySelector('[data-countdown-center-3]');
    if (!c) return;
    const end = new Date(c.dataset.end).getTime();
    function u() {
      const now = Date.now(), diff = Math.max(0, end - now);
      const d = Math.floor(diff/86400000), h = Math.floor((diff%86400000)/3600000), m = Math.floor((diff%3600000)/60000), s = Math.floor((diff%60000)/1000);
      c.querySelector('[data-days]').textContent = String(d).padStart(2,'0');
      c.querySelector('[data-hours]').textContent = String(h).padStart(2,'0');
      c.querySelector('[data-minutes]').textContent = String(m).padStart(2,'0');
      c.querySelector('[data-seconds]').textContent = String(s).padStart(2,'0');
    }
    u(); setInterval(u, 1000);
  })();
{% endjavascript %}

{% schema %}
{
  "name": "MK Countdown Center 3",
  "tag": "section",
  "settings": [
    { "type": "image_picker", "id": "image", "label": "背景图片" },
    { "type": "text", "id": "subtitle", "label": "副标题" },
    { "type": "text", "id": "title", "label": "标题" },
    { "type": "text", "id": "end_date", "label": "结束日期" },
    { "type": "text", "id": "button_text", "label": "按钮文字" },
    { "type": "url", "id": "button_link", "label": "按钮链接" }
  ],
  "presets": [{ "name": "MK Countdown Center 3" }]
}
{% endschema %}
