{%- doc -%}
  MK 预测搜索组件

  渲染预测搜索下拉框

  @param {string} [class] - 额外CSS类名

  @example
  <div class="mk-predictive-search-wrapper">
    {% render 'mk-predictive-search' %}
  </div>
{%- enddoc -%}

{% liquid
  assign class = class | default: ''
-%}

<div class="mk-predictive-search {{ class }}" data-predictive-search>
  <div class="mk-predictive-search__loading" hidden>
    <span class="mk-predictive-search__spinner"></span>
  </div>

  <div class="mk-predictive-search__results" hidden>
    <div class="mk-predictive-search__result" data-result-type="products">
      <h4 class="mk-predictive-search__result-title">{{ 'general.search.products' | t | default: '产品' }}</h4>
      <ul class="mk-predictive-search__list" data-result-list="products"></ul>
    </div>

    <div class="mk-predictive-search__result" data-result-type="collections">
      <h4 class="mk-predictive-search__result-title">{{ 'general.search.collections' | t | default: '集合' }}</h4>
      <ul class="mk-predictive-search__list" data-result-list="collections"></ul>
    </div>

    <div class="mk-predictive-search__result" data-result-type="articles">
      <h4 class="mk-predictive-search__result-title">{{ 'general.search.articles' | t | default: '文章' }}</h4>
      <ul class="mk-predictive-search__list" data-result-list="articles"></ul>
    </div>
  </div>

  <div class="mk-predictive-search__empty" hidden>
    <p>{{ 'general.search.no_results' | t | default: '没有找到相关结果' }}</p>
  </div>
</div>

{% stylesheet %}
  .mk-predictive-search {
    position: relative;
    background-color: var(--color-background);
    border: 1px solid var(--color-border);
    border-radius: var(--mk-radius-md);
    box-shadow: 0 4px 20px var(--mk-shadow-md));
    overflow: hidden;
  }

  .mk-predictive-search[hidden] {
    display: none;
  }

  .mk-predictive-search__loading {
    display: flex;
    align-items: center;
    justify-content: center;
    padding: var(--mk-spacing-2xl);
  }

  .mk-predictive-search__spinner {
    width: 24px;
    height: 24px;
    border: 2px solid var(--color-border);
    border-top-color: var(--color-primary, #000);
    border-radius: 50%;
    animation: mk-spin 0.8s linear infinite;
  }

  @keyframes mk-spin {
    to {
      transform: rotate(360deg);
    }
  }

  .mk-predictive-search__results {
    max-height: 400px;
    overflow-y: auto;
  }

  .mk-predictive-search__result {
    padding: var(--mk-spacing-lg);
    border-bottom: 1px solid var(--color-border);
  }

  .mk-predictive-search__result:last-child {
    border-bottom: none;
  }

  .mk-predictive-search__result-title {
    margin: 0 0 12px 0;
    font-size: var(--mk-font-size-sm);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 1px;
    color: var(--color-text-secondary, #666);
  }

  .mk-predictive-search__list {
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .mk-predictive-search__list li {
    margin-bottom: 8px;
  }

  .mk-predictive-search__list li:last-child {
    margin-bottom: 0;
  }

  .mk-predictive-search__item {
    display: flex;
    align-items: center;
    gap: var(--mk-spacing-md);
    padding: var(--mk-spacing-sm);
    text-decoration: none;
    color: var(--color-foreground);
    border-radius: var(--mk-radius-sm);
    transition: background-color 0.2s ease;
  }

  .mk-predictive-search__item:hover {
    background-color: var(--color-background-secondary, var(--mk-color-bg-secondary));
  }

  .mk-predictive-search__item-image {
    width: 48px;
    height: 48px;
    object-fit: cover;
    border-radius: var(--mk-radius-xs);
  }

  .mk-predictive-search__item-info {
    flex: 1;
    min-width: 0;
  }

  .mk-predictive-search__item-title {
    margin: 0 0 2px 0;
    font-size: var(--mk-font-size-md);
    font-weight: 500;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .mk-predictive-search__item-price {
    font-size: var(--mk-font-size-sm);
    color: var(--color-text-secondary, #666);
  }

  .mk-predictive-search__empty {
    padding: var(--mk-spacing-2xl);
    text-align: center;
  }

  .mk-predictive-search__empty p {
    margin: 0;
    font-size: var(--mk-font-size-md);
    color: var(--color-text-secondary, #666);
  }
{% endstylesheet %}
