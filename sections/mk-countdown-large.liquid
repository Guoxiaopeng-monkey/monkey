{%- comment -%}
  MK Countdown Large板块

  大号倒计时

  作者：崽崽 (AI助手)
{%- endcomment -%}

{% liquid
  assign ss = section.settings
-%}

<section id="{{ section.id }}" class="mk-countdown-large color-{{ ss.color_scheme | default: 'background-1' }}">
  <div class="mk-countdown-large__container">
    {%- if ss.title != blank -%}
      <h2 class="mk-countdown-large__title">{{ ss.title }}</h2>
    {%- endif -%}
    <div class="mk-countdown-large__countdown" data-countdown-large data-end="{{ ss.end_date | default: '' | date: '%Y-%m-%dT%H:%M:%S' }}">
      <div class="mk-countdown-large__item"><span class="mk-countdown-large__num" data-days>00</span><span class="mk-countdown-large__label">Days</span></div>
      <div class="mk-countdown-large__sep">:</div>
      <div class="mk-countdown-large__item"><span class="mk-countdown-large__num" data-hours>00</span><span class="mk-countdown-large__label">Hours</span></div>
      <div class="mk-countdown-large__sep">:</div>
      <div class="mk-countdown-large__item"><span class="mk-countdown-large__num" data-minutes>00</span><span class="mk-countdown-large__label">Minutes</span></div>
      <div class="mk-countdown-large__sep">:</div>
      <div class="mk-countdown-large__item"><span class="mk-countdown-large__num" data-seconds>00</span><span class="mk-countdown-large__label">Seconds</span></div>
    </div>
  </div>
</section>

{% stylesheet %}
  .mk-countdown-large { padding: 100px 0; background: var(--color-background-secondary, var(--mk-color-bg-secondary)); text-align: center; }
  .mk-countdown-large__container { max-width: 1000px; margin: 0 auto; padding: 0 32px; }
  .mk-countdown-large__title { margin: 0 0 48px 0; font-size: 42px; font-weight: 700; }
  .mk-countdown-large__countdown { display: flex; justify-content: center; align-items: center; gap: var(--mk-spacing-lg); }
  .mk-countdown-large__item { display: flex; flex-direction: column; align-items: center; gap: var(--mk-spacing-md); }
  .mk-countdown-large__num { min-width: 120px; padding: var(--mk-spacing-2xl); background: var(--color-background); border-radius: 20px; font-size: 56px; font-weight: 700; box-shadow: 0 4px 20px rgba(0,0,0,0.08); }
  .mk-countdown-large__label { font-size: var(--mk-font-size-sm); text-transform: uppercase; letter-spacing: 2px; color: var(--color-text-secondary, #666); }
  .mk-countdown-large__sep { font-size: 56px; font-weight: 700; color: var(--color-border); }
{% endstylesheet %}

{% javascript %}
  (function() {
    const c = document.querySelector('[data-countdown-large]');
    if (!c) return;
    const end = new Date(c.dataset.end).getTime();
    function u() {
      const now = Date.now(), diff = Math.max(0, end - now);
      const d = Math.floor(diff/86400000), h = Math.floor((diff%86400000)/3600000), m = Math.floor((diff%3600000)/60000), s = Math.floor((diff%60000)/1000);
      c.querySelector('[data-days]').textContent = String(d).padStart(2,'0');
      c.querySelector('[data-hours]').textContent = String(h).padStart(2,'0');
      c.querySelector('[data-minutes]').textContent = String(m).padStart(2,'0');
      c.querySelector('[data-seconds]').textContent = String(s).padStart(2,'0');
    }
    u(); setInterval(u, 1000);
  })();
{% endjavascript %}

{% schema %}
{
  "name": "MK Countdown Large",
  "tag": "section",
  "settings": [
    { "type": "text", "id": "title", "label": "标题" },
    { "type": "text", "id": "end_date", "label": "结束日期" },
    { "type": "color_scheme", "id": "color_scheme", "label": "颜色方案", "default": "scheme-1" }
  ],
  "presets": [{ "name": "MK Countdown Large" }]
}
{% endschema %}
