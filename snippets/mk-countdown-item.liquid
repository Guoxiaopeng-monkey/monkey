{%- doc -%}
  MK 倒计时项组件

  渲染单个倒计时数字

  @param {number} value - 数值
  @param {string} label - 标签（如 天、时、分、秒）

  @example
  {% render 'mk-countdown-item', value: days, label: '天' %}
{%- enddoc -%}

{% liquid
  assign value = value | default: 0
  assign label = label | default: ''
-%}

<div class="mk-countdown-item">
  <span class="mk-countdown-item__value">{{ value | prepend: '0' | slice: -2, 2 }}</span>
  {%- if label != blank -%}
    <span class="mk-countdown-item__label">{{ label }}</span>
  {%- endif -%}
</div>

{% stylesheet %}
  .mk-countdown-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 4px;
    min-width: 60px;
  }

  .mk-countdown-item__value {
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 12px 16px;
    font-size: 28px;
    font-weight: 700;
    color: var(--color-foreground);
    background-color: var(--color-background-secondary, #f5f5f5);
    border-radius: 8px;
  }

  .mk-countdown-item__label {
    font-size: 12px;
    font-weight: 500;
    color: var(--color-text-secondary, #666);
    text-transform: uppercase;
    letter-spacing: 1px;
  }
{% endstylesheet %}
