{%- comment -%}
  MK 图片画廊组件

  展示多张图片的画廊

  作者：崽崽 (AI助手)
{%- endcomment -%}

{% liquid
  assign ss = section.settings
  assign aspect_ratio = ss.aspect_ratio | default: '1/1'
-%}

<section
  id="{{ section.id }}"
  class="mk-image-gallery color-{{ ss.color_scheme | default: 'background-1' }}"
>
  <div class="mk-image-gallery__container">
    {%- if ss.title != blank -%}
      <h2 class="mk-image-gallery__title">{{ ss.title }}</h2>
    {%- endif -%}

    <div class="mk-image-gallery__grid" style="--aspect-ratio: {{ aspect_ratio }};">
      {%- for i in (1..6) -%}
        {%- assign image_setting = 'image_' | append: i -%}
        {%- assign link_setting = 'link_' | append: i -%}
        {%- assign image = ss[image_setting] -%}
        {%- assign link = ss[link_setting] -%}

        {%- if image != blank -%}
          <div class="mk-image-gallery__item">
            {%- if link != blank -%}
              <a href="{{ link }}" class="mk-image-gallery__link">
            {%- endif -%}

            {{ image | image_url: width: 800 | image_tag: class: 'mk-image-gallery__image' }}

            {%- if link != blank -%}
              </a>
            {%- endif -%}
          </div>
        {%- endif -%}
      {%- endfor -%}
    </div>
  </div>
</section>

{% stylesheet %}
  .mk-image-gallery {
    padding: {{ ss.padding_top_mobile | default: 48 }}px 0 {{ ss.padding_bottom_mobile | default: 48 }}px;
  }

  @media (min-width: 750px) {
    .mk-image-gallery {
      padding: {{ ss.padding_top_desktop | default: 64 }}px 0 {{ ss.padding_bottom_desktop | default: 64 }}px;
    }
  }

  .mk-image-gallery__container {
    max-width: var(--container-max-width, 1200px);
    margin: 0 auto;
    padding: 0 var(--container-padding, 32px);
  }

  .mk-image-gallery__title {
    margin: 0 0 24px 0;
    font-size: var(--mk-font-size-3xl);
    font-weight: 700;
    text-align: center;
  }

  .mk-image-gallery__grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--mk-spacing-sm);
  }

  @media (min-width: 480px) {
    .mk-image-gallery__grid {
      grid-template-columns: repeat(3, 1fr);
      gap: var(--mk-spacing-md);
    }
  }

  @media (min-width: 750px) {
    .mk-image-gallery__grid {
      grid-template-columns: repeat(3, 1fr);
      gap: var(--mk-spacing-lg);
    }

    .mk-image-gallery__grid:has(.mk-image-gallery__item:nth-child(5)) {
      grid-template-columns: repeat(4, 1fr);
    }

    .mk-image-gallery__grid:has(.mk-image-gallery__item:nth-child(6)) {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  .mk-image-gallery__item {
    position: relative;
    overflow: hidden;
    border-radius: var(--mk-radius-sm);
    background-color: var(--color-background-secondary, var(--mk-color-bg-secondary));
  }

  .mk-image-gallery__link {
    display: block;
    cursor: pointer;
  }

  .mk-image-gallery__image {
    width: 100%;
    aspect-ratio: var(--aspect-ratio, 1 / 1);
    object-fit: cover;
    transition: transform 0.3s ease;
  }

  .mk-image-gallery__item:hover .mk-image-gallery__image {
    transform: scale(1.05);
  }

  @media (min-width: 750px) {
    .mk-image-gallery__grid:has(.mk-image-gallery__item:nth-child(5)) .mk-image-gallery__item:first-child {
      grid-row: span 2;
    }

    .mk-image-gallery__grid:has(.mk-image-gallery__item:nth-child(5)) .mk-image-gallery__item:first-child .mk-image-gallery__image {
      aspect-ratio: 1 / 2;
    }
  }
{% endstylesheet %}

