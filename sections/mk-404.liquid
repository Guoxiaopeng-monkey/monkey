{%- comment -%}
  MK 404错误页面

  展示404错误页面

  作者：崽崽 (AI助手)
{%- endcomment -%}

{% liquid
  assign ss = section.settings
-%}

<section
  id="{{ section.id }}"
  class="mk-404 color-{{ ss.color_scheme | default: 'background-1' }}"
>
  <div class="mk-404__container">
    <h1 class="mk-404__title">404</h1>

    {%- if ss.title != blank -%}
      <h2 class="mk-404__subtitle">{{ ss.title }}</h2>
    {%- else -%}
      <h2 class="mk-404__subtitle">{{ '404.title' | t | default: '页面未找到' }}</h2>
    {%- endif -%}

    {%- if ss.description != blank -%}
      <p class="mk-404__description">{{ ss.description }}</p>
    {%- else -%}
      <p class="mk-404__description">{{ '404.message' | t | default: '抱歉，您访问的页面不存在或已移除。' }}</p>
    {%- endif -%}

    <div class="mk-404__actions">
      <a href="{{ routes.root_url }}" class="mk-404__button mk-404__button--primary">
        {{ '404.homepage' | t | default: '返回首页' }}
      </a>

      {%- if ss.show_search -%}
        <a href="{{ routes.search_url }}" class="mk-404__button mk-404__button--secondary">
          {{ '404.search' | t | default: '搜索产品' }}
        </a>
      {%- endif -%}
    </div>
  </div>
</section>

{% stylesheet %}
  .mk-404 {
    min-height: 60vh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: {{ ss.padding_top_mobile | default: 48 }}px 0 {{ ss.padding_bottom_mobile | default: 48 }}px;
  }

  @media (min-width: 750px) {
    .mk-404 {
      padding: {{ ss.padding_top_desktop | default: 64 }}px 0 {{ ss.padding_bottom_desktop | default: 64 }}px;
    }
  }

  .mk-404__container {
    max-width: 500px;
    margin: 0 auto;
    padding: 0 var(--container-padding, 32px);
    text-align: center;
  }

  .mk-404__title {
    margin: 0 0 16px 0;
    font-size: 120px;
    font-weight: 700;
    line-height: 1;
    color: var(--color-primary, #000);
    opacity: 0.1;
  }

  @media (min-width: 750px) {
    .mk-404__title {
      font-size: 180px;
    }
  }

  .mk-404__subtitle {
    margin: 0 0 16px 0;
    font-size: 24px;
    font-weight: 700;
  }

  @media (min-width: 750px) {
    .mk-404__subtitle {
      font-size: 32px;
    }
  }

  .mk-404__description {
    margin: 0 0 32px 0;
    font-size: 16px;
    line-height: 1.7;
    color: var(--color-text-secondary, #666);
  }

  .mk-404__actions {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  @media (min-width: 480px) {
    .mk-404__actions {
      flex-direction: row;
      justify-content: center;
    }
  }

  .mk-404__button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 14px 28px;
    font-size: 14px;
    font-weight: 600;
    text-decoration: none;
    border-radius: 8px;
    transition: all 0.2s ease;
  }

  .mk-404__button--primary {
    color: var(--color-on-primary, #fff);
    background-color: var(--color-primary, #000);
  }

  .mk-404__button--primary:hover {
    opacity: 0.85;
  }

  .mk-404__button--secondary {
    color: var(--color-foreground);
    background-color: transparent;
    border: 1px solid var(--color-border);
  }

  .mk-404__button--secondary:hover {
    background-color: var(--color-background-secondary, #f5f5f5);
  }
{% endstylesheet %}

{% schema %}
{
  "name": "MK 404页面",
  "tag": "section",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "标题",
      "default": "页面未找到"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "描述",
      "default": "抱歉，您访问的页面不存在或已移除。"
    },
    {
      "type": "checkbox",
      "id": "show_search",
      "label": "显示搜索按钮",
      "default": true
    },
    {
      "type": "header",
      "content": "间距"
    },
    {
      "type": "range",
      "id": "padding_top_mobile",
      "label": "上边距 (移动端)",
      "min": 0,
      "max": 120,
      "default": 48,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "label": "下边距 (移动端)",
      "min": 0,
      "max": 120,
      "default": 48,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_top_desktop",
      "label": "上边距 (PC端)",
      "min": 0,
      "max": 200,
      "default": 64,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_bottom_desktop",
      "label": "下边距 (PC端)",
      "min": 0,
      "max": 200,
      "default": 64,
      "unit": "px"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "颜色方案",
      "default": "scheme-1"
    }
  ],
  "presets": [
    {
      "name": "MK 404页面"
    }
  ]
}
{% endschema %}
