{%- comment -%}
  MK 对比表格组件
  
  功能：产品对比表格
  
  作者：崽崽 (AI助手)
  基于：spx-compare-card.liquid
{%- endcomment -%}

{%- liquid
  assign ss = section.settings
  assign bg_color = ss.background_color | default: '#ffffff'
  
  assign pt_mob = ss.padding_top_mobile | default: 48
  assign pb_mob = ss.padding_bottom_mobile | default: 48
  assign pt_desk = ss.padding_top_desktop | default: 80
  assign pb_desk = ss.padding_bottom_desktop | default: 80
  
  assign columns = ss.columns | default: 3
-%}

<style>
  #{{ section.id }} {
    --compare-bg: {{ bg_color }};
    --compare-pt-mob: {{ pt_mob }}px;
    --compare-pb-mob: {{ pb_mob }}px;
    --compare-pt-desk: {{ pt_desk }}px;
    --compare-pb-desk: {{ pb_desk }}px;
    --compare-cols: {{ columns }};
    background-color: var(--compare-bg);
    padding: var(--compare-pt-mob) 0 var(--compare-pb-mob);
  }
  
  @media (min-width: 750px) {
    #{{ section.id }} {
      padding: var(--compare-pt-desk) 0 var(--compare-pb-desk);
    }
  }
</style>

<section
  id="{{ section.id }}"
  class="mk-comparison-table"
  data-skip-node-update
>
  <div class="mk-comparison-table__container">
    
    {%- comment -%} 标题区域 {%- endcomment -%}
    <div class="mk-comparison-table__header">
      {% if ss.heading != blank %}
        <h2 class="mk-comparison-table__heading">{{ ss.heading }}</h2>
      {% endif %}
      {% if ss.description != blank %}
        <p class="mk-comparison-table__description">{{ ss.description }}</p>
      {% endif %}
    </div>
    
    {%- comment -%} 表格 {%- endcomment -%}
    <div class="mk-comparison-table__wrapper">
      <table class="mk-comparison-table__table">
        <thead>
          <tr class="mk-comparison-table__header-row">
            <th class="mk-comparison-table__feature-header" scope="col">
              <span class="mk-comparison-table__feature-text">{{ ss.feature_label | default: '特性' }}</span>
            </th>
            {%- for block in section.blocks -%}
              {%- if block.type == 'product' -%}
                {%- assign product = block.settings.product -%}
                <th class="mk-comparison-table__product-header" scope="col" {{ block.shopify_attributes }}>
                  {% if product != blank %}
                    <div class="mk-comparison-table__product-image">
                      <img
                        src="{{ product.featured_media | image_url: width: 200 }}"
                        alt="{{ product.title }}"
                        width="200"
                        height="{{ 200 | divided_by: product.featured_media.aspect_ratio | round }}"
                        loading="lazy"
                      >
                    </div>
                    <span class="mk-comparison-table__product-name">{{ product.title }}</span>
                  {% else %}
                    <div class="mk-comparison-table__product-image mk-comparison-table__product-image--placeholder">
                      {{ 'image' | placeholder_svg_tag: '' }}
                    </div>
                    <span class="mk-comparison-table__product-name">产品 {{ forloop.index }}</span>
                  {% endif %}
                </th>
              {%- endif -%}
            {%- endfor -%}
          </tr>
        </thead>
        <tbody>
          {%- for block in section.blocks -%}
            {%- if block.type == 'feature_row' -%}
              <tr class="mk-comparison-table__row" {{ block.shopify_attributes }}>
                <th class="mk-comparison-table__feature-cell" scope="row">
                  {{ block.settings.feature }}
                </th>
                {%- for i in (0..columns) -%}
                  <td class="mk-comparison-table__value-cell">
                    {% case block.settings.value_type %}
                      {% when 'check' %}
                        <span class="mk-comparison-table__check">{{- 'icon-check.svg' | inline_asset_content -}}</span>
                      {% when 'cross' %}
                        <span class="mk-comparison-table__cross">{{- 'icon-close.svg' | inline_asset_content -}}</span>
                      {% when 'text' %}
                        <span>{{ block.settings.value }}</span>
                    {% endcase %}
                  </td>
                {%- endfor -%}
              </tr>
            {%- endif -%}
          {%- endfor -%}
        </tbody>
        <tfoot>
          <tr class="mk-comparison-table__footer-row">
            <td class="mk-comparison-table__footer-cell"></td>
            {%- for block in section.blocks -%}
              {%- if block.type == 'product' -%}
                {%- assign product = block.settings.product -%}
                <td class="mk-comparison-table__footer-cell" {{ block.shopify_attributes }}>
                  {% if product != blank %}
                    <a href="{{ product.url }}" class="mk-comparison-table__cta">
                      {{ ss.cta_text | default: '查看详情' }}
                    </a>
                  {% endif %}
                </td>
              {%- endif -%}
            {%- endfor -%}
          </tr>
        </tfoot>
      </table>
    </div>
  </div>
</section>

{% stylesheet %}
  .mk-comparison-table__container {
    max-width: var(--container-max-width, 1440px);
    margin: 0 auto;
    padding: 0 var(--container-padding, 32px);
  }

  /* Header */
  .mk-comparison-table__header {
    text-align: center;
    max-width: 700px;
    margin: 0 auto 48px auto;
  }

  .mk-comparison-table__heading {
    margin: 0 0 16px 0;
    font-size: clamp(28px, 4vw, 40px);
    font-weight: 700;
    line-height: 1.2;
  }

  .mk-comparison-table__description {
    margin: 0;
    font-size: 16px;
    line-height: 1.6;
    opacity: 0.85;
  }

  /* Wrapper */
  .mk-comparison-table__wrapper {
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
    border-radius: 16px;
    box-shadow: 0 2px 16px rgba(0, 0, 0, 0.08);
  }

  /* Table */
  .mk-comparison-table__table {
    width: 100%;
    min-width: 600px;
    border-collapse: collapse;
    background: var(--color-background, #fff);
  }

  /* Header Row */
  .mk-comparison-table__header-row th {
    padding: 24px 20px;
    background: var(--color-background-secondary, #f9f9f9);
    border-bottom: 2px solid rgba(var(--color-border), 0.1);
  }

  .mk-comparison-table__feature-header {
    text-align: left;
    width: 25%;
  }

  .mk-comparison-table__feature-text {
    font-size: 14px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 1px;
  }

  .mk-comparison-table__product-header {
    text-align: center;
    width: calc(75% / var(--compare-cols, 3));
  }

  .mk-comparison-table__product-image {
    width: 120px;
    height: 120px;
    margin: 0 auto 16px auto;
    border-radius: 12px;
    overflow: hidden;
  }

  .mk-comparison-table__product-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .mk-comparison-table__product-image--placeholder {
    background: var(--color-background-secondary, #f5f5f5);
  }

  .mk-comparison-table__product-image--placeholder svg {
    width: 100%;
    height: 100%;
  }

  .mk-comparison-table__product-name {
    display: block;
    font-size: 16px;
    font-weight: 600;
  }

  /* Rows */
  .mk-comparison-table__row {
    border-bottom: 1px solid rgba(var(--color-border), 0.08);
  }

  .mk-comparison-table__row:last-child {
    border-bottom: none;
  }

  .mk-comparison-table__feature-cell {
    padding: 20px;
    font-size: 14px;
    font-weight: 500;
    text-align: left;
    background: var(--color-background-secondary, #f9f9f9);
  }

  .mk-comparison-table__value-cell {
    padding: 20px;
    font-size: 14px;
    text-align: center;
    vertical-align: middle;
  }

  /* Check/Cross */
  .mk-comparison-table__check,
  .mk-comparison-table__cross {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 24px;
    height: 24px;
    border-radius: 50%;
  }

  .mk-comparison-table__check {
    background: #4caf50;
    color: #fff;
  }

  .mk-comparison-table__check svg {
    width: 14px;
    height: 14px;
  }

  .mk-comparison-table__cross {
    background: #e53935;
    color: #fff;
  }

  .mk-comparison-table__cross svg {
    width: 12px;
    height: 12px;
  }

  /* Footer */
  .mk-comparison-table__footer-row {
    background: var(--color-background-secondary, #f9f9f9);
  }

  .mk-comparison-table__footer-cell {
    padding: 24px 20px;
    text-align: center;
  }

  .mk-comparison-table__cta {
    display: inline-block;
    padding: 12px 24px;
    font-size: 14px;
    font-weight: 600;
    text-decoration: none;
    color: var(--color-primary, #000);
    background: var(--color-background, #fff);
    border: 1.5px solid var(--color-primary, #000);
    border-radius: 4px;
    transition: all 0.2s ease;
  }

  .mk-comparison-table__cta:hover {
    background: var(--color-primary, #000);
    color: var(--color-background, #fff);
  }
{% endstylesheet %}

{% schema %}
{
  "name": "MK 对比表格",
  "tag": "section",
  "settings": [
    {
      "type": "header",
      "content": "内容设置"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "标题",
      "default": "产品对比"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "描述文字"
    },
    {
      "type": "text",
      "id": "feature_label",
      "label": "特性列标题",
      "default": "特性"
    },
    {
      "type": "text",
      "id": "cta_text",
      "label": "按钮文字",
      "default": "查看详情"
    },
    {
      "type": "header",
      "content": "布局设置"
    },
    {
      "type": "range",
      "id": "columns",
      "label": "产品列数",
      "min": 2,
      "max": 4,
      "default": 3
    },
    {
      "type": "header",
      "content": "颜色设置"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "背景颜色",
      "default": "#ffffff"
    },
    {
      "type": "header",
      "content": "间距设置"
    },
    {
      "type": "range",
      "id": "padding_top_mobile",
      "label": "上边距 (移动端)",
      "min": 0,
      "max": 120,
      "default": 48,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "label": "下边距 (移动端)",
      "min": 0,
      "max": 120,
      "default": 48,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_top_desktop",
      "label": "上边距 (PC端)",
      "min": 0,
      "max": 200,
      "default": 80,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_bottom_desktop",
      "label": "下边距 (PC端)",
      "min": 0,
      "max": 200,
      "default": 80,
      "unit": "px"
    }
  ],
  "blocks": [
    {
      "type": "product",
      "name": "产品",
      "settings": [
        {
          "type": "product",
          "id": "product",
          "label": "产品"
        }
      ]
    },
    {
      "type": "feature_row",
      "name": "特性行",
      "settings": [
        {
          "type": "text",
          "id": "feature",
          "label": "特性名称",
          "default": "防水性能"
        },
        {
          "type": "select",
          "id": "value_type",
          "label": "值类型",
          "options": [
            { "value": "check", "label": "✓" },
            { "value": "cross", "label": "✗" },
            { "value": "text", "label": "文本" }
          ],
          "default": "check"
        },
        {
          "type": "text",
          "id": "value",
          "label": "值（文本类型时）",
          "default": "IP68"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "MK 对比表格"
    }
  ]
}
{% endschema %}
