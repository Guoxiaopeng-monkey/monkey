{%- comment -%}
  MK Countdown Simple 2板块

  简约倒计时第二版

  作者：崽崽 (AI助手)
{%- endcomment -%}

{% liquid
  assign ss = section.settings
-%}

<div id="{{ section.id }}" class="mk-countdown-simple-2" data-countdown-simple-2 data-end="{{ ss.end_date | default: '' | date: '%Y-%m-%dT%H:%M:%S' }}">
  <span class="mk-countdown-simple-2__text">{{ ss.text | default: 'Ends in' }}:</span>
  <span class="mk-countdown-simple-2__time">
    <span data-days>00</span>d
    <span data-hours>00</span>h
    <span data-minutes>00</span>m
    <span data-seconds>00</span>s
  </span>
</div>

{% stylesheet %}
  .mk-countdown-simple-2 { display: inline-flex; align-items: center; gap: 8px; font-size: 14px; }
  .mk-countdown-simple-2__text { font-weight: 500; }
  .mk-countdown-simple-2__time { font-weight: 700; font-variant-numeric: tabular-nums; }
{% endstylesheet %}

{% javascript %}
  (function() {
    const c = document.querySelector('[data-countdown-simple-2]');
    if (!c) return;
    const end = new Date(c.dataset.end).getTime();
    function u() {
      const now = Date.now(), diff = Math.max(0, end - now);
      const d = Math.floor(diff/86400000), h = Math.floor((diff%86400000)/3600000), m = Math.floor((diff%3600000)/60000), s = Math.floor((diff%60000)/1000);
      c.querySelector('[data-days]').textContent = String(d).padStart(2,'0');
      c.querySelector('[data-hours]').textContent = String(h).padStart(2,'0');
      c.querySelector('[data-minutes]').textContent = String(m).padStart(2,'0');
      c.querySelector('[data-seconds]').textContent = String(s).padStart(2,'0');
    }
    u(); setInterval(u, 1000);
  })();
{% endjavascript %}

{% schema %}
{
  "name": "MK Countdown Simple 2",
  "tag": "div",
  "settings": [
    { "type": "text", "id": "text", "label": "文字" },
    { "type": "text", "id": "end_date", "label": "结束日期" }
  ],
  "presets": [{ "name": "MK Countdown Simple 2" }]
}
{% endschema %}
