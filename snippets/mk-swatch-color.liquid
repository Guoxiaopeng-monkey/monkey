{%- doc -%}
  MK 颜色选项组件

  渲染颜色选择色块组

  @param {object} product - 产品对象
  @param {string} [class] - 额外CSS类名

  @example
  {% render 'mk-swatch-color', product: product %}
{%- enddoc -%}

{% liquid
  assign product = product | default: nil
  assign class = class | default: ''
  assign option = nil

  for opt in product.options_with_values
    if opt.name == 'Color' or opt.name == 'Colour' or opt.name == '颜色'
      assign option = opt
      break
    endif
  endfor
-%}

{%- if option != blank -%}
  <div class="mk-swatch-color {{ class }}" data-option-index="{{ option.position | minus: 1 }}">
    <label class="mk-swatch-color__label">
      {{ option.name }}: <span class="mk-swatch-color__selected">{{ option.selected_value }}</span>
    </label>

    <div class="mk-swatch-color__swatches">
      {%- for value in option.values -%}
        {% liquid
          assign is_selected = false
          if option.selected_value == value
            assign is_selected = true
          endif

          assign is_available = true
          for variant in product.variants
            if variant.options[forloop.index0] == value and variant.available == false
              assign is_available = false
              break
            endif
          endfor

          assign color_value = value | downcase | replace: ' ', '-'
        %}

        <button
          type="button"
          class="mk-swatch-color__swatch {% if is_selected %}mk-swatch-color__swatch--selected{% endif %} {% unless is_available %}mk-swatch-color__swatch--unavailable{% endunless %}"
          data-value="{{ value }}"
          title="{{ value }}"
          style="--swatch-color: {{ color_value }};"
          {% unless is_available %}disabled{% endunless %}
        >
          <span class="mk-swatch-color__inner"></span>
        </button>
      {%- endfor -%}
    </div>
  </div>
{%- endif -%}

{% stylesheet %}
  .mk-swatch-color {
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .mk-swatch-color__label {
    font-size: 13px;
    font-weight: 500;
    color: var(--color-foreground);
  }

  .mk-swatch-color__selected {
    font-weight: 400;
    color: var(--color-text-secondary, #666);
  }

  .mk-swatch-color__swatches {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }

  .mk-swatch-color__swatch {
    position: relative;
    width: 32px;
    height: 32px;
    padding: 2px;
    background: transparent;
    border: 2px solid transparent;
    border-radius: 50%;
    cursor: pointer;
    transition: all 0.2s ease;
  }

  .mk-swatch-color__swatch:hover:not(:disabled) {
    border-color: var(--color-border);
  }

  .mk-swatch-color__swatch--selected {
    border-color: var(--color-primary, #000);
  }

  .mk-swatch-color__swatch--unavailable {
    opacity: 0.4;
    cursor: not-allowed;
  }

  .mk-swatch-color__swatch--unavailable::after {
    content: '';
    position: absolute;
    top: 50%;
    left: 0;
    right: 0;
    height: 1px;
    background-color: var(--color-text-secondary, #999);
    transform: rotate(-45deg);
  }

  .mk-swatch-color__inner {
    display: block;
    width: 100%;
    height: 100%;
    background-color: var(--swatch-color);
    border-radius: 50%;
    box-shadow: inset 0 0 0 1px rgba(0, 0, 0, 0.1);
  }
{% endstylesheet %}
