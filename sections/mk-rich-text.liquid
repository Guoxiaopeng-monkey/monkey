{%- comment -%}
  MK 富文本板块

  展示富文本内容

  作者：崽崽 (AI助手)
{%- endcomment -%}

{% liquid
  assign ss = section.settings
  assign text_alignment = ss.text_alignment | default: 'center'
-%}

<section
  id="{{ section.id }}"
  class="mk-rich-text color-{{ ss.color_scheme | default: 'background-1' }}"
>
  <div class="mk-rich-text__container">
    {%- if ss.subtitle != blank -%}
      <p class="mk-rich-text__subtitle">{{ ss.subtitle }}</p>
    {%- endif -%}

    {%- if ss.title != blank -%}
      <h2 class="mk-rich-text__title">{{ ss.title }}</h2>
    {%- endif -%}

    {%- if ss.text != blank -%}
      <div class="mk-rich-text__content">{{ ss.text }}</div>
    {%- endif -%}

    {%- if ss.button_text != blank -%}
      <div class="mk-rich-text__actions">
        <a href="{{ ss.button_link | default: '#' }}" class="mk-rich-text__button">
          {{ ss.button_text }}
        </a>
      </div>
    {%- endif -%}
  </div>
</section>

{% stylesheet %}
  .mk-rich-text {
    padding: {{ ss.padding_top_mobile | default: 48 }}px 0 {{ ss.padding_bottom_mobile | default: 48 }}px;
  }

  @media (min-width: 750px) {
    .mk-rich-text {
      padding: {{ ss.padding_top_desktop | default: 64 }}px 0 {{ ss.padding_bottom_desktop | default: 64 }}px;
    }
  }

  .mk-rich-text__container {
    max-width: var(--container-max-width, 800px);
    margin: 0 auto;
    padding: 0 var(--container-padding, 32px);
    text-align: {{ text_alignment }};
  }

  .mk-rich-text__subtitle {
    margin: 0 0 8px 0;
    font-size: var(--mk-font-size-sm);
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 1px;
    color: var(--color-text-secondary, #666);
  }

  .mk-rich-text__title {
    margin: 0 0 16px 0;
    font-size: var(--mk-font-size-3xl);
    font-weight: 700;
    line-height: 1.2;
  }

  @media (min-width: 750px) {
    .mk-rich-text__title {
      font-size: var(--mk-font-size-5xl);
    }
  }

  .mk-rich-text__content {
    font-size: var(--mk-font-size-lg);
    line-height: 1.7;
    color: var(--color-text-secondary, #666);
  }

  .mk-rich-text__content p {
    margin: 0 0 16px 0;
  }

  .mk-rich-text__content p:last-child {
    margin-bottom: 0;
  }

  .mk-rich-text__content a {
    color: var(--color-primary, #000);
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  .mk-rich-text__content a:hover {
    opacity: 0.7;
  }

  .mk-rich-text__actions {
    margin-top: 24px;
  }

  .mk-rich-text__button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 14px 32px;
    font-size: var(--mk-font-size-md);
    font-weight: 600;
    color: var(--color-on-primary, #fff);
    background-color: var(--color-primary, #000);
    border-radius: var(--mk-radius-sm);
    text-decoration: none;
    transition: all 0.2s ease;
  }

  .mk-rich-text__button:hover {
    opacity: 0.85;
    transform: translateY(-1px);
  }

  /* 左对齐变体 */
  .mk-rich-text--left .mk-rich-text__container {
    text-align: left;
  }

  /* 右对齐变体 */
  .mk-rich-text--right .mk-rich-text__container {
    text-align: right;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "MK 富文本",
  "tag": "section",
  "settings": [
    {
      "type": "text",
      "id": "subtitle",
      "label": "副标题"
    },
    {
      "type": "text",
      "id": "title",
      "label": "标题"
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "文本"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "按钮文字"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "按钮链接"
    },
    {
      "type": "select",
      "id": "text_alignment",
      "label": "文本对齐",
      "options": [
        { "value": "left", "label": "左对齐" },
        { "value": "center", "label": "居中" },
        { "value": "right", "label": "右对齐" }
      ],
      "default": "center"
    },
    {
      "type": "header",
      "content": "间距"
    },
    {
      "type": "range",
      "id": "padding_top_mobile",
      "label": "上边距 (移动端)",
      "min": 0,
      "max": 120,
      "default": 48,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "label": "下边距 (移动端)",
      "min": 0,
      "max": 120,
      "default": 48,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_top_desktop",
      "label": "上边距 (PC端)",
      "min": 0,
      "max": 200,
      "default": 64,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_bottom_desktop",
      "label": "下边距 (PC端)",
      "min": 0,
      "max": 200,
      "default": 64,
      "unit": "px"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "颜色方案",
      "default": "scheme-1"
    }
  ],
  "presets": [
    {
      "name": "MK 富文本"
    }
  ]
}
{% endschema %}
