{%- doc -%}
  MK 配送估算组件

  渲染配送日期估算

  @param {string} [class] - 额外CSS类名

  @example
  {% render 'mk-shipping-estimate' %}
{%- enddoc -%}

{% liquid
  assign class = class | default: ''
-%}

<div class="mk-shipping-estimate {{ class }}" data-shipping-estimate>
  <div class="mk-shipping-estimate__icon">
    {{- 'icon-truck.svg' | inline_asset_content -}}
  </div>
  <p class="mk-shipping-estimate__text">
    {{ 'shipping.estimate' | t | default: '配送估算' }}
  </p>
</div>

{% stylesheet %}
  .mk-shipping-estimate {
    display: flex;
    align-items: center;
    gap: var(--mk-spacing-md);
    padding: 14px 16px;
    background-color: var(--color-background-secondary, var(--mk-color-bg-secondary));
    border-radius: var(--mk-radius-sm);
    cursor: pointer;
    transition: background-color 0.2s ease;
  }

  .mk-shipping-estimate:hover {
    background-color: var(--color-border);
  }

  .mk-shipping-estimate__icon {
    display: flex;
    width: 20px;
    height: 20px;
    color: var(--color-primary, #000);
  }

  .mk-shipping-estimate__icon svg {
    width: 100%;
    height: 100%;
  }

  .mk-shipping-estimate__text {
    margin: 0;
    font-size: var(--mk-font-size-sm);
    font-weight: 500;
    color: var(--color-foreground);
  }
{% endstylesheet %}
