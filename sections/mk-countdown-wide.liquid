{%- comment -%}
  MK Countdown Wide板块

  宽型倒计时

  作者：崽崽 (AI助手)
{%- endcomment -%}

{% liquid
  assign ss = section.settings
-%}

<section id="{{ section.id }}" class="mk-countdown-wide color-{{ ss.color_scheme | default: 'background-1' }}">
  <div class="mk-countdown-wide__container">
    {%- if ss.title != blank -%}
      <h2 class="mk-countdown-wide__title">{{ ss.title }}</h2>
    {%- endif -%}
    <div class="mk-countdown-wide__countdown" data-countdown-wide data-end="{{ ss.end_date | default: '' | date: '%Y-%m-%dT%H:%M:%S' }}">
      <div class="mk-countdown-wide__item"><span class="mk-countdown-wide__num" data-days>00</span><span class="mk-countdown-wide__label">Days</span></div>
      <div class="mk-countdown-wide__item"><span class="mk-countdown-wide__num" data-hours>00</span><span class="mk-countdown-wide__label">Hours</span></div>
      <div class="mk-countdown-wide__item"><span class="mk-countdown-wide__num" data-minutes>00</span><span class="mk-countdown-wide__label">Minutes</span></div>
      <div class="mk-countdown-wide__item"><span class="mk-countdown-wide__num" data-seconds>00</span><span class="mk-countdown-wide__label">Seconds</span></div>
    </div>
  </div>
</section>

{% stylesheet %}
  .mk-countdown-wide { padding: 80px 0; }
  .mk-countdown-wide__container { max-width: 1000px; margin: 0 auto; padding: 0 32px; text-align: center; }
  .mk-countdown-wide__title { margin: 0 0 40px 0; font-size: 36px; font-weight: 700; }
  .mk-countdown-wide__countdown { display: flex; justify-content: center; gap: 24px; }
  .mk-countdown-wide__item { display: flex; flex-direction: column; align-items: center; gap: 8px; }
  .mk-countdown-wide__num { min-width: 100px; padding: 24px 16px; background: var(--color-background-secondary, #f5f5f5); border-radius: 16px; font-size: 40px; font-weight: 700; }
  .mk-countdown-wide__label { font-size: 12px; text-transform: uppercase; letter-spacing: 1px; color: var(--color-text-secondary, #666); }
{% endstylesheet %}

{% javascript %}
  (function() {
    const c = document.querySelector('[data-countdown-wide]');
    if (!c) return;
    const end = new Date(c.dataset.end).getTime();
    function u() {
      const now = Date.now(), diff = Math.max(0, end - now);
      const d = Math.floor(diff/86400000), h = Math.floor((diff%86400000)/3600000), m = Math.floor((diff%3600000)/60000), s = Math.floor((diff%60000)/1000);
      c.querySelector('[data-days]').textContent = String(d).padStart(2,'0');
      c.querySelector('[data-hours]').textContent = String(h).padStart(2,'0');
      c.querySelector('[data-minutes]').textContent = String(m).padStart(2,'0');
      c.querySelector('[data-seconds]').textContent = String(s).padStart(2,'0');
    }
    u(); setInterval(u, 1000);
  })();
{% endjavascript %}

{% schema %}
{
  "name": "MK Countdown Wide",
  "tag": "section",
  "settings": [
    { "type": "text", "id": "title", "label": "标题" },
    { "type": "text", "id": "end_date", "label": "结束日期" },
    { "type": "color_scheme", "id": "color_scheme", "label": "颜色方案", "default": "scheme-1" }
  ],
  "presets": [{ "name": "MK Countdown Wide" }]
}
{% endschema %}
