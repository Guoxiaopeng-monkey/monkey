{%- comment -%}
  MK 标签页组件
  
  功能：支持水平切换的标签页内容
  
  作者：崽崽 (AI助手)
  基于：spx-tab-*.liquid
{%- endcomment -%}

{%- liquid
  assign ss = section.settings
  assign bg_color = ss.background_color | default: '#ffffff'
  
  assign pt_mob = ss.padding_top_mobile | default: 48
  assign pb_mob = ss.padding_bottom_mobile | default: 48
  assign pt_desk = ss.padding_top_desktop | default: 80
  assign pb_desk = ss.padding_bottom_desktop | default: 80
-%}

<style>
  #{{ section.id }} {
    --tabs-bg: {{ bg_color }};
    --tabs-pt-mob: {{ pt_mob }}px;
    --tabs-pb-mob: {{ pb_mob }}px;
    --tabs-pt-desk: {{ pt_desk }}px;
    --tabs-pb-desk: {{ pb_desk }}px;
    background-color: var(--tabs-bg);
    padding: var(--tabs-pt-mob) 0 var(--tabs-pb-mob);
  }
  
  @media (min-width: 750px) {
    #{{ section.id }} {
      padding: var(--tabs-pt-desk) 0 var(--tabs-pb-desk);
    }
  }
</style>

<section
  id="{{ section.id }}"
  class="mk-tabs"
  data-skip-node-update
>
  <div class="mk-tabs__container">
    
    {%- comment -%} 标签导航 {%- endcomment -%}
    <div class="mk-tabs__nav" role="tablist">
      {%- for block in section.blocks -%}
        {%- if block.type == 'tab' -%}
          <button
            type="button"
            id="tab-{{ section.id }}-{{ forloop.index }}"
            class="mk-tabs__tab{% if forloop.first %} mk-tabs__tab--active{% endif %}"
            role="tab"
            aria-selected="{% if forloop.first %}true{% else %}false{% endif %}"
            aria-controls="tabpanel-{{ section.id }}-{{ forloop.index }}"
            data-tab-index="{{ forloop.index }}"
            {{ block.shopify_attributes }}
          >
            {{ block.settings.title }}
          </button>
        {%- endif -%}
      {%- endfor -%}
    </div>
    
    {%- comment -%} 标签面板 {%- endcomment -%}
    <div class="mk-tabs__panels">
      {%- for block in section.blocks -%}
        {%- if block.type == 'tab' -%}
          <div
            id="tabpanel-{{ section.id }}-{{ forloop.index }}"
            class="mk-tabs__panel{% if forloop.first %} mk-tabs__panel--active{% endif %}"
            role="tabpanel"
            aria-labelledby="tab-{{ section.id }}-{{ forloop.index }}"
            data-panel-index="{{ forloop.index }}"
            {% if forloop.first %}tabindex="0"{% else %}tabindex="-1"{% endif %}
          >
            <div class="mk-tabs__panel-content">
              {%- case block.settings.content_type -%}
                {%- when 'text' -%}
                  {{ block.settings.text_content }}
                  
                {%- when 'image' -%}
                  {% if block.settings.image != blank %}
                    <img
                      src="{{ block.settings.image | image_url: width: 1200 }}"
                      alt="{{ block.settings.image.alt }}"
                      width="1200"
                      height="{{ 1200 | divided_by: block.settings.image.aspect_ratio | round }}"
                      loading="lazy"
                      class="mk-tabs__panel-image"
                    >
                  {% endif %}
                  
                {%- when 'video' -%}
                  {% if block.settings.video_url != blank %}
                    <video
                      src="{{ block.settings.video_url }}"
                      autoplay="{{ block.settings.autoplay }}"
                      loop="{{ block.settings.loop }}"
                      muted="{{ block.settings.muted }}"
                      playsinline
                      controls
                      class="mk-tabs__panel-video"
                    ></video>
                  {% endif %}
                  
                {%- when 'product' -%}
                  {% if block.settings.product != blank %}
                    {% render 'mk-product-card', product: block.settings.product %}
                  {% endif %}
                  
                {%- when 'products' -%}
                  <div class="mk-tabs__panel-products">
                    {% if block.settings.product_1 != blank %}
                      {% render 'mk-product-card', product: block.settings.product_1 %}
                    {% endif %}
                    {% if block.settings.product_2 != blank %}
                      {% render 'mk-product-card', product: block.settings.product_2 %}
                    {% endif %}
                    {% if block.settings.product_3 != blank %}
                      {% render 'mk-product-card', product: block.settings.product_3 %}
                    {% endif %}
                    {% if block.settings.product_4 != blank %}
                      {% render 'mk-product-card', product: block.settings.product_4 %}
                    {% endif %}
                  </div>
              {%- endcase -%}
            </div>
          </div>
        {%- endif -%}
      {%- endfor -%}
    </div>
    
  </div>
</section>

{% stylesheet %}
  .mk-tabs__container {
    max-width: var(--container-max-width, 1440px);
    margin: 0 auto;
    padding: 0 var(--container-padding, 32px);
  }

  /* Nav */
  .mk-tabs__nav {
    display: flex;
    gap: 4px;
    margin-bottom: 32px;
    border-bottom: 2px solid rgba(var(--color-border), 0.15);
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
  }

  .mk-tabs__nav::-webkit-scrollbar {
    display: none;
  }

  .mk-tabs__tab {
    flex-shrink: 0;
    padding: 16px 24px;
    font-size: 15px;
    font-weight: 500;
    color: var(--color-text-secondary, #666);
    background: transparent;
    border: none;
    border-bottom: 2px solid transparent;
    margin-bottom: -2px;
    cursor: pointer;
    transition: all 0.2s ease;
    white-space: nowrap;
  }

  .mk-tabs__tab:hover {
    color: var(--color-primary, #000);
  }

  .mk-tabs__tab--active {
    color: var(--color-primary, #000);
    border-bottom-color: var(--color-primary, #000);
  }

  /* Panel */
  .mk-tabs__panel {
    display: none;
  }

  .mk-tabs__panel--active {
    display: block;
  }

  .mk-tabs__panel-content {
    font-size: 16px;
    line-height: 1.7;
  }

  .mk-tabs__panel-content p {
    margin: 0 0 16px 0;
  }

  .mk-tabs__panel-content p:last-child {
    margin-bottom: 0;
  }

  /* Image */
  .mk-tabs__panel-image {
    width: 100%;
    height: auto;
    border-radius: 12px;
  }

  /* Video */
  .mk-tabs__panel-video {
    width: 100%;
    height: auto;
    border-radius: 12px;
  }

  /* Products */
  .mk-tabs__panel-products {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 16px;
  }

  @media (min-width: 750px) {
    .mk-tabs__panel-products {
      grid-template-columns: repeat(4, 1fr);
      gap: 24px;
    }
  }
{% endstylesheet %}

{% javascript %}
  class MKTabs extends HTMLElement {
    constructor() {
      super();
      this.tabs = this.querySelectorAll('.mk-tabs__tab');
      this.panels = this.querySelectorAll('.mk-tabs__panel');
      
      this.init();
    }

    init() {
      this.tabs.forEach((tab) => {
        tab.addEventListener('click', () => {
          this.activateTab(tab.dataset.tabIndex);
        });
        
        tab.addEventListener('keydown', (e) => {
          if (e.key === 'ArrowLeft' || e.key === 'ArrowRight') {
            this.handleKeyboardNavigation(e);
          }
        });
      });
    }

    activateTab(index) {
      this.tabs.forEach((tab) => {
        const isActive = tab.dataset.tabIndex === index.toString();
        tab.classList.toggle('mk-tabs__tab--active', isActive);
        tab.setAttribute('aria-selected', isActive);
      });

      this.panels.forEach((panel) => {
        const isActive = panel.dataset.panelIndex === index.toString();
        panel.classList.toggle('mk-tabs__panel--active', isActive);
        panel.tabIndex = isActive ? 0 : -1;
      });
    }

    handleKeyboardNavigation(e) {
      const currentIndex = Array.from(this.tabs).findIndex((tab) => 
        tab.classList.contains('mk-tabs__tab--active')
      );
      
      let newIndex;
      if (e.key === 'ArrowLeft') {
        newIndex = currentIndex > 0 ? currentIndex - 1 : this.tabs.length - 1;
      } else if (e.key === 'ArrowRight') {
        newIndex = currentIndex < this.tabs.length - 1 ? currentIndex + 1 : 0;
      }
      
      this.activateTab(newIndex + 1);
      this.tabs[newIndex].focus();
    }
  }

  customElements.define('mk-tabs', MKTabs);
{% endjavascript %}

{% schema %}
{
  "name": "MK 标签页",
  "tag": "section",
  "settings": [
    {
      "type": "header",
      "content": "颜色设置"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "背景颜色",
      "default": "#ffffff"
    },
    {
      "type": "header",
      "content": "间距设置"
    },
    {
      "type": "range",
      "id": "padding_top_mobile",
      "label": "上边距 (移动端)",
      "min": 0,
      "max": 120,
      "default": 48,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "label": "下边距 (移动端)",
      "min": 0,
      "max": 120,
      "default": 48,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_top_desktop",
      "label": "上边距 (PC端)",
      "min": 0,
      "max": 200,
      "default": 80,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_bottom_desktop",
      "label": "下边距 (PC端)",
      "min": 0,
      "max": 200,
      "default": 80,
      "unit": "px"
    }
  ],
  "blocks": [
    {
      "type": "tab",
      "name": "标签页",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "标签标题",
          "default": "标签"
        },
        {
          "type": "select",
          "id": "content_type",
          "label": "内容类型",
          "options": [
            { "value": "text", "label": "文本" },
            { "value": "image", "label": "图片" },
            { "value": "video", "label": "视频" },
            { "value": "product", "label": "单个产品" },
            { "value": "products", "label": "多个产品" }
          ],
          "default": "text"
        },
        {
          "type": "richtext",
          "id": "text_content",
          "label": "文本内容",
          "default": "<p>标签页内容...</p>"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "图片"
        },
        {
          "type": "url",
          "id": "video_url",
          "label": "视频URL"
        },
        {
          "type": "checkbox",
          "id": "autoplay",
          "label": "自动播放",
          "default": false
        },
        {
          "type": "checkbox",
          "id": "loop",
          "label": "循环播放",
          "default": true
        },
        {
          "type": "checkbox",
          "id": "muted",
          "label": "静音",
          "default": true
        },
        {
          "type": "product",
          "id": "product",
          "label": "产品"
        },
        {
          "type": "product",
          "id": "product_1",
          "label": "产品 1"
        },
        {
          "type": "product",
          "id": "product_2",
          "label": "产品 2"
        },
        {
          "type": "product",
          "id": "product_3",
          "label": "产品 3"
        },
        {
          "type": "product",
          "id": "product_4",
          "label": "产品 4"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "MK 标签页"
    }
  ]
}
{% endschema %}
