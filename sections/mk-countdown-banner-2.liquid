{%- comment -%}
  MK Countdown Banner 2板块

  倒计时横幅第二版

  作者：崽崽 (AI助手)
{%- endcomment -%}

{% liquid
  assign ss = section.settings
-%}

<section id="{{ section.id }}" class="mk-countdown-banner-2 color-{{ ss.color_scheme | default: 'background-1' }}">
  <div class="mk-countdown-banner-2__container">
    {%- if ss.title != blank -%}
      <h2 class="mk-countdown-banner-2__title">{{ ss.title }}</h2>
    {%- endif -%}

    <div class="mk-countdown-banner-2__countdown" data-countdown data-end="{{ ss.end_date | default: '' | date: '%Y-%m-%dT%H:%M:%S' }}">
      <div class="mk-countdown-banner-2__item">
        <span class="mk-countdown-banner-2__number" data-days>00</span>
        <span class="mk-countdown-banner-2__label">天</span>
      </div>
      <div class="mk-countdown-banner-2__item">
        <span class="mk-countdown-banner-2__number" data-hours>00</span>
        <span class="mk-countdown-banner-2__label">时</span>
      </div>
      <div class="mk-countdown-banner-2__item">
        <span class="mk-countdown-banner-2__number" data-minutes>00</span>
        <span class="mk-countdown-banner-2__label">分</span>
      </div>
      <div class="mk-countdown-banner-2__item">
        <span class="mk-countdown-banner-2__number" data-seconds>00</span>
        <span class="mk-countdown-banner-2__label">秒</span>
      </div>
    </div>

    {%- if ss.button_text != blank -%}
      <a href="{{ ss.button_link | default: '#' }}" class="mk-countdown-banner-2__button">{{ ss.button_text }}</a>
    {%- endif -%}
  </div>
</section>

{% stylesheet %}
  .mk-countdown-banner-2 { padding: {{ ss.padding_top_mobile | default: 48 }}px 0 {{ ss.padding_bottom_mobile | default: 48 }}px; background: var(--color-background-secondary, #f5f5f5); }
  @media (min-width: 750px) { .mk-countdown-banner-2 { padding: {{ ss.padding_top_desktop | default: 80 }}px 0 {{ ss.padding_bottom_desktop | default: 80 }}px; } }
  .mk-countdown-banner-2__container { max-width: var(--container-max-width, 800px); margin: 0 auto; padding: 0 var(--container-padding, 32px); text-align: center; }
  .mk-countdown-banner-2__title { margin: 0 0 24px 0; font-size: 28px; font-weight: 700; }
  .mk-countdown-banner-2__countdown { display: flex; justify-content: center; gap: 16px; margin-bottom: 24px; }
  .mk-countdown-banner-2__item { display: flex; flex-direction: column; align-items: center; min-width: 72px; padding: 16px; background: var(--color-background); border-radius: 12px; box-shadow: 0 2px 8px rgba(0,0,0,0.06); }
  .mk-countdown-banner-2__number { font-size: 32px; font-weight: 700; color: var(--color-primary, #000); line-height: 1; }
  .mk-countdown-banner-2__label { font-size: 12px; color: var(--color-text-secondary, #666); margin-top: 4px; }
  .mk-countdown-banner-2__button { display: inline-flex; padding: 14px 32px; font-size: 14px; font-weight: 600; color: var(--color-on-primary, #fff); background: var(--color-primary, #000); border-radius: 8px; text-decoration: none; }
  .mk-countdown-banner-2__button:hover { opacity: 0.85; }
{% endstylesheet %}

{% javascript %}
  (function() {
    const countdown = document.querySelector('[data-countdown]');
    if (!countdown) return;
    const endDate = new Date(countdown.dataset.end).getTime();
    function update() {
      const now = Date.now();
      const diff = Math.max(0, endDate - now);
      const days = Math.floor(diff / 86400000);
      const hours = Math.floor((diff % 86400000) / 3600000);
      const minutes = Math.floor((diff % 3600000) / 60000);
      const seconds = Math.floor((diff % 60000) / 1000);
      countdown.querySelector('[data-days]').textContent = String(days).padStart(2, '0');
      countdown.querySelector('[data-hours]').textContent = String(hours).padStart(2, '0');
      countdown.querySelector('[data-minutes]').textContent = String(minutes).padStart(2, '0');
      countdown.querySelector('[data-seconds]').textContent = String(seconds).padStart(2, '0');
    }
    update();
    setInterval(update, 1000);
  })();
{% endjavascript %}

{% schema %}
{
  "name": "MK Countdown Banner 2",
  "tag": "section",
  "settings": [
    { "type": "text", "id": "title", "label": "标题" },
    { "type": "text", "id": "end_date", "label": "结束日期", "info": "格式: YYYY-MM-DD HH:MM" },
    { "type": "text", "id": "button_text", "label": "按钮文字" },
    { "type": "url", "id": "button_link", "label": "按钮链接" },
    { "type": "header", "content": "间距" },
    { "type": "range", "id": "padding_top_mobile", "label": "上边距 (移动端)", "min": 0, "max": 120, "default": 48, "unit": "px" },
    { "type": "range", "id": "padding_bottom_mobile", "label": "下边距 (移动端)", "min": 0, "max": 120, "default": 48, "unit": "px" },
    { "type": "range", "id": "padding_top_desktop", "label": "上边距 (PC端)", "min": 0, "max": 200, "default": 80, "unit": "px" },
    { "type": "range", "id": "padding_bottom_desktop", "label": "下边距 (PC端)", "min": 0, "max": 200, "default": 80, "unit": "px" },
    { "type": "color_scheme", "id": "color_scheme", "label": "颜色方案", "default": "scheme-1" }
  ],
  "presets": [{ "name": "MK Countdown Banner 2" }]
}
{% endschema %}
