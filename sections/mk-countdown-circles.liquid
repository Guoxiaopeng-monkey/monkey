{%- comment -%}
  MK Countdown Circles板块

  圆形倒计时

  作者：崽崽 (AI助手)
{%- endcomment -%}

{% liquid
  assign ss = section.settings
-%}

<section id="{{ section.id }}" class="mk-countdown-circles color-{{ ss.color_scheme | default: 'background-1' }}">
  <div class="mk-countdown-circles__container">
    {%- if ss.title != blank -%}
      <h2 class="mk-countdown-circles__title">{{ ss.title }}</h2>
    {%- endif -%}

    <div class="mk-countdown-circles__grid" data-countdown-circles data-end="{{ ss.end_date | default: '' | date: '%Y-%m-%dT%H:%M:%S' }}">
      <div class="mk-countdown-circles__item">
        <div class="mk-countdown-circles__circle">
          <svg viewBox="0 0 100 100"><circle cx="50" cy="50" r="45" class="mk-countdown-circles__bg"/><circle cx="50" cy="50" r="45" class="mk-countdown-circles__progress" data-days/></svg>
          <span class="mk-countdown-circles__num" data-days>00</span>
        </div>
        <span class="mk-countdown-circles__label">天</span>
      </div>
      <div class="mk-countdown-circles__item">
        <div class="mk-countdown-circles__circle">
          <svg viewBox="0 0 100 100"><circle cx="50" cy="50" r="45" class="mk-countdown-circles__bg"/><circle cx="50" cy="50" r="45" class="mk-countdown-circles__progress" data-hours/></svg>
          <span class="mk-countdown-circles__num" data-hours>00</span>
        </div>
        <span class="mk-countdown-circles__label">时</span>
      </div>
      <div class="mk-countdown-circles__item">
        <div class="mk-countdown-circles__circle">
          <svg viewBox="0 0 100 100"><circle cx="50" cy="50" r="45" class="mk-countdown-circles__bg"/><circle cx="50" cy="50" r="45" class="mk-countdown-circles__progress" data-minutes/></svg>
          <span class="mk-countdown-circles__num" data-minutes>00</span>
        </div>
        <span class="mk-countdown-circles__label">分</span>
      </div>
      <div class="mk-countdown-circles__item">
        <div class="mk-countdown-circles__circle">
          <svg viewBox="0 0 100 100"><circle cx="50" cy="50" r="45" class="mk-countdown-circles__bg"/><circle cx="50" cy="50" r="45" class="mk-countdown-circles__progress" data-seconds/></svg>
          <span class="mk-countdown-circles__num" data-seconds>00</span>
        </div>
        <span class="mk-countdown-circles__label">秒</span>
      </div>
    </div>
  </div>
</section>

{% stylesheet %}
  .mk-countdown-circles { padding: {{ ss.padding_top_mobile | default: 48 }}px 0 {{ ss.padding_bottom_mobile | default: 48 }}px; }
  @media (min-width: 750px) { .mk-countdown-circles { padding: {{ ss.padding_top_desktop | default: 80 }}px 0 {{ ss.padding_bottom_desktop | default: 80 }}px; } }
  .mk-countdown-circles__container { max-width: var(--container-max-width, 800px); margin: 0 auto; padding: 0 var(--container-padding, 32px); text-align: center; }
  .mk-countdown-circles__title { margin: 0 0 32px 0; font-size: var(--mk-font-size-3xl); font-weight: 700; }
  .mk-countdown-circles__grid { display: flex; justify-content: center; gap: var(--mk-spacing-2xl); }
  .mk-countdown-circles__item { display: flex; flex-direction: column; align-items: center; gap: var(--mk-spacing-sm); }
  .mk-countdown-circles__circle { position: relative; width: 80px; height: 80px; }
  @media (min-width: 750px) { .mk-countdown-circles__circle { width: 100px; height: 100px; } }
  .mk-countdown-circles__circle svg { transform: rotate(-90deg); width: 100%; height: 100%; }
  .mk-countdown-circles__bg { fill: none; stroke: var(--color-background-secondary, var(--mk-color-bg-secondary)); stroke-width: 8; }
  .mk-countdown-circles__progress { fill: none; stroke: var(--color-primary, #000); stroke-width: 8; stroke-linecap: round; stroke-dasharray: 283; stroke-dashoffset: 0; transition: stroke-dashoffset 0.5s ease; }
  .mk-countdown-circles__num { position: absolute; inset: 0; display: flex; align-items: center; justify-content: center; font-size: var(--mk-font-size-2xl); font-weight: 700; }
  @media (min-width: 750px) { .mk-countdown-circles__num { font-size: var(--mk-font-size-3xl); } }
  .mk-countdown-circles__label { font-size: var(--mk-font-size-sm); color: var(--color-text-secondary, #666); }
{% endstylesheet %}

{% javascript %}
  (function() {
    const countdown = document.querySelector('[data-countdown-circles]');
    if (!countdown) return;
    const endDate = new Date(countdown.dataset.end).getTime();
    const circumference = 2 * Math.PI * 45;
    function update() {
      const now = Date.now();
      const diff = Math.max(0, endDate - now);
      const totalSeconds = Math.floor(diff / 1000);
      const days = Math.floor(totalSeconds / 86400);
      const hours = Math.floor((diff % 86400000) / 3600000);
      const minutes = Math.floor((diff % 3600000) / 60000);
      const seconds = Math.floor((diff % 60000) / 1000);
      countdown.querySelector('[data-days]').textContent = String(days).padStart(2, '0');
      countdown.querySelector('[data-hours]').textContent = String(hours).padStart(2, '0');
      countdown.querySelector('[data-minutes]').textContent = String(minutes).padStart(2, '0');
      countdown.querySelector('[data-seconds]').textContent = String(seconds).padStart(2, '0');
      const dayProgress = (days / 365) * circumference;
      countdown.querySelector('[data-days]').closest('.mk-countdown-circles__item').querySelector('.mk-countdown-circles__progress').style.strokeDashoffset = circumference - dayProgress;
      const hourProgress = (hours / 24) * circumference;
      countdown.querySelector('[data-hours]').closest('.mk-countdown-circles__item').querySelector('.mk-countdown-circles__progress').style.strokeDashoffset = circumference - hourProgress;
      const minProgress = (minutes / 60) * circumference;
      countdown.querySelector('[data-minutes]').closest('.mk-countdown-circles__item').querySelector('.mk-countdown-circles__progress').style.strokeDashoffset = circumference - minProgress;
      const secProgress = (seconds / 60) * circumference;
      countdown.querySelector('[data-seconds]').closest('.mk-countdown-circles__item').querySelector('.mk-countdown-circles__progress').style.strokeDashoffset = circumference - secProgress;
    }
    update();
    setInterval(update, 1000);
  })();
{% endjavascript %}

{% schema %}
{
  "name": "MK Countdown Circles",
  "tag": "section",
  "settings": [
    { "type": "text", "id": "title", "label": "标题" },
    { "type": "text", "id": "end_date", "label": "结束日期", "info": "格式: YYYY-MM-DD HH:MM" },
    { "type": "header", "content": "间距" },
    { "type": "range", "id": "padding_top_mobile", "label": "上边距 (移动端)", "min": 0, "max": 120, "default": 48, "unit": "px" },
    { "type": "range", "id": "padding_bottom_mobile", "label": "下边距 (移动端)", "min": 0, "max": 120, "default": 48, "unit": "px" },
    { "type": "range", "id": "padding_top_desktop", "label": "上边距 (PC端)", "min": 0, "max": 200, "default": 80, "unit": "px" },
    { "type": "range", "id": "padding_bottom_desktop", "label": "下边距 (PC端)", "min": 0, "max": 200, "default": 80, "unit": "px" },
    { "type": "color_scheme", "id": "color_scheme", "label": "颜色方案", "default": "scheme-1" }
  ],
  "presets": [{ "name": "MK Countdown Circles" }]
}
{% endschema %}
