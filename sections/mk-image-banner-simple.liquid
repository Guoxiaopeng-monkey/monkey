{%- comment -%}
  MK Image Banner Simple板块

  简约图片横幅

  作者：崽崽 (AI助手)
{%- endcomment -%}

{% liquid
  assign ss = section.settings
-%}

<section id="{{ section.id }}" class="mk-image-banner-simple color-{{ ss.color_scheme | default: 'background-1' }}">
  <div class="mk-image-banner-simple__wrapper">
    {%- if ss.image != blank -%}
      {{ ss.image | image_url: width: 1920 | image_tag: loading: 'lazy', class: 'mk-image-banner-simple__image' }}
    {%- endif -%}
    <div class="mk-image-banner-simple__overlay"></div>
    <div class="mk-image-banner-simple__content">
      {%- if ss.title != blank -%}
        <h2 class="mk-image-banner-simple__title">{{ ss.title }}</h2>
      {%- endif -%}
      {%- if ss.text != blank -%}
        <p class="mk-image-banner-simple__text">{{ ss.text }}</p>
      {%- endif -%}
      {%- if ss.button_text != blank -%}
        <a href="{{ ss.button_link | default: '#' }}" class="mk-image-banner-simple__button">{{ ss.button_text }}</a>
      {%- endif -%}
    </div>
  </div>
</section>

{% stylesheet %}
  .mk-image-banner-simple__wrapper { position: relative; min-height: {{ ss.height_mobile | default: 300 }}px; display: flex; align-items: center; justify-content: center; overflow: hidden; }
  @media (min-width: 750px) { .mk-image-banner-simple__wrapper { min-height: {{ ss.height_desktop | default: 500 }}px; } }
  .mk-image-banner-simple__image { position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; }
  .mk-image-banner-simple__overlay { position: absolute; inset: 0; background: rgba(0,0,0,{{ ss.overlay_opacity | default: 0.3 }}); }
  .mk-image-banner-simple__content { position: relative; z-index: 1; text-align: center; padding: 48px 24px; max-width: 600px; }
  .mk-image-banner-simple__title { margin: 0 0 12px 0; font-size: 28px; font-weight: 700; color: #fff; }
  @media (min-width: 750px) { .mk-image-banner-simple__title { font-size: 40px; } }
  .mk-image-banner-simple__text { margin: 0 0 20px 0; font-size: 15px; color: rgba(255,255,255,0.9); }
  .mk-image-banner-simple__button { display: inline-flex; padding: 14px 32px; font-size: 14px; font-weight: 600; color: var(--color-on-primary, #fff); background: var(--color-primary, #000); border-radius: 8px; text-decoration: none; }
  .mk-image-banner-simple__button:hover { opacity: 0.85; }
{% endstylesheet %}

{% schema %}
{
  "name": "MK Image Banner Simple",
  "tag": "section",
  "settings": [
    { "type": "image_picker", "id": "image", "label": "图片" },
    { "type": "text", "id": "title", "label": "标题" },
    { "type": "textarea", "id": "text", "label": "描述" },
    { "type": "text", "id": "button_text", "label": "按钮文字" },
    { "type": "url", "id": "button_link", "label": "按钮链接" },
    { "type": "range", "id": "overlay_opacity", "label": "遮罩透明度", "min": 0, "max": 1, "step": 0.1, "default": 0.3 },
    { "type": "range", "id": "height_mobile", "label": "高度 (移动端)", "min": 200, "max": 600, "default": 300, "unit": "px" },
    { "type": "range", "id": "height_desktop", "label": "高度 (PC端)", "min": 300, "max": 800, "default": 500, "unit": "px" },
    { "type": "color_scheme", "id": "color_scheme", "label": "颜色