{%- comment -%}
  MK Countdown Simple板块

  简约倒计时

  作者：崽崽 (AI助手)
{%- endcomment -%}

{% liquid
  assign ss = section.settings
-%}

<div id="{{ section.id }}" class="mk-countdown-simple color-{{ ss.color_scheme | default: 'background-1' }}" data-countdown-simple data-end="{{ ss.end_date | default: '' | date: '%Y-%m-%dT%H:%M:%S' }}">
  <div class="mk-countdown-simple__container">
    <span class="mk-countdown-simple__text">{{ ss.text | default: '剩余时间' }}:</span>
    <span class="mk-countdown-simple__time">
      <span data-days>00</span>天
      <span data-hours>00</span>时
      <span data-minutes>00</span>分
      <span data-seconds>00</span>秒
    </span>
  </div>
</div>

{% stylesheet %}
  .mk-countdown-simple { padding: var(--mk-spacing-md) 0; }
  .mk-countdown-simple__container { max-width: var(--container-max-width, 1200px); margin: 0 auto; padding: 0 var(--container-padding, 32px); display: flex; align-items: center; justify-content: center; gap: var(--mk-spacing-sm); }
  .mk-countdown-simple__text { font-size: var(--mk-font-size-md); font-weight: 500; }
  .mk-countdown-simple__time { font-size: var(--mk-font-size-md); font-weight: 600; }
  .mk-countdown-simple__time span { font-weight: 700; }
{% endstylesheet %}

{% javascript %}
  (function() {
    const el = document.querySelector('[data-countdown-simple]');
    if (!el) return;
    const endDate = new Date(el.dataset.end).getTime();
    function update() {
      const now = Date.now();
      const diff = Math.max(0, endDate - now);
      const days = Math.floor(diff / 86400000);
      const hours = Math.floor((diff % 86400000) / 3600000);
      const minutes = Math.floor((diff % 3600000) / 60000);
      const seconds = Math.floor((diff % 60000) / 1000);
      el.querySelector('[data-days]').textContent = String(days).padStart(2, '0');
      el.querySelector('[data-hours]').textContent = String(hours).padStart(2, '0');
      el.querySelector('[data-minutes]').textContent = String(minutes).padStart(2, '0');
      el.querySelector('[data-seconds]').textContent = String(seconds).padStart(2, '0');
    }
    update();
    setInterval(update, 1000);
  })();
{% endjavascript %}

{% schema %}
{
  "name": "MK Countdown Simple",
  "tag": "div",
  "settings": [
    { "type": "text", "id": "text", "label": "文字" },
    { "type": "text", "id": "end_date", "label": "结束日期", "info": "格式: YYYY-MM-DD HH:MM" },
    { "type": "color_scheme", "id": "color_scheme", "label": "颜色方案", "default": "scheme-1" }
  ],
  "presets": [{ "name": "MK Countdown Simple" }]
}
{% endschema %}
