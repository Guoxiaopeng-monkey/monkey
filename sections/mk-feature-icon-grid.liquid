{%- comment -%}
  MK 功能图标网格组件
  
  功能：展示特性图标网格，每个特性包含图标、标题和描述
  
  作者：崽崽 (AI助手)
  基于：spx-feature-icon-grid.liquid
{%- endcomment -%}

{%- liquid
  assign ss = section.settings
  assign bg_color = ss.background_color | default: '#ffffff'
  
  assign pt_mob = ss.padding_top_mobile | default: 48
  assign pb_mob = ss.padding_bottom_mobile | default: 48
  assign pt_desk = ss.padding_top_desktop | default: 80
  assign pb_desk = ss.padding_bottom_desktop | default: 80
  
  assign columns_mobile = ss.columns_mobile | default: 1
  assign columns_tablet = ss.columns_tablet | default: 2
  assign columns_desktop = ss.columns_desktop | default: 4
  assign icon_size = ss.icon_size | default: 80
-%}

<style>
  #{{ section.id }} {
    --feat-bg: {{ bg_color }};
    --feat-icon-size: {{ icon_size }}px;
    --feat-pt-mob: {{ pt_mob }}px;
    --feat-pb-mob: {{ pb_mob }}px;
    --feat-pt-desk: {{ pt_desk }}px;
    --feat-pb-desk: {{ pb_desk }}px;
    --feat-cols-mob: {{ columns_mobile }};
    --feat-cols-tablet: {{ columns_tablet }};
    --feat-cols-desk: {{ columns_desktop }};
    background-color: var(--feat-bg);
    padding: var(--feat-pt-mob) 0 var(--feat-pb-mob);
  }
  
  @media (min-width: 750px) {
    #{{ section.id }} {
      padding: var(--feat-pt-desk) 0 var(--feat-pb-desk);
    }
  }
</style>

<section
  id="{{ section.id }}"
  class="mk-feature-icon-grid"
  data-skip-node-update
>
  <div class="mk-feature-icon-grid__container">
    
    {%- comment -%} 标题区域 {%- endcomment -%}
    <div class="mk-feature-icon-grid__header">
      {%- for block in section.blocks -%}
        {%- case block.type -%}
          {%- when 'title' -%}
            <h2 class="mk-feature-icon-grid__title">{{ block.settings.text }}</h2>
          {%- when 'description' -%}
            <p class="mk-feature-icon-grid__description">{{ block.settings.text }}</p>
        {%- endcase -%}
      {%- endfor -%}
    </div>
    
    {%- comment -%} 特性网格 {%- endcomment -%}
    <div class="mk-feature-icon-grid__grid">
      {%- for block in section.blocks -%}
        {%- if block.type == 'item' -%}
          <div class="mk-feature-icon-grid__item" {{ block.shopify_attributes }}>
            {%- comment -%} 图标 {%- endcomment -%}
            <div class="mk-feature-icon-grid__icon">
              {% if block.settings.icon != blank %}
                {{ block.settings.icon | image_url: width: 160 | image_tag }}
              {% else %}
                <div class="mk-feature-icon-grid__icon-placeholder">
                  {{ forloop.index }}
                </div>
              {% endif %}
            </div>
            
            {%- comment -%} 内容 {%- endcomment -%}
            <div class="mk-feature-icon-grid__content">
              {% if block.settings.title != blank %}
                <h3 class="mk-feature-icon-grid__item-title">{{ block.settings.title }}</h3>
              {% endif %}
              {% if block.settings.description != blank %}
                <p class="mk-feature-icon-grid__item-desc">{{ block.settings.description }}</p>
              {% endif %}
            </div>
          </div>
        {%- endif -%}
      {%- endfor -%}
    </div>
  </div>
</section>

{% stylesheet %}
  .mk-feature-icon-grid__container {
    max-width: var(--container-max-width, 1440px);
    margin: 0 auto;
    padding: 0 var(--container-padding, 32px);
  }

  /* Header */
  .mk-feature-icon-grid__header {
    text-align: center;
    max-width: 700px;
    margin: 0 auto 48px auto;
  }

  .mk-feature-icon-grid__title {
    margin: 0 0 16px 0;
    font-size: clamp(28px, 4vw, 42px);
    font-weight: 700;
    line-height: 1.2;
  }

  .mk-feature-icon-grid__description {
    margin: 0;
    font-size: var(--mk-font-size-lg);
    line-height: 1.6;
    opacity: 0.85;
  }

  /* Grid */
  .mk-feature-icon-grid__grid {
    display: grid;
    grid-template-columns: repeat(var(--feat-cols-mob, 1), 1fr);
    gap: var(--mk-spacing-3xl);
  }

  @media (min-width: 480px) {
    .mk-feature-icon-grid__grid {
      grid-template-columns: repeat(var(--feat-cols-tablet, 2), 1fr);
    }
  }

  @media (min-width: 990px) {
    .mk-feature-icon-grid__grid {
      grid-template-columns: repeat(var(--feat-cols-desk, 4), 1fr);
      gap: 48px;
    }
  }

  /* Item */
  .mk-feature-icon-grid__item {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    padding: var(--mk-spacing-2xl);
    border-radius: var(--mk-radius-lg);
    transition: background 0.2s ease;
  }

  .mk-feature-icon-grid__item:hover {
    background: rgba(0, 0, 0, 0.02);
  }

  /* Icon */
  .mk-feature-icon-grid__icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: var(--feat-icon-size, 80px);
    height: var(--feat-icon-size, 80px);
    margin-bottom: 20px;
    border-radius: 50%;
    background: var(--color-background-secondary, var(--mk-color-bg-secondary));
    transition: transform 0.2s ease;
  }

  .mk-feature-icon-grid__item:hover .mk-feature-icon-grid__icon {
    transform: scale(1.05);
  }

  .mk-feature-icon-grid__icon img {
    width: 60%;
    height: 60%;
    object-fit: contain;
  }

  .mk-feature-icon-grid__icon-placeholder {
    font-size: var(--mk-font-size-3xl);
    font-weight: 700;
    color: var(--color-text-secondary, #999);
  }

  /* Content */
  .mk-feature-icon-grid__item-title {
    margin: 0 0 12px 0;
    font-size: var(--mk-font-size-xl);
    font-weight: 600;
    line-height: 1.3;
  }

  .mk-feature-icon-grid__item-desc {
    margin: 0;
    font-size: var(--mk-font-size-md);
    line-height: 1.6;
    opacity: 0.85;
  }
{% endstylesheet %}

{% schema %}
{
