{%- comment -%}
  MK Cart Drawer Section板块

  购物车抽屉区块

  作者：崽崽 (AI助手)
{%- endcomment -%}

{% liquid
  assign ss = section.settings
-%}

<section id="{{ section.id }}" class="mk-cart-drawer-section" data-cart-drawer-section>
  <div class="mk-cart-drawer-section__overlay" data-cart-close></div>
  <div class="mk-cart-drawer-section__drawer">
    <div class="mk-cart-drawer-section__header">
      <h2 class="mk-cart-drawer-section__title">{{ ss.title | default: '购物车' }}</h2>
      <button type="button" class="mk-cart-drawer-section__close" data-cart-close aria-label="关闭">
        {{- 'icon-close.svg' | inline_asset_content -}}
      </button>
    </div>

    <div class="mk-cart-drawer-section__body">
      {%- if cart.item_count == 0 -%}
        <div class="mk-cart-drawer-section__empty">
          <p>{{ 'cart.empty' | t | default: '购物车是空的' }}</p>
          <a href="{{ routes.all_products_collection_url }}" class="mk-cart-drawer-section__continue">{{ 'cart.continue_shopping' | t | default: '继续购物' }}</a>
        </div>
      {%- else -%}
        <div class="mk-cart-drawer-section__items">
          {%- for item in cart.items -%}
            <div class="mk-cart-drawer-section__item" data-item-id="{{ item.id }}">
              <div class="mk-cart-drawer-section__item-image">
                {{ item.image | image_url: width: 120 | image_tag: width: 60, height: 60, loading: 'lazy' }}
              </div>
              <div class="mk-cart-drawer-section__item-info">
                <a href="{{ item.url }}" class="mk-cart-drawer-section__item-title">{{ item.product.title }}</a>
                {%- unless item.product.has_only_default_variant -%}
                  <p class="mk-cart-drawer-section__item-variant">{{ item.variant.title }}</p>
                {%- endunless -%}
                <div class="mk-cart-drawer-section__item-qty">
                  <button type="button" data-qty-change="-1">-</button>
                  <span>{{ item.quantity }}</span>
                  <button type="button" data-qty-change="1">+</button>
                </div>
              </div>
              <div class="mk-cart-drawer-section__item-price">
                {{ item.final_line_price | money }}
              </div>
            </div>
          {%- endfor -%}
        </div>

        <div class="mk-cart-drawer-section__summary">
          <div class="mk-cart-drawer-section__subtotal">
            <span>{{ 'cart.subtotal' | t | default: '小计' }}</span>
            <span>{{ cart.total_price | money }}</span>
          </div>
          <p class="mk-cart-drawer-section__note">{{ 'cart.taxes_shipping_at_checkout' | t | default: '结账时计算税费和运费' }}</p>
          <a href="{{ routes.checkout_url }}" class="mk-cart-drawer-section__checkout">{{ 'cart.checkout' | t | default: '结账' }}</a>
        </div>
      {%- endif -%}
    </div>
  </div>
</section>

{% stylesheet %}
  .mk-cart-drawer-section { position: fixed; inset: 0; z-index: 9999; visibility: hidden; }
  .mk-cart-drawer-section.active { visibility: visible; }
  .mk-cart-drawer-section__overlay { position: absolute; inset: 0; background: rgba(0,0,0,0.5); }
  .mk-cart-drawer-section__drawer { position: absolute; top: 0; right: 0; bottom: 0; width: 420px; max-width: 100%; background: var(--color-background); display: flex; flex-direction: column; transform: translateX(100%); transition: transform 0.3s ease; }
  .mk-cart-drawer-section.active .mk-cart-drawer-section__drawer { transform: translateX(0); }
  .mk-cart-drawer-section__header { display: flex; justify-content: space-between; align-items: center; padding: 20px 24px; border-bottom: 1px solid var(--color-border); }
  .mk-cart-drawer-section__title { margin: 0; font-size: 18px; font-weight: 700; }
  .mk-cart-drawer-section__close { display: flex; align-items: center; justify-content: center; width: 32px; height: 32px; background: transparent; border: none; cursor: pointer; }
  .mk-cart-drawer-section__close svg { width: 20px; height: 20px; }
  .mk-cart-drawer-section__body { flex: 1; overflow-y: auto; padding: 24px; }
  .mk-cart-drawer-section__empty { text-align: center; padding: 48px 0; }
  .mk-cart-drawer-section__empty p { font-size: 15px; color: var(--color-text-secondary, #666); margin: 0 0 16px 0; }
  .mk-cart-drawer-section__continue { font-size: 14px; font-weight: 600; color: var(--color-primary, #000); }
  .mk-cart-drawer-section__items { display: flex; flex-direction: column; gap: 20px; }
  .mk-cart-drawer-section__item { display: flex; gap: 16px; }
  .mk-cart-drawer-section__item-image { width: 80px; height: 80px; border-radius: 8px; overflow: hidden; flex-shrink: 0; }
  .mk-cart-drawer-section__item-image img { width: 100%; height: 100%; object-fit: cover; }
  .mk-cart-drawer-section__item-info { flex: 1; }
  .mk-cart-drawer-section__item-title { margin: 0 0 4px 0; font-size: 14px; font-weight: 500; text-decoration: none; color: inherit; }
  .mk-cart-drawer-section__item-variant { margin: 0 0 8px 0; font-size: 12px; color: var(--color-text-secondary, #666); }
  .mk-cart-drawer-section__item-qty { display: flex; align-items: center; gap: 8px; }
  .mk-cart-drawer-section__item-qty button { width: 24px; height: 24px; display: flex; align-items: center; justify-content: center; background: var(--color-background-secondary); border: none; border-radius: 4px; cursor: pointer; }
  .mk-cart-drawer-section__item-price { font-size: 14px; font-weight: 600; }
  .mk-cart-drawer-section__summary { padding-top: 20px; border-top: 1px solid var(--color-border); margin-top: 20px; }
  .mk-cart-drawer-section__subtotal { display: flex; justify-content: space-between; margin-bottom: 12px; font-size: 16px; font-weight: 600; }
  .mk-cart-drawer-section__note { font-size: 12px; color: var(--color-text-secondary, #666); margin: 0 0 16px 0; }
  .mk-cart-drawer-section__checkout { display: block; padding: 16px; font-size: 14px; font-weight: 600; color: #fff; background: var(--color-primary, #000); border-radius: 8px; text-align: center; text-decoration: none; }
  .mk-cart-drawer-section__checkout:hover { opacity: 0.85; }
{% endstylesheet %}

{% javascript %}
  (function() {
    const section = document.querySelector('[data-cart-drawer-section]');
    if (!section) return;
    section.querySelectorAll('[data-cart-close]').forEach(btn => btn.addEventListener('click', () => section.classList.remove('active')));
  })();
{% endjavascript %}

