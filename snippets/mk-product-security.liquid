{%- doc -%}
  MK 产品安全信息组件

  渲染产品安全/认证信息

  @param {string} [class] - 额外CSS类名

  @example
  {% render 'mk-product-security' %}
{%- enddoc -%}

{% liquid
  assign class = class | default: ''
-%}

<div class="mk-product-security {{ class }}">
  <div class="mk-product-security__item">
    <span class="mk-product-security__icon">{{- 'icon-shield.svg' | inline_asset_content -}}</span>
    <span class="mk-product-security__text">{{ 'products.secure_payment' | t | default: '安全支付' }}</span>
  </div>

  <div class="mk-product-security__item">
    <span class="mk-product-security__icon">{{- 'icon-truck.svg' | inline_asset_content -}}</span>
    <span class="mk-product-security__text">{{ 'products.fast_shipping' | t | default: '快速配送' }}</span>
  </div>

  <div class="mk-product-security__item">
    <span class="mk-product-security__icon">{{- 'icon-undo.svg' | inline_asset_content -}}</span>
    <span class="mk-product-security__text">{{ 'products.returns' | t | default: '30天退换' }}</span>
  </div>

  <div class="mk-product-security__item">
    <span class="mk-product-security__icon">{{- 'icon-support.svg' | inline_asset_content -}}</span>
    <span class="mk-product-security__text">{{ 'products.support' | t | default: '在线客服' }}</span>
  </div>
</div>

{% stylesheet %}
  .mk-product-security {
    display: flex;
    flex-wrap: wrap;
    gap: 16px;
    justify-content: center;
  }

  .mk-product-security__item {
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .mk-product-security__icon {
    display: flex;
    width: 20px;
    height: 20px;
    color: var(--color-primary, #000);
  }

  .mk-product-security__icon svg {
    width: 100%;
    height: 100%;
  }

  .mk-product-security__text {
    font-size: 13px;
    color: var(--color-text-secondary, #666);
  }
{% endstylesheet %}
