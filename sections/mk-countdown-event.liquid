{%- comment -%}
  MK Countdown Event板块

  活动倒计时

  作者：崽崽 (AI助手)
{%- endcomment -%}

{% liquid
  assign ss = section.settings
-%}

<section id="{{ section.id }}" class="mk-countdown-event">
  <div class="mk-countdown-event__bg">
    {%- if ss.image != blank -%}
      {{ ss.image | image_url: width: 1920 | image_tag: loading: 'lazy', class: 'mk-countdown-event__image' }}
    {%- endif -%}
    <div class="mk-countdown-event__overlay"></div>
  </div>
  <div class="mk-countdown-event__content">
    {%- if ss.badge != blank -%}
      <span class="mk-countdown-event__badge">{{ ss.badge }}</span>
    {%- endif -%}
    {%- if ss.title != blank -%}
      <h2 class="mk-countdown-event__title">{{ ss.title }}</h2>
    {%- endif -%}
    <div class="mk-countdown-event__countdown" data-countdown-event data-end="{{ ss.end_date | default: '' | date: '%Y-%m-%dT%H:%M:%S' }}">
      <div class="mk-countdown-event__item"><span class="mk-countdown-event__num" data-days>00</span><span class="mk-countdown-event__label">Days</span></div>
      <div class="mk-countdown-event__item"><span class="mk-countdown-event__num" data-hours>00</span><span class="mk-countdown-event__label">Hours</span></div>
      <div class="mk-countdown-event__item"><span class="mk-countdown-event__num" data-minutes>00</span><span class="mk-countdown-event__label">Minutes</span></div>
      <div class="mk-countdown-event__item"><span class="mk-countdown-event__num" data-seconds>00</span><span class="mk-countdown-event__label">Seconds</span></div>
    </div>
  </div>
</section>

{% stylesheet %}
  .mk-countdown-event { position: relative; min-height: 500px; display: flex; align-items: center; }
  .mk-countdown-event__bg { position: absolute; inset: 0; }
  .mk-countdown-event__image { width: 100%; height: 100%; object-fit: cover; }
  .mk-countdown-event__overlay { position: absolute; inset: 0; background: rgba(0,0,0,0.5); }
  .mk-countdown-event__content { position: relative; z-index: 1; width: 100%; text-align: center; padding: var(--mk-spacing-6xl) 32px; }
  .mk-countdown-event__badge { display: inline-block; padding: var(--mk-spacing-sm) 20px; font-size: var(--mk-font-size-sm); font-weight: 700; text-transform: uppercase; letter-spacing: 2px; color: #fff; background: #e94560; border-radius: 100px; margin-bottom: 20px; }
  .mk-countdown-event__title { margin: 0 0 40px 0; font-size: 40px; font-weight: 700; color: #fff; }
  .mk-countdown-event__countdown { display: flex; justify-content: center; gap: 20px; }
  .mk-countdown-event__item { display: flex; flex-direction: column; align-items: center; gap: var(--mk-spacing-sm); }
  .mk-countdown-event__num { min-width: 80px; padding: var(--mk-spacing-lg); background: rgba(255,255,255,0.2); backdrop-filter: blur(10px); border-radius: var(--mk-radius-md); font-size: var(--mk-font-size-5xl); font-weight: 700; color: #fff; }
  .mk-countdown-event__label { font-size: var(--mk-font-size-xs); text-transform: uppercase; letter-spacing: 1px; color: rgba(255,255,255,0.8); }
{% endstylesheet %}

{% javascript %}
  (function() {
    const c = document.querySelector('[data-countdown-event]');
    if (!c) return;
    const end = new Date(c.dataset.end).getTime();
    function u() {
      const now = Date.now(), diff = Math.max(0, end - now);
      const d = Math.floor(diff/86400000), h = Math.floor((diff%86400000)/3600000), m = Math.floor((diff%3600000)/60000), s = Math.floor((diff%60000)/1000);
      c.querySelector('[data-days]').textContent = String(d).padStart(2,'0');
      c.querySelector('[data-hours]').textContent = String(h).padStart(2,'0');
      c.querySelector('[data-minutes]').textContent = String(m).padStart(2,'0');
      c.querySelector('[data-seconds]').textContent = String(s).padStart(2,'0');
    }
    u(); setInterval(u, 1000);
  })();
{% endjavascript %}

{% schema %}
{
  "name": "MK Countdown Event",
  "tag": "section",
  "settings": [
    { "type": "image_picker", "id": "image", "label": "背景图片" },
    { "type": "text", "id": "badge", "label": "徽章" },
    { "type": "text", "id": "title", "label": "标题" },
    { "type": "text", "id": "end_date", "label": "结束日期" }
  ],
  "presets": [{ "name": "MK Countdown Event" }]
}
{% endschema %}
