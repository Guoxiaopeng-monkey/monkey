{%- doc -%}
  MK 颜色色块组件

  渲染颜色选择色块

  @param {string} color - 颜色值（如 #FF0000 或 red）
  @param {boolean} [selected] - 是否选中
  @param {string} [value] - 关联的值
  @param {string} [class] - 额外CSS类名

  @example
  {% render 'mk-color-swatch', color: '#FF0000', selected: true, value: 'red' %}
{%- enddoc -%}

{% liquid
  assign color = color | default: '#ccc'
  assign selected = selected | default: false
  assign value = value | default: color
  assign class = class | default: ''
-%}

<button
  type="button"
  class="mk-color-swatch {{ class }}"
  data-value="{{ value }}"
  {% if selected %}
    selected
  {% endif %}
  style="--swatch-color: {{ color }};"
  aria-label="{{ value }}"
>
  <span class="mk-color-swatch__inner"></span>
</button>

{% stylesheet %}
  .mk-color-swatch {
    position: relative;
    width: 32px;
    height: 32px;
    padding: 2px;
    background: transparent;
    border: 2px solid transparent;
    border-radius: 50%;
    cursor: pointer;
    transition: all 0.2s ease;
  }

  .mk-color-swatch:hover {
    border-color: var(--color-border);
  }

  .mk-color-swatch[selected] {
    border-color: var(--color-primary, #000);
  }

  .mk-color-swatch__inner {
    display: block;
    width: 100%;
    height: 100%;
    background-color: var(--swatch-color);
    border-radius: 50%;
    box-shadow: inset 0 0 0 1px rgba(0, 0, 0, 0.1);
  }

  /* 白色需要特殊处理边框 */
  .mk-color-swatch[style*="ffffff"] .mk-color-swatch__inner,
  .mk-color-swatch[style*="FFFFFF"] .mk-color-swatch__inner {
    border: 1px solid var(--color-border);
  }
{% endstylesheet %}
