{%- comment -%}
  MK 客服聊天板块

  展示客服联系方式

  作者：崽崽 (AI助手)
{%- endcomment -%}

{% liquid
  assign ss = section.settings
-%}

<section
  id="{{ section.id }}"
  class="mk-customer-service color-{{ ss.color_scheme | default: 'background-1' }}"
>
  <div class="mk-customer-service__container">
    {%- if ss.title != blank -%}
      <h2 class="mk-customer-service__title">{{ ss.title }}</h2>
    {%- endif -%}

    {%- if ss.subtitle != blank -%}
      <p class="mk-customer-service__subtitle">{{ ss.subtitle }}</p>
    {%- endif -%}

    <div class="mk-customer-service__methods">
      {%- for i in (1..3) -%}
        {%- assign icon_setting = 'icon_' | append: i -%}
        {%- assign title_setting = 'title_' | append: i -%}
        {%- assign value_setting = 'value_' | append: i -%}
        {%- assign link_setting = 'link_' | append: i -%}
        {%- assign icon = ss[icon_setting] -%}
        {%- assign title = ss[title_setting] -%}
        {%- assign value = ss[value_setting] -%}
        {%- assign link = ss[link_setting] -%}

        {%- if title != blank and value != blank -%}
          <div class="mk-customer-service__method">
            {%- if icon != blank -%}
              <div class="mk-customer-service__icon">
                {{ icon | image_url: width: 64 | image_tag }}
              </div>
            {%- endif -%}

            <div class="mk-customer-service__info">
              <h3 class="mk-customer-service__method-title">{{ title }}</h3>
              {%- if link != blank -%}
                <a href="{{ link }}" class="mk-customer-service__method-value">{{ value }}</a>
              {%- else -%}
                <p class="mk-customer-service__method-value">{{ value }}</p>
              {%- endif -%}
            </div>
          </div>
        {%- endif -%}
      {%- endfor -%}
    </div>

    {%- if ss.hours != blank -%}
      <p class="mk-customer-service__hours">{{ ss.hours }}</p>
    {%- endif -%}
  </div>
</section>

{% stylesheet %}
  .mk-customer-service {
    padding: {{ ss.padding_top_mobile | default: 48 }}px 0 {{ ss.padding_bottom_mobile | default: 48 }}px;
  }

  @media (min-width: 750px) {
    .mk-customer-service {
      padding: {{ ss.padding_top_desktop | default: 64 }}px 0 {{ ss.padding_bottom_desktop | default: 64 }}px;
    }
  }

  .mk-customer-service__container {
    max-width: var(--container-max-width, 800px);
    margin: 0 auto;
    padding: 0 var(--container-padding, 32px);
    text-align: center;
  }

  .mk-customer-service__title {
    margin: 0 0 8px 0;
    font-size: 24px;
    font-weight: 700;
  }

  .mk-customer-service__subtitle {
    margin: 0 0 32px 0;
    font-size: 14px;
    color: var(--color-text-secondary, #666);
  }

  .mk-customer-service__methods {
    display: grid;
    grid-template-columns: repeat(1, 1fr);
    gap: 24px;
    margin-bottom: 24px;
  }

  @media (min-width: 480px) {
    .mk-customer-service__methods {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  .mk-customer-service__method {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 12px;
  }

  .mk-customer-service__icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 64px;
    height: 64px;
  }

  .mk-customer-service__icon img {
    width: 100%;
    height: 100%;
    object-fit: contain;
  }

  .mk-customer-service__method-title {
    margin: 0 0 4px 0;
    font-size: 14px;
    font-weight: 600;
  }

  .mk-customer-service__method-value {
    margin: 0;
    font-size: 14px;
    color: var(--color-primary, #000);
    text-decoration: none;
  }

  a.mk-customer-service__method-value:hover {
    text-decoration: underline;
  }

  .mk-customer-service__hours {
    margin: 0;
    font-size: 13px;
    color: var(--color-text-secondary, #666);
  }
{% endstylesheet %}

