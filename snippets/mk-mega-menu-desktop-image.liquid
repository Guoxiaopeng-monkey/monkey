{%- comment -%}
  MK MegaMenu Desktop Image 组件 (PC端带图片)
  
  功能：渲染桌面端带图片的 MegaMenu 下拉菜单
  
  参数：
    - mega_menu_block: MegaMenu block 对象
    - link: 父级链接对象
  
  作者：崽崽 (AI助手)
  基于：mypetcustom/mk-mega-menu-desktop-image.liquid
{%- endcomment -%}

{%- doc -%}
  Renders desktop mega menu with image for header navigation.

  @param {object} mega_menu_block - The mega menu block settings
  @param {linklist} link - The parent menu link

  @example
  {% render 'mk-mega-menu-desktop-image', mega_menu_block: block, link: link %}
{%- enddoc -%}

<div class="mk-mega-menu mk-mega-menu--with-image" data-mega-menu>
  <div class="mk-mega-menu__content">
    {% if mega_menu_block.settings.title != blank %}
      <h3 class="mk-mega-menu__title">{{ mega_menu_block.settings.title }}</h3>
    {% endif %}
    
    {% if mega_menu_block.settings.description != blank %}
      <p class="mk-mega-menu__description">{{ mega_menu_block.settings.description }}</p>
    {% endif %}
    
    {% if mega_menu_block.settings.link_text != blank and mega_menu_block.settings.link_url != blank %}
      <a 
        href="{{ mega_menu_block.settings.link_url }}" 
        class="mk-mega-menu__link"
      >
        {{ mega_menu_block.settings.link_text }}
        <span class="mk-mega-menu__arrow">
          {{- 'icon-arrow-right.svg' | inline_asset_content -}}
        </span>
      </a>
    {% endif %}
  </div>
  
  {% if mega_menu_block.settings.image != blank %}
    <div class="mk-mega-menu__image">
      {% if mega_menu_block.settings.image_link_url != blank %}
        <a href="{{ mega_menu_block.settings.image_link_url }}">
      {% endif %}
      
      <img
        src="{{ mega_menu_block.settings.image | image_url: width: 400 }}"
        alt="{{ mega_menu_block.settings.image_title | default: mega_menu_block.settings.title }}"
        width="400"
        height="{{ 400 | divided_by: mega_menu_block.settings.image.aspect_ratio | round }}"
        loading="lazy"
      >
      
      {% if mega_menu_block.settings.image_title != blank %}
        <p class="mk-mega-menu__image-title">{{ mega_menu_block.settings.image_title }}</p>
      {% endif %}
      
      {% if mega_menu_block.settings.image_link_url != blank %}
        </a>
      {% endif %}
    </div>
  {% endif %}
</div>

{% stylesheet %}
  .mk-mega-menu--with-image {
    display: flex;
    min-width: 500px;
    max-width: 700px;
  }

  .mk-mega-menu--with-image .mk-mega-menu__content {
    flex: 1;
    padding: 28px 24px;
  }

  .mk-mega-menu--with-image .mk-mega-menu__image {
    flex: 0 0 45%;
    position: relative;
    overflow: hidden;
    border-radius: 0 8px 8px 0;
  }

  .mk-mega-menu--with-image .mk-mega-menu__image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .mk-mega-menu__image-title {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    margin: 0;
    padding: 16px;
    background: linear-gradient(transparent, rgba(0, 0, 0, 0.7));
    color: #fff;
    font-size: 14px;
    font-weight: 500;
  }
{% endstylesheet %}
