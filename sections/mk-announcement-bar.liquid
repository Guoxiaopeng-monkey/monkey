{%- comment -%}
  MK 公告栏板块

  顶部公告信息栏

  作者：崽崽 (AI助手)
{%- endcomment -%}

{% liquid
  assign ss = section.settings
-%}

{%- if ss.text != blank -%}
  <div
    id="{{ section.id }}"
    class="mk-announcement-bar"
    style="--announcement-bg: {{ ss.background_color | default: '#000' }}; --announcement-text: {{ ss.text_color | default: '#fff' }};"
  >
    <div class="mk-announcement-bar__container">
      {%- if ss.link != blank -%}
        <a href="{{ ss.link }}" class="mk-announcement-bar__link">
      {%- endif -%}

      <p class="mk-announcement-bar__text">{{ ss.text }}</p>

      {%- if ss.show_close_button -%}
        <button type="button" class="mk-announcement-bar__close" aria-label="{{ 关闭 }}">
          {{- 'icon-close.svg' | inline_asset_content -}}
        </button>
      {%- endif -%}

      {%- if ss.link != blank -%}
        </a>
      {%- endif -%}
    </div>
  </div>
{%- endif -%}

{% stylesheet %}
  .mk-announcement-bar {
    background-color: var(--announcement-bg, #000);
    color: var(--announcement-text, #fff);
  }

  .mk-announcement-bar__container {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 12px;
    max-width: var(--container-max-width, 1200px);
    margin: 0 auto;
    padding: 12px var(--container-padding, 32px);
    text-align: center;
  }

  .mk-announcement-bar__link {
    text-decoration: none;
    color: inherit;
  }

  .mk-announcement-bar__text {
    margin: 0;
    font-size: 13px;
    font-weight: 500;
    letter-spacing: 0.5px;
  }

  .mk-announcement-bar__close {
    position: absolute;
    right: 16px;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 28px;
    height: 28px;
    padding: 0;
    background: transparent;
    border: none;
    border-radius: 50%;
    cursor: pointer;
    color: inherit;
    opacity: 0.7;
    transition: opacity 0.2s ease;
  }

  .mk-announcement-bar__close:hover {
    opacity: 1;
  }

  .mk-announcement-bar__close svg {
    width: 16px;
    height: 16px;
  }

  @media (max-width: 480px) {
    .mk-announcement-bar__close {
      right: 8px;
    }
  }
{% endstylesheet %}

{% javascript %}
  class AnnouncementBar extends HTMLElement {
    constructor() {
      super();
      this.closeBtn = this.querySelector('.mk-announcement-bar__close');
      if (this.closeBtn) {
        this.closeBtn.addEventListener('click', () => this.close());
      }
    }

    close() {
      this.style.display = 'none';
      // 可以保存到localStorage以记住用户关闭了公告栏
      try {
        localStorage.setItem('announcement-' + this.id, 'closed');
      } catch (e) {}
    }
  }

  customElements.define('announcement-bar', AnnouncementBar);
{% endjavascript %}

{% schema %}
{
  "name": "MK 公告栏",
  "tag": "section",
  "settings": [
    {
      "type": "textarea",
      "id": "text",
      "label": "公告文本",
      "default": "全场满100减10，限时优惠中！"
    },
    {
      "type": "url",
      "id": "link",
      "label": "链接"
    },
    {
      "type": "checkbox",
      "id": "show_close_button",
      "label": "显示关闭按钮",
      "default": true
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "背景颜色",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "文字颜色",
      "default": "#ffffff"
    }
  ],
  "presets": [
    {
      "name": "MK 公告栏"
    }
  ]
}
{% endschema %}
