{%- comment -%}
  MK 联系页面板块

  展示联系信息页面

  作者：崽崽 (AI助手)
{%- endcomment -%}

{% liquid
  assign ss = section.settings
-%}

<section
  id="{{ section.id }}"
  class="mk-contact color-{{ ss.color_scheme | default: 'background-1' }}"
>
  <div class="mk-contact__container">
    {%- if ss.title != blank -%}
      <h1 class="mk-contact__title">{{ ss.title }}</h1>
    {%- endif -%}

    <div class="mk-contact__grid">
      {%- for i in (1..3) -%}
        {%- assign icon_setting = 'icon_' | append: i -%}
        {%- assign title_setting = 'title_' | append: i -%}
        {%- assign value_setting = 'value_' | append: i -%}
        {%- assign link_setting = 'link_' | append: i -%}

        {%- if ss[title_setting] != blank -%}
          <div class="mk-contact__card">
            <div class="mk-contact__icon">
              {{ ss[icon_setting] | default: 'icon-mail.svg' | inline_asset_content }}
            </div>
            <div class="mk-contact__info">
              <h3 class="mk-contact__card-title">{{ ss[title_setting] }}</h3>
              {%- if ss[link_setting] != blank -%}
                <a href="{{ ss[link_setting] }}" class="mk-contact__card-value">{{ ss[value_setting] }}</a>
              {%- else -%}
                <p class="mk-contact__card-value">{{ ss[value_setting] }}</p>
              {%- endif -%}
            </div>
          </div>
        {%- endif -%}
      {%- endfor -%}
    </div>

    {%- if ss.show_form -%}
      <div class="mk-contact__form-wrapper">
        {% form 'contact', class: 'mk-contact__form' %}
          {%- if form.posted_successfully? -%}
            <p class="mk-contact__success">{{ 'contact.success' | t | default: '感谢您的留言，我们会尽快与您联系！' }}</p>
          {%- endif -%}

          <div class="mk-contact__form-row">
            <div class="mk-contact__field">
              <label for="contact-name" class="mk-contact__label">{{ 'contact.name' | t | default: '姓名' }}</label>
              <input type="text" id="contact-name" name="contact[name]" class="mk-contact__input" required>
            </div>

            <div class="mk-contact__field">
              <label for="contact-email" class="mk-contact__label">{{ 'contact.email' | t | default: '邮箱' }}</label>
              <input type="email" id="contact-email" name="contact[email]" class="mk-contact__input" required>
            </div>
          </div>

          <div class="mk-contact__field">
            <label for="contact-message" class="mk-contact__label">{{ 'contact.message' | t | default: '留言' }}</label>
            <textarea id="contact-message" name="contact[body]" class="mk-contact__textarea" rows="6" required></textarea>
          </div>

          <button type="submit" class="mk-contact__submit">
            {{ 'contact.submit' | t | default: '提交' }}
          </button>
        {% endform %}
      </div>
    {%- endif -%}
  </div>
</section>

{% stylesheet %}
  .mk-contact {
    padding: {{ ss.padding_top_mobile | default: 48 }}px 0 {{ ss.padding_bottom_mobile | default: 48 }}px;
  }

  @media (min-width: 750px) {
    .mk-contact {
      padding: {{ ss.padding_top_desktop | default: 64 }}px 0 {{ ss.padding_bottom_desktop | default: 64 }}px;
    }
  }

  .mk-contact__container {
    max-width: var(--container-max-width, 1000px);
    margin: 0 auto;
    padding: 0 var(--container-padding, 32px);
  }

  .mk-contact__title {
    margin: 0 0 32px 0;
    font-size: 28px;
    font-weight: 700;
    text-align: center;
  }

  .mk-contact__grid {
    display: grid;
    grid-template-columns: repeat(1, 1fr);
    gap: 24px;
    margin-bottom: 48px;
  }

  @media (min-width: 480px) {
    .mk-contact__grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  .mk-contact__card {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    padding: 24px;
    background-color: var(--color-background-secondary, #f5f5f5);
    border-radius: 12px;
  }

  .mk-contact__icon {
    display: flex;
    width: 48px;
    height: 48px;
    margin-bottom: 16px;
    color: var(--color-primary, #000);
  }

  .mk-contact__icon svg {
    width: 100%;
    height: 100%;
  }

  .mk-contact__card-title {
    margin: 0 0 8px 0;
    font-size: 16px;
    font-weight: 600;
  }

  .mk-contact__card-value {
    margin: 0;
    font-size: 14px;
    color: var(--color-text-secondary, #666);
  }

  a.mk-contact__card-value {
    color: var(--color-primary, #000);
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  .mk-contact__form-wrapper {
    max-width: 600px;
    margin: 0 auto;
  }

  .mk-contact__form {
    display: flex;
    flex-direction: column;
    gap: 20px;
  }

  .mk-contact__form-row {
    display: grid;
    grid-template-columns: 1fr;
    gap: 20px;
  }

  @media (min-width: 480px) {
    .mk-contact__form-row {
      grid-template-columns: 1fr 1fr;
    }
  }

  .mk-contact__field {
    display: flex;
    flex-direction: column;
    gap: 6px;
  }

  .mk-contact__label {
    font-size: 14px;
    font-weight: 500;
  }

  .mk-contact__input,
  .mk-contact__textarea {
    padding: 14px 16px;
    font-size: 14px;
    color: var(--color-foreground);
    background-color: var(--color-background);
    border: 1px solid var(--color-border);
    border-radius: 8px;
    transition: border-color 0.2s ease;
  }

  .mk-contact__input:focus,
  .mk-contact__textarea:focus {
    outline: none;
    border-color: var(--color-primary, #000);
  }

  .mk-contact__textarea {
    resize: vertical;
    min-height: 150px;
  }

  .mk-contact__submit {
    padding: 14px 32px;
    font-size: 14px;
    font-weight: 600;
    color: var(--color-on-primary, #fff);
    background-color: var(--color-primary, #000);
    border: none;
    border-radius: 8px;
    cursor: pointer;
    transition: all 0.2s ease;
  }

  .mk-contact__submit:hover {
    opacity: 0.85;
  }

  .mk-contact__success {
    padding: 16px;
    background-color: rgba(46, 125, 50, 0.1);
    color: var(--color-success, #2e7d32);
    border-radius: 8px;
    text-align: center;
  }
{% endstylesheet %}

