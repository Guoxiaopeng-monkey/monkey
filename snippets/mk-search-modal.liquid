{%- doc -%}
  MK 搜索模态框组件

  渲染搜索弹窗

  @param {string} [class] - 额外CSS类名

  @example
  {% render 'mk-search-modal' %}
{%- enddoc -%}

{% liquid
  assign class = class | default: ''
-%}

<div class="mk-search-modal {{ class }}" data-search-modal hidden>
  <div class="mk-search-modal__overlay" data-search-close></div>
  <div class="mk-search-modal__container">
    <div class="mk-search-modal__header">
      <div class="mk-search-modal__input-wrap">
        <span class="mk-search-modal__icon">{{- 'icon-search.svg' | inline_asset_content -}}</span>
        <input type="search" class="mk-search-modal__input" placeholder="{{ 'search.placeholder' | t | default: '搜索产品...' }}" data-search-input autocomplete="off">
        <button type="button" class="mk-search-modal__clear" hidden data-search-clear>{{- 'icon-close.svg' | inline_asset_content -}}</button>
      </div>
      <button type="button" class="mk-search-modal__close" data-search-close>{{ 'actions.close' | t | default: '关闭' }}</button>
    </div>
    <div class="mk-search-modal__content" data-search-content></div>
  </div>
</div>

{% stylesheet %}
  .mk-search-modal[hidden] { display: none; }
  .mk-search-modal__overlay { position: fixed; inset: 0; background: rgba(0,0,0,0.5); z-index: 998; }
  .mk-search-modal__container { position: fixed; top: 10%; left: 50%; transform: translateX(-50%); width: 90%; max-width: 600px; max-height: 80vh; background: var(--color-background); border-radius: 16px; z-index: 999; display: flex; flex-direction: column; box-shadow: 0 4px 30px rgba(0,0,0,0.2); overflow: hidden; }
  .mk-search-modal__header { display: flex; align-items: center; gap: 12px; padding: 16px 20px; border-bottom: 1px solid var(--color-border); }
  .mk-search-modal__input-wrap { flex: 1; display: flex; align-items: center; gap: 10px; }
  .mk-search-modal__icon { display: flex; width: 20px; height: 20px; color: var(--color-text-secondary, #666); }
  .mk-search-modal__icon svg { width: 100%; height: 100%; }
  .mk-search-modal__input { flex: 1; border: none; outline: none; font-size: 16px; background: transparent; }
  .mk-search-modal__clear { display: flex; width: 20px; height: 20px; padding: 0; background: transparent; border: none; cursor: pointer; color: var(--color-text-secondary, #666); }
  .mk-search-modal__clear svg { width: 100%; height: 100%; }
  .mk-search-modal__close { padding: 8px 16px; font-size: 14px; font-weight: 500; background: transparent; border: 1px solid var(--color-border); border-radius: 6px; cursor: pointer; }
  .mk-search-modal__content { flex: 1; overflow-y: auto; padding: 16px 20px; }
{% endstylesheet %}

{% javascript %}
  class SearchModal extends HTMLElement {
    constructor() {
      super();
      this.modal = this.querySelector('.mk-search-modal');
      this.input = this.querySelector('[data-search-input]');
      this.content = this.querySelector('[data-search-content]');
      this.init();
    }
    init() {
      document.querySelectorAll('[data-search-trigger]').forEach(trigger => {
        trigger.addEventListener('click', () => this.open());
      });
      this.querySelectorAll('[data-search-close]').forEach(btn => {
        btn.addEventListener('click', () => this.close());
      });
      this.input?.addEventListener('input', (e) => this.search(e.target.value));
    }
    open() { this.modal.hidden = false; document.body.style.overflow = 'hidden'; this.input?.focus(); }
    close() { this.modal.hidden = true; document.body.style.overflow = ''; }
    async search(query) {
      if (query.length < 2) { this.content.innerHTML = ''; return; }
      // Implement search logic
      this.content.innerHTML = '<p>搜索: ' + query + '</p>';
    }
  }
  customElements.define('search-modal', SearchModal);
{% endjavascript %}
