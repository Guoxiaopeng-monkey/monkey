{%- doc -%}
  MK 按钮组件

  渲染一个按钮链接

  @param {string} href - 链接地址
  @param {string} [label] - 按钮文字
  @param {string} [style] - 样式：primary, secondary, outline
  @param {boolean} [disabled] - 是否禁用
  @param {string} [class] - 额外CSS类名

  @example
  {% render 'mk-button', href: '/collections/all', label: '查看全部', style: 'primary' %}
{%- enddoc -%}

{% liquid
  assign href = href | default: '#'
  assign label = label | default: '按钮'
  assign style = style | default: 'primary'
  assign disabled = disabled | default: false
-%}

<a
  {% if href == blank %}
    role="link"
    aria-disabled="true"
  {% else %}
    href="{{ href }}"
  {% endif %}
  class="mk-button mk-button--{{ style }} {{ class }}"
  {% if disabled %}
    aria-disabled="true"
  {% endif %}
>
  {{ label }}
</a>

{% stylesheet %}
  .mk-button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: var(--mk-spacing-sm);
    padding: 14px 28px;
    font-size: var(--mk-font-size-md);
    font-weight: 600;
    text-decoration: none;
    border-radius: var(--mk-radius-sm);
    cursor: pointer;
    transition: all 0.2s ease;
  }

  .mk-button:focus {
    outline: none;
    box-shadow: 0 0 0 3px var(--mk-shadow-md));
  }

  /* Primary 样式 */
  .mk-button--primary {
    color: var(--color-on-primary, #fff);
    background-color: var(--color-primary, #000);
    border: none;
  }

  .mk-button--primary:hover {
    opacity: 0.85;
    transform: translateY(-1px);
  }

  /* Secondary 样式 */
  .mk-button--secondary {
    color: var(--color-foreground);
    background-color: var(--color-background-secondary, var(--mk-color-bg-secondary));
    border: none;
  }

  .mk-button--secondary:hover {
    background-color: var(--color-border);
  }

  /* Outline 样式 */
  .mk-button--outline {
    color: var(--color-primary, #000);
    background-color: transparent;
    border: 1px solid var(--color-primary, #000);
  }

  .mk-button--outline:hover {
    color: var(--color-on-primary, #fff);
    background-color: var(--color-primary, #000);
  }

  /* 禁用状态 */
  .mk-button[aria-disabled="true"] {
    opacity: 0.5;
    cursor: not-allowed;
    pointer-events: none;
  }

  /* 尺寸变体 */
  .mk-button--small {
    padding: var(--mk-spacing-sm) 20px;
    font-size: var(--mk-font-size-sm);
  }

  .mk-button--large {
    padding: 18px 36px;
    font-size: var(--mk-font-size-lg);
  }

  /* 全宽按钮 */
  .mk-button--full {
    width: 100%;
  }
{% endstylesheet %}
