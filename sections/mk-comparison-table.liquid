{%- comment -%}
  MK Comparison Table板块

  对比表格

  作者：崽崽 (AI助手)
{%- endcomment -%}

{% liquid
  assign ss = section.settings
-%}

<section id="{{ section.id }}" class="mk-comparison-table color-{{ ss.color_scheme | default: 'background-1' }}">
  <div class="mk-comparison-table__container">
    {%- if ss.title != blank -%}
      <h2 class="mk-comparison-table__title">{{ ss.title }}</h2>
    {%- endif -%}

    <div class="mk-comparison-table__wrapper">
      <table class="mk-comparison-table__table">
        <thead>
          <tr>
            <th></th>
            {%- for i in (1..4) -%}
              {%- assign product_setting = 'product_' | append: i -%}
              {%- if ss[product_setting] != blank -%}
                <th>{{ ss[product_setting] }}</th>
              {%- endif -%}
            {%- endfor -%}
          </tr>
        </thead>
        <tbody>
          {%- for row in (1..6) -%}
            {%- assign label_setting = 'row_label_' | append: row -%}
            {%- if ss[label_setting] != blank -%}
              <tr>
                <td class="mk-comparison-table__label">{{ ss[label_setting] }}</td>
                {%- for col in (1..4) -%}
                  {%- assign value_setting = 'row_' | append: row | append: '_col_' | append: col -%}
                  <td>{{ ss[value_setting] }}</td>
                {%- endfor -%}
              </tr>
            {%- endif -%}
          {%- endfor -%}
        </tbody>
      </table>
    </div>
  </div>
</section>

{% stylesheet %}
  .mk-comparison-table { padding: {{ ss.padding_top_mobile | default: 48 }}px 0 {{ ss.padding_bottom_mobile | default: 48 }}px; }
  @media (min-width: 750px) { .mk-comparison-table { padding: {{ ss.padding_top_desktop | default: 80 }}px 0 {{ ss.padding_bottom_desktop | default: 80 }}px; } }
  .mk-comparison-table__container { max-width: var(--container-max-width, 1000px); margin: 0 auto; padding: 0 var(--container-padding, 32px); }
  .mk-comparison-table__title { margin: 0 0 32px 0; font-size: var(--mk-font-size-3xl); font-weight: 700; text-align: center; }
  .mk-comparison-table__wrapper { overflow-x: auto; }
  .mk-comparison-table__table { width: 100%; border-collapse: collapse; }
  .mk-comparison-table__table th, .mk-comparison-table__table td { padding: var(--mk-spacing-lg); text-align: center; border-bottom: 1px solid var(--color-border); }
  .mk-comparison-table__table th { font-size: var(--mk-font-size-md); font-weight: 600; }
  .mk-comparison-table__table .mk-comparison-table__label { text-align: left; font-weight: 500; }
{% endstylesheet %}

{% schema %}
{
  "name": "MK Comparison Table",
  "tag": "section",
  "settings": [
    { "type": "text", "id": "title", "label": "标题" },
    { "type": "header", "content": "产品列" },
    { "type": "text", "id": "product_1", "label": "产品 1" }, { "type": "text", "id": "product_2", "label": "产品 2" }, { "type": "text", "id": "product_3", "label": "产品 3" }, { "type": "text", "id": "product_4", "label": "产品 4" },
    { "type": "header", "content": "行 1" }, { "type": "text", "id": "row_label_1", "label": "标签 1" }, { "type": "text", "id": "row_1_col_1", "label": "值 1-1" }, { "type": "text", "id": "row_1_col_2", "label": "值 1-2" }, { "type": "text", "id": "row_1_col_3", "label": "值 1-3" }, { "type": "text", "id": "row_1_col_4", "label": "值 1-4" },
    { "type": "header", "content": "行 2" }, { "type": "text", "id": "row_label_2", "label": "标签 2" }, { "type": "text", "id": "row_2_col_1", "label": "值 2-1" }, { "type": "text", "id": "row_2_col_2", "label": "值 2-2" }, { "type": "text", "id": "row_2_col_3", "label": "值 2-3" }, { "type": "text", "id": "row_2_col_4", "label": "值 2-4" },
    { "type": "header", "content": "行 3" }, { "type": "text", "id": "row_label_3", "label": "标签 3" }, { "type": "text", "id": "row_3_col_1", "label": "值 3-1" }, { "type": "text", "id": "row_3_col_2", "label": "值 3-2" }, { "type": "text", "id": "row_3_col_3", "label": "值 3-3" }, { "type": "text", "id": "row_3_col_4", "label": "值 3-4" },
    { "type": "header", "content": "间距" },
    { "type": "range", "id": "padding_top_mobile", "label": "上边距 (移动端)", "min": 0, "max": 120, "default": 48, "unit": "px" },
    { "type": "range", "id": "padding_bottom_mobile", "label": "下边距 (移动端)", "min": 0, "max": 120, "default": 48, "unit": "px" },
    { "type": "range", "id": "padding_top_desktop", "label": "上边距 (PC端)", "min": 0, "max": 200, "default": 80, "unit": "px" },
    { "type": "range", "id": "padding_bottom_desktop", "label": "下边距 (PC端)", "min": 0, "max": 200, "default": 80, "unit": "px" },
    { "type": "color_scheme", "id": "color_scheme", "label": "颜色方案", "default": "scheme-1" }
  ],
  "presets": [{ "name": "MK Comparison Table" }]
}
{% endschema %}
