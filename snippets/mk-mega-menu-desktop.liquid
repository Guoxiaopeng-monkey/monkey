{%- comment -%}
  MK MegaMenu Desktop 组件 (PC端)
  
  功能：渲染桌面端 MegaMenu 下拉菜单
  特点：只显示配置的内容，不显示子菜单
  
  参数：
    - mega_menu_block: MegaMenu block 对象
    - link: 父级链接对象
  
  作者：崽崽 (AI助手)
  基于：mypetcustom/mk-mega-menu-desktop.liquid
{%- endcomment -%}

{%- doc -%}
  Renders desktop mega menu for header navigation.
  如果存在 mega menu，只显示配置的内容，不显示子菜单。

  @param {object} mega_menu_block - The mega menu block settings
  @param {linklist} link - The parent menu link

  @example
  {% render 'mk-mega-menu-desktop', mega_menu_block: block, link: link %}
{%- enddoc -%}

<div class="mk-mega-menu" data-mega-menu>
  <div class="mk-mega-menu__content">
    {% if mega_menu_block.settings.title != blank %}
      <h3 class="mk-mega-menu__title">{{ mega_menu_block.settings.title }}</h3>
    {% endif %}
    
    {% if mega_menu_block.settings.description != blank %}
      <p class="mk-mega-menu__description">{{ mega_menu_block.settings.description }}</p>
    {% endif %}
    
    {% if mega_menu_block.settings.link_text != blank and mega_menu_block.settings.link_url != blank %}
      <a 
        href="{{ mega_menu_block.settings.link_url }}" 
        class="mk-mega-menu__link"
      >
        {{ mega_menu_block.settings.link_text }}
        <span class="mk-mega-menu__arrow">
          {{- 'icon-arrow-right.svg' | inline_asset_content -}}
        </span>
      </a>
    {% endif %}
  </div>
</div>

{% stylesheet %}
  .mk-mega-menu {
    position: absolute;
    top: 100%;
    left: 50%;
    transform: translateX(-50%) translateY(8px);
    min-width: 280px;
    background: var(--header-bg, #ffffff);
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.12);
    border-radius: 8px;
    opacity: 0;
    visibility: hidden;
    transition: all 0.25s ease;
    z-index: 100;
    pointer-events: none;
  }

  /* 当父级菜单项 hover 时显示 */
  .mk-header__menu-item--has-mega-menu:hover .mk-mega-menu {
    opacity: 1;
    visibility: visible;
    transform: translateX(-50%) translateY(0);
    pointer-events: auto;
  }

  .mk-mega-menu__content {
    padding: 24px 28px;
  }

  .mk-mega-menu__title {
    margin: 0 0 8px 0;
    font-size: 16px;
    font-weight: 600;
    color: inherit;
    line-height: 1.4;
  }

  .mk-mega-menu__description {
    margin: 0 0 16px 0;
    font-size: 14px;
    color: rgba(var(--color-foreground), 0.75);
    line-height: 1.5;
  }

  .mk-mega-menu__link {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-size: 14px;
    font-weight: 500;
    color: var(--color-primary, #000);
    text-decoration: none;
    transition: gap 0.2s ease;
  }

  .mk-mega-menu__link:hover {
    gap: 10px;
  }

  .mk-mega-menu__arrow {
    display: flex;
    align-items: center;
    width: 16px;
    height: 16px;
  }

  .mk-mega-menu__arrow svg {
    width: 100%;
    height: 100%;
  }
{% endstylesheet %}
