{%- comment -%}
  MK Services板块

  展示服务项目

  作者：崽崽 (AI助手)
{%- endcomment -%}

{% liquid
  assign ss = section.settings
-%}

<section
  id="{{ section.id }}"
  class="mk-services color-{{ ss.color_scheme | default: 'background-1' }}"
>
  <div class="mk-services__container">
    {%- if ss.title != blank -%}
      <h2 class="mk-services__title">{{ ss.title }}</h2>
    {%- endif -%}

    <div class="mk-services__grid">
      {%- for i in (1..6) -%}
        {%- assign icon_setting = 'icon_' | append: i -%}
        {%- assign title_setting = 'title_' | append: i -%}
        {%- assign description_setting = 'description_' | append: i -%}

        {%- if ss[title_setting] != blank -%}
          <div class="mk-services__item">
            {%- if ss[icon_setting] != blank -%}
              <div class="mk-services__icon">
                {{ ss[icon_setting] | default: 'icon-check.svg' | inline_asset_content }}
              </div>
            {%- endif -%}
            <h3 class="mk-services__item-title">{{ ss[title_setting] }}</h3>
            {%- if ss[description_setting] != blank -%}
              <p class="mk-services__description">{{ ss[description_setting] }}</p>
            {%- endif -%}
          </div>
        {%- endif -%}
      {%- endfor -%}
    </div>
  </div>
</section>

{% stylesheet %}
  .mk-services { padding: {{ ss.padding_top_mobile | default: 48 }}px 0 {{ ss.padding_bottom_mobile | default: 48 }}px; }
  @media (min-width: 750px) { .mk-services { padding: {{ ss.padding_top_desktop | default: 80 }}px 0 {{ ss.padding_bottom_desktop | default: 80 }}px; } }
  .mk-services__container { max-width: var(--container-max-width, 1200px); margin: 0 auto; padding: 0 var(--container-padding, 32px); }
  .mk-services__title { margin: 0 0 40px 0; font-size: 28px; font-weight: 700; text-align: center; }
  .mk-services__grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 32px; }
  @media (min-width: 750px) { .mk-services__grid { grid-template-columns: repeat(3, 1fr); gap: 48px; } }
  .mk-services__item { display: flex; flex-direction: column; align-items: center; text-align: center; gap: 16px; }
  .mk-services__icon { display: flex; align-items: center; justify-content: center; width: 64px; height: 64px; background: var(--color-background-secondary, #f5f5f5); border-radius: 50%; }
  .mk-services__icon svg { width: 32px; height: 32px; color: var(--color-primary, #000); }
  .mk-services__item-title { margin: 0; font-size: 16px; font-weight: 600; }
  .mk-services__description { margin: 0; font-size: 14px; color: var(--color-text-secondary, #666); }
{% endstylesheet %}

{% schema %}
{
  "name": "MK Services",
  "tag": "section",
  "settings": [
    { "type": "text", "id": "title", "label": "标题" },
    { "type": "header", "content": "服务项 1" },
    { "type": "text", "id": "title_1", "label": "标题 1" },
    { "type": "textarea", "id": "description_1", "label": "描述 1" },
    { "type": "header", "content": "服务项 2" },
    { "type": "text", "id": "title_2", "label": "标题 2" },
    { "type": "textarea", "id": "description_2", "label": "描述 2" },
    { "type": "header", "content": "服务项 3" },
    { "type": "text", "id": "title_3", "label": "标题 3" },
    { "type": "textarea", "id": "description_3", "label": "描述 3" },
    { "type": "header", "content": "服务项 4" },
    { "type": "text", "id": "title_4", "label": "标题 4" },
    { "type": "textarea", "id": "description_4", "label": "描述 4" },
    { "type": "header", "content": "服务项 5" },
    { "type": "text", "id": "title_5", "label": "标题 5" },
    { "type": "textarea", "id": "description_5", "label": "描述 5" },
    { "type": "header", "content": "服务项 6" },
    { "type": "text", "id": "title_6", "label": "标题 6" },
    { "type": "textarea", "id": "description_6", "label": "描述 6" },
    { "type": "header", "content": "间距" },
    { "type": "range", "id": "padding_top_mobile", "label": "上边距 (移动端)", "min": 0, "max": 120, "default": 48, "unit": "px" },
    { "type": "range", "id": "padding_bottom_mobile", "label": "下边距 (移动端)", "min": 0, "max": 120, "default": 48, "unit": "px" },
    { "type": "range", "id": "padding_top_desktop", "label": "上边距 (PC端)", "min": 0, "max": 200, "default": 80, "unit": "px" },
    { "type": "range", "id": "padding_bottom_desktop", "label": "下边距 (PC端)", "min": 0, "max": 200, "default": 80, "unit": "px" },
    { "type": "color_scheme", "id": "color_scheme", "label": "颜色方案", "default": "scheme-1" }
  ],
  "presets": [{ "name": "MK Services" }]
}
{% endschema %}
