{%- comment -%}
  MK Banner板块

  展示通栏横幅

  作者：崽崽 (AI助手)
{%- endcomment -%}

{% liquid
  assign ss = section.settings
-%}

<section
  id="{{ section.id }}"
  class="mk-banner color-{{ ss.color_scheme | default: 'background-1' }}"
>
  <div class="mk-banner__container">
    {%- if ss.image != blank -%}
      <div class="mk-banner__image">
        {{ ss.image | image_url: width: 1920 | image_tag: loading: 'lazy' }}
      </div>
    {%- endif -%}

    <div class="mk-banner__content">
      {%- if ss.title != blank -%}
        <h2 class="mk-banner__title">{{ ss.title }}</h2>
      {%- endif -%}

      {%- if ss.description != blank -%}
        <p class="mk-banner__description">{{ ss.description }}</p>
      {%- endif -%}

      {%- if ss.button_text != blank -%}
        <a href="{{ ss.button_link | default: '#' }}" class="mk-banner__button">
          {{ ss.button_text }}
        </a>
      {%- endif -%}
    </div>
  </div>
</section>

{% stylesheet %}
  .mk-banner { position: relative; overflow: hidden; }
  .mk-banner__image { position: absolute; inset: 0; }
  .mk-banner__image img { width: 100%; height: 100%; object-fit: cover; }
  .mk-banner__content { position: relative; display: flex; flex-direction: column; align-items: center; justify-content: center; text-align: center; min-height: {{ ss.height_mobile | default: 300 }}px; padding: var(--mk-spacing-5xl) {{ ss.padding_mobile | default: 24 }}px; }
  @media (min-width: 750px) { .mk-banner__content { min-height: {{ ss.height_desktop | default: 400 }}px; padding: var(--mk-spacing-6xl) {{ ss.padding_desktop | default: 64 }}px; } }
  .mk-banner__title { margin: 0 0 16px 0; font-size: var(--mk-font-size-3xl); font-weight: 700; }
  @media (min-width: 750px) { .mk-banner__title { font-size: var(--mk-font-size-5xl); } }
  .mk-banner__description { margin: 0 0 24px 0; font-size: var(--mk-font-size-lg); max-width: 600px; }
  .mk-banner__button { display: inline-flex; padding: 14px 32px; font-size: var(--mk-font-size-md); font-weight: 600; color: var(--color-on-primary, #fff); background: var(--color-primary, #000); border-radius: var(--mk-radius-sm); text-decoration: none; }
  .mk-banner__button:hover { opacity: 0.85; }
{% endstylesheet %}

{% schema %}
{
  "name": "MK Banner",
  "tag": "section",
  "settings": [
    { "type": "image_picker", "id": "image", "label": "背景图片" },
    { "type": "text", "id": "title", "label": "标题" },
    { "type": "textarea", "id": "description", "label": "描述" },
    { "type": "text", "id": "button_text", "label": "按钮文字" },
    { "type": "url", "id": "button_link", "label": "按钮链接" },
    { "type": "range", "id": "height_mobile", "label": "高度 (移动端)", "min": 200, "max": 600, "default": 300, "unit": "px" },
    { "type": "range", "id": "height_desktop", "label": "高度 (PC端)", "min": 300, "max": 800, "default": 400, "unit": "px" },
    { "type": "range", "id": "padding_mobile", "label": "内边距 (移动端)", "min": 16, "max": 64, "default": 24, "unit": "px" },
    { "type": "range", "id": "padding_desktop", "label": "内边距 (PC端)", "min": 32, "max": 128, "default": 64, "unit": "px" },
    { "type": "color_scheme", "id": "color_scheme", "label": "颜色方案", "default": "scheme-1" }
  ],
  "presets": [{ "name": "MK Banner" }]
}
{% endschema %}
