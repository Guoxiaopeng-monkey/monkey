{%- doc -%}
  MK 购物车抽屉组件

  渲染购物车抽屉，一个滑出面板显示购物车内容。

  @param {object} [settings] - 主题设置对象
  @param {boolean} [settings.auto_open_cart_drawer] - 是否在添加商品后自动打开抽屉
  @param {string} [settings.drawer_color_scheme] - 抽屉的颜色方案

  @example
  {% render 'mk-cart-drawer', settings: section.settings %}
{%- enddoc -%}

<script
  src="{{ 'mk-cart-drawer.js' | asset_url }}"
  type="module"
  fetchpriority="low"
></script>

<cart-drawer-component
  class="mk-cart-drawer"
  {{ block.shopify_attributes }}
  {% if settings.auto_open_cart_drawer %}
    auto-open
  {% endif %}
>
  {%- comment -%} 购物车图标按钮 {%- endcomment -%}
  <button
    class="mk-cart-drawer__trigger button button-unstyled"
    on:click="/open"
    aria-label="{{ 打开购物车 }} {{ 购物车数量 }}: {{ cart.item_count }}"
  >
    {% render 'mk-icon', icon: 'cart' %}
    {% if cart.item_count > 0 %}
      <span class="mk-cart-drawer__badge">{{ cart.item_count }}</span>
    {% endif %}
  </button>

  {%- comment -%} 抽屉弹窗 {%- endcomment -%}
  <dialog
    ref="dialog"
    class="mk-cart-drawer__dialog dialog-modal color-{{ settings.drawer_color_scheme | default: 'background-1' }}{% if cart.empty? %} mk-cart-drawer--empty{% endif %}"
    scroll-lock
  >
    <div class="mk-cart-drawer__inner">
      <cart-items-component
        class="mk-cart-items"
        data-section-id="{{ section.id }}"
      >
        {%- if cart.empty? -%}
          {%- comment -%} 空购物车状态 {%- endcomment -%}
          <div class="mk-cart-drawer__header">
            <button
              ref="closeButton"
              on:click="cart-drawer-component/close"
              class="mk-cart-drawer__close button button-unstyled"
              aria-label="{{ 关闭 }}"
            >
              {{- 'icon-close.svg' | inline_asset_content -}}
            </button>
          </div>

          <div class="mk-cart-drawer__content motion-reduce">
            <span class="mk-cart-drawer__heading h3 mk-cart-drawer__heading--empty">
              {{ 您的购物车是空的 }}
            </span>

            <div class="mk-cart-drawer__items">
              {% render 'mk-cart-products', type: 'empty' %}
            </div>
          </div>
        {%- else -%}
          {%- comment -%} 有商品的购物车 {%- endcomment -%}
          <div class="mk-cart-drawer__header" id="mk-cart-drawer-header">
            <span class="mk-cart-drawer__heading h3">
              {{ 购物车 }}
              <span class="mk-cart-bubble">{{ cart.item_count }}</span>
            </span>

            <button
              ref="closeButton"
              on:click="cart-drawer-component/close"
              class="mk-cart-drawer__close button button-unstyled"
              aria-label="{{ 关闭 }}"
            >
              {{- 'icon-close.svg' | inline_asset_content -}}
            </button>
          </div>

          <div
            class="mk-cart-drawer__content motion-reduce"
            aria-label="{{ 购物车 }}"
            style="--header-height: 60px;"
          >
            <scroll-hint class="mk-cart-drawer__items">
              {% render 'mk-cart-products' %}
            </scroll-hint>

            <div class="mk-cart-drawer__summary">
              {% render 'mk-cart-summary' %}
            </div>
          </div>
        {%- endif -%}
      </cart-items-component>
    </div>
  </dialog>
</cart-drawer-component>

{% stylesheet %}
  .mk-cart-items {
    width: 100%;
    height: 100%;
    display: flex;
    flex-direction: column;
  }

  .mk-cart-drawer__badge {
    position: absolute;
    top: -4px;
    right: -4px;
    min-width: 18px;
    height: 18px;
    padding: 0 4px;
    font-size: var(--mk-font-size-xs);
    font-weight: 600;
    line-height: 18px;
    text-align: center;
    color: var(--color-on-primary, #fff);
    background-color: var(--color-primary, #000);
    border-radius: 50%;
  }

  .mk-cart-drawer__heading .mk-cart-bubble {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 24px;
    height: 24px;
    padding: 0 6px;
    font-size: var(--mk-font-size-sm);
    font-weight: 600;
    border-radius: var(--mk-radius-md);
    background-color: var(--color-secondary, var(--mk-color-bg-secondary));
    margin-left: 8px;
  }

  .mk-cart-drawer__header {
    background-color: var(--color-background);
    display: flex;
    align-items: center;
    justify-content: space-between;
    width: 100%;
    padding: var(--mk-spacing-lg) 20px;
    border-bottom: 1px solid var(--color-border);
    position: sticky;
    top: 0;
    z-index: 1;
  }

  .mk-cart-drawer__dialog {
    overflow: hidden;
  }

  .mk-cart-drawer__inner {
    height: 100%;
    overflow: hidden;
  }

  .mk-cart-drawer__content {
    height: calc(100% - var(--header-height));
    display: flex;
    flex-direction: column;
  }

  .mk-cart-drawer__summary {
    background-color: var(--color-background);
    position: sticky;
    bottom: 0;
    z-index: 1;
  }

  .mk-cart-drawer__close {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    padding: 0;
    background: transparent;
    border: none;
    cursor: pointer;
    color: var(--color-foreground);
    transition: transform 0.2s ease;
  }

  .mk-cart-drawer__close:hover {
    transform: scale(0.95);
  }

  .mk-cart-drawer__close svg {
    width: 20px;
    height: 20px;
  }

  .mk-cart-drawer__heading {
    margin: 0;
    font-size: var(--mk-font-size-xl);
    font-weight: 600;
    display: flex;
    align-items: center;
  }

  .mk-cart-drawer__heading--empty {
    color: var(--color-foreground);
  }
{% endstylesheet %}

{% schema %}
{
  "name": "MK 购物车抽屉",
  "tag": "section",
  "settings": [
    {
      "type": "checkbox",
      "id": "auto_open_cart_drawer",
      "label": "添加商品后自动打开",
      "default": true
    },
    {
      "type": "select",
      "id": "drawer_color_scheme",
      "label": "颜色方案",
      "options": [
        { "value": "background-1", "label": "背景 1" },
        { "value": "background-2", "label": "背景 2" },
        { "value": "inverse", "label": "反向" }
      ],
      "default": "background-1"
    }
  ],
  "presets": [
    {
      "name": "MK 购物车抽屉"
    }
  ]
}
{% endschema %}
