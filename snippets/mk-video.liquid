{%- doc -%}
  MK 视频播放器组件

  渲染视频内容（支持YouTube、Vimeo、本地视频）

  @param {object} video - Shopify视频对象或视频URL
  @param {string} [video_type] - 视频类型：youtube, vimeo, hosted
  @param {boolean} [autoplay] - 是否自动播放
  @param {boolean} [loop] - 是否循环
  @param {boolean} [muted] - 是否静音
  @param {string} [class] - 额外CSS类名

  @example
  {% render 'mk-video', video: section.settings.video, autoplay: false %}
{%- enddoc -%}

{% liquid
  assign video = video | default: nil
  assign video_type = video_type | default: 'youtube'
  assign autoplay = autoplay | default: false
  assign loop = loop | default: false
  assign muted = muted | default: true
  assign class = class | default: ''
-%}

<div class="mk-video {{ class }}" data-video-type="{{ video_type }}">
  {%- if video != blank -%}
    {%- case video_type -%}
      {%- when 'youtube' -%}
        <div class="mk-video__wrapper">
          <iframe
            src="https://www.youtube.com/embed/{{ video }}?enablejsapi=1{% if autoplay %}&autoplay=1&mute=1{% endif %}{% if loop %}&loop=1&playlist={{ video }}{% endif %}"
            frameborder="0"
            allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
            allowfullscreen
            loading="lazy"
          ></iframe>
        </div>

      {%- when 'vimeo' -%}
        <div class="mk-video__wrapper">
          <iframe
            src="https://player.vimeo.com/video/{{ video }}?api=1{% if autoplay %}&autoplay=1&muted=1{% endif %}{% if loop %}&loop=1{% endif %}"
            frameborder="0"
            allow="autoplay; fullscreen; picture-in-picture"
            allowfullscreen
            loading="lazy"
          ></iframe>
        </div>

      {%- when 'hosted' -%}
        <video
          class="mk-video__element"
          src="{{ video }}"
          autoplay="{{ autoplay }}"
          loop="{{ loop }}"
          muted="{{ muted }}"
          controls
          playsinline
        >
          您的浏览器不支持视频标签。
        </video>

      {%- else -%}
        {%- if video.src -%}
          <video
            class="mk-video__element"
            src="{{ video.src }}"
            autoplay="{{ autoplay }}"
            loop="{{ loop }}"
            muted="{{ muted }}"
            controls
            playsinline
          >
            您的浏览器不支持视频标签。
          </video>
        {%- endif -%}
    {%- endcase -%}

  {%- else -%}
    <div class="mk-video__placeholder">
      {{ 'video' | placeholder_svg_tag: 'mk-video__placeholder-svg' }}
      <span class="mk-video__placeholder-icon">{{- 'icon-play.svg' | inline_asset_content -}}</span>
    </div>
  {%- endif -%}
</div>

{% stylesheet %}
  .mk-video {
    position: relative;
    width: 100%;
    overflow: hidden;
    border-radius: 12px;
    background-color: #000;
  }

  .mk-video__wrapper {
    position: relative;
    width: 100%;
    aspect-ratio: 16 / 9;
  }

  .mk-video__wrapper iframe {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
  }

  .mk-video__element {
    width: 100%;
    height: auto;
    display: block;
  }

  .mk-video__placeholder {
    position: relative;
    width: 100%;
    aspect-ratio: 16 / 9;
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: var(--color-background-secondary, #f5f5f5);
  }

  .mk-video__placeholder-svg {
    width: 100%;
    height: 100%;
    opacity: 0.3;
  }

  .mk-video__placeholder-icon {
    position: absolute;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 64px;
    height: 64px;
    background-color: rgba(0, 0, 0, 0.7);
    border-radius: 50%;
    color: #fff;
  }

  .mk-video__placeholder-icon svg {
    width: 32px;
    height: 32px;
    fill: #fff;
  }
{% endstylesheet %}
