{%- comment -%}
  MK 标题组件
  
  功能：统一的标题样式组件
  
  参数：
    - text: 标题文本
    - level: 标题级别（h1/h2/h3/h4/h5/h6）
    - style: 样式类型（default/center/left）
    - class: 额外的 CSS 类
  
  作者：崽崽 (AI助手)
{%- endcomment -%}

{%- doc -%}
  Renders a styled heading.

  @param {string} text - Heading text
  @param {string} [level] - Heading level: h1, h2, h3, h4, h5, h6
  @param {string} [style] - Style: default, center, left
  @param {string} [class] - Additional CSS classes

  @example
  {% render 'mk-heading', text: 'Welcome', level: 'h1', style: 'center' %}
{%- enddoc -%}

{%- liquid
  assign level = level | default: 'h2'
  assign style = style | default: 'default'
-%}

<{{ level }} class="mk-heading mk-heading--{{ style }} {{ class | default: '' }}">
  {{ text }}
</{{ level }}>

{% stylesheet %}
  .mk-heading {
    margin: 0;
    font-family: var(--font-heading, inherit);
    font-weight: 600;
    line-height: 1.2;
    color: var(--color-heading, inherit);
  }

  .mk-heading--default {
    text-align: left;
  }

  .mk-heading--center {
    text-align: center;
  }

  .mk-heading--left {
    text-align: left;
  }

  /* Heading sizes */
  .mk-heading--h1 {
    font-size: clamp(32px, 5vw, 56px);
  }

  .mk-heading--h2 {
    font-size: clamp(26px, 4vw, 42px);
  }

  .mk-heading--h3 {
    font-size: clamp(22px, 3vw, 32px);
  }

  .mk-heading--h4 {
    font-size: clamp(18px, 2.5vw, 24px);
  }

  .mk-heading--h5 {
    font-size: var(--mk-font-size-xl);
  }

  .mk-heading--h6 {
    font-size: var(--mk-font-size-lg);
  }
{% endstylesheet %}
