{%- comment -%}
  MK Icon Row Section板块

  图标行展示

  作者：崽崽 (AI助手)
{%- endcomment -%}

{% liquid
  assign ss = section.settings
-%}

<section id="{{ section.id }}" class="mk-icon-row-section color-{{ ss.color_scheme | default: 'background-1' }}">
  <div class="mk-icon-row-section__container">
    <div class="mk-icon-row-section__row">
      {%- for i in (1..4) -%}
        {%- assign icon_setting = 'icon_' | append: i -%}
        {%- assign title_setting = 'title_' | append: i -%}
        {%- assign text_setting = 'text_' | append: i -%}

        {%- if ss[title_setting] != blank -%}
          <div class="mk-icon-row-section__item">
            {%- if ss[icon_setting] != blank -%}
              <div class="mk-icon-row-section__icon">
                {{ ss[icon_setting] | default: 'icon-check.svg' | inline_asset_content }}
              </div>
            {%- endif -%}
            <div class="mk-icon-row-section__content">
              <h4 class="mk-icon-row-section__title">{{ ss[title_setting] }}</h4>
              {%- if ss[text_setting] != blank -%}
                <p class="mk-icon-row-section__text">{{ ss[text_setting] }}</p>
              {%- endif -%}
            </div>
          </div>
        {%- endif -%}
      {%- endfor -%}
    </div>
  </div>
</section>

{% stylesheet %}
  .mk-icon-row-section { padding: var(--mk-spacing-2xl) 0; border-top: 1px solid var(--color-border); border-bottom: 1px solid var(--color-border); }
  .mk-icon-row-section__container { max-width: var(--container-max-width, 1200px); margin: 0 auto; padding: 0 var(--container-padding, 32px); }
  .mk-icon-row-section__row { display: grid; grid-template-columns: repeat(2, 1fr); gap: var(--mk-spacing-2xl); }
  @media (min-width: 750px) { .mk-icon-row-section__row { grid-template-columns: repeat(4, 1fr); gap: var(--mk-spacing-3xl); } }
  .mk-icon-row-section__item { display: flex; align-items: flex-start; gap: var(--mk-spacing-md); }
  .mk-icon-row-section__icon { display: flex; flex-shrink: 0; width: 24px; height: 24px; }
  .mk-icon-row-section__icon svg { width: 100%; height: 100%; color: var(--color-primary, #000); }
  .mk-icon-row-section__title { margin: 0 0 2px 0; font-size: var(--mk-font-size-md); font-weight: 600; }
  .mk-icon-row-section__text { margin: 0; font-size: var(--mk-font-size-sm); color: var(--color-text-secondary, #666); }
{% endstylesheet %}

{% schema %}
{
  "name": "MK Icon Row Section",
  "tag": "section",
  "settings": [
    { "type": "header", "content": "项 1" }, { "type": "text", "id": "icon_1", "label": "图标 1" }, { "type": "text", "id": "title_1", "label": "标题 1" }, { "type": "textarea", "id": "text_1", "label": "描述 1" },
    { "type": "header", "content": "项 2" }, { "type": "text", "id": "icon_2", "label": "图标 2" }, { "type": "text", "id": "title_2", "label": "标题 2" }, { "type": "textarea", "id": "text_2", "label": "描述 2" },
    { "type": "header", "content": "项 3" }, { "type": "text", "id": "icon_3", "label": "图标 3" }, { "type": "text", "id": "title_3", "label": "标题 3" }, { "type": "textarea", "id": "text_3", "label": "描述 3" },
    { "type": "header", "content": "项 4" }, { "type": "text", "id": "icon_4", "label": "图标 4" }, { "type": "text", "id": "title_4", "label": "标题 4" }, { "type": "textarea", "id": "text_4", "label": "描述 4" },
    { "type": "color_scheme", "id": "color_scheme", "label": "颜色方案", "default": "scheme-1" }
  ],
  "presets": [{ "name": "MK Icon Row Section" }]
}
{% endschema %}
