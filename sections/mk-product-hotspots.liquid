{%- comment -%}
  MK 图片热点组件

  在图片上创建可点击的热点，点击显示产品信息

  作者：崽崽 (AI助手)
  迁移自: poolin_store/sections/product-hotspots.liquid
{%- endcomment -%}

{% liquid
  assign ss = section.settings
  assign bg_color = ss.background_color | default: '#ffffff'
  assign text_color = ss.text_color | default: '#1a1a1a'

  # 图片比例
  case ss.section_height
    when 'small'
      assign aspect_ratio = '21 / 9'
    when 'medium'
      assign aspect_ratio = '16 / 9'
    when 'large'
      assign aspect_ratio = '4 / 3'
    else
      assign aspect_ratio = 'auto'
  endcase
-%}

<style>
  #{{ section.id }} {
    --mk-hotspot-bg: {{ ss.hotspot_color | default: 'rgba(0,0,0,0.5)' }};
    --mk-hotspot-bullseye: {{ ss.bullseye_color | default: '#ffffff' }};
    --mk-hotspot-size: {{ ss.hotspot_size | default: 36 }}px;
  }
</style>

<section
  id="{{ section.id }}"
  class="mk-product-hotspots color-{{ ss.color_scheme | default: 'background-1' }}"
  data-section-type="product-hotspots"
>
  {%- comment -%} 热点图片容器 {%- endcomment -%}
  <div
    class="mk-product-hotspots__container"
    {% if ss.section_height != 'auto' %}
      style="--aspect-ratio: {{ aspect_ratio }};"
    {% endif %}
  >
    {%- if ss.image != blank -%}
      {{ ss.image | image_url: width: 1600 | image_tag: class: 'mk-product-hotspots__image' }}
    {%- else -%}
      {{ 'hero-apparel-1' | placeholder_svg_tag: 'mk-product-hotspots__image' }}
    {%- endif -%}

    {%- comment -%} 热点标记 {%- endcomment -%}
    <div class="mk-hotspots-container">
      {% content_for 'blocks' %}
    </div>
  </div>
</section>

{% stylesheet %}
  .mk-product-hotspots {
    width: 100%;
  }

  .mk-product-hotspots__container {
    position: relative;
    width: 100%;
    aspect-ratio: var(--aspect-ratio, auto);
    overflow: hidden;
  }

  .mk-product-hotspots__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .mk-hotspots-container {
    position: absolute;
    inset: 0;
    z-index: 5;
  }

  /* 热点按钮 */
  .mk-hotspot {
    position: absolute;
    width: var(--mk-hotspot-size);
    height: var(--mk-hotspot-size);
    transform: translate(-50%, -50%);
    cursor: pointer;
    z-index: 10;
  }

  .mk-hotspot__trigger {
    width: 100%;
    height: 100%;
    background-color: var(--mk-hotspot-bg);
    border: none;
    border-radius: 50%;
    cursor: pointer;
    position: relative;
    transition: transform 0.2s ease, background-color 0.2s ease;
  }

  .mk-hotspot__trigger::after {
    content: '';
    position: absolute;
    top: 50%;
    left: 50%;
    width: 40%;
    height: 40%;
    background-color: var(--mk-hotspot-bullseye);
    border-radius: 50%;
    transform: translate(-50%, -50%);
    transition: width 0.2s ease, height 0.2s ease;
  }

  .mk-hotspot:hover .mk-hotspot__trigger {
    transform: scale(1.1);
  }

  .mk-hotspot:hover .mk-hotspot__trigger::after {
    width: 50%;
    height: 50%;
  }

  /* 热点弹窗 */
  .mk-hotspot__dialog {
    position: absolute;
    padding: var(--mk-spacing-md);
    min-width: 260px;
    max-width: 330px;
    background-color: var(--color-background);
    border: 1px solid var(--color-border);
    border-radius: var(--mk-radius-md);
    box-shadow: 0 4px 20px var(--mk-shadow-md)5);
    opacity: 0;
    visibility: hidden;
    transform: scale(0.9);
    transition: opacity 0.2s ease, transform 0.2s ease, visibility 0.2s ease;
    z-index: 20;
  }

  .mk-hotspot__dialog[open] {
    opacity: 1;
    visibility: visible;
    transform: scale(1);
  }

  /* 弹窗位置 */
  .mk-hotspot__dialog--bottom {
    top: calc(100% + 10px);
    left: 50%;
    transform: translateX(-50%) scale(0.9);
  }

  .mk-hotspot__dialog--bottom[open] {
    transform: translateX(-50%) scale(1);
  }

  .mk-hotspot__dialog--top {
    bottom: calc(100% + 10px);
    left: 50%;
    transform: translateX(-50%) scale(0.9);
  }

  .mk-hotspot__dialog--top[open] {
    transform: translateX(-50%) scale(1);
  }

  .mk-hotspot__dialog--left {
    right: calc(100% + 10px);
    top: 50%;
    transform: translateY(-50%) scale(0.9);
  }

  .mk-hotspot__dialog--left[open] {
    transform: translateY(-50%) scale(1);
  }

  .mk-hotspot__dialog--right {
    left: calc(100% + 10px);
    top: 50%;
    transform: translateY(-50%) scale(0.9);
  }

  .mk-hotspot__dialog--right[open] {
    transform: translateY(-50%) scale(1);
  }

  .mk-hotspot__product {
    display: grid;
    grid-template-columns: 80px 1fr;
    gap: var(--mk-spacing-md);
  }

  .mk-hotspot__product-image {
    width: 80px;
    height: 80px;
    object-fit: cover;
    border-radius: var(--mk-radius-sm);
  }

  .mk-hotspot__product-info {
    display: flex;
    flex-direction: column;
    gap: var(--mk-spacing-xs);
  }

  .mk-hotspot__product-title {
    margin: 0;
    font-size: var(--mk-font-size-md);
    font-weight: 600;
    line-height: 1.3;
    color: inherit;
    text-decoration: none;
  }

  .mk-hotspot__product-price {
    font-size: var(--mk-font-size-md);
    font-weight: 500;
    color: var(--color-primary, #000);
  }

  .mk-hotspot__product-price-compare {
    text-decoration: line-through;
    color: var(--color-text-secondary, #999);
    margin-right: 8px;
  }

  .mk-hotspot__sold-out {
    font-size: var(--mk-font-size-xs);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    color: var(--color-text-secondary, #666);
    padding: 2px 6px;
    background-color: var(--color-background-secondary, var(--mk-color-bg-secondary));
    border-radius: var(--mk-radius-xs);
  }

  .mk-hotspot__quick-add {
    margin-top: 8px;
  }

  .mk-hotspot__quick-add-btn {
    width: 100%;
    padding: var(--mk-spacing-sm) 12px;
    font-size: var(--mk-font-size-sm);
    font-weight: 600;
    color: var(--color-on-primary, #fff);
    background-color: var(--color-primary, #000);
    border: none;
    border-radius: var(--mk-radius-xs);
    cursor: pointer;
    transition: opacity 0.2s ease;
  }

  .mk-hotspot__quick-add-btn:hover {
    opacity: 0.85;
  }

  .mk-hotspot__quick-add-btn:disabled {
    opacity: 0.5;
    cursor: not-allowed;
  }

  /* 移动端适配 */
  @media (max-width: 749px) {
    .mk-hotspot__dialog {
      display: none;
    }

    .mk-hotspot--mobile-modal {
      z-index: 100;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "MK 图片热点",
  "tag": "section",
  "settings": [
    {
      "type": "header",
      "content": "图片设置"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "背景图片"
    },
    {
      "type": "select",
      "id": "section_height",
      "label": "图片比例",
      "options": [
        { "value": "auto", "label": "自动" },
        { "value": "small", "label": "21:9 (宽屏)" },
        { "value": "medium", "label": "16:9 (标准)" },
        { "value": "large", "label": "4:3 (横向)" }
      ],
      "default": "auto"
    },
    {
      "type": "header",
      "content": "热点样式"
    },
    {
      "type": "color",
      "id": "hotspot_color",
      "label": "热点背景色",
      "default": "rgba(0,0,0,0.5)"
    },
    {
      "type": "color",
      "id": "bullseye_color",
      "label": "热点中心颜色",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "hotspot_size",
      "label": "热点大小",
      "min": 24,
      "max": 60,
      "default": 36,
      "unit": "px"
    },
    {
      "type": "header",
      "content": "颜色设置"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "颜色方案",
      "default": "scheme-1"
    }
  ],
  "blocks": [
    {
      "type": "hotspot_item",
      "name": "热点",
      "settings": [
        {
          "type": "product",
          "id": "product",
          "label": "产品"
        },
        {
          "type": "range",
          "id": "x_position",
          "label": "X 位置",
          "min": 0,
          "max": 100,
          "default": 50,
          "unit": "%"
        },
        {
          "type": "range",
          "id": "y_position",
          "label": "Y 位置",
          "min": 0,
          "max": 100,
          "default": 50,
          "unit": "%"
        },
        {
          "type": "select",
          "id": "dialog_position",
          "label": "弹窗位置",
          "options": [
            { "value": "top", "label": "上方" },
            { "value": "bottom", "label": "下方" },
            { "value": "left", "label": "左侧" },
            { "value": "right", "label": "右侧" }
          ],
          "default": "bottom"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "MK 图片热点"
    }
  ]
}
{% endschema %}
