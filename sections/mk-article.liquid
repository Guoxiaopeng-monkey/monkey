{%- comment -%}
  MK 文章详情板块

  展示单篇文章内容

  作者：崽崽 (AI助手)
{%- endcomment -%}

{% liquid
  assign ss = section.settings
  assign article = article | default: nil
-%}

{%- if article != nil -%}
  <section
    id="{{ section.id }}"
    class="mk-article color-{{ ss.color_scheme | default: 'background-1' }}"
  >
    <div class="mk-article__container">
      {%- comment -%} 文章元信息 {%- endcomment -%}
      <div class="mk-article__meta">
        <time class="mk-article__date" datetime="{{ article.published_at | date: '%Y-%m-%d' }}">
          {{ article.published_at | date: '%Y年%m月%d日' }}
        </time>
        {%- if article.tags.size > 0 -%}
          <div class="mk-article__tags">
            {%- for tag in article.tags limit: 3 -%}
              <a href="{{ blog.url }}/tagged/{{ tag | handle }}" class="mk-article__tag">{{ tag }}</a>
            {%- endfor -%}
          </div>
        {%- endif -%}
      </div>

      {%- comment -%} 文章标题 {%- endcomment -%}
      <h1 class="mk-article__title">{{ article.title }}</h1>

      {%- comment -%} 文章图片 {%- endcomment -%}
      {%- if article.image != blank -%}
        <div class="mk-article__image">
          {{ article.image | image_url: width: 1200 | image_tag: class: 'mk-article__image-img' }}
        </div>
      {%- endif -%}

      {%- comment -%} 文章内容 {%- endcomment -%}
      <div class="mk-article__content rte">
        {{ article.content }}
      </div>

      {%- comment -%} 文章分享 {%- endcomment -%}
      {%- if ss.show_share -%}
        <div class="mk-article__share">
          <span class="mk-article__share-label">{{ 'general.social.share' | t | default: '分享' }}</span>
          {% render 'mk-share-button', title: article.title, url: article.url %}
        </div>
      {%- endif -%}

      {%- comment -%} 文章导航 {%- endcomment -%}
      {%- if ss.show_navigation and blog.previous_article or blog.next_article -%}
        <nav class="mk-article__nav">
          {%- if blog.previous_article -%}
            <a href="{{ blog.previous_article.url }}" class="mk-article__nav-link mk-article__nav-link--prev">
              ← {{ blog.previous_article.title }}
            </a>
          {%- endif -%}

          {%- if blog.next_article -%}
            <a href="{{ blog.next_article.url }}" class="mk-article__nav-link mk-article__nav-link--next">
              {{ blog.next_article.title }} →
            </a>
          {%- endif -%}
        </nav>
      {%- endif -%}
    </div>
  </section>
{%- endif -%}

{% stylesheet %}
  .mk-article {
    padding: {{ ss.padding_top_mobile | default: 48 }}px 0 {{ ss.padding_bottom_mobile | default: 48 }}px;
  }

  @media (min-width: 750px) {
    .mk-article {
      padding: {{ ss.padding_top_desktop | default: 64 }}px 0 {{ ss.padding_bottom_desktop | default: 64 }}px;
    }
  }

  .mk-article__container {
    max-width: 800px;
    margin: 0 auto;
    padding: 0 var(--container-padding, 32px);
  }

  .mk-article__meta {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 12px;
    margin-bottom: 16px;
  }

  .mk-article__date {
    font-size: 13px;
    color: var(--color-text-secondary, #666);
  }

  .mk-article__tags {
    display: flex;
    gap: 8px;
  }

  .mk-article__tag {
    font-size: 12px;
    color: var(--color-primary, #000);
    text-decoration: none;
    padding: 4px 8px;
    background-color: var(--color-background-secondary, #f5f5f5);
    border-radius: 4px;
    transition: background-color 0.2s ease;
  }

  .mk-article__tag:hover {
    background-color: var(--color-border);
  }

  .mk-article__title {
    margin: 0 0 24px 0;
    font-size: 28px;
    font-weight: 700;
    line-height: 1.3;
  }

  @media (min-width: 750px) {
    .mk-article__title {
      font-size: 36px;
    }
  }

  .mk-article__image {
    margin-bottom: 32px;
    border-radius: 12px;
    overflow: hidden;
  }

  .mk-article__image-img {
    width: 100%;
    height: auto;
  }

  .mk-article__content {
    font-size: 16px;
    line-height: 1.8;
    color: var(--color-foreground);
  }

  .mk-article__content p {
    margin: 0 0 16px 0;
  }

  .mk-article__content h2 {
    margin: 32px 0 16px 0;
    font-size: 24px;
    font-weight: 700;
  }

  .mk-article__content h3 {
    margin: 24px 0 12px 0;
    font-size: 20px;
    font-weight: 600;
  }

  .mk-article__content img {
    max-width: 100%;
    height: auto;
    border-radius: 8px;
  }

  .mk-article__share {
    display: flex;
    align-items: center;
    gap: 16px;
    margin-top: 32px;
    padding-top: 24px;
    border-top: 1px solid var(--color-border);
  }

  .mk-article__share-label {
    font-size: 14px;
    font-weight: 500;
  }

  .mk-article__nav {
    display: flex;
    justify-content: space-between;
    gap: 16px;
    margin-top: 32px;
    padding-top: 24px;
    border-top: 1px solid var(--color-border);
  }

  .mk-article__nav-link {
    font-size: 14px;
    color: var(--color-primary, #000);
    text-decoration: none;
    max-width: 45%;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .mk-article__nav-link:hover {
    text-decoration: underline;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "MK 文章详情",
  "tag": "section",
  "settings": [
    {
      "type": "checkbox",
      "id": "show_share",
      "label": "显示分享按钮",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_navigation",
      "label": "显示文章导航",
      "default": true
    },
    {
      "type": "header",
      "content": "间距"
    },
    {
      "type": "range",
      "id": "padding_top_mobile",
      "label": "上边距 (移动端)",
      "min": 0,
      "max": 120,
      "default": 48,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "label": "下边距 (移动端)",
      "min": 0,
      "max": 120,
      "default": 48,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_top_desktop",
      "label": "上边距 (PC端)",
      "min": 0,
      "max": 200,
      "default": 64,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_bottom_desktop",
      "label": "下边距 (PC端)",
      "min": 0,
      "max": 200,
      "default": 64,
      "unit": "px"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "颜色方案",
      "default": "scheme-1"
    }
  ],
  "presets": [
    {
      "name": "MK 文章详情"
    }
  ]
}
{% endschema %}
