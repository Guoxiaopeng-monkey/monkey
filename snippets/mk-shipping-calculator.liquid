{%- doc -%}
  MK 物流计算器组件

  渲染运费计算器

  @param {string} [class] - 额外CSS类名

  @example
  {% render 'mk-shipping-calculator' %}
{%- enddoc -%}

{% liquid
  assign class = class | default: ''
-%}

<div class="mk-shipping-calculator {{ class }}" data-shipping-calculator>
  <div class="mk-shipping-calculator__row">
    <div class="mk-shipping-calculator__field">
      <label for="shipping-zip" class="mk-shipping-calculator__label">{{ 'cart.zip_code' | t | default: '邮政编码' }}</label>
      <input
        type="text"
        id="shipping-zip"
        name="zip"
        class="mk-shipping-calculator__input"
        placeholder="{{ 'cart.zip_placeholder' | t | default: '请输入邮政编码' }}"
      >
    </div>

    <button type="button" class="mk-shipping-calculator__button" data-shipping-submit>
      {{ 'cart.calculate' | t | default: '计算' }}
    </button>
  </div>

  <div class="mk-shipping-calculator__results" hidden data-shipping-results></div>
</div>

{% stylesheet %}
  .mk-shipping-calculator {
    padding: 20px;
    background-color: var(--color-background-secondary, #f5f5f5);
    border-radius: 12px;
  }

  .mk-shipping-calculator__row {
    display: flex;
    gap: 12px;
  }

  .mk-shipping-calculator__field {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 6px;
  }

  .mk-shipping-calculator__label {
    font-size: 13px;
    font-weight: 500;
    color: var(--color-foreground);
  }

  .mk-shipping-calculator__input {
    padding: 12px 14px;
    font-size: 14px;
    color: var(--color-foreground);
    background-color: var(--color-background);
    border: 1px solid var(--color-border);
    border-radius: 8px;
    transition: border-color 0.2s ease;
  }

  .mk-shipping-calculator__input:focus {
    outline: none;
    border-color: var(--color-primary, #000);
  }

  .mk-shipping-calculator__button {
    padding: 12px 24px;
    font-size: 14px;
    font-weight: 600;
    color: var(--color-on-primary, #fff);
    background-color: var(--color-primary, #000);
    border: none;
    border-radius: 8px;
    cursor: pointer;
    transition: all 0.2s ease;
    align-self: flex-end;
  }

  .mk-shipping-calculator__button:hover {
    opacity: 0.85;
  }

  .mk-shipping-calculator__results {
    margin-top: 16px;
    padding-top: 16px;
    border-top: 1px solid var(--color-border);
  }

  .mk-shipping-calculator__results[hidden] {
    display: none;
  }

  .mk-shipping-calculator__rate {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 8px 0;
    font-size: 14px;
  }

  .mk-shipping-calculator__rate-name {
    color: var(--color-foreground);
  }

  .mk-shipping-calculator__rate-price {
    font-weight: 600;
    color: var(--color-primary, #000);
  }
{% endstylesheet %}
