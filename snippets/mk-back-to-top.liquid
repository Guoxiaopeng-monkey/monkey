{%- doc -%}
  MK 返回顶部组件

  渲染返回顶部按钮

  @param {string} [class] - 额外CSS类名

  @example
  {% render 'mk-back-to-top' %}
{%- enddoc -%}

{% liquid
  assign class = class | default: ''
-%}

<button
  type="button"
  class="mk-back-to-top {{ class }}"
  data-back-to-top
  aria-label="{{ 'general.back_to_top' | t | default: '返回顶部' }}"
  hidden
>
  {{- 'icon-arrow-up.svg' | inline_asset_content -}}
</button>

{% stylesheet %}
  .mk-back-to-top {
    position: fixed;
    bottom: 24px;
    right: 24px;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 48px;
    height: 48px;
    padding: 0;
    background-color: var(--color-primary, #000);
    color: var(--color-on-primary, #fff);
    border: none;
    border-radius: 50%;
    cursor: pointer;
    opacity: 0;
    visibility: hidden;
    transform: translateY(16px);
    transition: all 0.3s ease;
    z-index: 100;
    box-shadow: 0 4px 12px var(--mk-shadow-md)5);
  }

  .mk-back-to-top:not([hidden]) {
    opacity: 1;
    visibility: visible;
    transform: translateY(0);
  }

  .mk-back-to-top:hover {
    opacity: 0.85;
    transform: translateY(-4px);
  }

  .mk-back-to-top svg {
    width: 20px;
    height: 20px;
  }
{% endstylesheet %}

{% javascript %}
  class BackToTop extends HTMLElement {
    constructor() {
      super();
      this.button = this.querySelector('.mk-back-to-top');
      this.init();
    }

    init() {
      // 监听滚动
      window.addEventListener('scroll', () => {
        if (window.scrollY > 300) {
          this.button.hidden = false;
        } else {
          this.button.hidden = true;
        }
      }, { passive: true });

      // 点击返回顶部
      this.button.addEventListener('click', () => {
        window.scrollTo({
          top: 0,
          behavior: 'smooth'
        });
      });
    }
  }

  customElements.define('back-to-top', BackToTop);
{% endjavascript %}
