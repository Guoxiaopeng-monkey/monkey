{%- comment -%}
  MK 特色产品推荐板块

  展示精选产品推荐

  作者：崽崽 (AI助手)
{%- endcomment -%}

{% liquid
  assign ss = section.settings
  assign collection = collections[ss.collection] | default: nil
  assign products = collection.products | default: empty_array | slice: 0, ss.products_to_show | default: 8
-%}

<section
  id="{{ section.id }}"
  class="mk-featured-collection color-{{ ss.color_scheme | default: 'background-1' }}"
>
  <div class="mk-featured-collection__container">
    <header class="mk-featured-collection__header">
      {%- if ss.title != blank -%}
        <h2 class="mk-featured-collection__title">{{ ss.title }}</h2>
      {%- endif -%}

      {%- if ss.show_description and collection.description != blank -%}
        <p class="mk-featured-collection__description">{{ collection.description }}</p>
      {%- endif -%}

      {%- if ss.show_view_all -%}
        <a href="{{ collection.url | default: routes.collections_url }}" class="mk-featured-collection__link">
          {{ 'sections.featured_collection.view_all' | t | default: '查看全部' }}
          {{- 'icon-arrow-right.svg' | inline_asset_content -}}
        </a>
      {%- endif -%}
    </header>

    {%- if products.size > 0 -%}
      <div class="mk-featured-collection__grid">
        {%- for product in products -%}
          {% render 'mk-product-card', product: product %}
        {%- endfor -%}
      </div>
    {%- else -%}
      <div class="mk-featured-collection__empty">
        {% render 'mk-empty-state', title: 'sections.featured_collection.empty' %}
      </div>
    {%- endif -%}
  </div>
</section>

{% stylesheet %}
  .mk-featured-collection {
    padding: {{ ss.padding_top_mobile | default: 48 }}px 0 {{ ss.padding_bottom_mobile | default: 48 }}px;
  }

  @media (min-width: 750px) {
    .mk-featured-collection {
      padding: {{ ss.padding_top_desktop | default: 80 }}px 0 {{ ss.padding_bottom_desktop | default: 80 }}px;
    }
  }

  .mk-featured-collection__container {
    max-width: var(--container-max-width, 1200px);
    margin: 0 auto;
    padding: 0 var(--container-padding, 32px);
  }

  .mk-featured-collection__header {
    margin-bottom: 32px;
    text-align: center;
  }

  .mk-featured-collection__title {
    margin: 0 0 12px 0;
    font-size: 28px;
    font-weight: 700;
  }

  .mk-featured-collection__description {
    margin: 0 0 16px 0;
    font-size: 16px;
    color: var(--color-text-secondary, #666);
    max-width: 600px;
    margin-left: auto;
    margin-right: auto;
  }

  .mk-featured-collection__link {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-size: 14px;
    font-weight: 600;
    color: var(--color-primary, #000);
    text-decoration: none;
  }

  .mk-featured-collection__link:hover {
    text-decoration: underline;
  }

  .mk-featured-collection__link svg {
    width: 16px;
    height: 16px;
  }

  .mk-featured-collection__grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 16px;
  }

  @media (min-width: 750px) {
    .mk-featured-collection__grid {
      grid-template-columns: repeat(4, 1fr);
      gap: 24px;
    }
  }

  .mk-featured-collection__empty {
    padding: 64px 0;
    text-align: center;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "MK 特色产品推荐",
  "tag": "section",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "标题",
      "default": "精选推荐"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "收藏夹"
    },
    {
      "type": "range",
      "id": "products_to_show",
      "label": "显示产品数量",
      "min": 2,
      "max": 16,
      "default": 8
    },
    {
      "type": "checkbox",
      "id": "show_description",
      "label": "显示描述",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "show_view_all",
      "label": "显示查看全部链接",
      "default": true
    },
    {
      "type": "header",
      "content": "间距"
    },
    {
      "type": "range",
      "id": "padding_top_mobile",
      "label": "上边距 (移动端)",
      "min": 0,
      "max": 120,
      "default": 48,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "label": "下边距 (移动端)",
      "min": 0,
      "max": 120,
      "default": 48,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_top_desktop",
      "label": "上边距 (PC端)",
      "min": 0,
      "max": 200,
      "default": 80,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_bottom_desktop",
      "label": "下边距 (PC端)",
      "min": 0,
      "max": 200,
      "default": 80,
      "unit": "px"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "颜色方案",
      "default": "scheme-1"
    }
  ],
  "presets": [
    {
      "name": "MK 特色产品推荐"
    }
  ]
}
{% endschema %}
