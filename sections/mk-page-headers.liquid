{%- comment -%}
  MK Page Headers板块

  页面头部区块

  作者：崽崽 (AI助手)
{%- endcomment -%}

{% liquid
  assign ss = section.settings
-%}

<section id="{{ section.id }}" class="mk-page-headers color-{{ ss.color_scheme | default: 'background-1' }}">
  <div class="mk-page-headers__container">
    {%- if ss.show_breadcrumbs -%}
      {% render 'mk-breadcrumbs' %}
    {%- endif -%}

    <h1 class="mk-page-headers__title">{{ ss.title | default: page_title }}</h1>

    {%- if ss.show_description and page_description != blank -%}
      <p class="mk-page-headers__description">{{ page_description }}</p>
    {%- endif -%}
  </div>
</section>

{% stylesheet %}
  .mk-page-headers { padding: {{ ss.padding_top_mobile | default: 32 }}px 0 {{ ss.padding_bottom_mobile | default: 32 }}px; text-align: {{ ss.text_align | default: 'center' }}; }
  @media (min-width: 750px) { .mk-page-headers { padding: {{ ss.padding_top_desktop | default: 48 }}px 0 {{ ss.padding_bottom_desktop | default: 48 }}px; } }
  .mk-page-headers__container { max-width: var(--container-max-width, 800px); margin: 0 auto; padding: 0 var(--container-padding, 32px); }
  .mk-page-headers__title { margin: 0 0 12px 0; font-size: 28px; font-weight: 700; }
  @media (min-width: 750px) { .mk-page-headers__title { font-size: 36px; } }
  .mk-page-headers__description { margin: 0; font-size: 16px; color: var(--color-text-secondary, #666); }
{% endstylesheet %}

{% schema %}
{
  "name": "MK Page Headers",
  "tag": "section",
  "settings": [
    { "type": "text", "id": "title", "label": "标题" },
    { "type": "checkbox", "id": "show_breadcrumbs", "label": "显示面包屑", "default": true },
    { "type": "checkbox", "id": "show_description", "label": "显示描述", "default": true },
    { "type": "select", "id": "text_align", "label": "文本对齐", "options": [{ "value": "left", "label": "左对齐" }, { "value": "center", "label": "居中" }, { "value": "right", "label": "右对齐" }], "default": "center" },
    { "type": "header", "content": "间距" },
    { "type": "range", "id": "padding_top_mobile", "label": "上边距 (移动端)", "min": 0, "max": 80, "default": 32, "unit": "px" },
    { "type": "range", "id": "padding_bottom_mobile", "label": "下边距 (移动端)", "min": 0, "max": 80, "default": 32, "unit": "px" },
    { "type": "range", "id": "padding_top_desktop", "label": "上边距 (PC端)", "min": 0, "max": 120, "default": 48, "unit": "px" },
    { "type": "range", "id": "padding_bottom_desktop", "label": "下边距 (PC端)", "min": 0, "max": 120, "default": 48, "unit": "px" },
    { "type": "color_scheme", "id": "color_scheme", "label": "颜色方案", "default": "scheme-1" }
  ],
  "presets": [{ "name": "MK Page Headers" }]
}
{% endschema %}
