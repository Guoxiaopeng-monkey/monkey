{%- doc -%}
  MK 视频组件

  渲染视频播放器

  @param {string} url - 视频URL
  @param {string} [poster] - 封面图
  @param {boolean} [autoplay] - 自动播放
  @param {boolean} [loop] - 循环播放
  @param {string} [class] - 额外CSS类名

  @example
  {% render 'mk-video', url: video_url, poster: image, autoplay: true, loop: true %}
{%- enddoc -%}

{% liquid
  assign url = url | default: ''
  assign poster = poster | default: ''
  assign autoplay = autoplay | default: false
  assign loop = loop | default: false
  assign class = class | default: ''
-%}

{%- if url != blank -%}
  <div class="mk-video {{ class }}" data-video>
    <video
      class="mk-video__player"
      src="{{ url }}"
      {% if poster != blank %}poster="{{ poster | image_url }}"{% endif %}
      {% if autoplay %}autoplay{% endif %}
      {% if loop %}loop{% endif %}
      muted
      playsinline
      controls
    ></video>
  </div>
{%- endif -%}

{% stylesheet %}
  .mk-video { width: 100%; border-radius: 12px; overflow: hidden; background: #000; }
  .mk-video__player { width: 100%; display: block; }
{% endstylesheet %}
