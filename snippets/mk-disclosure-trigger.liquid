{%- doc -%}
  MK Disclosure触发器组件

  渲染Disclosure切换按钮

  @param {string} [text] - 按钮文本
  @param {string} [class] - 额外CSS类名

  @example
  {% render 'mk-disclosure-trigger', text: '展开' %}
{%- enddoc -%}

{% liquid
  assign text = text | default: ''
  assign class = class | default: ''
-%}

<button
  type="button"
  class="mk-disclosure-trigger {{ class }}"
  data-disclosure-trigger
  aria-expanded="false"
>
  <span class="mk-disclosure-trigger__text">{{ text }}</span>
  <span class="mk-disclosure-trigger__icon">{{- 'icon-chevron-down.svg' | inline_asset_content -}}</span>
</button>

{% stylesheet %}
  .mk-disclosure-trigger {
    display: flex; align-items: center; gap: 8px; padding: 0; background: transparent;
    border: none; cursor: pointer; color: var(--color-foreground);
  }
  .mk-disclosure-trigger__text { font-size: 14px; font-weight: 500; }
  .mk-disclosure-trigger__icon {
    display: flex; width: 16px; height: 16px; transition: transform 0.2s ease;
  }
  .mk-disclosure-trigger__icon svg { width: 100%; height: 100%; }
  .mk-disclosure-trigger[aria-expanded="true"] .mk-disclosure-trigger__icon {
    transform: rotate(180deg);
  }
{% endstylesheet %}

{% javascript %}
  document.querySelectorAll('[data-disclosure-trigger]').forEach(trigger => {
    const targetId = trigger.dataset.disclosureTrigger;
    const target = targetId ? document.getElementById(targetId) : trigger.nextElementSibling;
    trigger?.addEventListener('click', () => {
      const isExpanded = trigger.getAttribute('aria-expanded') === 'true';
      trigger.setAttribute('aria-expanded', !isExpanded);
      if (target) target.hidden = isExpanded;
    });
  });
{% endjavascript %}
